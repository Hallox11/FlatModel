    var catego = [];

    function readCat(catList) {

        fetch(catList)
            .then(response => response.text())
            .then(data => {
                //   console.log(JSON.parse(data));
                addSearchBtns(JSON.parse(data));
            });
        $("#buttons").show();
    }


    function addSearchBtns(topic) {

        $("#buttons").empty();

        $("#buttons").html("");
        for (i = 0; i < topic.length + 1; i++) {
            var but = "butx" + i;
            var $button = $("<input type='button' class='btn bt' />");
            $button.val(topic[i]);
            $("#buttons").append($button);
            $button.attr('id', but);
            $("#buttons").append($button);

        }

        $button.attr('id', "catBack");
        $button.val("BACK");
        $("#buttons").append($button);

        $("#buttons").show();
    }
