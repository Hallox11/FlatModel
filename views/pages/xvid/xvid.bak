var off1=true;
function myFunction1() {
   if (off1)
   { 
         del();
  var x = document.createElement("SELECT");
  x.setAttribute("id", "favList1");
  document.body.appendChild(x);
   x.setAttribute("onchange", "insert1()");
  document.body.appendChild(x);
  

   z = document.createElement("option");
  z.setAttribute("value", "");
  var t = document.createTextNode("select order");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);

  var z = document.createElement("option");
  z.setAttribute("value", "relevance");
  var t = document.createTextNode("relevance");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);
 
  var z = document.createElement("option");
  z.setAttribute("value", "views");
  var t = document.createTextNode("views");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);
  
  var z = document.createElement("option");
  z.setAttribute("value", "rating");
  var t = document.createTextNode("rating");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);
  
  var z = document.createElement("option");
  z.setAttribute("value", "length");
  var t = document.createTextNode("length");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);
  
  var z = document.createElement("option");
  z.setAttribute("value", "uploaddate");
  var t = document.createTextNode("uploaddate");
  z.appendChild(t);
  document.getElementById("favList1").appendChild(z);

  off1=false;
   }
   else
   {
       var myobj = document.getElementById("favList1");
       myobj.remove();
       off1=true;
   }
}

function insert1()
{
 var x = document.getElementById("favList1").value;
  document.getElementById("orderBut").value =  x;
 
  var myobj = document.getElementById("favList1");
  myobj.remove();
  off1=true;
  
}
