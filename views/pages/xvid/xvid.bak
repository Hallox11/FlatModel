<body>
 
 <div id="header" >
        
<!-- MAIN TITLE -->
        <p style="position:fixed;top:5px;left:400px;color:gold;font-size:50px;"    >XVideos Public Videos</p>
        <p style="position:fixed;top:105px;left:200px;font-size:30px;">the Videos on this slideshow are provide by the public XVideos feed</p>


<!-- ORDER BUTTONS and TXT HEADERS -->
       <div id="orderTxt"    class="filter"  style="left:300px;">ORDER</div>
       <div id="dateTxt"     class="filter"  style="left:515px;">DATE</div>
       <div id="durationTxt" class="filter"  style="left:685px;">DURATION</div>
       <div id="qualityTxt"  class="filter"  style="left:890px;">QUALITY</div>
      
<input data-sub='all' id="orderBut"    onclick="myFunction1();" type="button" class="btn filter" value="relevance" />
<input data-sub='all' id="dateBut"     onclick="myFunction2();" type="button" class="btn filter" value="all" />
<input data-sub='all' id="durationBut" onclick="myFunction3();" type="button" class="btn filter" value="all" />
<input data-sub='all' id="hdBut"       onclick="myFunction4();" type="button" class="btn filter" value="HD720 ++" />
       

<!-- INFO TXT FIELD -->
       <input id="infoBut"   type="button"  class="btn buinfo" value="chose filter options and submit your tags" />
       
<!-- MAIN BUTTONS + INFO BUTTONS -->       
       <input id="userBut"   onclick="callMode='tag';help();"  type="button"  class="btn mainbu" value="Suggested Tag´s" />
    
   <!--    <input id="groupBut"   style="background:rgba(255, 0, 0, 0.2);pointer-events: none;;" type="button"  class="btn mainbu" value="User Channel's" /> -->
    
       <input id="tagBut"    onclick="openSub('tag');"   type="button"  class="btn mainbu" value="Tag's Search" />

<!-- TOPICS DIV DINAMIC -->  
      <div id="buttons"></div>


<!-- INPUT AND SUBMITE FIELD -->
       <input id="tag" type="text" name="query" class="sub"   />
       <input id="submit" onclick="submit();"  type="button" value="Submit" class="btn sub subbut" />
    
        <input id="sugestBut" onclick="help();" type="button"  class="btn  sub subbut" value="Suggested users" />
        <input id="group" onclick="submit2();" type="button"  class="btn  sub subbut" value="Start Search" />

<!-- END HEADER DIV -->
       </div>
<!-- OVERPAGE TXT INFO -->    
       <input id="title" class="backBut"  />
     
<!-- SEARCH AND EXIT BUTTONS -->            
       <div id="back" style="left:960px;"             onclick="toggle_off()"  class="but ">SEARCH</div> 
       <div id="back" style="left:1145px;width:80px;" onclick="menu()"        class="but">EXIT</div> 

<!-- PAGE UP AND DOWN -->       
       <input  id="page"   value="0" class="backBut" type="text" />
       <div id="pagedw" value="0" class="backBut" onclick="page_dw()" >page dw</div>
       <div id="pageup" value="0" class="backBut" onclick="page_up()" >page up</div>
       
       
         <input id="infodw"  type="button"  class="backbut" value="Start Search" />
        
       
<!-- GALLERY DISPLAY DIV DINAMIC -->    
        <div id="conteiner">
       <div id="output" >
           </div>
           
<!-- HTML END -->
           

                
      
<script>

var pageArray=[];
var dataArray=[];
var keyApi ='AIzaSyBheJJ58YA7kplGUG3dRg0BZNTW0oM_epI';  // youtube api Key
var apii;

var pic = sessionStorage.getItem("pic");
         console.log(pic);

 
        document.body.style.backgroundImage = "url("+pic+")";
///////////////////////////////////////////////////////////////////////////////////////
	////////////////////////////////////////////////////////////////////////////////
// FUNCTION TO GET THE ATRIBUTES PASSED ON THE URL
      var queryString = decodeURIComponent(window.location.search); //parsing 
      queryString = queryString.substring(1); 
      var queries = queryString.split("&"); 
     

       var picStart=(queries[0]); // GET THE VIDEO ID FROM THE URL
       console.log("ret: " + picStart);
       
       if(picStart!="") 
       {
            $("#header").toggle();
               $("#topics").empty();
               clear();
       }
       
//////////


function page_up(){
    
    
     var query=$("#tag").val();
     var page = $('#page').val();
     console.log(page);
      page++;
      search_tag(query, page);
    
      $('#page').val(page);
   
}
///////////////////////////////////////////////////////////////////////////////////////
function page_dw(){
    
    var query=$("#tag").val();
     var page = $('#page').val();
     page--;
     
   //  if(page < 1) page=1;
     $('#page').val(page);
          console.log(page);
     search_tag(query, page);
}
///////////////////////////////////////////////////////////////////////////////////////
// MENU BUTTON GET BACK TO INDEX2.HTML
function menu()
{
       window.open("./../xxx-index", "_self");
}
///////////////////////////////////////////////////////////////////////////////////////
// HIDE/SHOW INFO PAGE 
function toggle_off(){
               
               $("#header").toggle();
               $("#topics").empty();
               clear();
      
}
///////////////////////////////////////////////////////////////////////////////////////
// OPEN SUBMIT FIELD /////////////////////////////////////////////
function openSub(type){ 
               
               $('.sub').show();
               if(type==="user")   {callMode="user";
                                    $('.mainbu').show();    // hide main buttons
                                    $('.groupbu').hide();   // hide group buttons
                                    $('.userbu').show();    // show user sub menu
                                    $('.sub').hide();              // hide submit
                                   }
                                    
               if(type==="group")  {callMode="group";
                                    $('.mainbu').hide();    // hide main buttons
                                    $('.groupbu').show();   // show group buttons
                                    $('.userbu').hide();    // hide user sub menu
                                    $('.sub').hide();              // hide submit
                                   }
            
               if(type==="tag")    {callMode="tag";
                                    $('.mainbu').hide();    // hide main buttons
                                 
                                    $('#infoBut').val('submit your tag words separated by space');  
                                    $('#infoBut').show();
                                    $('#tag').attr("placeholder", " insert tag words");
                                    $('#tag').val("");
              
                                    $("#infoBut").  css({ top: 270 });
                                    $("#tag").      css({ top: 410, left: 230});
                                    $("#submit").   css({ top: 400, left: 580});
                                    $("#sugestBut").css({ top: 400, left: 745});
                                    $('#own').hide();    // hide main buttons
                                    $('#fav').hide();    // hide main buttons
                                    $('#group').hide();    // hide main buttons
                                    $("#sugestBut").val('Suggested Tags');
                                   }
              
              
         if(type==="userPhotos")   {callMode="userPhotos";
                                    $('.mainbu').hide();    // hide main buttons
                                    $('.groupbu').hide();   // hide group buttons
                                    $('.userbu').hide();    // hide user sub menu
                                    $('.sub').show();       // show submit
                                    $('#infoBut').val('select order and submit a Username or User Id');   // show info button
                                    $('.buinfo').show();    // show info
                                   }                    
             
     if(type==="favoritePhotos")   {callMode="favoritePhotos";
                                    $('.mainbu').hide();    // hide main buttons
                                    $('.groupbu').hide();   // hide group buttons
                                    $('.userbu').hide();    // hide user sub menu
                                    $('.sub').show();       // show submit
                                    $('#infoBut').val('select order and submit a Username or User Id');   // show info button
                                    $('.buinfo').show();    // show info
                                   }              
      
         if(type==="userSugest")   {callMode="userPhotos";
                                    $('.mainbu').hide();    // hide main buttons
                                    $('.groupbu').hide();   // hide group buttons
                                    $('.userbu').hide();    // hide user sub menu
                                    $('.sub').show();       // hide submit
                                    addSearchBtns();
                                   }                                         
           
           
        if(type==="groupPhotos")   {callMode="groupPhotos";
                                    $('.mainbu').hide();    // hide main buttons
                                    $('.groupbu').hide();   // hide group buttons
                                    $('.userbu').hide();    // hide user sub menu
                                    $('.sub').show();       // show submit
                                    $('#infoBut').val('select order and submit a Groupname or Group Id');   // show info button
                                    $('.buinfo').show();    // show info
                                   }                    
   
}// opensub() end
// EXECUTE THE SUBMIT DATA /////////////////////////////////////////
function submit(){
                    
                     if(callMode==="tag")
                     {
                        $('.filter').show();
                        $('.sub').hide();
                        $('#own').hide();
                        $('#fav').hide();
                        $('#group').hide();
                        $('#infoBut').val('select filter options for tags: '+ $('#tag').val());  
                        $("#infoBut").  css({ top: 230 });
                        $('#infoBut').show();
                        $('#group').show();
                        
                     }
                    
 }                    
function submit2(){
                   console.log(callMode);
                   var query=$("#tag").val();
                   
                    array2=[];
                    count=0;
                    pageCount=0;
                    $("#header").hide();
                   
                   
                   if(callMode==="tag" && query)   { $('#page').val(1); tagSearch (query,0);}
               
               
               
               
                   if(callMode==="userPhotos" && query)  { userSearch (callMode,query,1);}
                   if(callMode==="favoritePhotos" && query)  { userSearch (callMode,query,1);}
                   if(callMode==="group" && query) { groupSearch(query,1);}
 
 

var pageField = document.getElementById("page");

pageField.onkeyup = function (e) {
   if (e.which == 13) tagSearch  (query, $('#page').val());
};

pageField.parentElement.onsubmit = function () {
   return false;
};
                                   
}// submit() end
//////////////////////////////////////////////////////////////////////////////
// ADD TOPICS BUTTONS  ///////////////////////////////////////////////////////

function help(){
              
                  catego=[];            // limpa array de categorias
                 $('.mainbu').hide();    // hide main buttons
                  $('.filter').hide();  // esconde filter txt
                  $('.buinfo').hide();  // esconde filter buttons
                  $('#buttons').show();  // mostra os botoes dos topicos
                  $('.sub').hide();  // esconde filter buttons
                  $('#sugestBut').hide();  // esconde filter buttons
                
                   readCat();            // le categorias do ficheiro txt e adiciona os botoes
                
            
    
}

var catego=[];

function readCat(){
 fetch('./catego.txt')
        .then(response => response.text())
        .then(data => {
                        //   console.log(JSON.parse(data));
                        addSearchBtns(JSON.parse(data));
                       });
}


function addSearchBtns(topic) {

  $("#buttons").html("");
  for (i = 0; i < topic.length; i++) {
       var but = "butx"+i;
    var $button = $("<input type='button' class='btn bt' />");
    $button.val(topic[i]);
    $("#buttons").append($button);
    $button.attr('id',but); 
    $("#buttons").append($button);
}
    $button.attr('id',"catBack"); 
    $button.val("BACK");
    $("#buttons").append($button);
    $("#buttons").show();
}
////////////////////////
 $(document).on("click", ".bt", function() {

      if ($(this).hasClass("bt")) {
       var query = $(this).val();
       
       $("#tag").val(query);
       $("#buttons").hide();
        $("#topics").hide();

        if(query==="BACK" ) {openSub('user');}  
        else   submit();

       
      }
});



// RESETS THE SEARCH VIEW /////////////////////////////////////////////
function clear(){

              
                $('#infoBut').hide();          // hide info txt
                $('.sub').hide();              // hide submit
                $('.buinfo').hide();           // hide order buttons 
                $('.filter').hide();           // hide filter txt
                $('.mainbu').show();           // show buttons
                $('#buttons').hide();           // show user sub menu
             //    $('').show();           // show buttons
             
}// clear() end



////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
var proc= function(videos) {
                                  
                                    $("#output").empty();
                                              
                                              console.log(videos);

                                        
                                            $.each(videos, function(i, item){

                                                var thumb = item.thumbnail;
                                                thumb=thumb.replace("thumbs169ll", "thumbs169lll");

                                                var title = item.title;
                                                          //    console.log(thumb);
                                      
                                            
                                                var vid = item.url;
                                
                          

                                      var $a = $("<a href='#'></a>").append(
                                            $("<img />").attr('src', thumb)
                                            .attr("data-image", thumb)             // title
                                             .attr("data-type", "image")             // title
                                            .attr("data-title", "title")           // description vai o owner id 
                                            .attr("data-videoid", vid)         // 
                                            .attr("data-description", vid)
                                            .attr("alt", title)
                                        );
                                        if(!thumb.includes("THUMBNUM"))
                                          {
                                            $("#output").append($a);
                                          }
                                     });
                                        
                               
                            
    ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
     
    apii = $("#output").unitegallery({

//     gallery_theme: "tilesgrid",
//  tiles_type:"nested",

   gallery_theme: "tiles",
    tiles_type:"justified",
tiles_justified_row_height: 280,                                    
tile_enable_shadow:false,
tile_enable_border:true,
tiles_space_between_cols:1,
tiles_justified_space_between:17,
tiles_col_width:35,
tile_border_color: "#000000",
tile_outline_color: "#ffffff",
tile_enable_outline:true,


tile_enable_textpanel:true,
tile_textpanel_title_text_align: "center",


     lightbox_type: "compact",
     gallery_width:"100%",
     gallery_play_interval: 4000,	
     gallery_autoplay:false,		

  theme_auto_open:picStart,

     gallery_enable_cache: true,					  //enable caching items
     gallery_images_preload_type:"minimal",
     slider_control_zoom:true,
   
     slider_scale_mode: "down",
   

/// TILESGRID THEME ///////////////////////////////////////

     tile_width: 285,
     tile_height: 294,
     grid_num_rows: 3,
     grid_padding: 10,
     tile_enable_border: true,
     tile_enable_shadow: false,
     tile_border_radius: 2,
     grid_space_between_cols: 12,
     grid_space_between_rows: 12,
     grid_space_between_mobile: 15,
     bullets_space_between: 10,
     grid_vertical_scroll_ondrag: true,

  

/////////////////////////////////////////////////////////////////////////////////////////////////////      

   // SHOW TITLE ON TILES 
     tile_textpanel_always_on:true, 
     tile_enable_textpanel:true,
     tile_textpanel_bg_color: "black",
     tile_textpanel_bg_opacity:0.8,
     tile_textpanel_title_color: "white",
     tile_textpanel_title_text_align: "center"
     
                                       
                                       
                                       
    });


                // ON GALLERY CHANGE    
                apii.on("item_change",function(num, data){		//on item change, get item number and item data
			    
			                   	console.log("data: " + data.urlImage + "  num:" + num);

                                var fotoInfo =apii.getItem(num);  // GET DA PHOTO
                                var owner=fotoInfo.description;   // GET DO ATRIBUTO DESCRIPTION
                                var title=fotoInfo.title;
                                var url=fotoInfo.urlImage;
                                var vid=fotoInfo.videoid;
                                console.log ("Photo n: " + num );
                                console.log ("Owner Id: " + owner );
                                console.log ("Title: " + title );
                                console.log ("imageUrl: " + url );
                                console.log ("VideoId: " + vid );



             
               
                                picIndex=num;


                                $('.but').hide();
                apii.on("close_lightbox",function(num, data){ $('.but').show(); $('#bak').hide();apii.stop(); });
                apii.on("open_lightbox",function(num, data){ apii.stop(); });
             
           //   window.open("./xvid.html?"+num,  "_self");
             
                apii.on("play",function(num, data){
                                                       console.log("video to play" + num +" : " + vid)

                                                              });
		                                          	});
                                                                
                                                                     
};
//// FIM DA FUNÇAO PROC  ////////////////////////////////////////////////////////////////////////////////////////////////////////
//// INICIO DA FUNÇAO SEARCH_USER  ////////////////////////////////////////////////////////////////////////////////////////////// 

var picIndex=0; 
   
var page=0; 


var search_tag= function(){
                             var tag=$('#tag').val();
                             console.log("tag search: " + tag);
                              var page=$('#page').val();
                             console.log("tag page: " + page);
                             clear();
                            // toggle_off();
                          
                             tagSearch(tag, page);
}

 var tagSearch= function(tag, page){

/*
   ?k=nature         tags
   &sort=relevance   views  length  rating  uploaddate
   &quality=hd       hd or blank
   &durf=20min_more  10-20min  3-10min  1-3min  allduration
   &datef=6month     3month  month  week  today  all
 */
              var quality=$('#hdBut').val(); 
              if( quality==="HD720 ++") quality="hd";
              var sort = $('#orderBut').val();
              var durf = $('#durationBut').val();;
              var datef= $('#dateBut').val();
              
              
          var searchUrl="/?k="+tag+"&sort="+sort+"&quality="+quality+"&durf="+durf+"&datef="+datef;
                        
           
              search(searchUrl);
                
                function search(searchUrl){
                
                functABC(searchUrl).then(function(data) {
                // Run this when your request was successful
                
                console.log("slide: " + data);
                readVids();
                
              //  play(videoLink, title, slideThumb);
                
                }).catch(function(err) {
                // Run this when promise was rejected via reject()
                 console.log(err)
                })
                
                }
                ////////////
                function functABC(searchUrl) {
                
                return new Promise(function(resolve, reject) {
                
                $.ajax({
                url: '/search',
                type: 'POST',
                data: {
                  'searchUrl':searchUrl
                },
                success: function(data) {
                resolve(data) // Resolve promise and go to then()
                },
                error: function(err) {
                reject(err) // Reject the promise and go to catch()
                }
                });
                });
                }
                                   
 }
 
 readVids();
    function readVids() {
                                  fetch('./xxx.txt')
                                   .then(response => response.text())
                                   .then(data => {
                                                 //   console.log(data);
                                                    var videos = JSON.parse(data);
                                           /*
                                                    var numVideos= videos.length; 
                                         
                                                    console.log("Numvideos from txt: "+ numVideos);
                                          
                                           $('#title').show();
                                           $('#infodw').show();
                                           
                                           var total= videos[0].numVids;
                                               total=(total.replace(/[^0-9]/g,''));
                                           var perPage=parseInt (total/numVideos);     
                           
                                $('#infodw').val("found "+total+ " videos in " + perPage +" pages");
                                $('.backBut').show();
                                        //     console.log("Numvideos from txt: "+ );
                                   */
                                   
                                        proc(videos);
                                    });
    }
                   
            // readVids();  

             // Retrieve
         var pic = sessionStorage.getItem("pic");
         console.log(pic);

 
        document.body.style.backgroundImage = "url("+pic+")";
             
