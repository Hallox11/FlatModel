var tagSearch= function(tag, page){

  

/*
   ?k=nature         tags
   &sort=relevance   views  length  rating  uploaddate
   &quality=hd       hd or blank
   &durf=20min_more  10-20min  3-10min  1-3min  allduration
   &datef=6month     3month  month  week  today  all
 */
              var quality=$('#hdBut').val(); 
              if( quality==="HD720 ++") quality="hd";
              var sort = $('#orderBut').val();
              var durf = $('#durationBut').val();;
              var datef= $('#dateBut').val();
              
              
          var searchUrl="/?k="+tag+"&sort="+sort+"&quality="+quality+"&durf="+durf+"&datef="+datef;
          
          from="main" // to reset scrool on search
          
          $('#menu').hide(); // hide menu button
          $('#conteiner').hide(); // hide menu
          $('#loader').show(); // show loader
          var title='search results for tags: ' + tag + ' in ' + sort +' order ';
                $('#title').val(title)
                $('#title').show();
             
               


              search(searchUrl,title);
                
                function search(searchUrl,title){
                
                functABC(searchUrl).then(function(data) {
                // Run this when your request was successful
                
                readVids("load");
                $('#conteiner').show(); 
                $('#loader').hide();
                $('#menu').text("SHOW MENU");
                $('#menu').show();
                $('#countInfo').val( videos.length + " videos found"); // hide menu button
                  $('#countInfo').show()
                
                  saveTitle(title, videos.length); 
              //  play(videoLink, title, slideThumb);
                
                }).catch(function(err) {
                // Run this when promise was rejected via reject()
                 console.log(err)
                })
                
                }
                ////////////
                function functABC(searchUrl) {
                
                return new Promise(function(resolve, reject) {
                
                $.ajax({
                url: '/search',
                type: 'POST',
                data: {
                  'searchUrl':searchUrl
                },
                success: function(data) {
                resolve(data) // Resolve promise and go to then()
                },
                error: function(err) {
                reject(err) // Reject the promise and go to catch()
                }
                });
                });
                }
                          
}

function saveTitle(data, numVideos){
                          $.ajax({
                          type: 'POST',
                          url: '/saveXvidTitle',
                          data: {
                                    data:data,
                                    num:numVideos
                                },
                          });
}


