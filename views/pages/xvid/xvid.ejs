function submit2(){
    var query = $("#tag").val();
    var order = $("#orderBut").val();
    
    // Show loader while waiting for the scraper
    $("#loader").show();
    $("#header").hide();
    $("#menu").text("SHOW MENU");

    // Send the request to your Node.js backend
    fetch('/api/scrape-xvideos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tag: query, sort: order })
    })
    .then(response => response.json())
    .then(data => {
        $("#loader").hide();
        // Call your proc function to render the thumbnails
        proc(data, "tag"); 
        $("#countInfo").val(data.length + " videos found").show();
    })
    .catch(err => {
        $("#loader").hide();
        alert("Error fetching videos");
    });
}
