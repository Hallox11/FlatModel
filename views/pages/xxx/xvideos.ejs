<style>
    /* 1. ESTRUTURA PRINCIPAL */
    #xxx-module {
        width: 1280px;
        height: 720px;
        display: flex;
        flex-direction: column;
        background: rgba(0, 0, 0, 0.4);
        color: white;
        overflow: hidden;
        font-family: 'Outfit', sans-serif;
        position: relative;
    }

    /* 2. NAV BAR ESTILO SL */
    .sl-nav-header {
        width: 100%; height: 55px;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 35px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
        z-index: 100; flex-shrink: 0; box-sizing: border-box;
        margin-bottom: 0px;
    }

    .nav-left .current-tag {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
        min-width: 160px;
    }

    .nav-left .current-tag span { font-size: 20px; font-weight: 400; letter-spacing: 1px; }
    .nav-left .current-tag small { font-size: 13px; color: #f00; text-transform: uppercase; font-weight: bold; }

    .category-chips { display: flex; gap: 8px; margin-left: 20px; align-items: center; }

    .chip { 
        background: rgba(255,255,255,0.05);
        border: 1px solid #444;
        color: white; 
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 400;
        font-size: 14px;
        transition: 0.2s;
    }

    .chip.active { background: rgba(255, 204, 0, 0.1); border-color: #ffcc00; color: #ffcc00; }
    .chip:hover { border-color: #fff; background: rgba(255,255,255,0.1); }

    .nav-right { margin-left: auto; display: flex; gap: 10px; align-items: center; }

    #xxx-search-input {
        background: rgba(26, 26, 26, 0.8);
        border: 1px solid #333;
        color: #fff;
        padding: 8px 15px;
        border-radius: 4px;
        font-size: 13px;
        width: 180px;
        outline: none;
    }

    .exit-btn {
        background: rgba(51, 51, 51, 0.8);
        border: 1px solid #444;
        color: #fff;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 18px;
    }

    /* 3. MODAL DE CATEGORIAS (DESIGN PREMIUM) */
    #xxx-cat-modal {
        display: none;
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 9999;
        flex-direction: column;
        align-items: center;
        padding: 50px;
        box-sizing: border-box;
    }

    .cat-scroll-wrapper { rgba(0, 0, 0, 0.8);; width: 100%; max-width: 1100px; overflow-y: hide; margin: 20px 0; }
    .category-map { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; }
    
    .cat-map-btn {
        background: rgba(0,0,0,0.03);
        border: 1px solid #797171;
        color: #ccc;
        padding: 12px;
        border-radius: 4px;
        font-size: 13px;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.2s;
    }
    .cat-map-btn:hover { background: #f00; color: #fff; border-color: #f00; transform: scale(1.05); }

    /* 4. SCROLL VERMELHO */
    #xxx-scroll-content {
        flex-grow: 1;
        width: 1240px;
        overflow-y: auto;
        overflow-x: hidden;
        margin-left: 20px;
    }

    #xxx-scroll-content::-webkit-scrollbar { width: 10px; }
    #xxx-scroll-content::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.3); }
    #xxx-scroll-content::-webkit-scrollbar-thumb { 
        background: #ff0000; 
        border-radius: 10px; 
        border: 2px solid rgba(0, 0, 0, 0.4); 
    }

    /* 5. GRID E CARDS (4 COLUNAS) */
    .video-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 10px 20px; }
    
    .video-card {
        background: #111;
        border: 1px solid #222;
        transition: transform 0.2s;
        cursor: pointer;
    }
    .video-card:hover { border: 2px solid yellow; transform: scale(1.02); }

    .thumb-wrap { width: 100%; aspect-ratio: 4 / 2.7; background: #000; overflow: hidden; }
    .thumb-wrap img { width: 100%; height: 100%; object-fit: cover; }

    .video-title { 
        font-size: 10.5px; 
        line-height: 1.3;
         padding: 8px; 
         color: #ccc; 
         text-align: center;
        text-transform: uppercase;
         display: -webkit-box; 
        -webkit-box-orient: vertical;
        letter-spacing: 1.1px;
         overflow: hidden;
          height: 21px;
           margin: 0;
    }
    .ltv-nav-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    padding: 3px 20px;
    border-radius: 20px; /* Pill shape */
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin: 0 5px;
}

.ltv-nav-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
}
</style>

<div id="xxx-module">
    <div id="xxx-cat-modal">
        <h2 style="margin: 0px; letter-spacing: 4px; font-weight: 200;">CATEGORIES</h2>
            <div class="close-menu-btn" onclick="toggleCatModal(false)">
        <span class="material-symbols-rounded">close</span>
    </div>
        <div class="cat-scroll-wrapper">
            <div class="category-map" id="modal-cat-grid">
                <% XXX_CATEGORIES.forEach(cat => { %>
                    <button class="cat-map-btn" onclick="selectCat('<%= cat %>')">
                        <%= cat %>
                    </button>
                <% }) %>
            </div>
        </div>
      
    </div>

    <nav class="sl-nav-header">
        <div class="nav-left">
            <div class="current-tag">
                <span>HARDCORE</span>
                <small id="active-tag-display"><%= tag %></small>
            </div>
        </div>

        <div class="category-chips" id="quick-chips">

            <button class="chip" onclick="toggleCatModal(true)">...</button>
        </div>

        <div class="nav-right">
            <input type="text" id="xxx-search-input" value="<%= tag %>" placeholder="Search..." onkeyup="if(event.key === 'Enter') xxxSearch()">
             <button class="ltv-nav-btn" onclick="handleNav('/xxx-index')">
        <span class="material-symbols-rounded" style="font-size:23px!important; vertical-align:middle;">arrow_back</span> BACK
    </button>
        </div>
    </nav>

    <div id="xxx-scroll-content">
        <div class="video-grid">
            <% videos.forEach(v => { %>
                <div class="video-card" data-url="<%= v.pageUrl %>" data-title="<%= v.title %>" onclick="playXXX(this)">
                    <div class="thumb-wrap">
                        <img src="<%= v.thumbnail %>" loading="lazy">
                    </div>
                    <p class="video-title"><%= v.title %></p>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
// Mantemos as funções globais para os cliques funcionarem
window.toggleCatModal = function(show) {
    $('#xxx-cat-modal').css('display', show ? 'flex' : 'none');
    if (window.socket && !window.isRemoteAction) {
        socket.emit('state_sync', { type: 'xxx_modal', show: show, room: window.myRoom });
    }
};

window.selectCat = function(cat) {
    sessionStorage.setItem('xxx_scroll_pos', 0);
    toggleCatModal(false);
    handleNav('/xvideos-grid?tag=' + encodeURIComponent(cat));
};

window.xxxSearch = function() {
    sessionStorage.setItem('xxx_scroll_pos', 0);
    const val = document.getElementById('xxx-search-input').value;
    handleNav('/xvideos-grid?tag=' + encodeURIComponent(val));
};

// Player e Sincronização de Scroll (Mantidos)
async function playXXX(el) {
    // 1. Capture current grid state before navigating
    const scrollPos = document.getElementById('xxx-scroll-content').scrollTop;
    const currentTag = document.getElementById('active-tag-display').innerText;

    // 2. Persist to Session Storage
    sessionStorage.setItem('xxx_scroll_pos', scrollPos);
    sessionStorage.setItem('xxx_active_tag', currentTag);

    const url = el.getAttribute('data-url');
    const title = el.getAttribute('data-title');

    try {
        const res = await fetch('/get-xxx-stream?url=' + encodeURIComponent(url));
        const data = await res.json();
        
        if (data.streamUrl) {
            handleNav(`/xxx-player?stream=${encodeURIComponent(data.streamUrl)}&title=${encodeURIComponent(title)}`); 
        }
    } catch (e) { 
        console.error("Error fetching stream:", e); 
    }
}

$('#xxx-scroll-content').on('scroll', function() {
    if (window.isSyncing || !window.socket) return; 
    socket.emit('state_sync', { type: 'scroll', position: $(this).scrollTop(), room: window.myRoom });
});

// Listener do Socket
if(window.socket) {
    socket.off('state_sync').on('state_sync', (data) => {
        if (data.type === 'scroll') {
            const $target = $('#xxx-scroll-content');
            window.isSyncing = true;
            $target.scrollTop(data.position);
            setTimeout(() => { window.isSyncing = false; }, 50);
        }
        if (data.type === 'xxx_modal') {
            window.isRemoteAction = true;
            $('#xxx-cat-modal').css('display', data.show ? 'flex' : 'none');
            setTimeout(() => { window.isRemoteAction = false; }, 100);
        }
    });
}
$(document).ready(function() {
    const savedScroll = sessionStorage.getItem('xxx_scroll_pos');
    
    if (savedScroll) {
        // We use a small delay to ensure the DOM elements (images) have rendered
        // and the container has reached its final scrollable height.
        setTimeout(() => {
            $('#xxx-scroll-content').scrollTop(parseInt(savedScroll));
        }, 150);
    }
});
</script>
