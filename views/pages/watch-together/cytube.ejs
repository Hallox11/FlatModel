<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1280, user-scalable=no">
    <title>CyTube Synchronized Player</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@700&display=swap" rel="stylesheet">
    
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    
    <script>
        window.__ROOM__   = '<%= room %>';
        window.__TV_ID__  = '<%= tvId || "" %>';
        window.socket = io({ query: { room: window.__ROOM__ } });
    </script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body, html {
            width: 1280px;
            height: 720px;
            background: #000000;
            overflow: hidden;
            font-family: 'Space Mono', monospace;
        }

        /* Edge-to-Edge Embedded Viewport (No toolbars or headers) */
        .cytube-viewport {
            width: 100%;
            height: 100%;
            border: none;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        /* Minimal Floating Overlay Container */
        .tv-overlay-controls {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 100;         /* Places it strictly above the iframe layer */
            pointer-events: none; /* Prevents an invisible layout container from eating clicks */
        }

        /* Glassmorphic Cyberpunk Back Button */
        .btn-exit {
            background: linear-gradient(135deg, rgba(28, 28, 38, 0.85) 0%, rgba(10, 10, 15, 0.95) 100%);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(123, 156, 255, 0.4);
            color: #7b9cff;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            pointer-events: auto; /* Re-enables clicking on the button element itself */
            transition: all 0.2s ease-in-out;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-exit:hover {
            transform: scale(1.05);
            border-color: #7b9cff;
            box-shadow: 0 0 15px rgba(123, 156, 255, 0.4);
        }
    </style>
</head>
<body>

    <div class="tv-overlay-controls">
        <button class="btn-exit" onclick="exitCyTube()">
            <span>←</span> Back to Main Menu
        </button>
    </div>

    <iframe class="cytube-viewport" 
            src="<%= cytubeUrl %>" 
            allow="autoplay; encrypted-media">
    </iframe>

    <script>
        // Multi-avatar remote room coordination listeners
        socket.on('openPage', function(fullRoute) {
            window.location.href = fullRoute;
        });

        function exitCyTube() {
            const homeRoute = '/';
            // Order the entire room channel audience to exit back to the main layout simultaneously
            socket.emit('nav_action', { path: homeRoute });
            window.location.href = homeRoute;
        }
    </script>
</body>
</html>