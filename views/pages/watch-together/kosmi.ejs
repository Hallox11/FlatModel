<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1280, user-scalable=no">

<title>Kosmi Room</title>

<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<script src="/socket.io/socket.io.js"></script>

<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
    width:1280px;
    height:720px;
    overflow:hidden;
    background:black;
    font-family:'Space Mono', monospace;
}

/* TOP BAR */
.topbar {
    position:absolute;
    top:0; left:0;
    width:100%;
    height:55px;

    display:grid;
    grid-template-columns:1fr auto 1fr;
    align-items:center;

    padding:0 20px;
    z-index:10;
}

.topbar-left { justify-self:start; }
.topbar-center { justify-self:center; opacity:0.7; letter-spacing:2px; }
.topbar-right { justify-self:end; }

/* BUTTON */
.btn {
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.2);
    color:white;
    padding:6px 12px;
    cursor:pointer;
}

/* VIEW */
#view {
    position:absolute;
    top:55px;
    left:0;
    width:100%;
    height:calc(100% - 55px);
}

/* KOSMI FRAME */
iframe {
    width:100%;
    height:100%;
    border:none;
}

/* EMPTY STATE */
.empty {
    width:100%;
    height:100%;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    color:#aaa;
    text-align:center;
}
</style>
</head>

<body>

<div class="topbar">

    <div class="topbar-left">
        <button class="btn" onclick="goBack()">← Back</button>
    </div>

    <div class="topbar-center">
        <span id="title">KOSMI</span>
    </div>

    <div class="topbar-right">
        <button class="btn" onclick="window.location.href='/'">☰ Menu</button>
    </div>

</div>

<div id="view"></div>

<script>

const socket = io();

/* =========================
   GET ROOM FROM URL
========================= */

function getRoomFromURL() {
    const params = new URLSearchParams(window.location.search);
    return params.get('room');
}

/* =========================
   RENDER
========================= */

function render() {
    const room = getRoomFromURL();
    const view = document.getElementById('view');

    if (room && room.length > 0) {
        view.innerHTML = `
            <iframe
                src="https://app.kosmi.io/room/${room}"
                allow="camera; microphone; display-capture; autoplay; encrypted-media">
            </iframe>
        `;
    } else {
        view.innerHTML = `
            <div class="empty">
                <h2>No Kosmi Room Selected</h2>
                <p>Provide a room ID in URL:</p>
                <code>?room=your-room-id</code>
            </div>
        `;
    }
}

/* =========================
   NAVIGATION
========================= */

function goBack() {
    window.history.back();
}

/* =========================
   SOCKET SYNC (optional)
========================= */

socket.on('openPage', (route) => {
    window.location.href = route;
});

/* =========================
   INIT
========================= */

render();

</script>

</body>
</html>