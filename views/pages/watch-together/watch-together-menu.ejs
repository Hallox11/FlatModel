    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 0.25rem;
}

.wt-input-group {
    margin-top: 0.75rem;
    display: block;
    position: relative;
    z-index: 10;
}

.wt-card input {
    width: 100%;
    background: rgba(10, 10, 15, 0.8);
    border: 1px solid #daa52082;
    color: #f0f0f0;
    padding: 0.65rem;
    border-radius: 6px;
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    position: relative;
    z-index: 10;
    cursor: text;
    transition: border-color 0.2s, background-color 0.2s;
}

.wt-card input:focus {
    outline: none;
    border-color: #daa520;
    background: rgba(10, 10, 15, 0.95);
}

.wt-card input::placeholder { color: #555; }

.wt-card input.wt-input-error {
    border-color: #e74c3c !important;
    background: rgba(30, 10, 10, 0.8);
}

.wt-btn {
    width: 100%;
    background: linear-gradient(135deg, #daa520 0%, #b8860b 100%);
    border: none;
    color: #0a0a0f;
    padding: 0.75rem;
    border-radius: 6px;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 0.25rem;
    position: relative;
    z-index: 10;
}

.wt-btn:hover {
    box-shadow: 0 5px 20px rgba(218, 165, 32, 0.5);
}

.wt-room-display {
    flex-grow: 1; 
    background: rgba(255, 255, 255, 0.02); 
    border: 1px solid #b0892382; 
    border-radius: 10px; 
    color: #daa520; 
    font-family: 'Outfit', sans-serif; 
    font-size: 1.1rem; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    letter-spacing: 2px;
}

.wt-copy-btn-inline {
    background: rgba(218, 165, 32, 0.1); 
    border: 1px solid #daa520; 
    border-radius: 10px; 
    color: #daa520; 
    padding: 10px 20px; 
    font-family: 'Orbitron', sans-serif; 
    font-size: 0.8rem; 
    font-weight: 700; 
    letter-spacing: 1px; 
    cursor: pointer; 
    transition: all 0.2s;
}

.wt-info-panel {
    background: rgba(218, 165, 32, 0.04);
    border: 1px dashed rgba(218, 165, 32, 0.25);
    border-left: 3px solid #daa520;
    border-radius: 6px;
    padding: 10px 14px;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
}

.wt-input-helper {
    font-size: 1rem;
    color: #b3b3b7;
    text-align: left;
    line-height: 1.4;
    font-family: 'Outfit', sans-serif;
}

.wt-input-helper strong {
    color: #daa520;
    font-family: 'Orbitron', sans-serif;
    font-size: 1.0rem;
    letter-spacing: 0.5px;
}

.wt-input-helper.wt-helper-error {
    color: #e74c3c;
}

.wt-features { 
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Splits into 2 equal columns */
    gap: 0.3rem 1.5rem;                    /* Sets spacing between rows and columns */
    margin-top: 0.6rem; 
    margin-bottom: 0.4rem; 
    margin-left: -31px;
    list-style: none; 
}
.wt-features li {
    color: #b3b3b7;
    font-size: 1.0rem;
    margin-bottom: 0.9rem;
    padding-left: 1.3rem;
    position: relative;
    line-height: 1.4;
}
.wt-features li::before { content: '▸'; position: absolute; left: 0; color: #daa520; }

#wt-back {
    position: absolute; top: 20px; left: 20px;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px;
    color: white; padding: 7px 14px; font-size: 0.78rem;
    font-family: 'Orbitron', sans-serif;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 6px;
    cursor: pointer; transition: all 0.2s; z-index: 200;
}
#wt-back:hover { border-color: #daa520; color: #daa520; }
#wt-back .wt-arrow { font-size: 1rem; line-height: 1; }

.wt-info-btn {
    position: absolute; top: 20px; right: 24px;
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(218, 165, 32, 0.08);
    border: 1px solid rgba(218, 165, 32, 0.25);
    color: #daa520; font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none; opacity: 0.7;
}
#fields{
    background: #0000009c;
    padding: 10px 10px;
    border-radius: 10px;
    margin-top: 20x;
}
</style>

<div id="wt-overlay-container">

    <button id="wt-back" onclick="closeSubMenu()">
        <span class="wt-arrow">←</span> Back
    </button>

    <div class="wt-grid" style="margin-top: 60px;">
        
<!-- ── LEFT CARD: BUILT-IN SYNC WITH AUTOMATIC SYNC CLARIFICATION ── -->
<div class="wt-card">
    <div class="wt-card-icon">
        <div class="wt-title">Built-in Sync</div>
        <span class="wt-badge" style="top:-20px;left: 220px;">Built-in</span>
    </div>
    <p><strong>Automatic Sync Active:</strong> TV content is fully synchronized by default. New arrivals join instantly — no action needed.<br>


<!-- ── NEW: Cross-Region Sync + TV Duplication side by side ── -->
<div style="grid-template-columns: 1fr 1fr; gap: 0 1.5rem; margin-top: 0.5rem;">
    <div>
        <div class="wt-sub-heading" style=" margin-bottom: 20px;margin-top: 20px;">Multiple TV´s on diferent Lands all playing sync</div>
        <ul class="wt-features" style="grid-template-columns: 1fr;">
            <li><strong>Seamless Connection:</strong> Sync your home TV with a friend’s TV to experience a shared view, even when you are in different locations.</li>
            <li><strong>Seamless Duplication: </strong>Put one TV in the living room and another in the bedroom to experience a unified view.Both Tv´s will show identical content in real-time.</li>
            <li style="margin-bottom: 20px;"><strong>Easy Access:</strong> Simply share your room link with friends or paste a received link to sync both TVs instantly.</li>
        </ul>
