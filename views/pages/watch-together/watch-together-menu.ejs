<style>
#wt-overlay-container {
    width: 1280px; height: 720px;
    color: #ffffff; font-family: 'Outfit', sans-serif;
    display: flex; flex-direction: column;
    position: relative;
    overflow: hidden;
}

.wt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    width: 86%;
    margin: auto;
       
}

.wt-card {
    background: rgba(28, 28, 38, 0.8);
    border: 2px solid rgba(218, 165, 32, 0.2);
    border-radius: 12px;
    padding: 10px 35px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.wt-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, rgba(218, 165, 32, 0.1) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
}

.wt-card:hover { border-color: #daa520; box-shadow: 0 10px 30px rgba(218, 165, 32, 0.3); }
.wt-card:hover::before { opacity: 1; }

.wt-card-icon { font-size: 2.3rem; margin-bottom: 0.3rem; display: block; }

.wt-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem;
    color: #daa520;
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
    display: inline;
}

.wt-sub-heading {
    color: #daa520; 
    font-family: 'Orbitron', sans-serif; 
    font-size: 0.8rem; 
    letter-spacing: 2px; 
    text-transform: uppercase; 
    margin-bottom: 5\px;
    margin-top: 5px;
    padding-left: 10px;
}

.wt-card p {
    color: #e9e6e6;
    font-size: 0.85rem;
    line-height: 1.5;
