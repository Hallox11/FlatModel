<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watch Together</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
    #wt-overlay-container {
        width: 1280px; height: 720px;
        color: #ffffff; font-family: 'Outfit', sans-serif;
        display: flex; flex-direction: column;
        background: rgba(0, 0, 0, 0.95);
        position: absolute; top: 0; left: 0; z-index: 100;
    }

        .header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, #daa520 0%, #ffd700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            font-size: 0.9rem;
            color: #888;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            max-width: 1200px;
            width: 100%;
            margin-left: 30px;
        }

        .card {
            background: rgba(28, 28, 38, 0.8);
            border: 2px solid rgba(218, 165, 32, 0.2);
            border-radius: 12px;
            padding: 10px 35px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(218, 165, 32, 0.1) 0%, transparent 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none; /* Don't block clicks on inputs! */
        }

        .card:hover {
            border-color: #daa520;
            box-shadow: 0 10px 30px rgba(218, 165, 32, 0.3);
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-icon {
            font-size: 2.3rem;
            margin-bottom: 1rem;
            display: block;
        }

        #title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            color: #daa520;
            margin-bottom: 0.5rem;
            letter-spacing: 1px;
            display: inline;
        }

        .card p {
            color: #e9e6e6;
            font-size: 0.85rem;
            line-height: 1.6;
            margin-bottom: 1rem;
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 1px;
        }

        .card-badge {
            display: inline-block;
            background: rgba(218, 165, 32, 0.2);
            color: #daa520;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 0.5rem;
        }

        .input-group {
            margin-top: 1rem;
            display: block;
            position: relative;
            z-index: 10;
        }

        input {
            width: 100%;
            background: rgba(10, 10, 15, 0.8);
            border: 1px solid rgba(218, 165, 32, 0.3);
            color: #f0f0f0;
            padding: 0.75rem;
            border-radius: 6px;
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 10;
            cursor: text;
        }

        input:focus {
            outline: none;
            border-color: #daa520;
            background: rgba(10, 10, 15, 0.95);
        }

        input::placeholder {
            color: #555;
        }

        .btn {
            width: 100%;
            background: linear-gradient(135deg, #daa520 0%, #b8860b 100%);
            border: none;
            color: #0a0a0f;
            padding: 0.75rem;
            border-radius: 6px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 0.5rem;
            position: relative;
            z-index: 10;
        }

        .btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(218, 165, 32, 0.5);
        }

        .input-helper {
            font-size: 0.7rem;
            color: #666;
            margin-bottom: 0.5rem;
            text-align: center;
        }

        .features {
            list-style: none;
            margin-top: 1rem;
        }

        .features li {
            color: #e9e6e6;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            padding-left: 1.5rem;
            position: relative;
        }

        .features li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: #daa520;
        }

        .quick-links {
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .quick-link {
            display: block;
            color: #daa520;
            text-decoration: none;
            font-size: 0.8rem;
            margin-bottom: 0.5rem;
            transition: all 0.2s ease;
        }

        .quick-link:hover {
            color: #ffd700;
            padding-left: 0.5rem;
        }
    </style>
</head>
<body>
  <div id="wt-overlay-container">
    <div class="header">
        <h1>Watch Together</h1>
        <p class="subtitle">Synchronized viewing platforms</p>
    </div>

    <div class="grid">
        <!-- Built-in Sync System -->
        <div class="card">
            <div class="card-icon">📺
            <div id="title">Built-in Sync</div></div>
            <p>Your native TV synchronization system with real-time streaming and multi-user support.</p>
            <span class="card-badge">Built-in</span>
            <ul class="features">
                <li>Real-time video streaming</li>
                <li>Multi-user synchronization</li>
                <li>Low latency</li>
                <li>Native integration</li>
            </ul>
            <div class="input-group">
                <button class="btn" onclick="window.location.href='/stream-cam'">Open Built-in Sync</button>
            </div>
        </div>

        <!-- Kosmi -->
        <div class="card">
            <div class="card-icon">🎬
            <div id="title">Kosmi</div></div>
            <p>Watch videos, play games, and hang out together with friends in synchronized rooms.</p>
            <span class="card-badge">External</span>
            <ul class="features">
                <li>YouTube, Netflix, Prime Video</li>
                <li>Screen sharing</li>
                <li>Built-in games</li>
                <li>Voice & video chat</li>
            </ul>
            <div class="input-group">
                <div class="input-helper">Optional: Enter room ID to join existing room</div>
                <input type="text" id="kosmi-room" placeholder="Enter Kosmi room ID (optional)">
                <button class="btn" onclick="joinKosmi()">Join Kosmi</button>
            </div>
            <div class="quick-links">
                <a href="https://kosmi.io" target="_blank" class="quick-link">Create a new room ↗</a>
            </div>
        </div>

        <!-- CyTube -->
        <div class="card">
            <div class="card-icon">🎥
            <div id="title">CyTube</div></div>
            <p>Open-source synchronized media player with playlist management and chat.</p>
            <span class="card-badge">External</span>
            <ul class="features">
                <li>YouTube, Vimeo, Dailymotion</li>
                <li>Playlist management</li>
                <li>Built-in chat</li>
                <li>Custom rooms</li>
            </ul>
            <div class="input-group">
                <div class="input-helper">Enter channel name to join</div>
                <input type="text" id="cytube-channel" placeholder="Enter CyTube channel name">
                <button class="btn" onclick="joinCyTube()">Join CyTube</button>
            </div>
            <div class="quick-links">
                <a href="https://cytu.be" target="_blank" class="quick-link">Browse channels ↗</a>
            </div>
        </div>
    </div>
  </div>
    <script>
        function joinKosmi() {
            const roomId = document.getElementById('kosmi-room').value.trim();
            if (roomId) {
                window.location.href = `/kosmi?room=${encodeURIComponent(roomId)}`;
            } else {
                // Open default Kosmi page
                window.location.href = '/kosmi';
            }
        }

        function joinCyTube() {
            const channel = document.getElementById('cytube-channel').value.trim();
            if (channel) {
                window.location.href = `/cytube?channel=${encodeURIComponent(channel)}`;
            } else {
                alert('Please enter a CyTube channel name');
            }
        }

        // Add Enter key support for inputs
        document.addEventListener('DOMContentLoaded', function() {
            const kosmiInput = document.getElementById('kosmi-room');
            const cytubeInput = document.getElementById('cytube-channel');
            
            if (kosmiInput) {
                kosmiInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        joinKosmi();
                    }
                });
            }
            
            if (cytubeInput) {
                cytubeInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        joinCyTube();
                    }
                });
            }
        });
    </script>
</body>
</html>
