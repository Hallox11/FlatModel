<style>
#wt-overlay-container {
    width: 1280px; height: 720px;
    color: #ffffff; font-family: 'Outfit', sans-serif;
    display: flex; flex-direction: column;
    position: relative;
    overflow: hidden;
}

.wt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    width: 86%;
    margin: auto;
       
}

.wt-card {
    background: rgba(28, 28, 38, 0.8);
    border: 2px solid rgba(218, 165, 32, 0.2);
    border-radius: 12px;
    padding: 15px 35px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.wt-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, rgba(218, 165, 32, 0.1) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
}

.wt-card:hover { border-color: #daa520; box-shadow: 0 10px 30px rgba(218, 165, 32, 0.3); }
.wt-card:hover::before { opacity: 1; }

.wt-card-icon { font-size: 2.3rem; margin-bottom: 0.3rem; display: block; }

.wt-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem;
    color: #daa520;
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
    display: inline;
}

.wt-sub-heading {
    color: #daa520; 
    font-family: 'Orbitron', sans-serif; 
    font-size: 0.8rem; 
    letter-spacing: 2px; 
    text-transform: uppercase; 
    margin-bottom: 8px;
    margin-top: 12px;
}

.wt-card p {
    color: #e9e6e6;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 0.4rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 1px;
}

.wt-badge {
    display: inline-block;
    background: rgba(218, 165, 32, 0.2);
    color: #daa520;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 0.25rem;
}

.wt-input-group {
    margin-top: 0.75rem;
    display: block;
    position: relative;
    z-index: 10;
}

.wt-card input {
    width: 100%;
    background: rgba(10, 10, 15, 0.8);
    border: 1px solid rgba(218, 165, 32, 0.3);
    color: #f0f0f0;
    padding: 0.65rem;
    border-radius: 6px;
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    position: relative;
    z-index: 10;
    cursor: text;
    transition: border-color 0.2s, background-color 0.2s;
}

.wt-card input:focus {
    outline: none;
    border-color: #daa520;
    background: rgba(10, 10, 15, 0.95);
}

.wt-card input::placeholder { color: #555; }

.wt-card input.wt-input-error {
    border-color: #e74c3c !important;
    background: rgba(30, 10, 10, 0.8);
}

.wt-btn {
    width: 100%;
    background: linear-gradient(135deg, #daa520 0%, #b8860b 100%);
    border: none;
    color: #0a0a0f;
    padding: 0.75rem;
    border-radius: 6px;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 0.25rem;
    position: relative;
    z-index: 10;
}

.wt-btn:hover {
    box-shadow: 0 5px 20px rgba(218, 165, 32, 0.5);
}

.wt-room-display {
    flex-grow: 1; 
    background: rgba(255, 255, 255, 0.02); 
    border: 1px solid rgba(218, 165, 32, 0.2); 
    border-radius: 10px; 
    color: #daa520; 
    font-family: 'Outfit', sans-serif; 
    font-size: 1.1rem; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    letter-spacing: 2px;
}

.wt-copy-btn-inline {
    background: rgba(218, 165, 32, 0.1); 
    border: 1px solid #daa520; 
    border-radius: 10px; 
    color: #daa520; 
    padding: 10px 20px; 
    font-family: 'Orbitron', sans-serif; 
    font-size: 0.8rem; 
    font-weight: 700; 
    letter-spacing: 1px; 
    cursor: pointer; 
    transition: all 0.2s;
}

.wt-info-panel {
    background: rgba(218, 165, 32, 0.04);
    border: 1px dashed rgba(218, 165, 32, 0.25);
    border-left: 3px solid #daa520;
    border-radius: 6px;
    padding: 10px 14px;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
}

.wt-input-helper {
    font-size: 1rem;
    color: #b3b3b7;
    text-align: left;
    line-height: 1.4;
    font-family: 'Outfit', sans-serif;
}

.wt-input-helper strong {
    color: #daa520;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.5px;
}

.wt-input-helper.wt-helper-error {
    color: #e74c3c;
}

.wt-features { 
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Splits into 2 equal columns */
    gap: 0.3rem 1.5rem;                    /* Sets spacing between rows and columns */
    margin-top: 0.6rem; 
    margin-bottom: 0.4rem; 
    list-style: none; 
}
.wt-features li {
    color: #e9e6e6;
    font-size: 0.82rem;
    margin-bottom: 0.3rem;
    padding-left: 1.3rem;
    position: relative;
}
.wt-features li::before { content: '▸'; position: absolute; left: 0; color: #daa520; }

#wt-back {
    position: absolute; top: 20px; left: 20px;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px;
    color: white; padding: 7px 14px; font-size: 0.78rem;
    font-family: 'Orbitron', sans-serif;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 6px;
    cursor: pointer; transition: all 0.2s; z-index: 200;
}
#wt-back:hover { border-color: #daa520; color: #daa520; }
#wt-back .wt-arrow { font-size: 1rem; line-height: 1; }

.wt-info-btn {
    position: absolute; top: 20px; right: 24px;
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(218, 165, 32, 0.08);
    border: 1px solid rgba(218, 165, 32, 0.25);
    color: #daa520; font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none; opacity: 0.7;
}
</style>

<div id="wt-overlay-container">

    <button id="wt-back" onclick="handleNav('games-menu', false)">
        <span class="wt-arrow">←</span> Back
    </button>

    <div class="wt-grid" style="margin-top: 75px;">
        
        <!-- ── LEFT CARD: BUILT-IN SYNC WITH AUTOMATIC SYNC CLARIFICATION ── -->
        <div class="wt-card">
            <div class="wt-info-btn">i</div>
            <div class="wt-card-icon">
                <div class="wt-title">Built-in Sync</div>
                                          <span class="wt-badge">Built-in</span>
            </div>
            <p><strong>Automatic Sync Active:</strong> TV content is already fully synchronized by default. New arrivals do not need to perform any action to watch together.<br><br>
  
           <!--
            <ul class="wt-features">
                <li>Real-time video streaming</li>
                <li>Multi-user synchronization</li>
                <li>Low latency</li>
                <li>Native integration</li>
            </ul>
--> 
            <!-- Added Contextual Sync Note -->
            <div class="wt-info-panel">
                <div class="wt-input-helper">
How to Use: Share your room link to stream across different TVs, or use a shared ID to sync up with someone else's stream (perfect for separate networks or mirroring content between your living room and bedroom).                </div>
            </div>

            <!-- Embedded Direct Forms matching image_826764.png -->
            <div class="wt-sub-heading">My Room</div>
            <div style="display: flex; gap: 12px; width: 100%; height: 42px; margin-bottom: 4px;">
                <div id="wt-room-code-box" class="wt-room-display">Lobby</div>
                <button id="wt-copy-btn" onclick="wtCopyRoomLink()" class="wt-copy-btn-inline">COPY LINK</button>
            </div>
            <div class="wt-input-helper" style="text-align: center; margin-bottom: 10px; font-size: 0.9rem; color: #ffffff;">
                Share this link with friends, they'll join your room and watch everything in sync with you.
            </div>

            <div style="border-top: 1px solid rgba(255,255,255,0.08); margin: 10px 0;"></div>

            <div class="wt-sub-heading">Join Another TV</div>
            <div style="display: flex; gap: 12px; width: 100%;">
                <input type="text" id="wt-tv-code" placeholder="Paste room code or full URL..." style="margin-bottom: 0; padding: 0.65rem;">
                <button onclick="wtJoinOtherTV()" class="wt-btn" style="width: auto; padding: 0 22px; margin-top: 0; border-radius: 6px; height: 38px;">JOIN</button>
            </div>
            <div id="wt-tv-helper" class="wt-input-helper" style="text-align: center; margin-top: 6px; font-size: 0.9rem; color: #ffffff;">
                Got a link from someone else's TV? Paste it above and both TVs will sync up instantly.
            </div>
        </div>

        <!-- ── RIGHT CARD: KOSMI CARD ── -->
        <div class="wt-card">
            <div class="wt-info-btn">i</div>
            <div class="wt-card-icon">
                <div class="wt-title">Kosmi</div>
                            <span class="wt-badge">External</span>
            </div>
            <p>Watch videos, play games, and hang out together with friends in synchronized rooms.</p>

            
            <ul class="wt-features">
                <li>YouTube, Netflix, Prime Video</li>
                <li>Screen sharing & Video chat</li>
                <li>Built-in multiplayer games</li>
                <li>Voice & video chat</li>
            </ul>

            <div class="wt-info-panel">
                <div id="wt-kosmi-helper" class="wt-input-helper">
                    🔑 <strong>How to Use Room IDs:</strong> Paste an active Kosmi Room ID key down below to embed their third-party video synchronization channel into this layout frame.<br><br>
                    🌐 <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.
                </div>
            </div>

            <div class="wt-input-group">
                <input type="text" id="wt-kosmi-room" placeholder="Enter Kosmi room ID">
                <button class="wt-btn" onclick="wtJoinKosmi()">Join Kosmi Channel</button>
                <button class="wt-btn" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: #f0f0f0; box-shadow: none; margin-top: 0.5rem;" onclick="wtOpenKosmiExternal()">Open Kosmi Homepage</button>
            </div>
        </div>
    </div>

</div>

<script>
(function () {
    const roomBox = document.getElementById('wt-room-code-box');
    if (roomBox && window.myRoom) {
        roomBox.innerText = window.myRoom;
    }

    window.wtCopyRoomLink = function() {
        const btn = document.getElementById('wt-copy-btn');
        const roomCode = window.myRoom || "Lobby";
        const shareUrl = `${window.location.origin}?room=${encodeURIComponent(roomCode)}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
            if (btn) {
                btn.innerText = "COPIED!";
                btn.style.background = "#daa520";
                btn.style.color = "#0a0a0f";
                setTimeout(() => {
                    btn.innerText = "COPY LINK";
                    btn.style.background = "rgba(218, 165, 32, 0.1)";
                    btn.style.color = "#daa520";
                }, 2000);
            }
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    };

    window.wtJoinOtherTV = function() {
        const input = document.getElementById('wt-tv-code');
        const helper = document.getElementById('wt-tv-helper');
        const targetRoom = input ? input.value.trim() : '';

        if (!targetRoom) {
            if (input) input.style.borderColor = '#e74c3c';
            if (helper) {
                helper.style.color = '#e74c3c';
                helper.innerText = "Error: Please enter a valid room code or link!";
            }
            return;
        }

        let parsedCode = targetRoom;
        try {
            if(targetRoom.includes('?room=')) {
                const urlParams = new URLSearchParams(targetRoom.split('?')[1]);
                parsedCode = urlParams.get('room') || targetRoom;
            } else if (targetRoom.startsWith('http')) {
                const parsedUrl = new URL(targetRoom);
                parsedCode = parsedUrl.searchParams.get('room') || targetRoom;
            }
        } catch(e) {
            console.error("URL parsing fallback initialized:", e);
        }

        if (!parsedCode) {
            if (helper) {
                helper.style.color = '#e74c3c';
                helper.innerText = "Error: Invalid room configuration code format.";
            }
            return;
        }

        const loader = document.getElementById('loading-overlay');
        if (loader) {
            loader.style.display = 'flex';
        }

        if (typeof handleNav === "function") {
            try {
                handleNav('watch-together', false);
            } catch(err) {}
        }

        setTimeout(() => {
            window.location.href = window.location.origin + '/?room=' + encodeURIComponent(parsedCode);
        }, 150);
    };

    window.wtOpenKosmiExternal = function() {
        window.open('https://kosmi.io', '_blank');
    };

    window.wtJoinKosmi = function (isRemote = false) {
        const input = document.getElementById('wt-kosmi-room');
        const helper = document.getElementById('wt-kosmi-helper');
        const roomId = input ? input.value.trim() : '';

        if (input) input.classList.remove('wt-input-error');
        if (helper) {
            helper.classList.remove('wt-helper-error');
            helper.innerHTML = `🔑 <strong>How to Use Room IDs:</strong> Paste an active Kosmi Room ID key down below to embed their third-party video synchronization channel into this layout frame.<br><br>🌐 <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.`;
        }

        if (!roomId) {
            if (input) input.classList.add('wt-input-error');
            if (helper) {
                helper.classList.add('wt-helper-error');
                helper.innerText = "Error: Room ID is required to join a channel!";
            }
            if (input) input.focus();
            return;
        }

        const container = document.getElementById('wt-overlay-container');
        if (!container) return;

        container.innerHTML = `
            <button id="wt-back" onclick="handleNav('watch-together', false)">
                <span class="wt-arrow">←</span> Back
            </button>
            <iframe
                src="https://app.kosmi.io/room/${encodeURIComponent(roomId)}"
                style="width:100%; height:100%; border:none;"
                allow="camera; microphone; display-capture; autoplay; encrypted-media; fullscreen; clipboard-write"
                allowfullscreen>
            </iframe>
        `;

        if (!isRemote && window.socket && window.socket.connected) {
            window.socket.emit('wt_sync', { room: window.myRoom, action: 'kosmi_room', roomId });
        }
    };

    const kosmiInput = document.getElementById('wt-kosmi-room');
    if (kosmiInput) {
        kosmiInput.addEventListener('input', function() {
            this.classList.remove('wt-input-error');
            const helper = document.getElementById('wt-kosmi-helper');
            if (helper) {
                helper.classList.remove('wt-helper-error');
                helper.innerHTML = `🔑 <strong>How to Use Room IDs:</strong> Paste an active Kosmi Room ID key down below to embed their third-party video synchronization channel into this layout frame.<br><br>🌐 <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.`;
            }
        });

        kosmiInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') wtJoinKosmi();
        });
    }

    const tvInput = document.getElementById('wt-tv-code');
    if (tvInput) {
        tvInput.addEventListener('input', function() {
            this.style.borderColor = 'rgba(218, 165, 32, 0.3)';
            const helper = document.getElementById('wt-tv-helper');
            if (helper) {
                helper.style.color = '#8e8e93';
                helper.innerText = "Got a link from someone else's TV? Paste it above and both TVs will sync up instantly.";
            }
        });
        tvInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') wtJoinOtherTV();
        });
    }

    if (window.socket) {
        window.socket.on('wt_sync', (data) => {
            if (data.action === 'kosmi_room' && data.roomId) {
                const input = document.getElementById('wt-kosmi-room');
                if (input) input.value = data.roomId;
                wtJoinKosmi(true);
            }
        });
    }
})();
</script>