</div>


    <!-- Embedded Direct Forms -->
     <div id="fields">
    <div class="wt-sub-heading">My Room</div>
    <div style="display: flex; gap: 12px; width: 100%; height: 42px; margin-bottom: 4px;">
        <div id="wt-room-code-box" class="wt-room-display">Lobby</div>
        <button id="wt-copy-btn" onclick="wtCopyRoomLink()" class="wt-copy-btn-inline">COPY LINK</button>
    </div>
    <div class="wt-input-helper" style="text-align: center; margin-bottom: 10px; font-size: 0.9rem; color: #ffffff;">
       
    </div>

    <div style="border-top: 1px solid rgba(255,255,255,0.08); margin: 10px 0;"></div>

    <div class="wt-sub-heading">Join Another TV</div>
    <div style="display: flex; gap: 12px; width: 100%;">
        <input type="text" id="wt-tv-code" placeholder="Paste room code or full URL..." style="margin-bottom: 0; padding: 0.65rem;">
        <button onclick="wtJoinOtherTV()" class="wt-btn" style="width: auto; padding: 0 22px; margin-top: 0; border-radius: 6px; height: 38px;">JOIN</button>
    </div>
    <div id="wt-tv-helper" class="wt-input-helper" style="text-align: center; margin-top: 6px; font-size: 0.9rem; color: #ffffff;">
      
    </div>
    </div>
</div>

        <!-- ── RIGHT CARD: KOSMI CARD ── -->
        <div class="wt-card">

            <div class="wt-card-icon">
                <div class="wt-title">Kosmi</div>
                        <span class="wt-badge" style="top:-20px;left: 295px;">External</span>

            </div>
            <p>Watch videos, play games, and hang out together with friends in synchronized rooms.</p>

            
            <ul class="wt-features">
                <li>YouTube, Netflix, Prime, Video stream share</li>
                <li>Screen sharing & Video chat Multiplayer games</li>
            </ul>

            <div class="wt-info-panel">
                <div id="wt-kosmi-helper" class="wt-input-helper">
                    <strong>How to Use Room IDs:</strong>To join an active session, paste a Kosmi Room ID or URL below to sync your TV with their stream.<br><br>
                    <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.
                </div>
            </div>

            <div class="wt-input-group">
                <input type="text" id="wt-kosmi-room" placeholder="Enter Kosmi room ID">
                <button class="wt-btn" onclick="wtJoinKosmi()">Join Kosmi Channel</button>
                <button class="wt-btn" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: #f0f0f0; box-shadow: none; margin-top: 0.5rem;" onclick="wtOpenKosmiExternal()">Open Kosmi Homepage</button>
            </div>
        </div>
    </div>

</div>

<script>
(function () {
    const roomBox = document.getElementById('wt-room-code-box');
    if (roomBox && window.myRoom) {
        roomBox.innerText = window.myRoom;
    }

    window.wtCopyRoomLink = function() {
        const btn = document.getElementById('wt-copy-btn');
        const roomCode = window.myRoom || "Lobby";
        const shareUrl = `${window.location.origin}?room=${encodeURIComponent(roomCode)}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
            if (btn) {
                btn.innerText = "COPIED!";
                btn.style.background = "#daa520";
                btn.style.color = "#0a0a0f";
                setTimeout(() => {
                    btn.innerText = "COPY LINK";
                    btn.style.background = "rgba(218, 165, 32, 0.1)";
                    btn.style.color = "#daa520";
                }, 2000);
            }
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    };

    window.wtJoinOtherTV = function() {
        const input = document.getElementById('wt-tv-code');
        const helper = document.getElementById('wt-tv-helper');
        const targetRoom = input ? input.value.trim() : '';

        if (!targetRoom) {
            if (input) input.style.borderColor = '#e74c3c';
            if (helper) {
                helper.style.color = '#e74c3c';
                helper.innerText = "Error: Please enter a valid room code or link!";
            }
            return;
        }

        let parsedCode = targetRoom;
        try {
            if(targetRoom.includes('?room=')) {
                const urlParams = new URLSearchParams(targetRoom.split('?')[1]);
                parsedCode = urlParams.get('room') || targetRoom;
            } else if (targetRoom.startsWith('http')) {
                const parsedUrl = new URL(targetRoom);
                parsedCode = parsedUrl.searchParams.get('room') || targetRoom;
            }
        } catch(e) {
            console.error("URL parsing fallback initialized:", e);
        }

        if (!parsedCode) {
            if (helper) {
                helper.style.color = '#e74c3c';
                helper.innerText = "Error: Invalid room configuration code format.";
            }
            return;
        }

        const loader = document.getElementById('loading-overlay');
        if (loader) {
            loader.style.display = 'flex';
        }

        if (typeof handleNav === "function") {
            try {
                handleNav('watch-together', false);
            } catch(err) {}
        }

        setTimeout(() => {
            window.location.href = window.location.origin + '/?room=' + encodeURIComponent(parsedCode);
        }, 150);
    };

    window.wtOpenKosmiExternal = function() {
        window.open('https://kosmi.io', '_self');
    };

window.wtJoinKosmi = function (isRemote = false) {
        const input = document.getElementById('wt-kosmi-room');
        const helper = document.getElementById('wt-kosmi-helper');
        let rawInput = input ? input.value.trim() : '';

        if (input) input.classList.remove('wt-input-error');
        if (helper) {
            helper.classList.remove('wt-helper-error');
            helper.innerHTML = `🔑 <strong>How to Use Room IDs:</strong> Paste an active Kosmi Room ID key down below to embed their third-party video synchronization channel into this layout frame.<br><br>🌐 <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.`;
        }

        if (!rawInput) {
            if (input) input.classList.add('wt-input-error');
            if (helper) {
                helper.classList.add('wt-helper-error');
                helper.innerText = "Error: Room ID or URL is required to join a channel!";
            }
            if (input) input.focus();
            return;
        }

        // 🔥 THE PARSER TRICK: Extract room name/ID from URLs or use raw text fallback
        let roomId = rawInput;
        try {
            // Checks for paths containing /room/room_id or matches standard domain signatures
            if (rawInput.includes('/room/')) {
                // Splits at /room/ and captures whatever comes after it
                const parts = rawInput.split('/room/');
                if (parts[1]) {
                    // Strips off any trailing URL query parameters like ?pass=123 if present
                    roomId = parts[1].split('?')[0].split('#')[0];
                }
            } else if (rawInput.startsWith('http')) {
                // If it's a URL but doesn't have /room/, extract the final segment of the pathname
                const urlObj = new URL(rawInput);
                const pathSegments = urlObj.pathname.split('/').filter(Boolean);
                if (pathSegments.length > 0) {
                    roomId = pathSegments[pathSegments.length - 1];
                }
            }
        } catch (e) {
            console.error("Kosmi URL extraction fallback error:", e);
            roomId = rawInput; // Fallback to raw text if parsing explodes
        }

        // Final sanitation check
        roomId = roomId.trim();

        const container = document.getElementById('wt-overlay-container');
        if (!container || !roomId) return;

        container.innerHTML = `
            <button id="wt-back" onclick="handleNav('watch-together', false)">
                <span class="wt-arrow">←</span> Back
            </button>
            <iframe
                src="https://app.kosmi.io/room/${encodeURIComponent(roomId)}"
                style="width:100%; height:100%; border:none;"
                allow="camera; microphone; display-capture; autoplay; encrypted-media; fullscreen; clipboard-write"
                allowfullscreen>
            </iframe>
        `;

        if (!isRemote && window.socket && window.socket.connected) {
            window.socket.emit('wt_sync', { room: window.myRoom, action: 'kosmi_room', roomId });
        }
    };
    const kosmiInput = document.getElementById('wt-kosmi-room');
    if (kosmiInput) {
        kosmiInput.addEventListener('input', function() {
            this.classList.remove('wt-input-error');
            const helper = document.getElementById('wt-kosmi-helper');
            if (helper) {
                helper.classList.remove('wt-helper-error');
                helper.innerHTML = `🔑 <strong>How to Use Room IDs:</strong> Paste an active Kosmi Room ID key down below to embed their third-party video synchronization channel into this layout frame.<br><br>🌐 <strong>Don't have a code?</strong> Click the secondary button underneath to navigate out to their webpage platform where you can set up a room and get an invite code.`;
            }
        });

        kosmiInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') wtJoinKosmi();
        });
    }

    const tvInput = document.getElementById('wt-tv-code');
    if (tvInput) {
        tvInput.addEventListener('input', function() {
            this.style.borderColor = 'rgba(218, 165, 32, 0.3)';
            const helper = document.getElementById('wt-tv-helper');
            if (helper) {
                helper.style.color = '#8e8e93';
                helper.innerText = "Got a link from someone else's TV? Paste it above and both TVs will sync up instantly.";
            }
        });
        tvInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') wtJoinOtherTV();
        });
    }

    if (window.socket) {
        window.socket.on('wt_sync', (data) => {
            if (data.action === 'kosmi_room' && data.roomId) {
                const input = document.getElementById('wt-kosmi-room');
                if (input) input.value = data.roomId;
                wtJoinKosmi(true);
            }
        });
    }
})();
</script>