<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1280">
    <title>Instructions - Smart TV</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@200;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --accent: #00d4ff;
            --glass-panel: rgba(0, 0, 0, 0.6);
        }

        body {
            margin: 0;
            padding: 0;
            width: 1280px;
            min-height: 100vh;
            background-color: #111;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            color: white;
            font-family: 'Fira Sans', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow: hidden;
        }

        /* Main Glass Container */
        #instructions-container {
            position: fixed;
            width: 1000px;
            top: 50px;
            padding: 40px;
            background: var(--glass-panel);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.8);
            text-align: center;
        }

        .title {
            font-size: 42px;
            color: var(--accent);
            text-transform: uppercase;
            margin-bottom: 30px;
            letter-spacing: 3px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
        }

        .section-title {
            font-size: 26px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #eee;
        }

        .text-line {
            font-size: 20px;
            margin: 12px 0;
            color: #ff0000;
            line-height: 1.5;
        }

        .green { color: #2ecc71; }
        .yellow { color: #f1c40f; }

        /* Bottom Footer for Legal/Buttons */
        .footer-area {
            position: fixed;
            bottom: 0;
            width: 1280px;
            height: 180px;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }

        .legal-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 30px;
            border-radius: 10px;
            font-size: 18px;
            text-align: center;
            width: 900px;
            border: 1px solid rgba(255, 255, 255, 0.1);
    
        }

        /* Buttons Styling */
        .nav-bar {
            display: flex;
            gap: 40px;
        }

        .btn {
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 12px;
            color: white;
            padding: 15px 80px;
            font-size: 22px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
        }

        .btn:hover, .btn:focus {
            outline: none;
            background: var(--accent);
            color: black;
            border-color: white;
            transform: scale(1.1);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.6);
        }
    </style>
</head>

<body>

    <div id="instructions-container">
        <div class="title">Instructions</div>

        <div class="section-title">FRAME BUTTONS</div>
        <div class="text-line">( <b class="yellow">Right Button</b> - Settings HUD for Size, Aspect, Textures, etc. )</div>
        <div class="text-line">( <b class="yellow">Left Button</b> - Page Back when browsing external sites )</div>

        <div style="margin: 25px 0; opacity: 0.3;">_________________________________</div>

        <div class="text-line green">( Use <b>SETUP</b> for the Menu or get the HUD via the Right Frame Button )</div>
        <div class="text-line green">( Move mouse to the <b class="yellow">Top</b> during video playback for the Back button )</div>
        
        <div class="text-line" style="margin-top: 30px; ">
            ( For legal reasons, copyright movies are not streamed )
        </div>
    </div>

    <div class="footer-area">
        <div class="legal-box">
            This TV is a pass-through device, all media is broadcast directly from original sites.<br>
            Internet links are subject to change or deletion at any time.
        </div>

<div class="nav-bar">
    <!-- Botão para carregar o fragmento de Settings via AJAX -->
    <div class="btn" data-type="menu" data-mode="settings">SETUP</div>
    
    <!-- Botão para voltar à Home -->
    <div class="btn" data-type="menu" data-mode="home">BACK</div>
</div>
    </div>

<script>
    // Handle dynamic background
    const pic = localStorage.getItem("user_bg") || localStorage.getItem("pic");
    if (pic) {
        document.body.style.backgroundImage = "url(" + pic + ")";
    } else {
        document.body.style.backgroundImage = "url('https://www.zastavki.com/pictures/1280x720/2014/Backgrounds_Black_wallpaper_with_red_abstraction_078603_26.jpg')";
    }

    // Handle session URLs
    const url1 = localStorage.getItem("url1");
    const url2 = localStorage.getItem("url2");
    const return_url = url1 + "&" + url2;
</script>

</body>
</html>