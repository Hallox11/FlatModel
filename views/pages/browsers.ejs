<style>
/* =========================
    MAIN WRAPPER
========================= */
#browsers-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20, 20, 20, 0.6), rgba(0, 0, 0, 0.5));
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
    margin: 20px auto;
    position: relative;
    font-family: Arial, sans-serif;
}

/* =========================
    CLOSE BUTTON
========================= */
.close-menu-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    cursor: pointer;
    color: white;
    font-size: 26px;
    user-select: none;
}

.close-menu-btn:hover {
    color: #ff6b6b;
}

/* =========================
    TITLE
========================= */
#title {
    font-size: 30px;
    color: #78ffd5;
    text-transform: uppercase;
    margin-bottom: 20px;
    letter-spacing: 4px;
}

/* =========================
    SCROLL CONTAINER
========================= */
.conteiner {
    width: 95%;
    max-height: 460px;
    overflow-y: auto;
    padding: 20px;
    background: rgba(0, 0, 0, 0.0);
    border-radius: 20px;
}

/* =========================
    SECTIONS
========================= */
.section-title {
    color: #78ffd5;
    font-size: 19px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 18px 0 10px 0;
    padding-bottom: 6px;
    border-bottom: 1px solid #78ffd5;
}

.section-title:first-child {
    margin-top: 0;
}

.grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
}

/* =========================
    BUTTONS
========================= */
.btn {
    background: rgba(255, 107, 107, 0.15);
    border: 1px solid #ff6b6b;
    border-radius: 12px;
    padding: 14px 12px;
    font-size: 18px;
    color: white;
    cursor: pointer;
    user-select: none;
    pointer-events: auto;
    transition: all 0.2s ease;
    display: grid;
    grid-template-columns: 28px 1fr;
    align-items: center;
    gap: 10px;
    width: 100%;
    box-sizing: border-box;
}

.btn img {
    width: 28px;
    height: 28px;
    border-radius: 6px;
}

.btn span {
    text-align: left;
}

.btn:hover {
    background: #ff6b6b;
    color: #000;
    transform: scale(1.05);
}

/* =========================
    INPUT BOX
========================= */
.input-box {
    margin-top: 20px;
    width: 90%;
    display: flex;
    gap: 10px;
    background: rgba(0, 0, 0, 0.6);
    padding: 10px;
    border-radius: 15px;
    border: 1px solid rgba(255, 107, 107, 0.3);
}

.input-box input[type="text"] {
    flex-grow: 1;
    background: transparent;
    border: none;
    color: white;
    font-size: 18px;
    outline: none;
    padding-left: 10px;
}

.input-box input[type="button"] {
    background: #27ae60;
    color: white;
    border: none;
    padding: 10px 25px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
}

/* =========================
    CUSTOM TV MODAL
========================= */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
}

.modal-content {
    background: #1a1a1a;
    border: 2px solid #ff6b6b;
    border-radius: 20px;
    padding: 40px;
    width: 650px;
    text-align: center;
    box-shadow: 0 0 30px rgba(255, 107, 107, 0.3);
    transform: scale(0.8);
    transition: transform 0.3s ease;
}

.modal-overlay.active .modal-content {
    transform: scale(1);
}

.modal-title {
    color: #ff6b6b;
    font-size: 28px;
    font-weight: bold;
    text-transform: uppercase;
    margin-bottom: 25px;
    letter-spacing: 2px;
}

.modal-text {
    color: #e0e0e0;
    font-size: 20px;
    line-height: 1.6;
    margin-bottom: 35px;
    text-align: left;
    padding: 0 10px;
}

.modal-text ul {
    margin-top: 15px;
    padding-left: 20px;
}

.modal-text li {
    margin-bottom: 12px;
}

.modal-text strong {
    color: #ff6b6b;
}

.modal-text .highlight-blue {
    color: #3498db;
}

.modal-buttons {
    display: flex;
    justify-content: center;
    gap: 25px;
}

.modal-btn {
    padding: 15px 40px;
    font-size: 18px;
    font-weight: bold;
    border-radius: 10px;
    cursor: pointer;
    border: none;
    transition: transform 0.2s;
}

.modal-btn:hover {
    transform: scale(1.05);
}

.btn-confirm {
    background: #27ae60;
    color: white;
}

.btn-cancel {
    background: #4f4f4f;
    color: white;
}

.modal-text {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 35px;
}

.modal-text p {
    margin: 0;
    font-size: 19px;
    line-height: 1.6;
    color: #e0e0e0;
    text-align: left;
}

.modal-tip {
    font-size: 17px;
    color: #cfcfcf;
}

.modal-note {
    font-size: 15px;
    color: #999;
}
</style>

