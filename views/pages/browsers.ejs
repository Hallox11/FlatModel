<script>
let targetUrlHolder = "";

function requestConfirmation(url) {
    targetUrlHolder = url;
    document.getElementById("tv-confirm-modal").classList.add("active");
}

function closeModal() {
    document.getElementById("tv-confirm-modal").classList.remove("active");
    targetUrlHolder = "";
}

function confirmNavigation() {
    if (targetUrlHolder) {
        window.location.href = targetUrlHolder;
    }
}

function submitUrl() {
    const input = document.getElementById("tag");
    let url = input.value.trim();

    if (url) {
        let finalUrl = "";

        if (url.startsWith("http://") || url.startsWith("https://")) {
            finalUrl = url;
        }
        else if (url.includes(".") && !url.includes(" ")) {
            finalUrl = "https://" + url;
        }
        else {
            finalUrl = "https://www.google.com/search?q=" + encodeURIComponent(url);
        }

        requestConfirmation(finalUrl);
    }
}

document.getElementById("tag").addEventListener("keydown", function(event) {
    if (event.key === "Enter") {
        submitUrl();
    }
});

</script>