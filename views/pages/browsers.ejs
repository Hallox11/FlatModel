<style>
    /* 1. Wrapper to activate the Red Theme and Grid */
    #browsers-menu-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 1150px;
        animation: fadeIn 0.4s ease-out;
    }

    /* 2. The Circular Close Button (Top Right) */
    #browsers-menu-wrapper .close-btn {
        position: absolute;
        top: -20px;
        right: 0px;
        width: 50px;
        height: 50px;
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid #ff6b6b;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
        padding: 0;
    }

    #browsers-menu-wrapper .close-btn:hover, 
    #browsers-menu-wrapper .close-btn:focus {
        background: #ff6b6b;
        color: black;
        transform: scale(1.1) rotate(90deg);
        box-shadow: 0 0 15px rgba(255, 107, 107, 0.5);
    }

    /* 3. Title Styling */
    #browsers-menu-wrapper #title {
        font-size: 42px;
        color: #ff6b6b;
        text-transform: uppercase;
        margin-bottom: 20px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Grid Container */
    #browsers-menu-wrapper .conteiner {
        display: grid !important;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        width: 100%;
        max-height: 420px;
        overflow-y: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* 5. Individual Browser Buttons */
    #browsers-menu-wrapper .btn {
        background: rgba(255, 107, 107, 0.15) !important;
        border: 1px solid #ff6b6b !important;
        border-radius: 12px;
        padding: 20px 10px !important;
        font-size: 20px;
        color: white;
        text-align: center;
        transition: all 0.2s ease;
    }

    #browsers-menu-wrapper .btn:focus, 
    #browsers-menu-wrapper .btn:hover {
        background: #ff6b6b !important;
        color: #000 !important;
        transform: scale(1.05);
        outline: none;
    }

    /* 6. URL Input Box */
    #browsers-menu-wrapper .input-box {
        margin-top: 30px;
        width: 800px;
        display: flex;
        gap: 10px;
        background: rgba(0, 0, 0, 0.6);
        padding: 10px;
        border-radius: 15px;
        border: 1px solid rgba(255, 107, 107, 0.3);
        backdrop-filter: blur(10px);
    }

    #browsers-view-container #tag {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        padding-left: 15px;
        outline: none;
    }

    /* Scrollbar reset */
    #browsers-menu-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div id="browsers-menu-wrapper">
    
    <button class="close-btn" onclick="closeSubMenu()" tabindex="30">
        <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <div id="title">Browsers Menu</div>

    <div class="conteiner">
        <div class="btn" data-type="external" data-mode="https://google.com" tabindex="1">Google</div>
        <div class="btn" data-type="external" data-mode="https://twitter.com" tabindex="2">Twitter</div>
        <div class="btn" data-type="external" data-mode="https://ted.com" tabindex="3">Ted Talks</div>
        <div class="btn" data-type="external" data-mode="https://instagram.com" tabindex="4">Instagram</div>
        <div class="btn" data-type="external" data-mode="https://facebook.com" tabindex="5">Facebook</div>
        <div class="btn" data-type="external" data-mode="https://linkedin.com" tabindex="6">LinkedIn</div>
        <div class="btn" data-type="external" data-mode="https://flickr.com/explore" tabindex="7">Flickr</div>
        <div class="btn" data-type="external" data-mode="https://reddit.com" tabindex="8">Reddit</div>
        <div class="btn" data-type="external" data-mode="https://youtube.com" tabindex="9">YouTube</div>
        <div class="btn" data-type="external" data-mode="https://wikipedia.org" tabindex="10">Wikipedia</div>
        <div class="btn" data-type="external" data-mode="https://amazon.com" tabindex="11">Amazon</div>
        <div class="btn" data-type="external" data-mode="https://vimeo.com" tabindex="12">Vimeo</div>
        <div class="btn" data-type="external" data-mode="https://twitch.tv" tabindex="13">Twitch</div>
        <div class="btn" data-type="external" data-mode="https://tiktok.com" tabindex="14">TikTok</div>
        <div class="btn" data-type="external" data-mode="https://pinterest.com" tabindex="15">Pinterest</div>
        <div class="btn" data-type="external" data-mode="https://quora.com" tabindex="16">Quora</div>
    </div>

    <div class="input-box">
        <input id="tag" type="text" placeholder="Enter URL (http://...)" onfocus="this.value=''" 
               style="flex-grow: 1; background: transparent; border: none; color: white; font-size: 20px; outline: none; padding-left:15px;">
        <input onclick="submitUrl()" type="button" value="GO" 
               style="background: #27ae60; color: white; border: none; padding: 10px 30px; border-radius: 8px; cursor: pointer; font-weight:bold;">
    </div>

</div>

<script>
    function submitUrl() {
        var url = $("#tag").val();
        if(url && url.startsWith("http")) {
            if (typeof handleNav === 'function') {
                handleNav(url);
            } else {
                window.location.href = url;
            }
        } else {
            $("#tag").css("color","yellow").val("Must start with http://");
        }
    }


    function goToMainPage() {
    // 1. Kill any active YouTube players to stop audio/video
    if (window.player) {
        if (typeof window.player.stopVideo === 'function') window.player.stopVideo();
        if (typeof window.player.destroy === 'function') window.player.destroy();
        window.player = null;
    }

    // 2. Kill any Radio/Audio streams
    $('audio, iframe[src*="muses"], object, embed').remove();

    // 3. Call your global close function 
    // This handles the FadeOut, shows the Grid, and Resets the Status Bar
    if (typeof closeSubMenu === 'function') {
        closeSubMenu(); 
    }
}
</script>