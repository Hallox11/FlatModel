<style>
/* ==========================================================================
   1. CORE WRAPPER & LAYOUT
   ========================================================================== */
#flickr-wrapper { 
    width: 1280px;
    height: 720px;
    color: #fff;
    font-family: 'Segoe UI', Roboto, sans-serif;
    display: flex;          
    flex-direction: column; 
    overflow: hidden;       
    position: relative;

}

/* Navbar */
#flickr-nav-container {
        width: 100%; height: 65px;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 35px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
        z-index: 100; flex-shrink: 0; box-sizing: border-box;
        margin-bottom: 0px;
}

/* ==========================================================================
   2. GRID & SCROLLBAR (O Coração do App)
   ========================================================================== */
#flickr-results-grid { 
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); /* Auto ajusta */
    grid-auto-rows: 10px; 
    gap: 15px;
    margin-left: 5px;
    width: 1250px; 
    height: 630px; 
    padding: 3px 20px 60px 30px;
    box-sizing: border-box;
    overflow-y: scroll;
    overflow-x: hidden;
    scrollbar-gutter: stable;
}

/* Custom Scrollbar */
#flickr-results-grid::-webkit-scrollbar { width: 12px; }
#flickr-results-grid::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
#flickr-results-grid::-webkit-scrollbar-thumb { 
    background: goldenrod; 
    border-radius: 10px; 
}

/* ==========================================================================
   3. DYNAMIC LAYOUT MODES (Grid 1, 2, 3)
   ========================================================================== */

/* MODO 1: FEED CENTRALIZADO (Fixes "Empty Screen" issue) */
/* Modos Fixos (Forçam a quantidade de colunas) */
.grid-cols-4 { grid-template-columns: repeat(4, 1fr) !important; }
.grid-cols-3 { grid-template-columns: repeat(3, 1fr) !important; }
.grid-cols-2 { grid-template-columns: repeat(2, 1fr) !important; }

/* Modo 1 (Feed) */
/* Modo 1 (Feed) - Mantendo a proporção original */
.grid-cols-1 { display: block !important; }
.grid-cols-1 .flickr-card {
    max-width: 65%; /* Ocupa a largura total disponível */
    margin: 0 auto 40px auto !important;
    grid-row-end: auto !important;
    height: auto !important; /* Força o cartão a moldar-se à imagem */
}

.grid-cols-1 .flickr-card img {
    width: 100%;
    height: auto !important; /* Garante que a imagem dita a proporção real */
    object-fit: contain;
}
/* ==========================================================================
   4. CARDS & INTERACTION
   ========================================================================== */
.flickr-card { 
    width: 100%;
    border: none; 
    cursor: pointer; 
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    outline: 0px solid transparent;
    outline-offset: -2px;
    transform: translateZ(0);
    backface-visibility: hidden;
    transition: transform 0.25s ease, outline 0.25s ease;
    border-radius: 4px;
}

.flickr-card img { width: 100%; height: auto; display: block; }

.flickr-card:hover { 
    transform: scale(1.0); 
    
    z-index: 10;
}

/* Remote Sync Signal */
.flickr-card.remote-hover {
   
    transform: scale(1.0) !important;
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.4);
    z-index: 999;
    position: relative;
}

/* ==========================================================================
   5. UI ELEMENTS (Buttons, Search, Tags)
   ========================================================================== */
.nav-group { display: flex; gap: 8px; align-items: center; }

.modern-btn {
    background: #daa5202e;
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgb(230, 229, 229);
    padding: 5px 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.modern-btn:hover {
    background: rgba(218, 165, 32, 0.15);
    border-color: rgba(218, 165, 32, 0.5);
    color: #fff;
}

.view-btn-active {
    background: goldenrod !important;
    color: #000 !important;
    border-color: goldenrod !important;
    box-shadow: 0 4px 12px rgba(218, 165, 32, 0.3);
}

/* Search Bar */
.search-pill {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    
    height: 25px;
    width: 250px;
    transition: 0.3s;
}

.search-pill:focus-within { border-color: goldenrod; background: rgba(255,255,255,0.1); }
.search-pill input { background: transparent; border: none; color: #fff; outline: none; font-size: 13px; width: 100%; }

.search-go-btn {
    background: #ffd50557;
    color: #fff; border: none; border-radius: 4px;
    padding: 7px 12px; font-size: 13px; font-weight: 400; cursor: pointer;
}

/* App Branding/Title */
.current-tag { display: flex; flex-direction: column; margin-right: 20px; min-width: 140px; }
.current-tag span { font-size: 18px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; }
.current-tag small { color: goldenrod; font-size: 11px; margin-top: 2px; opacity: 0.8; letter-spacing: 1px; }

/* ==========================================================================
   6. LIGHTBOX & OVERLAYS
   ========================================================================== */
#flickr-lightbox {
    position: fixed; top: 0; left: 0;
    width: 1280px; height: 720px;
    background: rgba(0, 0, 0, 0.9); 
    display: none; justify-content: center; align-items: center;
    z-index: 10000; flex-direction: column;
}

#lightbox-img-container {
    position: relative; max-width: 90%; max-height: 80%;
    border: 2px solid rgba(255,255,255,0.1); background: #000;
}

#lightbox-img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }

/* Navigation & Controls */
.ss-nav { 
    position: absolute; top: 50%; transform: translateY(-50%); 
    background: rgba(0, 0, 0, 0.5); color: white; padding: 20px 15px;
    cursor: pointer; font-size: 30px; border: none; transition: 0.2s;
}
.ss-nav:hover { background: goldenrod; color: black; }
.ss-prev { left: 40px; border-radius: 5px; }
.ss-next { right: 40px; border-radius: 5px; }

.ss-close { 
    position: absolute; top: 20px; right: 20px; 
    color: white; background: rgba(255,255,255,0.1); 
    border: 1px solid white; border-radius: 50%;
    width: 50px; height: 50px; font-size: 30px; cursor: pointer;
}

/* Utils */
.spinner { 
    border: 3px solid rgba(218,165,32,0.1); border-top: 3px solid goldenrod; 
    border-radius: 50%; width: 35px; height: 35px; margin: 0 auto 15px; 
    animation: spin 1s linear infinite; 
}
@keyframes spin { to { transform: rotate(360deg); } }  

/* ==========================================================================
   5B. RE-DESIGN: CHANNELS & CATEGORIES MODAL ADVANCED
   ========================================================================== */
.manager-modal-container {
    padding: 30px;
    background: rgba(15, 15, 20, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    margin: 20px auto;
    width: 1180px;
    box-sizing: border-box;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    animation: modalSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes modalSlideUp {
    from { transform: translateY(15px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.manager-modal-title {
    color: #fff;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 0;
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 15px;
}

.manager-modal-title::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 18px;
    background: goldenrod;
    border-radius: 4px;
}

/* Grelha de Chips Responsiva e Limpa */
.chips-flex-container {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)) !important;
    gap: 12px !important;
    width: 100%;
}

/* O Novo Botão em Formato de Chip Premium */
.modern-pill-chip {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 10px !important;
    color: #e0e0e0 !important;
    padding: 10px 18px !important;
    font-size: 14px !important;
    font-weight: 400 !important;
    text-align: left !important;
    cursor: pointer !important;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
    box-sizing: border-box !important;
}

.modern-pill-chip:hover {
    background: rgba(218, 165, 32, 0.08) !important;
    border-color: rgba(218, 165, 32, 0.6) !important;
    color: #fff !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 20px rgba(218, 165, 32, 0.15) !important;
}

.modern-pill-chip .chip-icon {
    color: goldenrod;
    opacity: 0.6;
    font-size: 11px;
    transition: transform 0.2s ease;
}

.modern-pill-chip:hover .chip-icon {
    opacity: 1;
    transform: translateX(3px);
}
.icon-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ccc;
    padding: 6px 10px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 12px;
}

.icon-btn:hover {
    background: goldenrod;
    color: #000;
}
</style>


