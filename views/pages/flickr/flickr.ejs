<script>
(function() {

const flickrGrid = document.getElementById('flickr-results-grid');

flickrGrid.addEventListener('wheel', (e) => {
    // Impede o scroll padrão lento
    e.preventDefault();

    // Ajuste este número para aumentar/diminuir a sensibilidade
    const speedMultiplier = 2.0; 

    // Move o scroll manualmente
    flickrGrid.scrollTop += e.deltaY * speedMultiplier;

    // Sincroniza o scroll com os outros usuários (opcional, já que você já tem o emit no scroll)
    // O seu código de scroll atual capturará essa mudança automaticamente.
}, { passive: false });




// CHANGE LAYOUT    
window.changeLayout = function(type, btn, isRemote = false) {
    const grid = $('#flickr-results-grid');
    
    // Limpa tudo
    grid.removeClass('grid-cols-1 grid-cols-2 grid-cols-3 grid-cols-4');
    $('.view-btn').removeClass('view-btn-active');
    if (btn) $(btn).addClass('view-btn-active');

    // Aplica o novo modo
    if (type !== 'auto') {
        grid.addClass(`grid-cols-${type}`);
    }

    // Reset de estilos internos para garantir que o Masonry ou o Feed funcionem
if (type === '1') {
    // Limpa qualquer resíduo de altura e spans do modo grelha
    $('.flickr-card').css({
        'grid-row-end': '',
        'height': 'auto'
    });
    $('.flickr-card img').css('height', 'auto');
} else {
    setTimeout(() => {
        window.currentPhotos.forEach((_, i) => window.resizeGridItem(i));
    }, 50);
}

    grid.scrollTop(0);

    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_layout_change', 
            layoutType: type, 
            room: window.myRoom 
        });
    }
};


// PHOTO SEARCH
window.currentPhotos = [];
window.currentIndex = 0;
window.runFlickrSearch = function(manualQuery = null, incomingPhotos = null, isRemote = false) {
    window.resetFlickrState();
    const tags = manualQuery || $('#flickr-search').val();

    // SE as fotos já vieram prontas pelo Socket (incomingPhotos), 
    // APENAS desenhe o grid. NÃO faça uma nova chamada de API.
    if (incomingPhotos) {
        console.log("Sincronizando fotos via Socket (Sem nova requisição API)");
        $('#flickr-loader').hide();
        $('#flickr-results-grid').show();
        window.renderGrid(incomingPhotos);
        return; // <--- O "Pulo do Gato" está aqui. Interrompe o loop.
    }

    // Se chegou aqui, é uma busca MANUAL do usuário
$('#flickr-loader').css('display', 'flex').hide().fadeIn(100);

    $.getJSON(`/api/flickr/search?tags=${encodeURIComponent(tags)}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            window.renderGrid(photos);

            // Avisa os outros, mas envia os DADOS das fotos junto
            if (window.socket && !isRemote) {
                window.socket.emit('state_sync', {
                    type: 'flickr_results_sync',
                    query: tags,
                    photos: photos, // Envia as fotos já baixadas
                    room: window.myRoom
                });
            }
        });
};
// RENDER GRID
window.renderGrid = function(photos) {
    window.currentPhotos = photos; 

    // ATUALIZAÇÃO DO CONTADOR:
    // Seleciona o elemento e atualiza com o número de fotos retornadas
    const countLabel = photos ? photos.length : 0;
    $('#photo-count').text(`${countLabel} PHOTOS`);

    if (!photos || photos.length === 0) {
        $('#flickr-results-grid').html('<p style="color:gray; text-align:center; padding:20px;">No photos found.</p>');
        return;
    }

    let html = photos.map((p, i) => `
        <div class="flickr-card" id="card-${i}" onclick="window.startSlideshow(${i})">
            <img src="https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_z.jpg" 
                 onload="window.resizeGridItem(${i})">
        </div>`).join('');
    $('#flickr-results-grid').html(html);
};
// RESIZE GRID
window.resizeGridItem = function(index) {
    const item = document.getElementById(`card-${index}`);
    const grid = document.getElementById('flickr-results-grid');
    if (!item || !grid) return;
    
    const rowHeight = 10, rowGap = 15;
    const img = item.querySelector('img');
    
    // Captura a altura atual na DOM
    let imgHeight = img.getBoundingClientRect().height;
    
    // CORREÇÃO: Se a altura for 0 (comum em imagens em cache), calcula proporcionalmente
    if (imgHeight === 0 && img.naturalHeight > 0) {
        const aspect = img.naturalWidth / img.naturalHeight;
        imgHeight = item.offsetWidth / aspect;
    }

    const rowSpan = Math.ceil((imgHeight + rowGap) / (rowHeight + rowGap));
    item.style.gridRowEnd = `span ${rowSpan}`;
};
// --- 3. CATEGORIES ---
// --- CATEGORIES ---
// Load Favorites from local JSON
window.showCategoriesPage = function(isRemote = false) {
    $('#flickr-results-grid, #favorites-manager').hide(); 
    $('#categories-manager').fadeIn(200);
    
    // Call the specific loader
    window.loadCategoriesList();

    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_show_categories', room: window.myRoom }); 
    }
};

window.closeCategoriesPage = function(isRemote = false) {
    $('#categories-manager').hide();
    $('#flickr-results-grid').fadeIn(200);
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_close_categories', room: window.myRoom });
    }
};
// --- FAVORITES/CHANNELS ---
window.showFavoritesPage = function(isRemote = false) {
    $('#flickr-results-grid, #categories-manager').hide();
    $('#favorites-manager').fadeIn(200);
    window.loadFavoritesList();

    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_show_channels', room: window.myRoom });
    }
};

// NOVO: Função para fechar os Channels com Sync
window.closeFavoritesPage = function(isRemote = false) {
    $('#favorites-manager').hide();
    $('#flickr-results-grid').fadeIn(200);
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_close_channels', room: window.myRoom });
    }
};


// Example modification for your existing loadFavoritesList
window.loadFavoritesList = function() {
    fetch('/api/favorites')
        .then(res => res.json())
        .then(data => {
            let html = Object.entries(data).map(([name, id]) => `
                <div class="modern-pill-chip">
                    <span>${name}</span>
                    <div style="display:flex; gap:5px;">
                        <button class="icon-btn" onclick="window.viewChannel('${id}')" title="View Photos">
                            <i class="fas fa-camera"></i>
                        </button>
                        <button class="icon-btn" onclick="window.viewUserAlbums('${id}')" title="View Albums">
                            <i class="fas fa-folder-open"></i>
                        </button>
                    </div>
                </div>`).join('');
            $('#channels-list').html(html);
        });
};
window.loadCategoriesList = function() {
    fetch('/api/favorites2')
        .then(res => res.json())
        .then(data => {
            let html = Object.entries(data).map(([name, id]) => `
                <div class="modern-pill-chip">
                    <span>${name}</span>
                    <button class="icon-btn" onclick="window.closeCategoriesPage(); window.viewChannel('${id}')" title="View Photos">
                        <i class="fas fa-camera"></i>
                    </button>
                </div>`).join('');
            $('#categories-list').html(html);
        })
        .catch(err => console.error("Error loading categories:", err));
};
/////////////7777
window.viewChannel = function(userId, isRemote = false) {
    
    $('#favorites-manager, #categories-manager, #flickr-results-grid').hide();
    $('#flickr-loader').css('display', 'flex').hide().fadeIn(100);
    
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_channel_sync', 
            userId: userId, 
            room: window.myRoom 
        });
    }

    // CHAMADA PARA O SEU SERVIDOR (Mais seguro e funciona!)
    $.getJSON(`/api/flickr/channel/${userId}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            $('#flickr-results-grid').fadeIn(300);
            window.resetFlickrState();
            window.renderGrid(photos); // Isso agora vai funcionar porque photos é o array correto
        })
        .fail(function() {
            $('#flickr-loader').text("Error: Could not load channel.");
            setTimeout(() => {
                $('#flickr-loader').hide();
                $('#favorites-manager').show();
            }, 2000);
        });
};

// --- 5. SLIDESHOW ---
window.startSlideshow = function(index, isRemote = false) {
        window.currentIndex = index;
        window.updateLightbox();
        $('#flickr-main-ui').fadeOut(100, () => {
            $('#flickr-lightbox').css('display', 'flex').hide().fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'start_slideshow', index: index, room: window.myRoom });
        }
    };

window.updateLightbox = function() {
    const p = window.currentPhotos[window.currentIndex];
    if (!p) {
        console.error("Slideshow Error: No photo found at index", window.currentIndex);
        return;
    }

    // Definição das URLs
    const urlLarge = `https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_b.jpg`;
    const urlMedium = `https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_z.jpg`;
    
    const imgElement = $('#lightbox-img');
    
    // CORREÇÃO: Remove o listener anterior (.off) e escuta o erro apenas uma vez (.one)
    imgElement.off('error').one('error', function() {
        $(this).attr('src', urlMedium);
    });

    imgElement.attr('src', urlLarge);
    $('#img-title').text(p.title || "Untitled");

    if (window.socket) {
        window.socket.emit('state_sync', { 
            type: 'flickr_remote_nav', 
            index: window.currentIndex, 
            url: urlLarge, 
            title: p.title, 
            room: window.myRoom 
        });
    }
};

window.nextPhoto = function() {
        window.currentIndex = (window.currentIndex + 1) % window.currentPhotos.length;
        window.updateLightbox();
    };

window.prevPhoto = function() {
        window.currentIndex = (window.currentIndex - 1 + window.currentPhotos.length) % window.currentPhotos.length;
        window.updateLightbox();
    };

window.exitSlideshow = function(isRemote = false) {
        $('#flickr-lightbox').fadeOut(200, () => {
            $('#flickr-main-ui').fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'exit_slideshow', room: window.myRoom });
        }
    };

    // --- 6. INITIAL LOAD & SCROLL ---
// --- 6. INITIAL LOAD & SCROLL ---
    $(document).ready(() => {
        // 1. Force the 3-column layout and highlight the 3x button on startup
        const btn3x = $("button[onclick*=\"changeLayout('3'\"]");
        window.changeLayout('3', btn3x, true); // true avoids sending an initial socket sync blast

        // 2. Only load if the grid is empty
        if(!window.currentPhotos.length) window.runFlickrSearch('Second life');
    });

// CLICK OUTSIDE MODALS TO CLOSE
$(document).on('click', function(event) {
    // 1. For Favorites Manager
    const favModal = $('#favorites-manager');
    const favBtn = $("button[onclick*='showFavoritesPage']"); // The navbar button
    
    if (favModal.is(':visible') && 
        !favModal.is(event.target) && 
        favModal.has(event.target).length === 0 && 
        !favBtn.is(event.target)) {
        
        favModal.hide();
        $('#flickr-results-grid').fadeIn(200);
    }

    // 2. For Categories Manager
    const catModal = $('#categories-manager');
    const catBtn = $("button[onclick*='showCategoriesPage']"); // The navbar button
    
    if (catModal.is(':visible') && 
        !catModal.is(event.target) && 
        catModal.has(event.target).length === 0 && 
        !catBtn.is(event.target)) {
        
        catModal.hide();
        $('#flickr-results-grid').fadeIn(200);
    }
});

$('#flickr-results-grid').on('scroll', function() {
    if (window.isSyncing) return;  // ← global flag
    if (window.socket && window.socket.connected) {
        window.socket.emit('state_sync', {
            type: 'scroll',          // ← global event type
            position: $(this).scrollTop(),
            room: window.myRoom
        });
    }
});  
    
    // Add this to your Flickr script block
window.closeSubMenuWithLightbox = function() {
    // If the lightbox is open, close it first
    if ($('#flickr-lightbox').is(':visible')) {
        window.exitSlideshow();
    } else {
        // Otherwise, close the whole Flickr app
        closeSubMenu();
    }
};

// Função para limpar o estado apenas ao mudar de conteúdo
window.resetFlickrState = function() {
    window.currentIndex = 0;       // Faz reset ao índice do Slideshow
    window.currentPhotos = [];      // Limpa as fotos antigas
    
    const grid = $('#flickr-results-grid');
   
        grid.scrollTop(0);          // Força o scroll a ir para o topo (0)
        grid.html('');              // Limpa a área visual
   
};

////////////////////////////////////
// 1. Show the list of albums for a specific user
// Add isRemote = false as a default parameter
window.viewUserAlbums = function(userId, isRemote = false) {
    $('#favorites-manager, #flickr-results-grid').hide();
    $('#flickr-loader').css('display', 'flex').fadeIn(100);

    $.getJSON(`/api/flickr/albums/${userId}`)
        .done(function(albums) {
            $('#flickr-loader').hide();
            $('#albums-manager').show();
            
            let html = albums.map(a => `
                <button class="modern-pill-chip" onclick="window.loadAlbumPhotos('${a.id}', '${userId}')">
                    <span>📁 ${a.title._content}</span>
                    <span class="chip-icon">➔</span>
                </button>`).join('');
            $('#albums-list').html(html);

            // SYNC ONLY AFTER SUCCESSFUL LOAD
            if (window.socket && !isRemote) {
                window.socket.emit('state_sync', { 
                    type: 'flickr_show_albums_modal', 
                    userId: userId, 
                    room: window.myRoom 
                });
            }
        });
};

// 2. Load photos from a chosen album into the main grid
window.loadAlbumPhotos = function(photosetId, userId, isRemote = false) {
    $('#albums-manager').hide();
    $('#flickr-loader').css('display', 'flex').fadeIn(100);

    // If this is a local click, sync it to others
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', {
            type: 'flickr_album_sync',
            photosetId: photosetId,
            userId: userId,
            room: window.myRoom
        });
    }

    $.getJSON(`/api/flickr/album-photos/${photosetId}/${userId}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            $('#flickr-results-grid').fadeIn(200);
            window.resetFlickrState();
            window.renderGrid(photos);
        });
};
window.viewGroup = function(groupId, isRemote = false) {
    $('#favorites-manager, #flickr-results-grid').hide();
    $('#flickr-loader').css('display', 'flex').fadeIn(100);

    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_group_sync', 
            groupId: groupId, 
            room: window.myRoom 
        });
    }

    $.getJSON(`/api/flickr/group/${groupId}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            $('#flickr-results-grid').fadeIn(200);
            window.resetFlickrState();
            window.renderGrid(photos);
        });
};

})();
