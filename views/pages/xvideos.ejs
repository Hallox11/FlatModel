<style>
    /* 1. ESTRUTURA PRINCIPAL */
    #xxx-module {
        width: 1280px;
        height: 720px;
        display: flex;
        flex-direction: column;
        background: rgba(0, 0, 0, 0.4);
        color: white;
        overflow: hidden;
        font-family: 'Outfit', sans-serif;
        position: relative;
    }

    /* 2. NAV BAR ESTILO SL */
    .sl-nav-header {
        height: 75px;
        padding: 0 40px;
        display: flex;
        align-items: center;
        background: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.8) 70%, rgba(0,0,0,0) 100%);
        flex-shrink: 0;
        z-index: 100;
        box-sizing: border-box;
    }

    .nav-left .current-tag {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
        min-width: 160px;
    }

    .nav-left .current-tag span { font-size: 20px; font-weight: 400; letter-spacing: 1px; }
    .nav-left .current-tag small { font-size: 13px; color: #f00; text-transform: uppercase; font-weight: bold; }

    .category-chips { display: flex; gap: 8px; margin-left: 20px; align-items: center; }

    .chip { 
        background: rgba(255,255,255,0.05);
        border: 1px solid #444;
        color: white; 
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 400;
        font-size: 14px;
        transition: 0.2s;
    }

    .chip.active { background: rgba(255, 204, 0, 0.1); border-color: #ffcc00; color: #ffcc00; }
    .chip:hover { border-color: #fff; background: rgba(255,255,255,0.1); }

    .nav-right { margin-left: auto; display: flex; gap: 10px; align-items: center; }

    #xxx-search-input {
        background: rgba(26, 26, 26, 0.8);
        border: 1px solid #333;
        color: #fff;
        padding: 8px 15px;
        border-radius: 4px;
        font-size: 13px;
        width: 180px;
        outline: none;
    }

    .exit-btn {
        background: rgba(51, 51, 51, 0.8);
        border: 1px solid #444;
        color: #fff;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 18px;
    }

    /* 3. MODAL DE CATEGORIAS (DESIGN PREMIUM) */
    #xxx-cat-modal {
        display: none;
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle, rgba(20,20,20,0.98) 0%, rgba(0,0,0,1) 100%);
        z-index: 9999;
        flex-direction: column;
        align-items: center;
        padding: 50px;
        box-sizing: border-box;
    }

    .cat-scroll-wrapper { width: 100%; max-width: 1100px; overflow-y: auto; margin: 20px 0; }
    .category-map { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    
    .cat-map-btn {
        background: rgba(255,255,255,0.03);
        border: 1px solid #333;
        color: #ccc;
        padding: 12px;
        border-radius: 4px;
        font-size: 13px;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.2s;
    }
    .cat-map-btn:hover { background: #f00; color: #fff; border-color: #f00; transform: scale(1.05); }

    /* 4. SCROLL VERMELHO */
    #xxx-scroll-content {
        flex-grow: 1;
        width: 1240px;
        overflow-y: auto;
        overflow-x: hidden;
        margin-left: 20px;
    }

    #xxx-scroll-content::-webkit-scrollbar { width: 10px; }
    #xxx-scroll-content::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.3); }
    #xxx-scroll-content::-webkit-scrollbar-thumb { 
        background: #ff0000; 
        border-radius: 10px; 
        border: 2px solid rgba(0, 0, 0, 0.4); 
    }

    /* 5. GRID E CARDS (4 COLUNAS) */
    .video-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 10px 20px; }
    
    .video-card {
        background: #111;
        border: 1px solid #222;
        transition: transform 0.2s;
        cursor: pointer;
    }
    .video-card:hover { border: 2px solid yellow; transform: scale(1.02); }

    .thumb-wrap { width: 100%; aspect-ratio: 4 / 2.7; background: #000; overflow: hidden; }
    .thumb-wrap img { width: 100%; height: 100%; object-fit: cover; }

    .video-title { 
        font-size: 10.5px; 
        line-height: 1.3;
         padding: 8px; 
         color: #ccc; 
         text-align: center;
        text-transform: uppercase;
         display: -webkit-box; 
        -webkit-box-orient: vertical;
        letter-spacing: 1.1px;
         overflow: hidden;
          height: 21px;
           margin: 0;
    }
</style>

<div id="xxx-module">
    <div id="xxx-cat-modal">
        <h2 style="letter-spacing: 4px; font-weight: 200;">CATEGORIES</h2>
        <div class="cat-scroll-wrapper">
            <div class="category-map" id="modal-cat-grid">
                <% XXX_CATEGORIES.forEach(cat => { %>
                    <button class="cat-map-btn" onclick="selectCat('<%= cat %>')">
                        <%= cat %>
                    </button>
                <% }) %>
            </div>
        </div>
        <button class="chip" style="border-color: #f00; color: #f00; padding: 10px 30px;" onclick="toggleCatModal(false)">CLOSE</button>
    </div>

    <nav class="sl-nav-header">
        <div class="nav-left">
            <div class="current-tag">
                <span>HARDCORE</span>
                <small id="active-tag-display"><%= tag %></small>
            </div>
        </div>

        <div class="category-chips" id="quick-chips">
            <% XXX_CATEGORIES.slice(0, 7).forEach(cat => { %>
                <button class="chip <%= tag === cat ? 'active' : '' %>" 
                        onclick="selectCat('<%= cat %>')">
                    <%= cat %>
                </button>
            <% }) %>
            <button class="chip" onclick="toggleCatModal(true)">...</button>
        </div>

        <div class="nav-right">
            <input type="text" id="xxx-search-input" value="<%= tag %>" placeholder="Search..." onkeyup="if(event.key === 'Enter') xxxSearch()">
            <button class="exit-btn" onclick="handleNav('/xxx-index')">✕</button>
        </div>
    </nav>

    <div id="xxx-scroll-content">
        <div class="video-grid">
            <% videos.forEach(v => { %>
                <div class="video-card" data-url="<%= v.pageUrl %>" data-title="<%= v.title %>" onclick="playXXX(this)">
                    <div class="thumb-wrap">
                        <img src="<%= v.thumbnail %>" loading="lazy">
                    </div>
                    <p class="video-title"><%= v.title %></p>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
// Mantemos as funções globais para os cliques funcionarem
window.toggleCatModal = function(show) {
    $('#xxx-cat-modal').css('display', show ? 'flex' : 'none');
    if (window.socket && !window.isRemoteAction) {
        socket.emit('state_sync', { type: 'xxx_modal', show: show, room: window.myRoom });
    }
};

window.selectCat = function(cat) {
    toggleCatModal(false);
    handleNav('/xvideos-grid?tag=' + encodeURIComponent(cat));
};

window.xxxSearch = function() {
    const val = document.getElementById('xxx-search-input').value;
    handleNav('/xvideos-grid?tag=' + encodeURIComponent(val));
};

// Player e Sincronização de Scroll (Mantidos)
async function playXXX(el) {
    const url = el.getAttribute('data-url');
    const title = el.getAttribute('data-title');
    try {
        const res = await fetch('/get-xxx-stream?url=' + encodeURIComponent(url));
        const data = await res.json();
        if (data.streamUrl) {
            handleNav(`/xxx-player?stream=${encodeURIComponent(data.streamUrl)}&title=${encodeURIComponent(title)}`); 
        }
    } catch (e) { console.error("Error", e); }
}

$('#xxx-scroll-content').on('scroll', function() {
    if (window.isSyncing || !window.socket) return; 
    socket.emit('state_sync', { type: 'scroll', position: $(this).scrollTop(), room: window.myRoom });
});

// Listener do Socket
if(window.socket) {
    socket.off('state_sync').on('state_sync', (data) => {
        if (data.type === 'scroll') {
            const $target = $('#xxx-scroll-content');
            window.isSyncing = true;
            $target.scrollTop(data.position);
            setTimeout(() => { window.isSyncing = false; }, 50);
        }
        if (data.type === 'xxx_modal') {
            window.isRemoteAction = true;
            $('#xxx-cat-modal').css('display', data.show ? 'flex' : 'none');
            setTimeout(() => { window.isRemoteAction = false; }, 100);
        }
    });
}
</script>
