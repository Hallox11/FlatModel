<style>
/* ── MAIN MODULE CONTAINER ── */
#yt-grid-module {
    width: 1280px; height: 720px;
    background: transparent;
    font-family: 'Fira Sans', sans-serif;
    position: relative; overflow: hidden;
}

/* ── HEADER SECTION ── */
#yt-grid-header {
    width: 100%; height: 57px;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 35px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.95) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0.1) 100%);
    z-index: 100; flex-shrink: 0; box-sizing: border-box;
    margin-bottom: 0px;
}

/* ── CHANNEL GRID CONTAINER ── */
.yt-grid-container {
    margin-left: 15px;
    padding: 0px 20px;
    display: grid;
    min-height: 500px; /* Forces the container to stay visible */
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    height: 650px;
    width: 1200px;
    overflow-y: auto;
}

/* Custom Scrollbar Styling */
.yt-grid-container::-webkit-scrollbar { width: 12px; }
.yt-grid-container::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
.yt-grid-container::-webkit-scrollbar-thumb { 
    background: rgb(224, 81, 24); 
    border-radius: 10px; 
}

/* ── CHANNEL CARD ── */
.ch-card {
    background: rgba(255,255,255,0.03);
    border: 2px solid #eeebebb3;
    height: 185px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    opacity: 1;
    transition: all 0.2s ease;
}

.ch-card:hover {
    transform: translateY(-2px) scale(1.01);
    border: 2px solid rgb(249, 184, 20);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05)); 
}
.ch-card.remote-hover {
    transform: translateY(-2px) scale(1.01);
    border: 2px solid rgb(249, 184, 20);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05)); 
}

/* Dark overlay on cards */
.ch-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    pointer-events: none;
    transition: background 0.3s ease;
}

.ch-card:hover::after {
    background: rgba(0, 0, 0, 0.1); 
}

/* Channel Thumbnail */
.ch-thumb {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 1.0;
}

/* Channel Info Overlay */
.ch-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 2px;
    background: linear-gradient(to top, black, transparent);
    text-align: center;
}

/* Channel Name Styling */
.ch-name {
    font-size: 0.7rem;
    font-weight: 400;
    background: #3837398a;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgb(225, 224, 224);
    /* ── LINE CLAMPING ── */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2; 
    height: 2.4em;
}

/* LIVE Label Indicator */
.yt-label {
    position: absolute; top: 8px; left: 245px;
    background: #ff0000; color: white;
    font-size: 0.55rem; font-weight: 600;
    padding: 2px 6px; border-radius: 3px;
}

/* ── CATEGORY MODAL OVERLAY ── */
#category-modal {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 2000;
}

/* Modal Content Box */
.modal-content {
    background: rgba(20, 20, 20, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 16px;
    padding: 40px;
    width: 500px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

.modal-content h3 {
    color: white;
    letter-spacing: 4px;
    margin-bottom: 30px;
    text-transform: uppercase;
    font-size: 1.2rem;
}

.cancel-btn {
    margin-top: 30px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    text-transform: uppercase;
    font-size: 0.7rem;
}


.header-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.0rem;
    letter-spacing: 3px;
    opacity: 0.8;
    pointer-events: none;
}

#modalTitle{
    font-size: 16px;
    margin: 20px;
}

/* ── MODAL GRID LAYOUT ── */
.modal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 25px;
}

.modal-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #e0e0e0;
    padding: 12px 15px;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    font-size: 0.85rem;
    transition: all 0.2s;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
}

.modal-btn::after {
    content: "📷";
    font-size: 0.7rem;
    opacity: 0.6;
}
</style>
<div id="yt-grid-module">
    <div id="yt-grid-header">

            <div style="margin-right: 24px!important;margin-top:2px;">
                <button class="ltv-nav-btn" onclick="openCategoryModal()">
                <span class="material-symbols-rounded" style="font-size:25px!important; vertical-align:middle;">menu</span>
                </button>
            </div>


            <h2 id="dynamic-header-title" class="header-title">LIVE STREAMS</h2>
          
            <div style="margin-right: 24px!important;margin-top:2px;">
                <button class="ltv-back-btn" onclick="closeSubMenu()">
                <span class="material-symbols-rounded" style="font-size:25px!important; vertical-align:middle;">close</span>
               </button>
            </div>

    </div>

    <div class="yt-grid-container" id="channel-list-target"></div>
</div>

<div id="category-modal">
    <div class="modal-content" style="width: 800px;"> 
        <h3 style="text-align: left; margin-bottom: 20px;">MY FAVORITES</h3>
        <div class="modal-grid">
            <button class="modal-btn" onclick="runCategorySearch('Live english News')">NEWS</button>
            <button class="modal-btn" onclick="runCategorySearch('Live Sports')">SPORTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Gaming Live')">GAMING</button>
            <button class="modal-btn" onclick="runCategorySearch('Nature Live')">NATURE</button>
            <button class="modal-btn" onclick="runCategorySearch('Space Live')">SPACE</button>
            <button class="modal-btn" onclick="runCategorySearch('City Traffic')">CITY</button>
            <button class="modal-btn" onclick="runCategorySearch('Airport Live')">AIRPORTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Train Journey')">TRAINS</button>
            <button class="modal-btn" onclick="runCategorySearch('Dangerous Weather')">DANGEROUS SPOTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Walking live cam')">CITY WALKING</button>
            <button class="modal-btn" onclick="runCategorySearch('World city live cam')">WORLD CITYS</button>
            <button class="modal-btn" onclick="runCategorySearch('Esports live cam')">ESports</button>
            <button class="modal-btn" onclick="runCategorySearch('OMG Live TV street cam')">OMG Live TV </button>
        </div>
        <button class="cancel-btn" onclick="closeModal()">Close</button>
    </div>
</div>
<script>
// ── MODAL UTILITIES ──
function closeModal() {
    document.getElementById('category-modal').style.display = 'none';
}
function openCategoryModal() {
    document.getElementById('category-modal').style.display = 'flex';
}

// ── SEARCH & SYNC LOGIC ──
window.runCategorySearch = async function(category, isFromSync = false) {
    // Hide modal on selection
    document.getElementById('category-modal').style.display = 'none';

    // Prevent recursive calls if triggered by sync
    if (isFromSync) return;

    try {
        const response = await fetch(`/api/live-search?q=${encodeURIComponent(category)}`);
        const liveResults = await response.json();

        // Broadcast search results to other clients via socket
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { 
                type: 'new_results', 
                category: category, 
                results: liveResults, 
                room: window.myRoom 
            });
        }
        
        // Render results locally
        renderResults(liveResults, category);
    } catch (e) { console.error(e); }
};

// ── RENDERER ──
window.renderResults = function(liveResults, category) {
    const target = document.getElementById('channel-list-target');
    const titleElement = document.getElementById('dynamic-header-title');

    if (target) target.scrollTop = 0;

    target.innerHTML = liveResults.map(ch => `
        <div class="ch-card" onclick="launchChannel('${ch.videoId || ''}')">
            <div class="yt-label">LIVE</div> 
            <img src="${ch.thumbnail}" class="ch-thumb">
            <div class="ch-info">
                <div class="ch-name">${ch.title}</div>
            </div>
        </div>
    `).join('');
    
    titleElement.textContent = `LIVE STREAMS FOR: ${category.toUpperCase()}`;
};

// ── CHANNEL LAUNCHER ──
window.launchChannel = function(videoId) {
    const container = document.getElementById('channel-list-target');
    const scroll = container ? container.scrollTop : 0;
    
    const category = document.getElementById('dynamic-header-title').textContent.replace('LIVE STREAMS FOR: ', '');
    
    const url = `/tvytube?videoId=${videoId}&origin=live-tv&targetID=${encodeURIComponent(category)}&menu=/live-menu&scrollPos=${scroll}`;
    
    if (typeof handleNav === 'function') {
        handleNav(url);
    } else {
        window.location.href = url;
    }
};

// ── SCROLL BROADCASTER ──
$('.yt-grid-container').on('scroll', function() {
    if (window.isSyncing) return;
    
    if (window.socket && window.myRoom) {
        window.socket.emit('state_sync', { 
            type: 'scroll', 
            position: $(this).scrollTop(), 
            room: window.myRoom 
        });
    }
});

// ── SOCKET EVENT LISTENER ──
window.isPageReady = false;
if (window.socket) {
    window.socket.on('state_sync', (data) => {
        if (data.type === 'layout_change') window.setFreebiesLayout(data.cols, true);
        
        // Sync scrolling position
        if (data.type === 'scroll' && window.isPageReady) {
            window.isSyncing = true;
            const grid = document.getElementById('channel-list-target'); 
            if (grid) grid.scrollTop = data.position;
            setTimeout(() => { window.isSyncing = false; }, 100);
        }
        
        // Handle hover state updates
        if (data.type === 'hover') {
            const el = document.getElementById(data.id);
            if (el) {
                el.style.background = data.active ? 'rgba(0,0,0,0.7)' : '';
                el.style.borderColor = data.active ? '#ffcc00' : '';
            }
        }
    });
}

// ── INITIALIZATION ──
(function() {
    const savedScroll = parseInt('<%= typeof scrollPos !== "undefined" ? scrollPos : 0 %>') || 0;
    const savedCategory = '<%= typeof targetID !== "undefined" ? targetID : "Live English News" %>';

    window.runCategorySearch(savedCategory).then(() => {
        if (savedScroll > 0) {
            requestAnimationFrame(() => {
                const container = document.getElementById('channel-list-target');
                if (container) {
                    container.scrollTop = savedScroll;
                    window.isPageReady = true;
                    if (window.socket && window.myRoom) {
                        window.socket.emit('state_sync', {
                            type: 'scroll',
                            position: savedScroll,
                            room: window.myRoom
                        });
                    }
                }
            });
        } else {
            window.isPageReady = true;
        }
    });
})();
</script>