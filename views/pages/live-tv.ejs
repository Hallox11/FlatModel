<style>
#live-tv-module {
    width: 1280px; height: 720px;
    display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    font-family: 'Fira Sans', sans-serif; color: white;
}
#ltv-topbar {
    position: absolute; top: 0; left: 0; right: 0; height: 58px;
    display: flex; align-items: center; padding: 0 20px; gap: 14px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.85), transparent); z-index: 200;
}
#ltv-back-btn {
    background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; color: white;
    padding: 7px 14px; font-size: 0.78rem; font-family: 'Fira Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s;
}
#ltv-back-btn:hover { border-color: rgba(255,255,255,0.5); }

.ltv-tabs { display: flex; gap: 8px; }
.ltv-tab {
    padding: 5px 16px; border-radius: 20px; cursor: pointer;
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1.5px;
    border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); transition: all 0.2s;
}
.ltv-tab:hover { border-color: rgba(255,255,255,0.35); }
.ltv-tab.active { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.55); }

/* loading overlay */
#ltv-checking {
    position: absolute; inset: 0; z-index: 300;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
}
.ltv-check-spinner {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.1);
    border-top-color: rgba(255,255,255,0.6);
    animation: ltvSpin 0.9s linear infinite;
}
#ltv-checking p { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 3px; opacity: 0.4; margin: 0; }

/* grid */
#ltv-grid-view { position: absolute; inset: 0; padding: 68px 18px 20px; overflow-y: auto; }
#ltv-grid-view::-webkit-scrollbar { width: 3px; }
#ltv-grid-view::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }
#ltv-channel-grid { display: grid; grid-template-columns: repeat(6,1fr); gap: 10px; }

/* ── CARD ── */
.ltv-card {
    position: relative; cursor: pointer;
    height: 160px; border-radius: 16px; overflow: hidden;
    background: #0e0e0e;
    /* layered border: inner glow + outer shadow */
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow:
        0 0 0 1px rgba(255,255,255,0.04),          /* outer ring */
        inset 0 1px 0 rgba(255,255,255,0.10),       /* top inner highlight */
        0 8px 24px rgba(0,0,0,0.6),
        0 2px 6px rgba(0,0,0,0.4);
    transition: transform 0.22s cubic-bezier(0.25,0.8,0.25,1),
                box-shadow 0.22s ease, border-color 0.22s ease;
    display: flex; flex-direction: column;
}
.ltv-card:hover {
    transform: translateY(-5px) scale(1.04);
    border-color: rgba(255,255,255,0.28);
    box-shadow:
        0 0 0 1px rgba(255,255,255,0.10),
        inset 0 1px 0 rgba(255,255,255,0.18),
        0 20px 48px rgba(0,0,0,0.75),
        0 4px 12px rgba(0,0,0,0.5),
        0 0 24px rgba(255,255,255,0.04);
    z-index: 10;
}
/* category glow on hover */
.ltv-card[data-cat="news"]:hover          { box-shadow: 0 0 0 1px rgba(231,76,60,0.3), inset 0 1px 0 rgba(255,255,255,0.12), 0 20px 48px rgba(0,0,0,0.75), 0 0 20px rgba(231,76,60,0.12); }
.ltv-card[data-cat="sports"]:hover        { box-shadow: 0 0 0 1px rgba(39,174,96,0.3),  inset 0 1px 0 rgba(255,255,255,0.12), 0 20px 48px rgba(0,0,0,0.75), 0 0 20px rgba(39,174,96,0.12); }
.ltv-card[data-cat="entertainment"]:hover { box-shadow: 0 0 0 1px rgba(142,68,173,0.3), inset 0 1px 0 rgba(255,255,255,0.12), 0 20px 48px rgba(0,0,0,0.75), 0 0 20px rgba(142,68,173,0.12); }
.ltv-card[data-cat="music"]:hover         { box-shadow: 0 0 0 1px rgba(41,128,185,0.3), inset 0 1px 0 rgba(255,255,255,0.12), 0 20px 48px rgba(0,0,0,0.75), 0 0 20px rgba(41,128,185,0.12); }

.ltv-card.yt-card { border-color: rgba(255,50,50,0.12); }
.ltv-card.yt-card:hover { border-color: rgba(255,50,50,0.4); }

/* ── THUMBNAIL AREA ── */
.ltv-card-logo {
    width: 100%; flex: 1; position: relative;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
}

/* when there IS a logo image */
.ltv-card-logo img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
}
.ltv-card:hover .ltv-card-logo img { transform: scale(1.06); }

/* scrim over image */
.ltv-card-logo img ~ .ltv-card-fallback { display: none; }
.ltv-card-logo::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.65) 100%);
}

/* ── NO-LOGO FALLBACK ── */
.ltv-card-fallback {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 8px;
    padding: 0 12px;
    /* push content slightly up to account for name bar at bottom */
    padding-bottom: 28px;
}
.ltv-card-fallback .ltv-ch-label {
    font-size: 1.1rem; font-weight: 800;
    letter-spacing: 3px; text-transform: uppercase;
    color: rgba(255,255,255,0.95); text-align: center;
    line-height: 1.1;
    text-shadow: 0 2px 16px rgba(0,0,0,0.9);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    max-width: 100%;
}
.ltv-card-fallback .ltv-ch-sub {
    font-size: 0.46rem; letter-spacing: 3px; text-transform: uppercase;
    color: rgba(255,255,255,0.25); text-align: center;
}

/* coloured left-edge accent per category */
.ltv-card::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0; width: 3px;
    border-radius: 14px 0 0 14px;
    background: var(--cat-color, rgba(255,255,255,0.15));
    opacity: 0.8;
}
.ltv-card[data-cat="news"]          { --cat-color: #e74c3c; }
.ltv-card[data-cat="sports"]        { --cat-color: #27ae60; }
.ltv-card[data-cat="entertainment"] { --cat-color: #8e44ad; }
.ltv-card[data-cat="music"]         { --cat-color: #2980b9; }

/* matching subtle tint on the background */
.ltv-card[data-cat="news"]          { background: #140a0a; }
.ltv-card[data-cat="sports"]        { background: #090e09; }
.ltv-card[data-cat="entertainment"] { background: #0d0910; }
.ltv-card[data-cat="music"]         { background: #090d14; }

/* ── NAME — centered inside the card ── */
.ltv-card-name {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 32px 10px 10px;
    font-size: 0.78rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
    color: #fff; line-height: 1;
    text-align: center;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, transparent 100%);
    pointer-events: none;
}

/* ── BADGES ── */
.ltv-live-badge {
    position: absolute; top: 8px; right: 8px;
    background: #e74c3c; border-radius: 4px;
    padding: 2px 6px; font-size: 0.46rem;
    letter-spacing: 1.5px; font-weight: 800; color: #fff;
    box-shadow: 0 2px 8px rgba(231,76,60,0.4);
}
.ltv-yt-badge {
    position: absolute; top: 8px; left: 8px;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(255,60,60,0.45);
    border-radius: 4px; padding: 2px 6px;
    font-size: 0.44rem; letter-spacing: 1px;
    font-weight: 700; color: #ff5555;
}

/* empty state */
#ltv-empty {
    display: none; position: absolute; inset: 68px 0 0;
    flex-direction: column; align-items: center; justify-content: center; gap: 10px;
    font-size: 0.78rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.35;
}

/* player */
#ltv-player-view { display: none; position: absolute; inset: 0; flex-direction: column; }
#ltv-video-wrap  { flex: 1; position: relative; background: #000; }
#ltv-video       { width: 100%; height: 100%; object-fit: contain; display: block; }
#ltv-yt-frame    { width: 100%; height: 100%; border: none; display: none; }

#ltv-error-msg {
    display: none; position: absolute; inset: 0;
    align-items: center; justify-content: center; flex-direction: column; gap: 10px;
    background: rgba(0,0,0,0.85); font-size: 0.8rem; opacity: 0.55;
    text-transform: uppercase; letter-spacing: 2px;
}
#ltv-player-bar {
    position: absolute; bottom: 0; left: 0; right: 0; height: 64px;
    display: flex; align-items: center; gap: 14px; padding: 0 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.92), transparent); z-index: 200;
}
.ltv-ctrl-btn {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px; color: white; cursor: pointer; padding: 6px 13px;
    font-size: 0.72rem; font-family: 'Fira Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 5px; transition: all 0.2s;
}
.ltv-ctrl-btn:hover { background: rgba(255,255,255,0.15); }
#ltv-channel-label { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.8; }
.ltv-live-pill { margin-left: auto; display: flex; align-items: center; gap: 6px; font-size: 0.68rem; letter-spacing: 2px; text-transform: uppercase; }
.ltv-live-dot  { width: 7px; height: 7px; border-radius: 50%; background: #e74c3c; animation: ltvBlink 1.5s infinite; }

#ltv-loader {
    display: none; position: absolute; inset: 0;
    align-items: center; justify-content: center;
    background: rgba(0,0,0,0.7); z-index: 50; flex-direction: column; gap: 14px;
}
.ltv-spinner { width: 36px; height: 36px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); border-top-color: rgba(255,255,255,0.7); animation: ltvSpin 0.9s linear infinite; }
#ltv-loader p { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.5; margin: 0; }

@keyframes ltvBlink { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes ltvSpin  { to{transform:rotate(360deg)} }
</style>

<div id="live-tv-module">

    <div id="ltv-checking">
        <div class="ltv-check-spinner"></div>
        <p>Loading channels...</p>
    </div>

    <div id="ltv-topbar">
        <button id="ltv-back-btn" onclick="ltvExitModule()">
            <span class="material-symbols-rounded" style="font-size:15px;">arrow_back</span> Back
        </button>
        <div class="ltv-tabs">
            <div class="ltv-tab active" onclick="ltvFilter('all',this)">All</div>
            <div class="ltv-tab" onclick="ltvFilter('news',this)">News</div>
            <div class="ltv-tab" onclick="ltvFilter('sports',this)">Sports</div>
            <div class="ltv-tab" onclick="ltvFilter('entertainment',this)">Entertainment</div>
        </div>
    </div>

    <div id="ltv-grid-view">
        <div id="ltv-channel-grid"></div>
        <div id="ltv-empty">
            <span class="material-symbols-rounded" style="font-size:2rem;">tv_off</span>
            <span>No channels in this category</span>
        </div>
    </div>

    <div id="ltv-player-view">
        <div id="ltv-video-wrap">
            <video id="ltv-video" autoplay playsinline></video>
            <div id="ltv-loader"><div class="ltv-spinner"></div><p>Loading stream...</p></div>
            <div id="ltv-error-msg">
                <span class="material-symbols-rounded" style="font-size:2.2rem;opacity:0.4;">signal_disconnected</span>
                <span>Stream unavailable</span>
                <button class="ltv-ctrl-btn" style="margin-top:8px;opacity:1" onclick="ltvClosePlayer()">Try another channel</button>
            </div>
        </div>
        <div id="ltv-player-bar">
            <button class="ltv-ctrl-btn" onclick="ltvClosePlayer()">
                <span class="material-symbols-rounded" style="font-size:14px;">grid_view</span> Channels
            </button>
            <span id="ltv-channel-label"></span>
            <div class="ltv-live-pill"><div class="ltv-live-dot"></div><span>Live</span></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.7/dist/hls.min.js"></script>

<script>
(function () {
    let ALL_CHANNELS   = [];
    let currentFilter  = 'all';
    let hls            = null;

    // ── BACK BUTTON ──────────────────────────────────────────
    window.ltvExitModule = function () {
        const video = document.getElementById('ltv-video');
        if (hls)   { hls.destroy(); hls = null; }
        if (video) { video.pause(); video.src = ''; }
        // Delegate to the app's own close function
        if (typeof closeSubMenu === 'function') closeSubMenu();
    };

    // ── GRID → PLAYER ────────────────────────────────────────
    window.ltvClosePlayer = function () {
        const video = document.getElementById('ltv-video');
        if (hls)   { hls.destroy(); hls = null; }
        if (video) { video.pause(); video.src = ''; }
        document.getElementById('ltv-player-view').style.display = 'none';
        document.getElementById('ltv-grid-view').style.display   = 'block';
        document.getElementById('ltv-topbar').style.display      = 'flex';
    };

    // ── PLAY ─────────────────────────────────────────────────
    window.ltvPlay = function (id) {
        const ch = ALL_CHANNELS.find(c => c.id === id);
        if (!ch) return;

        document.getElementById('ltv-player-view').style.display = 'flex';
        document.getElementById('ltv-grid-view').style.display   = 'none';
        document.getElementById('ltv-topbar').style.display      = 'none';
        document.getElementById('ltv-channel-label').innerText   = ch.name;

        const video  = document.getElementById('ltv-video');
        const loader = document.getElementById('ltv-loader');
        const errMsg = document.getElementById('ltv-error-msg');

        if (hls) hls.destroy();
        video.style.display  = 'none';
        errMsg.style.display = 'none';
        loader.style.display = 'flex';

        if (ch.type === 'yt') {
            loader.style.display = 'none';
            // Use tvytube (YT IFrame API) — avoids embed restrictions
            if (typeof handleNav === 'function') {
                handleNav(`/tvytube?videoId=${ch.ytId}&origin=live-tv`);
            }
        } else {
            video.style.display = 'block';
            const proxyUrl = '/hls-proxy?url=' + encodeURIComponent(ch.url);

            if (Hls.isSupported()) {
                hls = new Hls({ enableWorker: true });
                hls.loadSource(proxyUrl);
                hls.attachMedia(video);
                hls.on(Hls.Events.MANIFEST_PARSED, () => {
                    loader.style.display = 'none';
                    video.play().catch(() => {});
                });
                hls.on(Hls.Events.ERROR, (_, data) => {
                    if (data.fatal) {
                        loader.style.display = 'none';
                        errMsg.style.display = 'flex';
                    }
                });
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                // Safari native HLS
                video.src = proxyUrl;
                video.addEventListener('loadedmetadata', () => {
                    loader.style.display = 'none';
                    video.play().catch(() => {});
                }, { once: true });
                video.addEventListener('error', () => {
                    loader.style.display = 'none';
                    errMsg.style.display = 'flex';
                }, { once: true });
            } else {
                loader.style.display = 'none';
                errMsg.style.display = 'flex';
            }
        }
    };

    // ── FILTER ───────────────────────────────────────────────
    window.ltvFilter = function (cat, el) {
        currentFilter = cat;
        document.querySelectorAll('.ltv-tab').forEach(t => t.classList.remove('active'));
        if (el) el.classList.add('active');
        buildGrid();
    };

    // ── BUILD GRID ───────────────────────────────────────────
    function buildGrid() {
        const grid  = document.getElementById('ltv-channel-grid');
        const empty = document.getElementById('ltv-empty');
        if (!grid) return;

        const list = currentFilter === 'all'
            ? ALL_CHANNELS
            : ALL_CHANNELS.filter(c => c.cat === currentFilter);

        if (list.length === 0) {
            grid.innerHTML    = '';
            empty.style.display = 'flex';
            return;
        }
        empty.style.display = 'none';

        grid.innerHTML = list.map(ch => {
            const isYT  = ch.type === 'yt';
            const badge = isYT
                ? `<div class="ltv-yt-badge">▶ YT</div>`
                : `<div class="ltv-live-badge">● LIVE</div>`;

            const logoImg = ch.logo
                ? `<img src="${ch.logo}" alt="${ch.name}"
                       onerror="this.style.display='none'">`
                : '';

            const fallback = `
                <div class="ltv-card-fallback">
                    <div class="ltv-ch-label">${ch.name}</div>
                    <div class="ltv-ch-sub">${ch.cat}</div>
                </div>`;

            return `
                <div class="ltv-card${isYT ? ' yt-card' : ''}"
                     data-cat="${ch.cat}"
                     onclick="ltvPlay('${ch.id}')">
                    <div class="ltv-card-logo">
                        ${logoImg}
                        ${fallback}
                    </div>
                    ${badge}
                    <div class="ltv-card-name">${ch.name}</div>
                </div>
            `;
        }).join('');
    }

    // ── INIT — fetch from /api/channels ──────────────────────
    async function init() {
        try {
            const res  = await fetch('/api/channels');
            ALL_CHANNELS = await res.json();
        } catch (e) {
            console.warn('[LiveTV] Could not load channels:', e);
            ALL_CHANNELS = [];
        } finally {
            document.getElementById('ltv-checking').style.display = 'none';
            buildGrid();
        }
    }

    init();
})();
</script>
