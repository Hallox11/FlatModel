<style>
/* ── HARDCODED YT CHANNELS ── */
#yt-grid-module {
    width: 1280px; height: 720px;
    background: transparent;
    font-family: 'Fira Sans', sans-serif;
    position: relative; overflow: hidden;
}

#yt-grid-header {
        width: 100%; height: 55px;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 35px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
        z-index: 100; flex-shrink: 0; box-sizing: border-box;
        margin-bottom: 0px;
}

.yt-grid-container {
    margin-left: 15px;
    padding: 1px 20px;
    display: grid;
    min-height: 500px; /* Forces the container to stay visible */
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    height: 650px;
    width: 1200px;
    overflow-y: auto;
}
/* Custom Scrollbar */
.yt-grid-container::-webkit-scrollbar { width: 12px; }
.yt-grid-container::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
.yt-grid-container::-webkit-scrollbar-thumb { 
    background: goldenrod; 
    border-radius: 10px; 
}
/* ── CHANNEL CARD ── */
.ch-card {
    background: rgba(255,255,255,0.03);
    border: 2px solid #eeebebb3;
    height: 185px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    opacity: 1;
    transition: all 0.2s ease;
}

.ch-card:hover {
    border-color: yellow;
    background: rgba(255,0,0,0.05);
}

/* Add this to create a dark overlay on all cards */
.ch-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3); /* Adjust 0.4 (40%) to make it darker or lighter */
    pointer-events: none; /* Allows the click to pass through to the card */
    transition: background 0.3s ease;
}

/* Optional: Make the card slightly clearer on hover */
.ch-card:hover::after {
    background: rgba(0, 0, 0, 0.1); 
}




.ch-thumb {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 1.0;
}

.ch-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 2px;
    background: linear-gradient(to top, black, transparent);
    text-align: center;
}

.ch-name {
    font-size: 0.7rem;
    font-weight: 400;
    background: #3837398a;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgb(225, 224, 224);
    /* ── LINE CLAMPING ── */
    display: -webkit-box;
    -webkit-line-clamp: 2; /* Limits text to 2 lines */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis; /* Adds '...' if text exceeds 2 lines */
    
    /* Ensure a consistent height so cards don't jump */
    line-height: 1.2; 
    height: 2.4em; /* 1.2 (line-height) * 2 (lines) = 2.4 */
}

.yt-label {
    position: absolute; top: 8px; left: 245px;
    background: #ff0000; color: white;
    font-size: 0.55rem; font-weight: 600;
    padding: 2px 6px; border-radius: 3px;
}

/* ── CATEGORY MODAL OVERLAY ── */
#category-modal {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.7); /* Dark semi-transparent background */

    display: none; /* Hidden by default */
    justify-content: center;
    align-items: center;
    z-index: 2000;
}

/* ── MODAL BOX ── */
.modal-content {
    background: rgba(20, 20, 20, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.3);

    border-radius: 16px;
    padding: 40px;
    width: 500px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

.modal-content h3 {
    color: white;
    letter-spacing: 4px;
    margin-bottom: 30px;
    text-transform: uppercase;
    font-size: 1.2rem;
}

/* ── MODAL GRID ── */
.modal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
}

.modal-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    padding: 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.8rem;
    letter-spacing: 1px;
}

.modal-btn:hover {
    background: rgba(0, 255, 60, 0.238);
    border-color: rgba(255,0,0,0.5);
}

.cancel-btn {
    margin-top: 30px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    text-transform: uppercase;
    font-size: 0.7rem;
}

/* ── PILL BUTTON STYLING ── */
.ltv-nav-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.173);
    color: white;
    padding: 3px 20px;
    border-radius: 0px; /* Pill shape */
    font-size: 0.80rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin: 0px 0px;
}

.ltv-nav-btn:hover {
    background: hsla(48, 93%, 41%, 0.67);
    border-color: rgba(255, 255, 255, 0.3);
}

/* ── CENTERING THE TITLE ── */
.header-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.0rem;
    letter-spacing: 3px;
    opacity: 0.6;
    pointer-events: none; /* Allows clicking through if needed */
}
#modalTitle{
    font-size: 16px;
    margin: 20px;
}

/* Layout for the buttons in a 4-column grid */
.modal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* Matches your image layout */
    gap: 12px;
    margin-top: 25px;
}

/* Styling for each individual button */
.modal-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #e0e0e0;
    padding: 12px 15px;
    border-radius: 8px;
    cursor: pointer;
    text-align: left; /* Aligns text like in your image */
    font-size: 0.85rem;
    transition: all 0.2s;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
}

/* Optional: Add a small icon placeholder to the right */
.modal-btn::after {
    content: "📷"; /* Or your camera icon */
    font-size: 0.7rem;
    opacity: 0.6;
}
</style>

<div id="yt-grid-module">
<div id="yt-grid-header">
        <button class="ltv-nav-btn" onclick="closeSubMenu()">
        <span class="material-symbols-rounded" style="font-size:23px!important; vertical-align:middle;">arrow_back</span> BACK
        </button>

<h2 id="dynamic-header-title" class="header-title">LIVE STREAMS</h2>

    <div style="margin-right: 22px;">
        <button class="ltv-nav-btn" onclick="openCategoryModal()">
            <span class="material-symbols-rounded" style="font-size:22px!important; vertical-align:middle;">menu</span> </button>
    </div>
</div>

    <div class="yt-grid-container" id="channel-list-target">
        </div>
</div>



<div id="category-modal">
    <div class="modal-content" style="width: 800px;"> <h3 style="text-align: left; margin-bottom: 20px;">MY FAVORITES</h3>
        <div class="modal-grid">
            <button class="modal-btn" onclick="runCategorySearch('Live english News')">NEWS</button>
            <button class="modal-btn" onclick="runCategorySearch('Live Sports')">SPORTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Gaming Live')">GAMING</button>
            <button class="modal-btn" onclick="runCategorySearch('Nature Live')">NATURE</button>
            <button class="modal-btn" onclick="runCategorySearch('Space Live')">SPACE</button>
            <button class="modal-btn" onclick="runCategorySearch('City Traffic')">CITY</button>
            <button class="modal-btn" onclick="runCategorySearch('Airport Live')">AIRPORTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Train Journey')">TRAINS</button>
            <button class="modal-btn" onclick="runCategorySearch('Dangerous Weather')">DANGEROUS SPOTS</button>
            <button class="modal-btn" onclick="runCategorySearch('Walking live cam')">CITY WALKING</button>
            <button class="modal-btn" onclick="runCategorySearch('World city live cam')">WORLD CITYS</button>
                        <button class="modal-btn" onclick="runCategorySearch('Esports live cam')">ESports</button>
                        <button class="modal-btn" onclick="runCategorySearch('OMG Live TV street cam')">OMG Live TV </button>
            </div>
        <button class="cancel-btn" onclick="closeModal()">Close</button>
    </div>
</div>
<script>
function closeModal() {
    document.getElementById('category-modal').style.display = 'none';
}
function openCategoryModal() {
    document.getElementById('category-modal').style.display = 'flex';
}

// Perform the search
window.runCategorySearch = async function(category, isFromSync = false) {
    // 1. Fechar o modal para quem clicou
    document.getElementById('category-modal').style.display = 'none';

    // 2. Se for um Guest que recebeu o sinal, não volta a pesquisar (evita loop)
    if (isFromSync) return;

    try {
        const response = await fetch(`/api/live-search?q=${encodeURIComponent(category)}`);
        const liveResults = await response.json();

        // 3. Emitir para todos na sala
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { 
                type: 'new_results', 
                category: category, 
                results: liveResults, 
                room: window.myRoom 
            });
        }
        
        // 4. Renderizar localmente para o Host
        renderResults(liveResults, category);
    } catch (e) { console.error(e); }
};
window.renderResults = function(liveResults, category) {
    const target = document.getElementById('channel-list-target');
    const titleElement = document.getElementById('dynamic-header-title');

if (target) target.scrollTop = 0;

    target.innerHTML = liveResults.map(ch => `
        <div class="ch-card" onclick="launchChannel('${ch.videoId || ''}')">
            <div class="yt-label">LIVE</div> 
            <img src="${ch.thumbnail}" class="ch-thumb">
            <div class="ch-info">
                <div class="ch-name">${ch.title}</div>
            </div>
        </div>
    `).join('');
    
    titleElement.textContent = `LIVE STREAMS FOR: ${category.toUpperCase()}`;
};
// This MUST be outside of any other functions, or attached to 'window'
window.launchChannel = function(videoId) {
    const container = document.getElementById('channel-list-target');
    const scroll = container ? container.scrollTop : 0;
    
    // Capture the current category from the header
    const category = document.getElementById('dynamic-header-title').textContent.replace('LIVE STREAMS FOR: ', '');
    
    // Construct the URL using the same pattern as your generic grid
    const url = `/tvytube?videoId=${videoId}&origin=live-tv&targetID=${encodeURIComponent(category)}&menu=/live-menu&scrollPos=${scroll}`;
    
    if (typeof handleNav === 'function') {
        handleNav(url);
    } else {
        window.location.href = url;
    }
};

window.syncHover = function(cardId, isActive) {
       
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'global_hover', id: cardId, active: isActive, room: window.myRoom });
        }
    };
// --- SCROLL BROADCASTER (Live TV Grid) ---
$('.yt-grid-container').on('scroll', function() {
    if (window.isSyncing) return; // Prevent loop
    
    if (window.socket && window.myRoom) {
        window.socket.emit('state_sync', { 
            type: 'scroll', 
            position: $(this).scrollTop(), 
            room: window.myRoom 
        });
    }
});
    // --- SOCKET LISTENER (Unified) ---

window.isPageReady = false;    
if (window.socket) {
        window.socket.on('state_sync', (data) => {
            if (data.type === 'layout_change') window.setFreebiesLayout(data.cols, true);
            
if (data.type === 'scroll' && window.isPageReady) {
            window.isSyncing = true;
            const grid = document.getElementById('channel-list-target'); 
            if (grid) grid.scrollTop = data.position;
            setTimeout(() => { window.isSyncing = false; }, 100);
        }
            
            if (data.type === 'hover') {
                const el = document.getElementById(data.id);
                if (el) {
                    el.style.background = data.active ? 'rgba(0,0,0,0.7)' : ''; // Default resets to CSS
                    el.style.borderColor = data.active ? '#ffcc00' : '';
                }
            }
        });
    }
// Define this as a globally accessible function
(function() {
    const savedScroll = parseInt('<%= typeof scrollPos !== "undefined" ? scrollPos : 0 %>') || 0;
    const savedCategory = '<%= typeof targetID !== "undefined" ? targetID : "Live English News" %>';

    window.runCategorySearch(savedCategory).then(() => {
        if (savedScroll > 0) {
            requestAnimationFrame(() => {
                const container = document.getElementById('channel-list-target');
                if (container) {
                    container.scrollTop = savedScroll;
                    
                    // Signal to guests that we are done moving
                    window.isPageReady = true; 
                    console.log("POSITIOn: ",savedScroll)
                    if (window.socket && window.myRoom) {
                        window.socket.emit('state_sync', {
                            type: 'scroll',
                            position: savedScroll,
                            room: window.myRoom
                        });
                    }
                }
            });
        } else {
            // Even if scroll is 0, signal readiness
            window.isPageReady = true;
        }
    });
})();
</script>