<style>
    /* Fixed Navigation Elements */
    #flickr-nav-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 5px 25px;
        position: fixed;
        top: 5px;
        z-index: 1000;
        width: 1280px;
        box-sizing: border-box;
    }

    .nav-group { display: flex; gap: 10px; flex: 1; }
    .nav-group-right { display: flex; justify-content: flex-end; flex: 1; }

    /* Modern Button Style */
    .modern-btn {
        background: #534b4bbf;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #e0e0e0;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .modern-btn:hover {
        background: rgba(218, 165, 32, 0.2);
        border-color: gold;
        color: gold;
    }

    /* Red Exit Button for Consistency */
    .flickr-close-btn-modern {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid #ff6b6b;
        color: #ff6b6b;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
    }

    .flickr-close-btn-modern:hover {
        background: #ff6b6b;
        color: #000;
        transform: rotate(90deg);
    }

    #conteiner {
        position: fixed;
        top: 60px;
        left: 0;
        width: 1280px;
        height: 660px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    #output {
        display: grid;
        grid-template-columns: repeat(3, 1fr); 
        gap: 20px;
        padding: 10px 40px;
        width: 1200px;
        margin: 0 auto;
    }

    .thumbs {
        position: relative;
        background: #1b171c;
        border: 2px solid white;
        overflow: hidden;
        transition: transform 0.2s;
    }

    .image { width: 100%; height: 220px; cursor: pointer; object-fit: cover; }

    .Vtitle {
        background: rgba(27, 23, 28, 0.85);
        color: white;
        text-align: center;
        font-size: 14px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .search-pill {
        display: flex;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 50px;
        padding: 3px 15px;
        color: gold;
        font-weight: bold;
        font-size: 13px;
    }
</style>

<div id="flickr-nav-container">
    <div class="nav-group">
        <button class="modern-btn" onclick="refreshMovies()">
            <span class="btn-icon">🔄</span> REFRESH
        </button>
        <div id="status-pill" class="search-pill">
            <span id="infodw_text">Loading Movies...</span>
        </div>
    </div>

    <div style="flex: 2; text-align: center;">
        <input id="movie-title" readonly 
               style="background:transparent; border:none; color:gold; text-align:center; width:100%; font-size:16px; font-weight:bold; pointer-events:none;">
    </div>

    <div class="nav-group-right">
        <button class="flickr-close-btn-modern" onclick="backToMoviesMenu()">
            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="3" fill="none">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>
</div>

<div id="conteiner">
    <div id="output"></div>
</div>

<script>
(function() {
    let updateFlag = 0;
    
    // 1. Capture params
    const targetID = "<%= (typeof targetID !== 'undefined') ? targetID : '' %>";
    const mode = "<%= (typeof targetMode !== 'undefined') ? targetMode : '' %>";

    // 2. DYNAMIC PATH LOGIC: Determine if we are in Music or Movies
    const currentPath = window.currentAjaxPath || "";
    const baseDir = currentPath.includes('/music') ? '/music/txt/' : '/movies/txt/';

  window.backToMoviesMenu = function() {
    console.log("Back button clicked. Path check:", currentPath);
    
    $('#sub-content-overlay').fadeOut(200, function() {
        // Use .html('') to match the music script exactly
        $(this).html('').hide(); 
        
        // Use a simpler check: if we see 'music' in the URL, go back to music.
        // Otherwise, go back to movies.
        if (currentPath.indexOf('/music') > -1) {
            handleNav('music');
        } else {
            handleNav('movies');
        }
    });
};
    window.refreshMovies = function() {
        updateFlag = 1;
        init();
    };

    function init() {
        if (mode === 'user') get_Svideos(targetID);
        else if (mode === 'list') get_Slists(targetID);
        else get_SvideosMix(targetID || 'full+movies+english+-hindi');
    }

    // 3. UPDATED FUNCTIONS: Use the dynamic ${baseDir}
    function get_Svideos(query) {
        if (updateFlag === 0) readVids(`${baseDir}${query}.txt`, "user");
        else userSearch('userChannel', query.replace('UC', 'UU'), 1);
    }

    function get_Slists(query) {
        if (updateFlag === 0) readVids(`${baseDir}${query}_list.txt`, "list");
        else userSearch('userLists', query, 1);
    }

    function get_SvideosMix(query) {
        // If query is an ID like 'concerts', use it. Otherwise use a tag search.
        if (updateFlag === 0) readVids(`${baseDir}${query}.txt`, "tags");
        else userSearch('tag', query, 1);
    }

    function readVids(txt, mode) {
        fetch(txt)
            .then(res => {
                if (!res.ok) throw new Error('File not found');
                return res.json();
            })
            .then(videos => {
                if (!videos || videos.length === 0) return;
                let activeMode = mode;
                if (videos[0].kind === "youtube#playlistItem") activeMode = "user";
                if (videos[0].kind === "youtube#playlist") activeMode = "list";
                
                const channelTitle = videos[0]?.snippet?.channelTitle || "Selection";
                $('#infodw_text').text(videos.length + " items");
                $('#movie-title').val(channelTitle);

                proc(videos, activeMode);
            })
            .catch(err => {
                console.warn("Local file missing, trying Live Search...", err);
                if (updateFlag === 0) { updateFlag = 1; init(); }
            });
    }

    function proc(videos, mode) {
        const $output = $("#output").empty();
        
        videos.forEach((item, i) => {
            let thumb, title, vid;
            thumb = item.snippet.thumbnails.high?.url || item.snippet.thumbnails.medium?.url;
            title = item.snippet.title;
            
            if (mode === "list") {
                vid = item.id;
            } else {
                vid = item.snippet.resourceId ? item.snippet.resourceId.videoId : (item.id.videoId || item.id);
            }

            const cardHtml = `
                <div class="thumbs" id="movie-${i}">
                    <img src="${thumb}" class="image movie-trigger" data-vid="${vid}">
                    <div class="Vtitle movie-trigger" data-vid="${vid}">${title.substring(0, 60)}</div>
                </div>`;
            $output.append(cardHtml);
        });

        // Click to Player
        $('.movie-trigger').on('click', function() {
            const vId = $(this).data('vid');
            const scroll = $('#conteiner').scrollTop() || 0;
            // Use tvytube for movies and ytmusic_player for music if you have separate players
            const playerPath = currentPath.includes('/music') ? '/music/ytmusic_player' : '/movies/tvytube';
            handleNav(`${playerPath}?videoId=${vId}&targetID=${targetID}&targetMode=${mode}&scrollPos=${scroll}`);
        });

        // Restore Scroll
        try {
            const urlParams = new URLSearchParams(currentPath.split('?')[1]);
            const savedScroll = urlParams.get('scrollPos');
            if (savedScroll) {
                setTimeout(() => {
                    $('#conteiner').scrollTop(parseInt(savedScroll));
                }, 100);
            }
        } catch (e) {}
    }

    // SCROLL SYNC TRIGGER
    $('#conteiner').on('scroll', function() {
        if (window.isSyncing) return; // Prevent loop flicker

        if (window.socket && window.socket.connected) {
            window.socket.emit('state_sync', {
                type: 'scroll',
                position: $(this).scrollTop(),
                room: window.myRoom
            });
        }
    });

    init();
})();
</script>