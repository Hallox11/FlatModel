<style>
/* ============================================================
   CINEMA HUB - PREMIUM TV INTERFACE
   ============================================================ */

#movies-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20, 20, 20, 0.6), rgba(0, 0, 0, 0.5));
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
    margin: 20px auto;
    position: relative;
}

#movies-menu-wrapper .movies-header {
    font-family: 'Segoe UI', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 7px;
    margin-bottom: 35px;
    opacity: 0.9;
    text-shadow: 0 0 20px rgba(0, 0, 0, 0.2), 0 2px 8px rgba(0, 0, 0, 0.7);
}

.movies-grid-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr); 
    gap: 20px;
    width: 100%;
}

.feature-row {
    grid-column: span 5;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
}

.feature-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 22px;
    border-radius: 15px;
    color: white;
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s ease;
}

.feature-btn:hover { background: white; color: black; }

.movie-group {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
}

.movie-group:hover {
    transform: scale(1.07);
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 255, 255, 0.8);
}

.main-title-btn {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
    text-align: center;
}

.sub-list-btn {
    font-size: 0.70rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 50px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    letter-spacing: 1px;
    transition: all 0.3s ease;
    text-align: center;
    white-space: nowrap;
}

/* Color Categories */
.cat-action { border-color: rgba(255, 75, 43, 0.3); }
.cat-action .main-title-btn { color: #ff4b2b; }
.cat-action .sub-list-btn { color: #ff4b2b; border-color: rgba(255, 75, 43, 0.4); }
.cat-action .sub-list-btn:hover { background: #ff4b2b; color: white; }

.cat-kids { border-color: rgba(0, 212, 255, 0.3); }
.cat-kids .main-title-btn { color: #00d4ff; }
.cat-kids .sub-list-btn { color: #00d4ff; border-color: rgba(0, 212, 255, 0.4); }
.cat-kids .sub-list-btn:hover { background: #00d4ff; color: white; }

.cat-classic { border-color: rgba(255, 179, 71, 0.3); }
.cat-classic .main-title-btn { color: #ffb347; }
.cat-classic .sub-list-btn { color: #ffb347; border-color: rgba(255, 179, 71, 0.4); }
.cat-classic .sub-list-btn:hover { background: #ffb347; color: white; }

.cat-docs { border-color: rgba(189, 0, 255, 0.3); }
.cat-docs .main-title-btn { color: #bd00ff; }
.cat-docs .sub-list-btn { color: #bd00ff; border-color: rgba(189, 0, 255, 0.4); }
.cat-docs .sub-list-btn:hover { background: #bd00ff; color: white; }

#loader {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background: #000000; display: none; flex-direction: column;
    justify-content: center; align-items: center; z-index: 999999;
}
.spinner {
    width: 60px; height: 60px; border: 6px solid rgba(255, 255, 255, 0.1);
    border-top: 6px solid #00d4ff; border-radius: 50%; animation: spin 1s linear infinite;
}
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

