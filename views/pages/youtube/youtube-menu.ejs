<script>
if (!window.ytMenuInitialized) {
    window.ytMenuInitialized = true;

// Standard loader helper
function loadWithSpinner(url) {
        // 1. Show the loader (assuming window.showLoader exists in your main layout)
        if (window.showLoader) {
            window.showLoader();
        }

        // 2. Defer navigation to ensure the loader paints
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                handleNav(url);
            });
        });
    }


// ===============================
// SEARCH
// ===============================
window.executeSearch = function() {
    const input = document.getElementById('yt-search-field');
    const query = input.value.trim();

    if (!query) {
        input.placeholder = "Type something first...";
        return;
    }

    input.placeholder = "Searching...";

    // Split by newline, comma, or space
    const parts = query.split(/[\n,\s]+/).map(p => p.trim()).filter(Boolean);

if (parts.length > 1) {
    const ids = parts.map(extractVideoId).filter(Boolean);
    console.log("IDSS: ", ids);
    if (ids.length > 0) {
        sessionStorage.setItem('yt_playlist', JSON.stringify(ids));
        sessionStorage.setItem('yt_playlist_index', '0');
        handleNav(`/tvytube?videoId=${encodeURIComponent(ids[0])}&vq=hd1080&origin=link&targetID=playlist&menu=/youtube-menu`);
        return;
    }
}

    // Single entry — existing logic
    const videoId = extractVideoId(query);
    if (videoId) {
        handleNav(`/tvytube?videoId=${encodeURIComponent(videoId)}&origin=link&menu=/youtube-menu`);
        return;
    }

    const isChannelId = /^UC[\w-]{22}$/.test(query);
    const url = isChannelId
        ? `/youtube-grid?genre=${encodeURIComponent(query)}&isChannel=true&menu=/youtube-menu`
        : `/youtube-grid?genre=${encodeURIComponent(query)}&menu=/youtube-menu`;

    loadWithSpinner(url);
};
function extractVideoId(input) {
  
    // v=xaQJbozY_Is  (query param, with or without full URL)
const vParam = input.match(/(?:[?&]|^)v=([a-zA-Z0-9_-]{11})/);
      

    if (vParam) return vParam[1];

    // youtu.be/xaQJbozY_Is
    const shortUrl = input.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/);
    if (shortUrl) return shortUrl[1];

    // bare 11-char video ID — must NOT match a channel ID pattern
    const bareId = /^[a-zA-Z0-9_-]{11}$/.test(input);
    if (bareId && !/^UC/.test(input)) return input;

    return null;
}



}
</script>
