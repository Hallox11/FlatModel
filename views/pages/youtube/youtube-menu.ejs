<style>
/* ===============================
   WRAPPER
=============================== */
#youtube-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20,20,20,0.6), rgba(0,0,0,0.5));
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0,0,0,0.9);
    margin: 20px auto;
    position: relative;
}

/* ===============================
   HEADER
=============================== */
#youtube-menu-wrapper .yt-header {
    font-family: 'Segoe UI', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 7px;
    margin-bottom: 40px;
    opacity: 0.9;
    text-shadow: 0 0 20px rgba(0,0,0,0.2), 0 2px 8px rgba(0,0,0,0.7);
}

/* ===============================
   SEARCH
=============================== */
#youtube-menu-wrapper .search-container {
    width: 100%;
    margin-bottom: 25px;
}

#youtube-menu-wrapper .search-input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.5);
    padding: 16px 25px;
    border-radius: 15px;
    font-size: 1.3rem;
    color: white;
    outline: none;
    transition: 0.3s;
    min-width: 0;
}

#youtube-menu-wrapper .search-input:focus {
    border-color: #ff0000;
    background: rgba(255,255,255,0.1);
    box-shadow: 0 0 20px rgba(255,0,0,0.2);
}

#youtube-menu-wrapper .search-btn {
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 15px;
    color: white;
    padding: 14px 22px;
    cursor: pointer;
    transition: 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

#youtube-menu-wrapper .search-btn:hover {
    background: #ff0000;
    border-color: #ff0000;
}

/* ===============================
   GRID CONTAINER
=============================== */
#youtube-menu-wrapper .yt-grid-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    width: 100%;
}

/* ===============================
   FEATURE ROW
=============================== */
#youtube-menu-wrapper .feature-row {
    grid-column: span 5;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 5px;
}

#youtube-menu-wrapper .feature-btn {
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.2);
    padding: 15px;
    border-radius: 15px;
    color: white;
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-transform: uppercase;
}

#youtube-menu-wrapper .feature-btn:hover {
    background: white;
    color: black;
}

#youtube-menu-wrapper .feature-btn.btn-fav {
    border-color: #ffd700;
    color: #ffd700;
}

#youtube-menu-wrapper .feature-btn.btn-fav:hover {
    background: #ffd700;
    color: black;
    border-color: #ffd700;
}

/* ===============================
   CATEGORY CARDS
=============================== */
#youtube-menu-wrapper .btn-group {
    background: rgba(0,0,0,0.6);
    border: 2px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    box-shadow: 0 5px 20px rgba(0,0,0,0.5);
}

#youtube-menu-wrapper .btn-group:hover {
    transform: scale(1.07);
    background: rgba(0,0,0,0.7);
    border-color: rgba(255,255,255,0.8);
}

#youtube-menu-wrapper .main-title-btn {
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
    text-align: center;
}

.sub-btn-group {
    font-size: 0.70rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 50px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.15);
    letter-spacing: 1px;
    transition: all 0.3s ease;
    text-align: center;
    white-space: nowrap;
}

/* ===============================
   COLOR CATEGORIES
=============================== */
/* Red — action/trending */
#youtube-menu-wrapper .yt-red { border-color: rgba(255,75,43,0.4); }
#youtube-menu-wrapper .yt-red .main-title-btn { color: #ff4b2b; }
#youtube-menu-wrapper .yt-red .sub-btn-group { color: #ff4b2b; border-color: rgba(255,75,43,0.6); }
#youtube-menu-wrapper .yt-red .sub-btn-group:hover { background: #ff4b2b; color: white; }

/* Cyan — tech/info */
#youtube-menu-wrapper .yt-cyan { border-color: rgba(0,212,255,0.4); }
#youtube-menu-wrapper .yt-cyan .main-title-btn { color: #00d4ff; }
#youtube-menu-wrapper .yt-cyan .sub-btn-group { color: #00d4ff; border-color: rgba(0,212,255,0.6); }
#youtube-menu-wrapper .yt-cyan .sub-btn-group:hover { background: #00d4ff; color: white; }

/* Amber — lifestyle/classic */
#youtube-menu-wrapper .yt-amber { border-color: rgba(255,179,71,0.4); }
#youtube-menu-wrapper .yt-amber .main-title-btn { color: #ffb347; }
#youtube-menu-wrapper .yt-amber .sub-btn-group { color: #ffb347; border-color: rgba(255,179,71,0.6); }
#youtube-menu-wrapper .yt-amber .sub-btn-group:hover { background: #ffb347; color: white; }

/* Purple — docs/knowledge */
#youtube-menu-wrapper .yt-purple { border-color: rgba(189,0,255,0.4); }
#youtube-menu-wrapper .yt-purple .main-title-btn { color: #d385ee; }
#youtube-menu-wrapper .yt-purple .sub-btn-group { color: #d385ee; border-color: rgba(189,0,255,0.6); }
#youtube-menu-wrapper .yt-purple .sub-btn-group:hover { background: #d385ee; color: white; }

/* ===============================
   MODALS
=============================== */
.yt-modal-overlay {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    border-radius: 30px;
    z-index: 100;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 10px 40px;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.yt-modal-overlay[style*="flex"] {
    opacity: 1;
}

/* ===============================
   MODAL GRID
=============================== */
.modal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    width: 100%;
    overflow: hidden;
    padding: 10px;
}



/* ===============================
   REMOTE HOVER STATES
=============================== */
#youtube-menu-wrapper .btn-group.remote-hover {
    transform: scale(1.07);
    background: rgba(0,0,0,0.7);
    border-color: rgba(255,255,255,0.8);
}

#youtube-menu-wrapper .feature-btn.remote-hover {
    background: white !important;
    color: black !important;
}

#youtube-menu-wrapper .feature-btn.btn-fav.remote-hover {
    background: #ffd700 !important;
    color: black !important;
}
.movie-group.remote-hover { transform: scale(1.07); background: rgba(0, 0, 0, 0.7); border-color: rgba(255, 255, 255, 0.8); }
.feature-btn.remote-hover { background: white; color: black; border-color: white; }
.sub-btn-group.remote-hover  { background: red;color:black;font-weight: 600; transform: scale(1.05); }

</style>

