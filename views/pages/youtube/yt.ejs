function readVids(txt, mode) {

     $("#header").hide();
        
            fetch(txt)
                .then(response => response.text())
                .then(data => {

                 //   console.log(data);
                 
                    var videos = JSON.parse(data);
                  //  console.log(videos);                 
                    var numVideos = videos.length;
                  //  console.log("Numvideos: " + numVideos);
       
                    var channelTitle= videos[0].snippet.channelTitle;
                   // console.log("CHANNEL TITLE: " + channelTitle);

            if(videos[0].kind === "youtube#playlistItem")  mode="user";                  
            if(videos[0].kind === "youtube#playlist")  mode="list";
            if(videos[0].kind === "youtube#searchResult")  mode="tags";
  
 
            if(mode==="user") $('#countInfo').val(numVideos + " videos found");
            if(mode==="list") $('#countInfo').val(numVideos + " lists found");
            if(mode==="tags") $('#countInfo').val(numVideos + " videos found");
             
            if(from==="player"|| from==="load"){  
            $("#countInfo").show();
            $("#title").show();
            }
           // menu();
           
               
          //  console.log("TXT:" + txt.substring(1));   
            rename(txt,mode);
                
            if(mode==="user") { $('#title').val( "Videos of channel:  " + channelTitle);proc(videos, "user");}
            if(mode==="list") { $('#title').val( "Playlists of channel:  " + channelTitle);proc(videos, "list");}
            if(mode==="tags") { $('#title').val( "Mix Videos Selection");proc(videos, "tags");}
                
            if(from==="main") {          
                     $('#conteiner').scrollTop(0)
                     $("#header").show();
       }
       if(from==="load") {          
                     $('#conteiner').scrollTop(0)
                     $('#menu').text("SHOW MENU");
                     $("#header").hide();
                     $("#topics").empty()
       }
       if(from==="player") {  
        console.log("SCROLL " + scroll)        
                     $('#conteiner').scrollTop(scroll);
                     $('#conteiner').scrollTop(scroll);
                     $('#menu').text("SHOW MENU");
                     $("#header").hide();
                     $("#topics").empty();
       }
            });
}

