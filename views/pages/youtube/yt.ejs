 function userSearch(mode,user,page){
           
            from="load";
            var userId=user;
            var order="date";
            var pages=5;
            console.log("MODE: " + mode);
            console.log("USER: " + user);

            functABC(mode,user,pages).then(function(data) {
    // Run this when your request was successful
            console.log("RESPOSTA: " + data);
            if(data==="ok") readVids("./ytube.txt", mode);
         }).catch(function(err) {
    // Run this when promise was rejected via reject()
             console.log(err)
         })
           
}
////////////
function functABC(mode,user,pages) {
   
    return new Promise(function(resolve, reject) {
         
           // var mode=mode;
            var userId=user;
            var tag=user; // in tag search tag comes on user
            var order='date';
            var pages=5;
          

      $.ajax({
        url: '/getChannelVideos',
        type: 'POST',
        data: {
           'mode'  : mode,
           'userId': userId,
           'tag': tag,
           'order' : order,
           'type' : 'youtube'
           },
        success: function(data) {
          resolve(data) // Resolve promise and go to then()
        },
        error: function(err) {
          reject(err) // Reject the promise and go to catch()
        }
      });
    });
  }

