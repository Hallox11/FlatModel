<style>
#quiz-module {
    width: 1280px; height: 720px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    font-family: 'Fira Sans', sans-serif; color: white;
}

#quiz-close {
    position: absolute; top: 20px; left: 20px;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px;
    color: white; padding: 7px 14px; font-size: 0.78rem;
    font-family: 'Fira Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 6px;
    cursor: pointer; transition: all 0.2s; z-index: 200;
}
#quiz-close:hover { border-color: rgba(255,255,255,0.5); }

.quiz-screen {
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    width: 100%; height: 100%;
    animation: qFadeIn 0.4s ease;
    background: #000000c9;
}
.quiz-screen.active { display: flex; }

/* ── LOBBY ── */
#qs-lobby { gap: 30px; }
.quiz-title {
    font-size: 2.5rem; font-weight: 200;
    letter-spacing: 8px; text-transform: uppercase; opacity: 0.9;
}
.quiz-subtitle {
    font-size: 1rem; letter-spacing: 3px;
    text-transform: uppercase; opacity: 0.9;
}
#quiz-players-list {
    display: flex; gap: 12px; flex-wrap: wrap;
    justify-content: center; max-width: 800px;
}
.quiz-player-chip {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50px; padding: 8px 20px;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 8px;
}
.quiz-player-chip .chip-dot {
    width: 6px; height: 6px; border-radius: 50%; background: #2ecc71;
}
.quiz-name-row { display: flex; gap: 10px; align-items: center; }
#quiz-name-input {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px;
    color: white; padding: 12px 20px; font-size: 0.9rem;
    font-family: 'Fira Sans', sans-serif; outline: none;
    width: 220px; text-align: center; letter-spacing: 1px;
    transition: border-color 0.2s;
}
#quiz-name-input:focus { border-color: #daa520; }
#quiz-name-input::placeholder { opacity: 0.8; }
.quiz-btn {
    background: linear-gradient(135deg, rgba(218,165,32,0.3), rgba(218,165,32,0.1));
    border: 1px solid rgba(218,165,32,0.5); border-radius: 10px;
    color: white; cursor: pointer; padding: 12px 28px;
    font-size: 0.82rem; font-family: 'Fira Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 2px; transition: all 0.2s ease;
}
.quiz-btn:hover { background: rgba(218,165,32,0.4); border-color: #daa520; transform: scale(1.03); }
.quiz-btn:disabled { opacity: 0.9; cursor: not-allowed; transform: none; }
.quiz-btn.green { background: rgba(46,204,113,0.2); border-color: rgba(46,204,113,0.5); }
.quiz-btn.green:hover { background: rgba(46,204,113,0.4); border-color: #2ecc71; }

/* ── COUNTDOWN ── */
#qs-countdown { gap: 20px; }
.countdown-number {
    font-size: 8rem; font-weight: 200; line-height: 1; animation: qPop 1s ease;
}
.countdown-label { font-size: 0.75rem; letter-spacing: 4px; text-transform: uppercase; opacity: 0.7; }

/* ── QUESTION ── */
#qs-question { gap: 0; justify-content: flex-start; padding-top: 90px; }

#quiz-timer-ring { position: absolute; top: 20px; right: 30px; width: 60px; height: 60px; }
#quiz-timer-ring svg { transform: rotate(-90deg); }
#quiz-timer-circle {
    fill: none; stroke: #daa520; stroke-width: 3;
    stroke-dasharray: 163; stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.1s linear; stroke-linecap: round;
}
#quiz-timer-text {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; font-weight: 200;
}
#quiz-q-number {
    font-size: 1.1rem; letter-spacing: 3px;
    text-transform: uppercase; opacity: 0.7; margin-bottom: 30px;
}
#quiz-question-text {
    position: fixed;
    top: 135px;
    font-size: 1.6rem; font-weight: 200; text-align: center;
    max-width: 900px; line-height: 1.5; margin-bottom: 40px; padding: 0 40px;
}
#quiz-answers {
    position: fixed;
    top: 235px;
     display: grid; 
     grid-template-columns: 1fr 1fr; 
     gap: 14px;
      width: 900px; 
    }
.quiz-answer {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px; padding: 18px 24px;
    cursor: pointer; font-size: 1.2rem; text-align: left; color: white;
    font-family: 'Fira Sans', sans-serif;
    transition: all 0.15s ease; display: flex; align-items: center; gap: 14px;
}
.quiz-answer:hover:not(:disabled) {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.12); transform: scale(1.02);
}
.quiz-answer:disabled { cursor: not-allowed; }
.quiz-answer.selected { border-color: #daa520; background: rgba(218,165,32,0.15); }
.quiz-answer.correct  { border-color: #2ecc71; background: rgba(46,204,113,0.2); }
.quiz-answer.wrong    { border-color: #e74c3c; background: rgba(231,76,60,0.15); opacity: 0.8; }
.answer-letter {
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.0rem; font-weight: 600; flex-shrink: 0;
}

/* ── SCOREBOARD ── */
#quiz-scoreboard {
    position: absolute; bottom: 20px; left: 50%;
    transform: translateX(-50%); display: flex; gap: 12px;
}
.score-chip {
    background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 50px;
    padding: 6px 16px; font-size: 1.2rem;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 8px;
}
.score-chip .score-name { opacity: 0.7; }
.score-chip .score-pts  { color: #daa520; font-weight: 600; }

/* ── INLINE RESULT ── */
.result-answer-reveal { font-size: 0.95rem; letter-spacing: 2px; text-transform: uppercase; opacity: 0.8; }
.result-correct-answer { font-size: 1.4rem; text-align: center; max-width: 700px; color: #1ae713; }
.result-scores { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
.result-score-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px; padding: 7px 24px;
    text-align: center; min-width: 140px; transition: all 0.3s ease;
}
.result-score-card.got-it { border-color: #2ecc71; }
.result-score-card .rs-name { font-size: 1rem; opacity: 0.8; text-transform: uppercase; letter-spacing: 1px; }
.result-score-card .rs-pts  { font-size: 1.6rem; font-weight: 200; color: #daa520; }

#quiz-result-inline{position:fixed;top:390px;display:none; margin-top:25px;padding-top:20px;}
/* ── FINAL ── */
#qs-final { gap: 28px; }
.podium { display: flex; align-items: flex-end; gap: 20px; }
.podium-place { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.podium-bar {
    width: 120px; background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15); border-radius: 8px 8px 0 0;
    display: flex; align-items: flex-end; justify-content: center; padding-bottom: 12px;
}
.podium-bar.first  { height: 160px; border-color: #daa520; background: rgba(218,165,32,0.1); }
.podium-bar.second { height: 120px; }
.podium-bar.third  { height: 90px; }
.podium-medal { font-size: 2rem; }
.podium-name  { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }
.podium-score { font-size: 1rem; color: #daa520; }

@keyframes qFadeIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
@keyframes qPop    { 0%{transform:scale(0.5);opacity:0} 60%{transform:scale(1.2)} 100%{transform:scale(1);opacity:1} }
</style>

<div id="quiz-module">
    <button id="quiz-close" onclick="quizClose()">
        <span class="material-symbols-rounded" style="font-size:15px;">arrow_back</span> Back
    </button>

    <div id="qs-lobby" class="quiz-screen active">
        <div class="quiz-title">🎯 Trivia</div>
        <div class="quiz-subtitle">General Knowledge · 10 Questions</div>
        <div id="quiz-players-list"></div>
        <div class="quiz-name-row">
            <input id="quiz-name-input" type="text" placeholder="Your name..." maxlength="16">
            <button class="quiz-btn" onclick="quizJoin()">Join</button>
        </div>
        <button class="quiz-btn green" id="quiz-start-btn" onclick="quizStart()" disabled>
            Start Game
        </button>
    </div>

    <div id="qs-countdown" class="quiz-screen">
        <div class="countdown-label">Game starts in</div>
        <div class="countdown-number" id="quiz-countdown-num">3</div>
    </div>

    <div id="qs-question" class="quiz-screen">
        <div id="quiz-timer-ring">
            <svg viewBox="0 0 60 60" width="60" height="60">
                <circle cx="30" cy="30" r="26" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="3"/>
                <circle id="quiz-timer-circle" cx="30" cy="30" r="26"/>
            </svg>
            <div id="quiz-timer-text">5</div>
        </div>
        <div id="quiz-q-number">Question 1 of 10</div>
        <div id="quiz-question-text">Loading...</div>
        <div id="quiz-answers"></div>
        <div id="quiz-scoreboard"></div>

        <div id="quiz-result-inline" >
            <div class="result-answer-reveal" style="font-weight:600; color:#daa520; font-size:1rem; text-transform:uppercase; opacity:0.9; text-align:center;">Correct Answer</div>
            <div class="result-correct-answer" id="result-correct-text" style="font-size:1.5rem; font-weight:bold; text-align:center; margin-bottom:15px;margin-top:10px;"></div>
            <div class="result-scores" id="result-scores"></div>
            <div style="text-align:center; margin-top:30px;">
                <button id="quiz-next-btn-r" class="quiz-btn" onclick="requestNext()" style="display:none;">Next Question</button>
                <div id="quiz-wait-msg" style="display:none; opacity:0.5; font-size:0.9rem; font-style:italic;">Waiting for host to continue...</div>
            </div>
        </div>
    </div>

    <div id="qs-final" class="quiz-screen">
        <div class="quiz-title" style="font-size:1.8rem;">Game Over</div>
        <div class="podium" id="quiz-podium"></div>
        <button class="quiz-btn" onclick="quizPlayAgain()">Play Again</button>
    </div>
</div>

<script>
(function () {
    const socket = window.socket || window.parent?.socket;
    if (!socket) { console.error('[Quiz] Socket not found'); return; }
    const myRoom = window.myRoom || 'Lobby';

    // ── GUARD: prevent duplicate listener registration on DOM reload ──
    if (window._quizListenersRegistered) {
        // Module was reloaded by jQuery — just re-render lobby state and exit
        renderPlayers();
        return;
    }
    window._quizListenersRegistered = true;

    // ── PERSISTENT STATE ──
    // Lives on window so it survives jQuery DOM reloads.
    // Rule: myName + players persist across Play Again (backend keeps them).
    //       Both are wiped only on quizClose() (leave to menu).
    if (!window.quizState) {
        window.quizState = { myName: null, players: {} };
    }

    // ── LOCAL (per-game) STATE ──
    let questions     = [];
    let currentQ      = 0;
    let answered      = false;
    let timerInterval = null;
    let timeLeft      = 0;
    let isHost        = false;
    let gameEnded     = false;
    const TOTAL_Q     = 3;
    const TIME_PER_Q  = 5;
    const LETTERS     = ['A','B','C','D'];

    // ── HELPERS ──
    function decodeHTML(str) {
        if (!str) return '';
        const t = document.createElement('textarea');
        t.innerHTML = str; return t.value;
    }

    function $(id) { return document.getElementById(id); }

    // ── SCREENS ──
    function showScreen(id) {
        document.querySelectorAll('.quiz-screen').forEach(s => s.classList.remove('active'));
        const el = $(id);
        if (el) el.classList.add('active');
    }

    // ── PLAYERS ──
    function renderPlayers() {
        const list = $('quiz-players-list');
        if (!list) return;
        const entries = Object.values(window.quizState.players);
        list.innerHTML = entries.length
            ? entries.map(p => `<div class="quiz-player-chip"><div class="chip-dot"></div>${p.name}</div>`).join('')
            : '<div style="opacity:0.3;font-size:0.8rem;letter-spacing:2px;text-transform:uppercase;">No players yet</div>';
        const startBtn = $('quiz-start-btn');
        if (startBtn) startBtn.disabled = entries.length < 1;
    }

    function renderScoreboard() {
        const sb = $('quiz-scoreboard');
        if (!sb) return;
        sb.innerHTML = Object.values(window.quizState.players)
            .sort((a, b) => b.score - a.score)
            .map(p => `<div class="score-chip">
                <span class="score-name">${p.name}</span>
                <span class="score-pts">${p.score}</span>
            </div>`).join('');
    }

    // ── RESET INPUT UI ──
    function resetInputUI() {
        const nameInput = $('quiz-name-input');
        if (nameInput) { nameInput.disabled = false; nameInput.value = ''; }
        const joinBtn = document.querySelector('.quiz-name-row .quiz-btn');
        if (joinBtn) joinBtn.disabled = false;
    }

    // ── FULL LOCAL RESET (per-game vars only) ──
    // Called on Play Again — does NOT wipe myName/players
    // because the backend keeps the players and re-emits quiz_players_update.
    function resetGameState() {
        questions  = [];
        currentQ   = 0;
        answered   = false;
        gameEnded  = false;
        isHost     = false;
        timeLeft   = 0;
        clearInterval(timerInterval);
    }

    // ── JOIN ──
    window.quizJoin = function () {
        const nameInput = $('quiz-name-input');
        const name = nameInput ? nameInput.value.trim() : '';
        if (!name) return;
        window.quizState.myName = name;
        socket.emit('quiz_join', { room: myRoom, name });
        if (nameInput) nameInput.disabled = true;
        const joinBtn = document.querySelector('.quiz-name-row .quiz-btn');
        if (joinBtn) joinBtn.disabled = true;
    };

    // ── START ──
    window.quizStart = function () { socket.emit('quiz_start', { room: myRoom }); };

    // ── PLAY AGAIN ──
    window.quizPlayAgain = function () { socket.emit('quiz_reset', { room: myRoom }); };

    // ── ANSWER ──
    window.quizAnswer = function (btn, index) {
        if (answered) return;
        answered = true;
        document.querySelectorAll('.quiz-answer').forEach(b => b.disabled = true);
        if (btn) btn.classList.add('selected');
        socket.emit('quiz_answer', { room: myRoom, questionIndex: currentQ, answerIndex: index, timeLeft });
    };

    // ── NEXT (host) ──
    window.requestNext = function () {
        socket.emit('quiz_next', { room: myRoom });
        const btn = $('quiz-next-btn-r');
        if (btn) btn.disabled = true;
    };

    // ── CLOSE (leave to menu) ──
    window.quizClose = function () {
        resetGameState();
        // Full wipe on leave — player must re-enter name when coming back
        window.quizState.myName    = null;
        window.quizState.players   = {};
        window._quizListenersRegistered = false; // allow fresh registration on re-entry
        resetInputUI();
        socket.emit('quiz_leave', { room: myRoom });
        if (typeof handleNav === 'function') handleNav('games-menu', false);
    };

    // ── TIMER ──
    function startTimer() {
        clearInterval(timerInterval);
        timeLeft = TIME_PER_Q;
        const circle = $('quiz-timer-circle');
        const timerText = $('quiz-timer-text');
        const circumference = 163;

        timerInterval = setInterval(() => {
            timeLeft = Math.max(0, timeLeft - 0.1);
            if (timerText) timerText.textContent = Math.ceil(timeLeft);
            if (circle) circle.style.strokeDashoffset = circumference * (1 - timeLeft / TIME_PER_Q);
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                if (!answered) {
                    answered = true;
                    document.querySelectorAll('.quiz-answer').forEach(b => b.disabled = true);
                    socket.emit('quiz_answer', { room: myRoom, questionIndex: currentQ, answerIndex: -1, timeLeft: 0 });
                }
            }
        }, 100);
    }

    // ── RENDER QUESTION ──
    function renderQuestion(q, index) {
        currentQ = index;
        answered = false;

        const resultInline = $('quiz-result-inline');
        if (resultInline) resultInline.style.display = 'none';

        const qNum = $('quiz-q-number');
        const qText = $('quiz-question-text');
        const answersDiv = $('quiz-answers');
        if (qNum)  qNum.textContent = `Question ${index + 1} of ${TOTAL_Q}`;
        if (qText) qText.innerHTML  = decodeHTML(q.question);
        if (answersDiv) {
            answersDiv.innerHTML = q.answers.map((a, i) => `
                <button class="quiz-answer" onclick="quizAnswer(this, ${i})">
                    <div class="answer-letter">${LETTERS[i]}</div>
                    ${decodeHTML(a)}
                </button>`).join('');
        }

        startTimer();
        renderScoreboard();
        showScreen('qs-question');
    }

    // ── SHOW RESULT (inline) ──
    function showResult(correctAnswer, scores) {
        clearInterval(timerInterval);

        // Colorize answers
        const answers = document.querySelectorAll('.quiz-answer');
        if (answers.length && questions[currentQ]) {
            answers.forEach((btn, i) => {
                if (i === questions[currentQ].correctIndex) btn.classList.add('correct');
                else if (btn.classList.contains('selected'))  btn.classList.add('wrong');
            });
        }

        const correctText = $('result-correct-text');
        if (correctText) correctText.innerHTML = decodeHTML(correctAnswer);

        // Delta scores
        const resultScoresEl = $('result-scores');
        if (resultScoresEl) {
            resultScoresEl.innerHTML = Object.values(window.quizState.players)
                .sort((a, b) => (scores[b.id] || 0) - (scores[a.id] || 0))
                .map(p => {
                    const newScore = scores[p.id] || 0;
                    const earned   = newScore - (p.score || 0);
                    return `<div class="result-score-card ${earned > 0 ? 'got-it' : ''}">
                        <div class="rs-name">${p.name}</div>
                        <div class="rs-pts">${earned > 0 ? '+ ' + earned : '0'} pts</div>
                    </div>`;
                }).join('');
        }

        // Update stored scores AFTER delta calc
        Object.entries(scores).forEach(([id, pts]) => {
            if (window.quizState.players[id]) window.quizState.players[id].score = pts;
        });

        const resultInline = $('quiz-result-inline');
        if (resultInline) resultInline.style.display = 'block';

        const nextBtn = $('quiz-next-btn-r');
        const waitMsg = $('quiz-wait-msg');
        if (isHost) {
            if (nextBtn) { nextBtn.style.display = 'inline-block'; nextBtn.disabled = false; }
            if (waitMsg) waitMsg.style.display = 'none';
        } else {
            if (nextBtn) nextBtn.style.display = 'none';
            if (waitMsg) waitMsg.style.display = 'block';
        }
    }

    // ── FINAL PODIUM ──
    function showFinal(finalScores) {
        const sorted = Object.values(window.quizState.players)
            .map(p => ({ ...p, score: finalScores[p.id] !== undefined ? finalScores[p.id] : p.score }))
            .sort((a, b) => b.score - a.score);

        const positions = ['second', 'first', 'third'];
        const medals    = ['🥈', '🥇', '🥉'];
        const order     = [sorted[1], sorted[0], sorted[2]].filter(Boolean);

        const podium = $('quiz-podium');
        if (podium) {
            podium.innerHTML = order.map((p, i) => `
                <div class="podium-place">
                    <div class="podium-name">${p.name}</div>
                    <div class="podium-score">${p.score} pts</div>
                    <div class="podium-bar ${positions[i]}">
                        <div class="podium-medal">${medals[i]}</div>
                    </div>
                </div>`).join('');
        }
        showScreen('qs-final');
    }

    // ── SOCKET EVENTS ──
    socket.on('quiz_host_assigned', () => {
        isHost = true;
        // If result panel is already visible, show Next button immediately
        const resultInline = $('quiz-result-inline');
        const nextBtn      = $('quiz-next-btn-r');
        const waitMsg      = $('quiz-wait-msg');
        if (resultInline && resultInline.style.display !== 'none') {
            if (nextBtn) { nextBtn.style.display = 'inline-block'; nextBtn.disabled = false; }
            if (waitMsg) waitMsg.style.display = 'none';
        }
    });

    socket.on('quiz_players_update', data => {
        window.quizState.players = data.players;
        renderPlayers();
    });

    socket.on('quiz_countdown', data => {
        showScreen('qs-countdown');
        const el = $('quiz-countdown-num');
        if (el) el.textContent = data.count;
    });

    socket.on('quiz_question', data => {
        questions = data.questions || questions;
        renderQuestion(data.question, data.index);
    });

    socket.on('quiz_result', data => {
        if (gameEnded) return;
        showResult(data.correctAnswer, data.scores);
    });

    socket.on('quiz_final', data => {
        gameEnded = true;
        showFinal(data.scores);
    });

    // Play Again: reset local game vars, keep myName+players (backend re-emits them)
    socket.on('quiz_reset', () => {
        resetGameState();
        resetInputUI();
        // Players will be repopulated by the quiz_players_update the backend emits after reset
        // Don't wipe quizState.players here — avoid flash of empty lobby
        showScreen('qs-lobby');
        renderPlayers();
    });

    socket.on('force_navigate', data => {
        quizClose();
        setTimeout(() => {
            if (typeof handleNav === 'function') handleNav(data.target, true);
        }, 500);
    });
socket.on('quiz_kicked', () => {
    clearInterval(timerInterval);
    isHost = false;
    gameEnded = false;
    answered = false;
    questions = [];
    window.quizState.myName = null;
    window.quizState.players = {};
    const nameInput = document.getElementById('quiz-name-input');
    if (nameInput) { nameInput.disabled = false; nameInput.value = ''; }
    const joinBtn = document.querySelector('.quiz-name-row .quiz-btn');
    if (joinBtn) joinBtn.disabled = false;
    if (typeof handleNav === 'function') handleNav('games-menu', false);
});
    // ── INIT ──
    renderPlayers();

    // Auto-rejoin if returning from a DOM reload mid-session
    if (window.quizState.myName) {
        socket.emit('quiz_join', { room: myRoom, name: window.quizState.myName });
    }

})();
</script>
