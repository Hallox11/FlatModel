<style>
:root {
    --chess-accent: #ffa260;
    --chess-success: #2ecc71;
    --chess-error: #ff6b6b;
    --chess-light-sq: #2c2c2c;
    --chess-dark-sq: #181818;
}

#chess-module {
    width: 1000px;
    padding: 30px 35px;
    background: radial-gradient(circle at center, rgba(20, 20, 20, 0.6), rgba(0, 0, 0, 0.3));
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
    margin: 20px auto;
    position: relative;
    color: #fff;
    font-family: 'Segoe UI', 'Fira Sans', sans-serif;
}

#chess-module .close-menu-btn {
    position: absolute; top: 20px; left: 20px;
    width: 40px; height: 40px; background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 10px;
    color: white; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s; z-index: 200;
}
#chess-module .close-menu-btn:hover { border-color: var(--chess-error); background: rgba(255,107,107,0.15); }

.chess-title {
    text-align: center;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 7px;
    margin-bottom: 22px;
    opacity: 0.9;
    text-shadow: 0 0 20px rgba(0,0,0,0.2), 0 2px 8px rgba(0,0,0,0.7);
}
.chess-title span { color: var(--chess-accent); }

/* ───────────── LOBBY SCREEN ───────────── */
#chess-lobby {
    display: flex; flex-direction: column; align-items: center; gap: 18px;
    padding: 30px 0 10px;
}
.chess-name-input {
    width: 280px; padding: 13px 18px; font-size: 14px; font-weight: 500;
    background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.15);
    border-radius: 12px; color: #fff; font-family: inherit; text-align: center;
    letter-spacing: 0.5px;
}
.chess-name-input:focus { border-color: var(--chess-accent); outline: none; }

.chess-btn {
    padding: 13px 34px; font-size: 13px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: #000; background: var(--chess-accent);
    border: none; border-radius: 12px; cursor: pointer; transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(255,162,96,0.25);
}
.chess-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(255,162,96,0.4); }
.chess-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.chess-btn.secondary {
    background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.2);
    box-shadow: none;
}
.chess-btn.secondary:hover { border-color: var(--chess-accent); color: var(--chess-accent); }

.chess-waiting-text {
    font-size: 13px; letter-spacing: 1px; color: rgba(255,255,255,0.5);
    text-transform: uppercase; display: flex; align-items: center; gap: 10px;
}
.chess-dot-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--chess-accent); animation: chessPulse 1.2s infinite ease-in-out; }
@keyframes chessPulse { 0%,100% { opacity: 0.3; transform: scale(0.8);} 50% { opacity: 1; transform: scale(1.15);} }

/* ───────────── GAME SCREEN ───────────── */
#chess-game-area { display: none; gap: 30px; }
#chess-game-area.active { display: flex; }

.chess-board-wrap { position: relative; flex-shrink: 0; }

#chess-board {
    width: 560px; height: 560px;
    display: grid; grid-template-columns: repeat(8, 1fr); grid-template-rows: repeat(8, 1fr);
    border-radius: 12px; overflow: hidden;
    border: 3px solid rgba(255,255,255,0.12);
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
}

.chess-sq {
    position: relative; display: flex; align-items: center; justify-content: center;
    cursor: pointer; user-select: none; transition: background 0.12s;
}
.chess-sq.light { background: #f0d9b5; }
.chess-sq.dark  { background: #b58863; }
.chess-sq.selected { background: #ffa260db !important; }

/* REPLACED PSEUDO-ELEMENT DOTS WITH NATIVE GRADIENTS FOR CEFS INSIDE SL */
.chess-sq.legal-move {
    background: radial-gradient(circle, rgba(20,20,20,0.25) 20%, transparent 21%) !important;
}
.chess-sq.legal-capture {
    background: radial-gradient(circle, transparent 65%, rgba(20,20,20,0.3) 66%, rgba(20,20,20,0.3) 76%, transparent 77%) !important;
}

.chess-sq.last-move { background: #f7ec74 !important; box-shadow: inset 0 0 0 3px #d4c41f; }
.chess-sq.in-check { background: rgba(255,80,80,0.55) !important; }

/* RADICAL POINTER EVENT ENFORCEMENT TO BYPASS EMBEDDED CHROMIUM SVG BUG */
.chess-piece,
.chess-piece svg,
.chess-piece path,
.chess-piece g {
    width: 78%; height: 78%; display: flex; align-items: center; justify-content: center;
    pointer-events: none !important; transition: transform 0.12s ease; filter: drop-shadow(0 3px 5px rgba(0,0,0,0.55));
}
.chess-sq:hover .chess-piece { transform: scale(1.07); }
.chess-piece svg { width: 100%; height: 100%; display: block; }

.chess-coord-file, .chess-coord-rank {
    position: absolute; font-size: 10px; font-weight: 800; color: rgba(0,0,0,0.35);
    text-transform: uppercase; pointer-events: none;
}
.chess-coord-file { bottom: 2px; right: 4px; }
.chess-coord-rank { top: 2px; left: 4px; }

/* ───────────── SIDE PANEL ───────────── */
#chess-side-panel { flex: 1; display: flex; flex-direction: column; gap: 16px; min-width: 280px; }

.chess-player-card {
    display: flex; align-items: center; gap: 14px; padding: 14px 18px;
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px; transition: all 0.2s;
}
.chess-player-card.turn-active { border-color: var(--chess-accent); box-shadow: 0 0 24px rgba(255,162,96,0.15); }
.chess-player-avatar {
    width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.chess-player-avatar.white-side { background: rgba(255,255,255,0.85); color: #000; }
.chess-player-avatar.black-side { background: #1a1a1a; color: #fff; border: 1px solid rgba(255,255,255,0.2); }
.chess-player-info { display: flex; flex-direction: column; gap: 2px; flex: 1; }
.chess-player-name { font-size: 14px; font-weight: 600; }
.chess-player-role { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4); }
.chess-player-clock { font-size: 18px; font-weight: 700; color: var(--chess-accent); font-variant-numeric: tabular-nums; }

.chess-status-banner {
    text-align: center; padding: 12px 16px; border-radius: 12px;
    background: rgba(255,162,96,0.08); border: 1px solid rgba(255,162,96,0.2);
    font-size: 13px; font-weight: 600; letter-spacing: 0.5px; color: var(--chess-accent);
    text-transform: uppercase;
}
.chess-status-banner.danger { background: rgba(255,107,107,0.1); border-color: rgba(255,107,107,0.3); color: var(--chess-error); }
.chess-status-banner.win { background: rgba(46,204,113,0.1); border-color: rgba(46,204,113,0.3); color: var(--chess-success); }

#chess-captured-row { display: flex; flex-direction: column; gap: 6px; }
.chess-captured-line {
    display: flex; align-items: center; gap: 3px; font-size: 20px; min-height: 26px;
    background: rgba(0,0,0,0.2); border-radius: 8px; padding: 4px 10px;
}
.chess-captured-line .chess-cap-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.35); margin-right: 8px; }
.chess-cap-piece { width: 18px; height: 18px; display: inline-block; opacity: 0.8; }
.chess-cap-piece svg { width: 100%; height: 100%; }

#chess-move-history {
    flex: 1; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px; padding: 12px 16px; overflow-y: auto; max-height: 180px;
    font-size: 13px; font-family: 'DM Mono', monospace, monospace;
}
#chess-move-history::-webkit-scrollbar { width: 5px; }
#chess-move-history::-webkit-scrollbar-thumb { background: rgba(255,162,96,0.3); border-radius: 4px; }
.chess-move-row { display: flex; gap: 10px; padding: 3px 0; color: rgba(255,255,255,0.7); }
.chess-move-row .chess-move-num { color: rgba(255,255,255,0.3); width: 22px; flex-shrink: 0; }
.chess-move-row .chess-move-white { flex: 1; }
.chess-move-row .chess-move-black { flex: 1; }

.chess-actions-row { display: flex; gap: 10px; }
.chess-actions-row .chess-btn { flex: 1; padding: 11px 0; font-size: 11px; }

.chess-promo-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(3px);
    display: none; align-items: center; justify-content: center; z-index: 50; border-radius: 12px;
}
.chess-promo-overlay.active { display: flex; }
.chess-promo-box {
    background: rgba(20,20,20,0.95); border: 1px solid var(--chess-accent); border-radius: 16px;
    padding: 20px 24px; display: flex; gap: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.7);
}
.chess-promo-piece {
    width: 56px; height: 56px; border-radius: 10px; background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;
    padding: 6px; cursor: pointer; transition: all 0.15s;
}
.chess-promo-piece svg { width: 100%; height: 100%; }
.chess-promo-piece:hover { background: rgba(255,162,96,0.2); border-color: var(--chess-accent); transform: scale(1.08); }

.chess-flip-hint { text-align: center; font-size: 10px; letter-spacing: 1px; color: rgba(255,255,255,0.3); text-transform: uppercase; margin-top: 8px; }
</style>

<div id="chess-module">
<div class="close-menu-btn" onclick="chessFullReset(); closeSubMenu();">
    <span style="font-size: 20px;" class="material-symbols-rounded">close</span>
</div>
    <div class="chess-title">CHESS <span>ONLINE</span></div>

    <!-- ═══════════ LOBBY ═══════════ -->
    <div id="chess-lobby">
        <input id="chess-name-input" class="chess-name-input" type="text" placeholder="Enter your name" maxlength="16">
        <div style="display:flex; gap:12px;">
            <button id="chess-create-btn" class="chess-btn" onclick="chessCreateGame()">Create Game</button>
            <button id="chess-join-btn" class="chess-btn secondary" onclick="chessJoinGame()">Join Random</button>
        </div>
        <div id="chess-waiting-msg" class="chess-waiting-text" style="display:none;">
            <div class="chess-dot-pulse"></div> Waiting for opponent…
        </div>
    </div>

    <!-- ═══════════ GAME AREA ═══════════ -->
    <div id="chess-game-area">
        <div class="chess-board-wrap">
            <div id="chess-board"></div>
            <div class="chess-flip-hint">You are playing as <span id="chess-my-color">—</span></div>

            <div class="chess-promo-overlay" id="chess-promo-overlay">
                <div class="chess-promo-box" id="chess-promo-box"></div>
            </div>
        </div>

        <div id="chess-side-panel">
            <div class="chess-player-card" id="chess-card-opponent">
                <div class="chess-player-avatar black-side">♚</div>
                <div class="chess-player-info">
                    <div class="chess-player-name" id="chess-opponent-name">Opponent</div>
                    <div class="chess-player-role">Black</div>
                </div>
                <div class="chess-player-clock" id="chess-opponent-clock">10:00</div>
            </div>

            <div class="chess-captured-line" id="chess-captured-by-opponent">
                <span class="chess-cap-label">Captured</span>
            </div>

            <div class="chess-status-banner" id="chess-status-banner">White to move</div>

            <div id="chess-move-history"></div>

            <div class="chess-captured-line" id="chess-captured-by-me">
                <span class="chess-cap-label">Captured</span>
            </div>

            <div class="chess-player-card turn-active" id="chess-card-me">
                <div class="chess-player-avatar white-side">♔</div>
                <div class="chess-player-info">
                    <div class="chess-player-name" id="chess-my-name">You</div>
                    <div class="chess-player-role">White</div>
                </div>
                <div class="chess-player-clock" id="chess-my-clock">10:00</div>
            </div>

            <div class="chess-actions-row">
                <button class="chess-btn secondary" onclick="chessOfferDraw()">Offer Draw</button>
                <button class="chess-btn secondary" onclick="chessResign()">Resign</button>
                <button class="chess-btn secondary" id="chess-rematch-btn" style="display:none;" onclick="chessRematch()">Rematch</button>
            </div>
        </div>
    </div>
</div>

