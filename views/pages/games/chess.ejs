        br:'<svg viewBox="0 0 45 45"><g fill="#2a2d33" stroke="#0d0e10" stroke-width="1.5" stroke-linejoin="round"><path d="M9 39h27v-3H9v3zM12 36v-4h21v4H12zM11 14V9h4v2h5V9h5v2h5V9h4v5"/><path d="M34 14l-3 3H14l-3-3"/><path d="M31 17v12.5H14V17"/><path d="M31 29.5l1.5 2.5h-20l1.5-2.5"/><path d="M11 14h23"/></g></svg>',
        bq:'<svg viewBox="0 0 45 45"><g fill="#2a2d33" stroke="#0d0e10" stroke-width="1.5" stroke-linejoin="round"><circle cx="6" cy="12" r="2.2"/><circle cx="14" cy="9" r="2.2"/><circle cx="22.5" cy="8" r="2.2"/><circle cx="31" cy="9" r="2.2"/><circle cx="39" cy="12" r="2.2"/><path d="M9 26c8.5-1.5 18.5-1.5 27 0l2-12-7 11-1.5-13-5.5 12-3-13-3 13-5.5-12L13 25l-7-11 3 12z"/><path d="M9 26c0 2 1.5 2 2.5 4 1 1.5 1 1 .5 3.5-1.5 1-1.5 2.5-1.5 2.5-1.5 1.5.5 2.5.5 2.5 6.5 1 16.5 1 23 0 0 0 1.5-1 0-2.5 0 0 .5-1.5-1-2.5-.5-2.5-.5-2 .5-3.5 1-2 2.5-2 2.5-4-8.5-1.5-18.5-1.5-27 0z"/></g></svg>',
        bk:'<svg viewBox="0 0 45 45"><g fill="none" stroke="#0d0e10" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"><path d="M22.5 11.63V6M20 8h5"/><path fill="#2a2d33" d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5"/><path fill="#2a2d33" d="M11.5 37c5.5 3.5 15.5 3.5 21 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27.5s-3-3-7-2c-4 1-7.5 3.5-7.5 3.5v9z"/><path fill="#2a2d33" d="M11.5 30c5.5-3 15.5-3 21 0M11.5 33.5c5.5-3 15.5-3 21 0M11.5 37c5.5-3 15.5-3 21 0"/></g></svg>'
    };

    const FILES = ['a','b','c','d','e','f','g','h'];

    // Cooldown tracker for Second Life double-clicks
    let lastChessClickTime = 0;

    // ── PERSISTENT STATE ACROSS DOM RELOADS ──
    window.chessState = window.chessState || {
        room: null,
        myColor: null,
        myName: null,
        selectedSquare: null,
        legalTargets: [],
        board: null,        // 8x8 array from server
        turn: 'w',
        lastMove: null,
        inCheck: null,
        gameOver: false
    };
let CS = window.chessState; // <-- Change const to let here

const socket = window.socket || io({ 
    transports: ['websocket'], // <--- FORCES WEBSOCKETS ONLY, SKIPS POLLING
    query: { room: (window.TV_ROOM || 'Lobby') }
    });
    window.socket = socket;

    function $(id) { return document.getElementById(id); }

    // ── BUILD EMPTY BOARD GRID (oriented for current player) ──
    function buildBoardDom() {
        const boardEl = $('chess-board');
        boardEl.innerHTML = '';
        boardEl.style.transform = 'none';

        const flip = flipped();
        for (let visRow = 0; visRow < 8; visRow++) {
            for (let visCol = 0; visCol < 8; visCol++) {
                const rank = flip ? (visRow + 1) : (8 - visRow);
                const fileIdx = flip ? (7 - visCol) : visCol;
                const file = FILES[fileIdx];

                const sq = document.createElement('div');
                const isLight = (rank + fileIdx) % 2 !== 0;
                sq.className = 'chess-sq ' + (isLight ? 'light' : 'dark');
                sq.dataset.square = file + rank;
                
                // Native individual onclicks removed to enforce the global coordinate point system below

                if (visCol === 0) {
                    const rl = document.createElement('span');
                    rl.className = 'chess-coord-rank'; rl.textContent = rank;
                    sq.appendChild(rl);
                }
                if (visRow === 7) {
                    const fl = document.createElement('span');
                    fl.className = 'chess-coord-file'; fl.textContent = file;
                    sq.appendChild(fl);
                }
                boardEl.appendChild(sq);
            }
        }
    }

    // ── COORDINATE-BASED INTERCEPTOR FOR SECOND LIFE CEF POINTER BUG ──
    document.addEventListener('click', function(e) {
        const board = $('chess-board');
        if (!board || !board.contains(e.target)) return;

        // Force a lookup at coordinates to bypass inline SVG layer interceptors
        const element = document.elementFromPoint(e.clientX, e.clientY);
        if (!element) return;

        const squareEl = element.closest('.chess-sq');
        if (squareEl && squareEl.dataset.square) {
            chessSquareClick(squareEl.dataset.square);
        }
    });

    function flipped() { return CS.myColor === 'b'; }

    function renderBoard(boardArray) {
        if (!boardArray) return;
        CS.board = boardArray;
        const squares = document.querySelectorAll('.chess-sq');
        squares.forEach(sq => {
            sq.classList.remove('selected','legal-move','legal-capture','last-move','in-check');
            const piece = sq.querySelector('.chess-piece');
            if (piece) piece.remove();
        });

        for (let r = 0; r < 8; r++) {
            for (let c = 0; c < 8; c++) {
                const piece = boardArray[r][c];
                if (!piece) continue;
                const file = FILES[c];
                const rank = 8 - r;
                const square = file + rank;
                const sq = document.querySelector(`.chess-sq[data-square="${square}"]`);
                if (!sq) continue;
                const span = document.createElement('span');
                span.className = 'chess-piece';
                span.innerHTML = PIECE_SVG[piece.color + piece.type];
                sq.appendChild(span);
            }
        }

        if (CS.lastMove) {
            [CS.lastMove.from, CS.lastMove.to].forEach(sqName => {
                const el = document.querySelector(`.chess-sq[data-square="${sqName}"]`);
                if (el) el.classList.add('last-move');
            });
        }
        if (CS.inCheck) {
            const el = document.querySelector(`.chess-sq[data-square="${CS.inCheck}"]`);
            if (el) el.classList.add('in-check');
        }

        if (CS.selectedSquare) {
            document.querySelector(`.chess-sq[data-square="${CS.selectedSquare}"]`)?.classList.add('selected');
            CS.legalTargets.forEach(sq => {
                const el = document.querySelector(`.chess-sq[data-square="${sq}"]`);
                if (!el) return;
                el.classList.add(el.querySelector('.chess-piece') ? 'legal-capture' : 'legal-move');
            });
        }
    }

    function chessSquareClick(square) {
        if (CS.gameOver) return;
        if (CS.turn !== CS.myColor) return;

        // Cooldown evaluation to reject ghost events from SL
        const now = Date.now();
        if (now - lastChessClickTime < 100) return;
        lastChessClickTime = now;

        if (CS.selectedSquare) {
            if (CS.selectedSquare === square) {
                clearSelection();
                return;
            }

            if (CS.legalTargets.includes(square)) {
                socket.emit('chess_move', { room: CS.room, from: CS.selectedSquare, to: square });
                CS.selectedSquare = null;
                CS.legalTargets = [];
                return;
            }
            
            // Only drop target if selecting an invalid/empty entity
            const piece = squarePieceAt(square);
            if (!piece || piece.color !== CS.myColor) {
                clearSelection();
                return;
            }
        }

        const piece = squarePieceAt(square);
        if (piece && piece.color === CS.myColor) {
            CS.selectedSquare = square;
            document.querySelector(`.chess-sq[data-square="${square}"]`)?.classList.add('selected');
            socket.emit('chess_get_moves', { room: CS.room, square });
        }
    }

    function squarePieceAt(square) {
        if (!CS.board) return null;
        const file = square[0], rank = parseInt(square[1]);
        const c = FILES.indexOf(file);
        const r = 8 - rank;
        return CS.board[r][c];
    }

    function clearSelection() {
        CS.selectedSquare = null;
        CS.legalTargets = [];
        document.querySelectorAll('.chess-sq').forEach(sq => sq.classList.remove('selected','legal-move','legal-capture'));
    }

    function showLegalMoves(moves) {
        CS.legalTargets = moves.map(m => m.to);
        moves.forEach(m => {
            const el = document.querySelector(`.chess-sq[data-square="${m.to}"]`);
            if (!el) return;
            el.classList.add(m.capture ? 'legal-capture' : 'legal-move');
        });
    }

    function formatClock(seconds) {
        if (seconds == null) return '--:--';
        const m = Math.floor(seconds / 60), s = Math.floor(seconds % 60);
        return m + ':' + (s < 10 ? '0' : '') + s;
    }

    function updateStatusBanner(text, type) {
        const el = $('chess-status-banner');
        el.textContent = text;
        el.className = 'chess-status-banner' + (type ? ' ' + type : '');
    }

    function renderMoveHistory(history) {
        const box = $('chess-move-history');
        box.innerHTML = '';
        for (let i = 0; i < history.length; i += 2) {
            const row = document.createElement('div');
            row.className = 'chess-move-row';
            row.innerHTML = `
                <span class="chess-move-num">${(i/2)+1}.</span>
                <span class="chess-move-white">${history[i] || ''}</span>
                <span class="chess-move-black">${history[i+1] || ''}</span>
            `;
            box.appendChild(row);
        }
        box.scrollTop = box.scrollHeight;
    }

    function renderCaptured(captured) {
        const meLine = $('chess-captured-by-me');
        const oppLine = $('chess-captured-by-opponent');
        const myCaps = (captured && captured[CS.myColor]) || [];
        const oppColor = CS.myColor === 'w' ? 'b' : 'w';
        const oppCaps = (captured && captured[oppColor]) || [];

        meLine.innerHTML = '<span class="chess-cap-label">Captured</span>' +
            myCaps.map(p => `<span class="chess-cap-piece">${PIECE_SVG[oppColor + p]}</span>`).join('');
        oppLine.innerHTML = '<span class="chess-cap-label">Captured</span>' +
            oppCaps.map(p => `<span class="chess-cap-piece">${PIECE_SVG[CS.myColor + p]}</span>`).join('');
    }

    // ── LOBBY ACTIONS ──
    window.chessCreateGame = function() {
        const name = $('chess-name-input').value.trim() || 'Player';
        CS.myName = name;
        $('chess-create-btn').disabled = true;
        $('chess-join-btn').disabled = true;
        $('chess-waiting-msg').style.display = 'flex';
        socket.emit('chess_create', { room: window.TV_ROOM || 'Lobby', name });
    };

    window.chessJoinGame = function() {
        const name = $('chess-name-input').value.trim() || 'Player';
        CS.myName = name;
        $('chess-create-btn').disabled = true;
        $('chess-join-btn').disabled = true;
        $('chess-waiting-msg').style.display = 'flex';
        socket.emit('chess_join_random', { room: window.TV_ROOM || 'Lobby', name });
    };

    window.chessOfferDraw = function() { socket.emit('chess_draw_offer', { room: CS.room }); };
    window.chessResign    = function() { if (confirm('Resign this game?')) socket.emit('chess_resign', { room: CS.room }); };
    window.chessRematch   = function() { socket.emit('chess_rematch', { room: CS.room }); };

    // ── PROMOTION DIALOG ──
    function showPromotionDialog(color, onChoose) {
        const overlay = $('chess-promo-overlay');
        const box = $('chess-promo-box');
        box.innerHTML = '';
        ['q','r','b','n'].forEach(p => {
            const div = document.createElement('div');
            div.className = 'chess-promo-piece';
            div.innerHTML = PIECE_SVG[color + p];
            div.onclick = () => { overlay.classList.remove('active'); onChoose(p); };
            box.appendChild(div);
        });
        overlay.classList.add('active');
    }

    // ── SOCKET EVENTS (guarded — only bind once) ──
    if (!socket.__chessBound) {
        socket.__chessBound = true;

        socket.on('chess_waiting', () => {
            updateStatusBanner('Waiting for opponent…');
        });
// Server forced a reset (triggered by either player exiting)
        socket.on('chess_force_lobby_reset', () => {
            // Call our cleanup routine, bypassing the emit step so we don't form a loop
            window.executeLocalUIReset();
        });
        socket.on('chess_game_start', (data) => {
            CS.room = data.room;
            CS.myColor = data.yourColor;
            CS.turn = 'w';
            CS.gameOver = false;
            CS.lastMove = null;
            CS.inCheck = null;

            $('chess-lobby').style.display = 'none';
            $('chess-game-area').classList.add('active');
            $('chess-rematch-btn').style.display = 'none';

            $('chess-my-name').textContent = CS.myColor === 'w' ? data.whiteName : data.blackName;
            $('chess-opponent-name').textContent = CS.myColor === 'w' ? data.blackName : data.whiteName;
            $('chess-my-color').textContent = CS.myColor === 'w' ? 'White' : 'Black';

            document.querySelector('#chess-card-me .chess-player-role').textContent = CS.myColor === 'w' ? 'White' : 'Black';
            document.querySelector('#chess-card-opponent .chess-player-role').textContent = CS.myColor === 'w' ? 'Black' : 'White';
            document.querySelector('#chess-card-me .chess-player-avatar').className = 'chess-player-avatar ' + (CS.myColor === 'w' ? 'white-side' : 'black-side');
            document.querySelector('#chess-card-me .chess-player-avatar').textContent = CS.myColor === 'w' ? '♔' : '♚';
            document.querySelector('#chess-card-opponent .chess-player-avatar').className = 'chess-player-avatar ' + (CS.myColor === 'w' ? 'black-side' : 'white-side');
            document.querySelector('#chess-card-opponent .chess-player-avatar').textContent = CS.myColor === 'w' ? '♚' : '♔';

            buildBoardDom();
            renderBoard(data.board);
            updateStatusBanner('White to move');
        });

        socket.on('chess_state', (data) => {
            CS.board = data.board;
            CS.turn = data.turn;
            CS.lastMove = data.lastMove;
            CS.inCheck = data.inCheckSquare || null;
            CS.gameOver = !!data.gameOver;

            renderBoard(data.board);
            renderMoveHistory(data.history || []);
            renderCaptured(data.captured || {});

            $('chess-my-clock').textContent = formatClock(CS.myColor === 'w' ? data.whiteTime : data.blackTime);
            $('chess-opponent-clock').textContent = formatClock(CS.myColor === 'w' ? data.blackTime : data.whiteTime);

            $('chess-card-me').classList.toggle('turn-active', data.turn === CS.myColor && !data.gameOver);
            $('chess-card-opponent').classList.toggle('turn-active', data.turn !== CS.myColor && !data.gameOver);

            if (data.gameOver) {
                $('chess-rematch-btn').style.display = 'block';
                let msg = 'Game Over';
                let type = 'win';
                if (data.result === 'checkmate') {
                    msg = (data.winner === CS.myColor ? 'You Win — Checkmate!' : 'You Lose — Checkmate');
                    type = data.winner === CS.myColor ? 'win' : 'danger';
                } else if (data.result === 'draw') { msg = 'Draw'; type = ''; }
                else if (data.result === 'resign') { msg = (data.winner === CS.myColor ? 'Opponent Resigned — You Win' : 'You Resigned'); type = data.winner === CS.myColor ? 'win' : 'danger'; }
                else if (data.result === 'stalemate') { msg = 'Stalemate — Draw'; type = ''; }
                updateStatusBanner(msg, type);
            } else if (CS.inCheck) {
                updateStatusBanner((data.turn === CS.myColor ? 'Check! Your move' : 'Opponent in Check'), 'danger');
            } else {
                updateStatusBanner((data.turn === CS.myColor ? 'Your move' : "Opponent's move"));
            }
        });

        socket.on('chess_legal_moves', (data) => {
            if (data.square !== CS.selectedSquare) return;
            showLegalMoves(data.moves || []);
        });

        socket.on('chess_promotion_needed', (data) => {
            showPromotionDialog(CS.myColor, (piece) => {
                socket.emit('chess_promote', { room: CS.room, from: data.from, to: data.to, promotion: piece });
            });
        });

        socket.on('chess_invalid_move', () => { clearSelection(); });

        socket.on('chess_draw_offered', () => {
            if (confirm('Your opponent offered a draw. Accept?')) {
                socket.emit('chess_draw_response', { room: CS.room, accepted: true });
            } else {
                socket.emit('chess_draw_response', { room: CS.room, accepted: false });
            }
        });

        socket.on('chess_opponent_left', () => {
            updateStatusBanner('Opponent disconnected', 'danger');
            CS.gameOver = true;
        });

        socket.on('chess_rematch_offer', () => {
            updateStatusBanner('Opponent wants a rematch — click Rematch to accept', '');
        });
    }

// This part runs locally and tells the server to blow up the room
    window.chessFullReset = function() {
        if (CS && CS.room) {
            socket.emit('chess_quit_room', { room: CS.room });
        } else {
            // If they weren't in a matched game yet, just clean up their local UI
            window.executeLocalUIReset();
        }
    };

    // This handles the dirty work of physically clearing elements and state tracking variables
    window.executeLocalUIReset = function() {
        // Clear out the persistent frontend state tracking object fields safely
        window.chessState = {
            room: null,
            myColor: null,
            myName: null,
            selectedSquare: null,
            legalTargets: [],
            board: null,
            turn: 'w',
            lastMove: null,
            inCheck: null,
            gameOver: false
        };
        
        // Update our let reference alias 
        CS = window.chessState;

        // Reset the UI containers back to the initial Lobby screen layout
        if ($('chess-lobby')) $('chess-lobby').style.display = 'flex';
        if ($('chess-game-area')) $('chess-game-area').classList.remove('active');
        if ($('chess-waiting-msg')) $('chess-waiting-msg').style.display = 'none';
        
        if ($('chess-create-btn')) $('chess-create-btn').disabled = false;
        if ($('chess-join-btn')) $('chess-join-btn').disabled = false;
        if ($('chess-name-input')) $('chess-name-input').value = '';

        // Clean out data containers, boards, histories, and clocks
        if ($('chess-board')) $('chess-board').innerHTML = '';
        if ($('chess-move-history')) $('chess-move-history').innerHTML = '';
        
        if ($('chess-status-banner')) {
            $('chess-status-banner').textContent = 'White to move';
            $('chess-status-banner').className = 'chess-status-banner';
        }
        
        if ($('chess-my-clock')) $('chess-my-clock').textContent = '10:00';
        if ($('chess-opponent-clock')) $('chess-opponent-clock').textContent = '10:00';
        if ($('chess-my-color')) $('chess-my-color').textContent = '—';
        if ($('chess-my-name')) $('chess-my-name').textContent = 'You';
        if ($('chess-opponent-name')) $('chess-opponent-name').textContent = 'Opponent';
        
        if ($('chess-captured-by-me')) $('chess-captured-by-me').innerHTML = '<span class="chess-cap-label">Captured</span>';
        if ($('chess-captured-by-opponent')) $('chess-captured-by-opponent').innerHTML = '<span class="chess-cap-label">Captured</span>';
    };

// ── RE-ENTRY (returning to this menu without full reload) ──
    window.chessReEnter = function() {
        if (CS.room && CS.board) {
            $('chess-lobby').style.display = 'none';
            $('chess-game-area').classList.add('active');
            buildBoardDom();
            renderBoard(CS.board);
        }
    };
    window.chessReEnter();

})();
</script>