<!-- views/pages/games/tv-clip-games-fragment.ejs -->
<style>
    #player-module-wrapper {
        width: 1280px; height: 720px;
        background: #000; position: relative;
        overflow: hidden; font-family: 'Fira Sans', sans-serif;
    }

    .player-container {
        position: absolute; inset: 0;
        z-index: 10; background: #191c17;
    }

    #game-iframe {
        width: 100%; height: 100%;
        border: none;
    }

    /* Red Menu Trigger Button */
    #menu-trigger-dot {
        position: absolute; top: 8px; right: 30px;
        width: 25px; height: 25px;
        background: #ff4444; border-radius: 50%;
        z-index: 100; cursor: pointer;
        opacity: 0.6; transition: opacity 0.3s;
        border: 2px solid white;
    }
    #menu-trigger-dot:hover { opacity: 1; }

    /* Instructions Overlay */
    #instructions-overlay {
        position: absolute; inset: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 200; display: none;
        flex-direction: column; align-items: center;
        justify-content: center; padding: 40px;
        text-align: center;
    }

    #instructions-overlay.visible { display: flex; }

    .inst-title { color: #daa520; font-size: 32px; margin-bottom: 20px; letter-spacing: 2px; }
    .inst-text { color: #ccc; font-size: 18px; margin: 8px 0; max-width: 900px; }
    
    .player-controls-row {
        margin-top: 40px; display: flex; gap: 20px;
    }

    .player-btn {
        background: #0b5b5b; border: 2px solid #9acd32;
        color: white; padding: 12px 30px; border-radius: 10px;
        font-size: 20px; cursor: pointer; text-transform: uppercase;
    }
    .player-btn:hover { background: #9acd32; color: #000; }
</style>

<div id="player-module-wrapper">
    <!-- The Game -->
    <div class="player-container">
        <iframe id="game-iframe" src="about:blank"></iframe>
    </div>

    <!-- Hidden Red Button to show instructions -->
    <div id="menu-trigger-dot" onclick="togglePlayerInstructions(true)"></div>

    <!-- Instructions & Navigation Overlay -->
    <div id="instructions-overlay" onclick="togglePlayerInstructions(false)">
        <h1 class="inst-title">INSTRUCTIONS</h1>
        <p class="inst-text">Games may take some time to load. Not all games are guaranteed to work.</p>
        <p class="inst-text">If a game freezes, use the red button at the top-right to return here.</p>
        <p class="inst-text">Click anywhere on the screen to hide these instructions and resume play.</p>

        <div class="player-controls-row" onclick="event.stopPropagation()">
            <button class="player-btn" onclick="handleNav('clip-games')">Back to List</button>
            <button class="player-btn" onclick="closeSubMenu()">Exit to TV</button>
        </div>
    </div>
</div>

<script>
(function() {
    // 1. Tentar obter o URL do jogo de várias formas
    const fullUrl = window.currentAjaxPath || window.location.search;
    const urlParams = new URLSearchParams(fullUrl.includes('?') ? fullUrl.split('?')[1] : fullUrl);
    let gameUrl = urlParams.get('videoId');

    // 2. Se falhar, tentamos extrair manualmente da string
    if (!gameUrl && fullUrl.includes('videoId=')) {
        gameUrl = fullUrl.split('videoId=')[1].split('&')[0];
    }

    const iframe = document.getElementById('game-iframe');
    
    if (gameUrl && iframe) {
        const decodedUrl = decodeURIComponent(gameUrl);
        console.log("Iniciando Jogo:", decodedUrl);
        iframe.src = decodedUrl;
    } else {
        console.error("Erro: videoId não encontrado no URL", fullUrl);
    }

    // Função de Overlay
    window.togglePlayerInstructions = function(show) {
        const overlay = document.getElementById('instructions-overlay');
        if (overlay) {
            show ? overlay.classList.add('visible') : overlay.classList.remove('visible');
        }
    };

    setTimeout(() => togglePlayerInstructions(false), 4000);
})();
</script>