<style>
/* ── MAIN LAYOUT ── */
#clips-wrapper { 
    width: 1280px; height: 720px;
    font-family: 'Fira Sans', sans-serif;
    display: flex; flex-direction: column; 
    overflow: hidden; position: relative;
}

#clips-nav {
    width: 100%; height: 57px;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 35px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
    z-index: 100; flex-shrink: 0; box-sizing: border-box;
    
}

.nav-group { display: flex; gap: 15px; align-items: center; }


/* ── GRID ── */
#clips-grid {
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: 15px; width: 1235px; margin-left: 15px;
    padding: 2px 20px 20px; box-sizing: border-box;
    overflow-y: auto;
}
#clips-grid::-webkit-scrollbar { width: 12px; }
#clips-grid::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
#clips-grid::-webkit-scrollbar-thumb { 
    background: rgb(224, 81, 24); 
    border-radius: 10px; 
}

.game-card {
    position: relative;
    background:rgba(0, 0, 0, 0.4); border: 2px solid rgba(255,255,255,0.08);
    border-radius: 0px; padding: 1px; cursor: pointer;
    display: flex; flex-direction: column; align-items: center;
    transition: transform 0.2s;
}
.game-card:hover { 
    transform: translateY(-2px) scale(1.01);
    border: 2px solid rgb(249, 184, 20);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05)); 
}
        
.game-card.remote-hover { 
     transform: translateY(-2px) scale(1.01);
    border: 2px solid rgb(249, 184, 20);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05)); 
}
/* Overlay to darken images */


.game-media { width: 100%; height: 120px; background: #111; border-radius: 0px; overflow: hidden; }
.game-thumbnail { width: 100%; height: 100%; object-fit: cover; opacity: 0.9; }
.game-name { font-size: 0.8rem; text-transform: uppercase; color: #fff; margin: 10px 0; }



/* ── CENTERING THE TITLE ── */
.active-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.0rem;
    letter-spacing: 3px;
    opacity: 0.6;
    pointer-events: none; /* Allows clicking through if needed */
}
/* ── UPDATED MODAL LAYOUT ── */
#category-modal {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(10, 10, 10, 0.95); display: none;
    justify-content: center; align-items: center; z-index: 2000;
}

.modal-content {
    background: rgba(20, 20, 20, 0.9); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px; padding: 40px; width: 800px; /* Wider for 4 columns */
    box-shadow: 0 20px 50px rgba(0,0,0,0.8);
}

.modal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4-column structure */
    gap: 12px;
    margin-top: 25px;
}

.modal-btn {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ccc; padding: 12px 15px; border-radius: 8px;
    cursor: pointer; text-align: left; font-size: 0.85rem;
    transition: all 0.2s;
    display: flex; justify-content: space-between; align-items: center;
}

.modal-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
}

/* Icon placeholder mimicking your reference */
.modal-btn::after {
    content: "📷"; font-size: 0.7rem; opacity: 0.4;
}
</style>

<div id="clips-wrapper">
<nav id="clips-nav">

            <div style="margin-right: 24px!important;margin-top:2px;">
                <button class="ltv-nav-btn" onclick="openCategoryModal()">
                <span class="material-symbols-rounded" style="font-size:25px!important; vertical-align:middle;">menu</span>
                </button>
            </div>

               <span id="active-label">PUZZLE</span>

            <div style="margin-right: 24px!important;margin-top:2px;">
                <button class="ltv-back-btn" onclick="closeSubMenu()">
                <span class="material-symbols-rounded" style="font-size:25px!important; vertical-align:middle;">close</span>
               </button>
            </div>




</nav>
    <div id="clips-grid"></div>
</div>

<div id="category-modal">
    <div class="modal-content">
        <h3 style="text-align: left; margin: 0; color: #fff; letter-spacing: 2px;">SELECT CATEGORY</h3>
        <div class="modal-grid">

            <button class="modal-btn" onclick="loadCategory('rand')">Mix Selection</button>
            <button class="modal-btn" onclick="loadCategory('puzzle')">Puzzle</button>
            <button class="modal-btn" onclick="loadCategory('strategy')">Strategy</button>
            <button class="modal-btn" onclick="loadCategory('action')">Action</button>

            <button class="modal-btn" onclick="loadCategory('card')">Card</button>
            <button class="modal-btn" onclick="loadCategory('escape')">Escape</button>
            <button class="modal-btn" onclick="loadCategory('math')">Math</button>
            <button class="modal-btn" onclick="loadCategory('arcade')">Arcade</button>


            <button class="modal-btn" onclick="loadCategory('sports')">Sports</button>
            <button class="modal-btn" onclick="loadCategory('avoider')">Avoider</button>
            <button class="modal-btn" onclick="loadCategory('war')">War</button>
            <button class="modal-btn" onclick="loadCategory('clicker')">Clicker</button>

        </div>
        <button class="cancel-btn" onclick="closeModal()" style="margin-top: 30px;">Close</button>
    </div>
</div>

<script>
window.isFetching = window.isFetching || false;

// ── BROADCAST MODAL STATE ──
function openCategoryModal() { 
    document.getElementById('category-modal').style.display = 'flex'; 
    if (window.socket && window.myRoom) {
        window.socket.emit('state_sync', { type: 'modal_toggle', open: true, room: window.myRoom });
    }
}

function closeModal() { 
    document.getElementById('category-modal').style.display = 'none'; 
    if (window.socket && window.myRoom) {
        window.socket.emit('state_sync', { type: 'modal_toggle', open: false, room: window.myRoom });
    }
}
window.handleImageError = (img) => { img.parentElement.innerHTML = '<div style="font-size:2rem; padding-top:40px;">🎮</div>'; };

// ── BROADCAST CATEGORY LOAD ──
window.loadCategory = function(fileName, isSync = false) {
    closeModal();
    if (window.isFetching) return;
    
    // If this is a sync call from another user, don't re-emit
    if (!isSync && window.socket && window.myRoom) {
        window.socket.emit('state_sync', { type: 'load_category', category: fileName, room: window.myRoom });
    }

    window.isFetching = true;
    $('#active-label').text('LOADING...');
    
    fetch('/games/clip-games/' + fileName)
        .then(res => res.json())
        .then(data => {
            renderGrid(data, fileName);
            $('#active-label').text(fileName.toUpperCase());
            window.isFetching = false;
        })
        .catch(err => { $('#active-label').text('ERROR'); window.isFetching = false; });
};

function renderGrid(games, categoryName) {
    const grid = $('#clips-grid');
    const html = games.map(game => `
        <div class="game-card" onclick="sendToPlayer('${game.url}')">
            <div class="game-media">
                ${game.thumb ? `<img src="${game.thumb}" class="game-thumbnail" onerror="handleImageError(this)">` : '🎮'}
            </div>
            <div class="game-name">${game.title}</div>
        </div>
    `).join('');
    grid.html(html).scrollTop(0);
}

// ── SOCKET LISTENER (Put this in your main app script) ──
if (window.socket) {
    window.socket.on('state_sync', (data) => {
        // Sync Modal
        if (data.type === 'modal_toggle') {
            document.getElementById('category-modal').style.display = data.open ? 'flex' : 'none';
        }
        
        // Sync Category Loading
        if (data.type === 'load_category') {
            window.loadCategory(data.category, true); // true = don't emit back
        }

        // NEW: Sync Scroll
        if (data.type === 'scroll') {
            window.isSyncing = true; // Flag to tell the listener above not to re-emit
            const grid = $('#clips-grid');
            if (grid) {
                grid.scrollTop(data.position);
            }
            // Reset the flag shortly after
            setTimeout(() => { window.isSyncing = false; }, 100);
        }
    });
}
//// SCROOL LISTENER
// ── SYNC SCROLL POSITION ──
$('#clips-grid').on('scroll', function() {
    // Prevent sync loop (if this scroll was caused by a socket update, ignore it)
    if (window.isSyncing) return;
    
    if (window.socket && window.myRoom) {
        window.socket.emit('state_sync', { 
            type: 'scroll', 
            position: $(this).scrollTop(), 
            room: window.myRoom 
        });
    }
});


window.sendToPlayer = (url) => { handleNav(`tv-clip-games?videoId=${encodeURIComponent(url)}`); };

$(document).ready(() => { window.loadCategory('puzzle'); });
</script>