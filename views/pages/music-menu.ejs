<style>
    /* 1. Wrapper to activate the Blue/Music Theme */
    #music-menu-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 800px;
        animation: fadeIn 0.4s ease-out;
    }

    /* 2. The Circular Close Button (Top Right) */
    #music-menu-wrapper .close-btn {
        position: absolute;
        top: -10px;
        right: 0px;
        width: 50px;
        height: 50px;
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid #00d4ff; /* Music Accent Color */
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #music-menu-wrapper .close-btn:hover, 
    #music-menu-wrapper .close-btn:focus {
        background: #00d4ff;
        color: black;
        transform: scale(1.1) rotate(90deg);
        box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
    }

    /* 3. Title Styling */
    #music-menu-wrapper #title {
        font-size: 30px;
        color: #00d4ff;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Grid Container - 2 Columns */
    #music-menu-wrapper .conteiner {
        display: grid !important;
        grid-template-columns: 2fr 1fr !important; /* Larger main button, smaller list button */
        gap: 12px !important;
        width: 100% !important;
        max-height: 480px;
        overflow-y: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 20px;
        border: 1px solid rgba(0, 212, 255, 0.1);
    }

    /* 5. Music Button Styling */
    #music-menu-wrapper .btn {
        background: rgba(0, 212, 255, 0.1) !important;
        border: 1px solid rgba(0, 212, 255, 0.3) !important;
        border-radius: 12px;
        padding: 22px 15px !important;
        font-size: 20px;
        color: white !important;
        text-align: center;
        display: flex !important;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    /* Special style for "Lists" buttons to make them look distinct */
    #music-menu-wrapper .list-btn {
        background: rgba(255, 255, 255, 0.05) !important;
        font-size: 16px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    #music-menu-wrapper .btn:focus, 
    #music-menu-wrapper .btn:hover {
        background: #00d4ff !important;
        color: #000 !important;
        transform: scale(1.03);
        outline: none;
        box-shadow: 0 5px 15px rgba(0, 212, 255, 0.3);
    }

    /* 6. Full-Width Override for single items */
    .full-row {
        grid-column: span 2;
    }

    /* Hide scrollbar */
    #music-menu-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div id="music-menu-wrapper">
    
    <button class="close-btn" onclick="closeSubMenu()" tabindex="50">
        <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <div id="title">Music Menu</div>

    <div class="conteiner">
        <div data-type="music" data-mode="concerts" class="btn full-row" tabindex="1">Live Concerts</div>  
        <div data-type="music" data-mode="full" class="btn full-row" tabindex="2">Full Albums</div>  

        <div data-type="music" data-mode="blues" class="btn" tabindex="3">Blues</div> 
        <div data-type="music" data-mode="blues_list" class="btn list-btn" tabindex="4">Lists</div>

        <div data-type="music" data-mode="jazz" class="btn" tabindex="5">Jazz</div> 
        <div data-type="music" data-mode="jazz_list" class="btn list-btn" tabindex="6">Lists</div>
            
        <div data-type="music" data-mode="classic" class="btn" tabindex="7">Classic Music</div> 
        <div data-type="music" data-mode="classic_list" class="btn list-btn" tabindex="8">Lists</div>

        <div data-type="music" data-mode="relax" class="btn" tabindex="9">Relax Music</div> 
        <div data-type="music" data-mode="relax_list" class="btn list-btn" tabindex="10">Lists</div>

        <div data-type="music" data-mode="pmb" class="btn" tabindex="11">PMB Music</div> 
        <div data-type="music" data-mode="pmb_list" class="btn list-btn" tabindex="12">Lists</div>

        <div data-type="music" data-mode="boiler" class="btn" tabindex="13">Boiler Room</div> 
        <div data-type="music" data-mode="boiler_list" class="btn list-btn" tabindex="14">Lists</div>

        <div data-type="music" data-mode="majestic" class="btn" tabindex="15">Majestic Casual</div> 
        <div data-type="music" data-mode="majestic_list" class="btn list-btn" tabindex="16">Lists</div>

        <div data-type="music" data-mode="love" class="btn" style="grid-column: span 1;" tabindex="17">Love Songs</div> 
        <div data-type="music" data-mode="slowrock" class="btn" tabindex="18">Slow Rock</div> 
        <div data-type="music" data-mode="rap" class="btn full-row" tabindex="19">RAP Fight</div> 
    </div>

</div>