<style>
/* ============================================================
   MUSIC DISCOVERY - PREMIUM TV INTERFACE
   ============================================================ */

#music-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20, 20, 20, 0.6), rgba(0, 0, 0, 0.5));
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
    margin: 20px auto;
    position: relative; /* Essential for the close button positioning */
}

#music-menu-wrapper .music-header {
    font-family: 'Segoe UI', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 10px;
    margin-bottom: 35px;
    opacity: 0.9;
}

.music-grid-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr); 
    gap: 20px;
    width: 100%;
}

.feature-row {
    grid-column: span 5;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.feature-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.4); /* Softened from 0.8 */
    padding: 22px;
    border-radius: 15px;
    color: white;
    text-align: center;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s ease;
}

.feature-btn:hover { background: white; color: black; border-color: white; }

.music-group {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
}

.music-group:hover {
    transform: translateY(-5px); /* Changed from 0px to create a lift effect */
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 255, 255, 0.4);
}

.main-genre-btn {
    font-size: 1.4rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.main-genre-btn1 {
    font-size: 0.75rem;
    font-weight: 400;
    padding: 5px 15px;
    border-radius: 50px;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.15);
    letter-spacing: 1px;
    transition: all 0.3s ease;
}

/* Energy Colors */
.energy-high { border-color: rgba(255, 75, 43, 0.4); }
.energy-high .main-genre-btn { color: #ff4b2b; }
.energy-high .main-genre-btn1 { color: #ff4b2b; border-color: rgba(255, 75, 43, 0.6); }
.energy-high .main-genre-btn1:hover { background: #ff4b2b; color: white; }

.energy-chill { border-color: rgba(0, 212, 255, 0.4); }
.energy-chill .main-genre-btn { color: #00d4ff; }
.energy-chill .main-genre-btn1 { color: #00d4ff; border-color: rgba(0, 212, 255, 0.6); }
.energy-chill .main-genre-btn1:hover { background: #00d4ff; color: white; }

.energy-smooth { border-color: rgba(255, 179, 71, 0.4); }
.energy-smooth .main-genre-btn { color: #ffb347; }
.energy-smooth .main-genre-btn1 { color: #ffb347; border-color: rgba(255, 179, 71, 0.6); }
.energy-smooth .main-genre-btn1:hover { background: #ffb347; color: white; }

.energy-soul { border-color: rgba(189, 0, 255, 0.4); }
.energy-soul .main-genre-btn { color: #d385ee; }
.energy-soul .main-genre-btn1 { color: #d385ee; border-color: rgba(189, 0, 255, 0.6); }
.energy-soul .main-genre-btn1:hover { background: #d385ee; color: white; }

.close-menu-btn {
    position: absolute;
    top: 25px;
    right: 25px;
    width: 45px;
    height: 45px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
    z-index: 10;
}

.close-menu-btn:hover {
    background: #ff4b2b;
    border-color: #ff4b2b;
    transform: scale(1.1);
}
</style>

