<style>
/* 1. Ajuste do Container Principal */
.tv-screen {
    width: 1280px;
    height: 720px;
    color: #fff;
    font-family: 'Segoe UI', Roboto, sans-serif;
    display: flex;         
    flex-direction: column; 
    overflow: hidden;      
    position: relative;
 
}

/* 2. BARRA DE NAVEGAÇÃO COM FADE (Preto para Transparente) */
.top-nav {
    width: 100%;
    height: 60px; /* Um pouco maior para suavizar o fade */
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 60px;
    /* Efeito de Fade Moderno */
    background: linear-gradient(to bottom, 
        rgba(0, 0, 0, 1) 0%, 
        rgba(0, 0, 0, 0.5) 80%, 
        rgba(0, 0, 0, 0) 100%
    );
    z-index: 100;
    flex-shrink: 0; 
    box-sizing: border-box;
}

/* 3. ÁREA DE CONTEÚDO (Scroll começa abaixo do nav) */
.content-wrapper { 
    flex-grow: 1;      
    overflow-y: auto;  
    overflow-x: hidden; 
    padding: 7px 23px; 
    box-sizing: border-box;
    width: 1230px;
    margin-left: 25px;
}

/* 4. ESTILIZAÇÃO DA BARRA DE ROLAGEM (Red YouTube Style) */
.content-wrapper::-webkit-scrollbar {
    width: 15px;
}

.content-wrapper::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
}

.content-wrapper::-webkit-scrollbar-thumb {
    background: #ff0000; 
    border-radius: 10px;
    border: 2px solid rgba(0, 0, 0, 0.2);
}

/* --- ESTILOS ORIGINAIS --- */
.page-title {
    margin: 0;
    font-size: 1.5rem;
    letter-spacing: 1px;
    color: #00d4ff;
    font-weight: 400;
    text-transform: uppercase;
}

.back-button {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    padding: 5px 25px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 400;
    transition: 0.3s;
    font-size: 16px;
}

.back-button:hover {
    background: #00d4ff;
    color: #000;
    border-color: #00d4ff;
}

.grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.card {
    background: #161616a3;
    border-radius: 0px;
    overflow: hidden;
    cursor: pointer;
    border: none; /* remove border entirely */
    outline: 1px solid white; /* use outline instead */
    will-change: transform;
    -webkit-font-smoothing: antialiased;
    transform: translateZ(0);
}

.card:hover {
    transform: scale(1.0);
    outline: 2px solid #fffb00; /* grows outside, never touches image */
}

.card-media { position: relative; aspect-ratio: 16/9; }
.card-media img { width: 100%; height: 100%; object-fit: cover; }

.play-hint {
    position: absolute;
    inset: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: 0.2s;
}

.play-hint {
    position: absolute;
    inset: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: 0.2s;
}

.card:hover .play-hint { opacity: 1; }

.card:hover .play-hint i {
    transform: scale(1); /* subtle grow on hover */
}
.card-info { padding: 5px 15px; }
.title {
    font-size: 0.9rem;
    margin: 4px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 400;
}

.subtitle {
    font-size: 14px;
    color: #ffd700;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0;
    letter-spacing: 1.04px;
}
.badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 10;
}

.badge.music   { background: #00d4ff; color: #000; }
.badge.movies  { background: #ff4b2b; color: #fff; }
.badge.youtube { background: #ff0000; color: #fff; }


.card.remote-hover {
    transform: scale(1.02);
    outline: 2px solid #fffb00;
}

.card.remote-hover .play-hint {
    opacity: 1;
}
</style>

<div class="tv-screen">
    <div class="top-nav">
        <h1 class="page-title"><%= title %></h1>
        <button class="back-button" onclick="goBackToMenu()">
            <i class="fas fa-chevron-left"></i> BACK
        </button>
    </div>

    <div class="content-wrapper" id="grid-content">
        <div class="grid-3">
            <% results.forEach(item => { %>
                <div class="card" onclick="playMedia('<%= item.id %>', '<%= type %>')">
<div class="card-media">
    <img src="<%= item.thumbnail %>" loading="lazy">

<div class="play-hint">
    <svg viewBox="0 0 24 24" width="56" height="56">
        <circle cx="12" cy="12" r="12" fill="rgba(0,212,255,0.85)"/>
        <polygon points="9,7 19,12 9,17" fill="white"/>
    </svg>
</div>

    <% if (item.badge) { %>
        <span class="badge <%= type %>"><%= item.badge %></span>
    <% } %>
</div>
<div class="card-info">
    <p class="subtitle"><%= item.subtitle %></p>
    <h3 class="title"><%= item.title %></h3>
</div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
function goBackToMenu() {
    const serverMenu = "<%= typeof menu !== 'undefined' ? menu : '' %>";
    const type = "<%= type %>";
    
    if (serverMenu) {
        handleNav(serverMenu);
    } else {
        handleNav(type === 'movies' ? '/movies-menu' : '/music-menu');
    }
}

function playMedia(id) {
    const container = document.getElementById('grid-content');
    const scroll = container ? container.scrollTop : 0;
    
    const query = "<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>";
    const menu  = "<%= typeof menu !== 'undefined' ? menu : '' %>";

    const url = `/tvytube?videoId=${id}&origin=grid&targetID=${encodeURIComponent(query)}&menu=${encodeURIComponent(menu)}&scrollPos=${scroll}`;
    handleNav(url);
}

var scrollContainer = document.getElementById('grid-content');

// Restore scroll position on load

scrollContainer.addEventListener('scroll', function() {
    if (window.isSyncing) return; // ← this must be here
    if (window.socket && window.socket.connected) {
        socket.emit('state_sync', {
            type: 'scroll',
            position: this.scrollTop,
            room: window.myRoom
        });
    }
});

(function() {
    const savedScroll = parseInt('<%= typeof scrollPos !== "undefined" ? scrollPos : 0 %>') || 0;

    if (savedScroll > 0) {
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                const container = document.getElementById('grid-content');
                if (container) {
                    container.scrollTop = savedScroll;

                    // Broadcast to other viewers
                    if (window.socket && window.socket.connected) {
                        socket.emit('state_sync', {
                            type: 'scroll',
                            position: savedScroll,
                            room: window.myRoom
                        });
                    }
                }
            });
        });
    }
})();
</script>