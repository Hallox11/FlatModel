
<style>
/* Container set to your fixed resolution */
.tv-screen {
    width: 1280px;
    height: 720px;
    background: #050505;
    color: #fff;
    font-family: 'Segoe UI', Roboto, sans-serif;
    overflow-y: auto;
    position: relative;
}

/* Fixed Header */
.top-nav {
    position: sticky;
    top: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 60px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
    z-index: 100;
}

.page-title {
    margin: 0;
    font-size: 1.8rem;
    letter-spacing: 1px;
    color: #00d4ff;
    font-weight: 400;
    text-transform: uppercase;
}

.back-button {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    padding: 10px 25px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    backdrop-filter: blur(5px);
}

.back-button:hover {
    background: #00d4ff;
    color: #000;
}

/* Grid Layout */
.content-wrapper { 
    padding: 0px 50px 50px 50px; 
}

.grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
}

/* Card Design */
.card {
    background: #111;
    border-radius: 8px;
    overflow: hidden;
    transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: 1px solid #f6f6f6;
}

.card:hover {
    transform: translateY(-10px);
    border-color: #00d4ff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.8);
}

.card-media {
    position: relative;
    aspect-ratio: 16/9;
}

.card-media img { width: 100%; height: 100%; object-fit: cover; }

/* The "Play" Overlay */
.play-hint {
    position: absolute;
    inset: 0;
    background: rgba(0, 212, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: 0.2s;
}

.card:hover .play-hint { opacity: 1; }
.play-hint i {
     font-size: 3rem;
      color: #fff; 
      text-shadow: 0 0 20px rgba(0,0,0,0.5); }

/* Text Info */
.card-info { padding: 5px 15px; }

.title {
    font-size: 1.0rem;
    margin: 4px 0 4px 0;
    font-weight: 400;
    white-space: nowrap;
    overflow: hidden;
    letter-spacing: 1.2px;
    text-overflow: ellipsis;
}

.subtitle {
    font-size: 0.85rem;
    color: yellow;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0;
}

.badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: red;
    color: #fff;
    padding: 3px 8px;
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: 3px;
}

/* Duration Label */
.duration-label {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    padding: 2px 6px;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    z-index: 10;
}
</style>
<div class="tv-screen" id="grid-content">
    <div class="top-nav">
        <h1 class="page-title"><%= title %></h1>

<button class="back-button" onclick="goBackToMenu()">
    <i class="fas fa-chevron-left"></i> BACK
</button>


    </div>

    <div class="content-wrapper">
        <div class="grid-3">
            <% results.forEach(item => { %>
                <div class="card" onclick="playMedia('<%= item.id %>', '<%= type %>')">
                    <div class="card-media">
                        <img src="<%= item.thumbnail %>" loading="lazy">
                        <% if (item.badge) { %><span class="badge"><%= item.badge %></span><% } %>
                        <div class="play-hint"><i class="fas fa-play"></i></div>
                    </div>
                    <div class="card-info">
                        <p class="subtitle"><%= item.subtitle %></p>
                        <h3 class="title"><%= item.title %></h3>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
function goBackToMenu() {
    // Tenta usar a variável vinda do servidor, se não existir, usa o type para decidir
    const serverMenu = "<%= typeof menu !== 'undefined' ? menu : '' %>";
    const type = "<%= type %>";
    
    if (serverMenu) {
        handleNav(serverMenu);
    } else {
        handleNav(type === 'movies' ? '/movies-menu' : '/music-menu');
    }
}

function playMedia(id) {
    const container = document.getElementById('grid-content');
    const scroll = container ? container.scrollTop : 0;
    
    const query = "<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>";  // ← already in your original code!
    const menu  = "<%= typeof menu !== 'undefined' ? menu : '' %>";               // ← add this

    const url = `/tvytube?videoId=${id}&origin=grid&targetID=${encodeURIComponent(query)}&menu=${encodeURIComponent(menu)}&scrollPos=${scroll}`;
    handleNav(url);
}
// --- SCROLL SYNC ---
// Change the ID from 'yt-module' to 'yt-content-scroll'
var scrollContainer = document.getElementById('grid-content');

scrollContainer.addEventListener('scroll', function() {
    if (window.isSyncing) return;
    
    if (window.socket && window.socket.connected) {
        socket.emit('state_sync', {
            type: 'scroll',
            position: this.scrollTop,
            room: window.myRoom
        });
    }
});
</script>