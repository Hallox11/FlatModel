<style>
/* ── GAME STREAM FRAGMENT ─────────────────────────── */
#game-stream-module {
    width: 1280px; height: 720px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    font-family: 'Fira Sans', sans-serif;
    color: white;
}

/* ── CLOSE BUTTON ─────────────────────────────────── */
#gs-close-btn {
    position: absolute; top: 20px; left: 20px;
    background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(0,0,0,0.7));
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 12px; color: white;
    padding: 8px 16px; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 1px;
    display: flex; align-items: center; gap: 8px;
    cursor: pointer; transition: all 0.2s ease;
    z-index: 200;
}
#gs-close-btn:hover { background: rgba(0,0,0,0.9); border-color: rgba(255,255,255,0.5); }

/* ── ROLE SELECTOR ────────────────────────────────── */
#gs-role-selector {
    display: flex; flex-direction: column;
    align-items: center; gap: 30px;
    animation: fadeInUp 0.4s ease;
}
#gs-role-selector h2 {
    font-size: 1.4rem; font-weight: 200;
    letter-spacing: 4px; text-transform: uppercase;
    opacity: 0.8; margin: 0;
}
.gs-role-btns { display: flex; gap: 20px; }

.gs-role-btn {
    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.03));
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.15);
    border-top-color: rgba(255,255,255,0.3);
    border-radius: 14px; padding: 35px 50px;
    color: white; cursor: pointer;
    text-align: center; min-width: 220px;
    transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.gs-role-btn:hover {
    transform: scale(1.07);
    border-color: white;
    background: rgba(0,0,0,0.5);
}
.gs-role-btn .gs-icon {
    font-size: 2.5rem; margin-bottom: 12px;
    display: block;
}
.gs-role-btn .gs-label {
    font-size: 1.1rem; text-transform: uppercase;
    letter-spacing: 2px; display: block;
}
.gs-role-btn .gs-desc {
    font-size: 0.75rem; opacity: 0.6;
    margin-top: 6px; display: block;
}

/* ── STREAMER UI ──────────────────────────────────── */
#gs-streamer-ui, #gs-viewer-ui {
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    width: 100%; height: 100%;
    animation: fadeInUp 0.4s ease;
}

/* External link panel (streamer) */
#gs-extlink-panel {
    display: flex; flex-direction: column;
    align-items: center; gap: 18px;
    text-align: center;
}
.gs-extlink-icon {
    font-size: 3rem; opacity: 0.35; margin-bottom: 4px;
}
.gs-extlink-title {
    font-size: 1.1rem; font-weight: 400;
    letter-spacing: 2px; text-transform: uppercase; margin: 0;
}
.gs-extlink-sub {
    font-size: 0.78rem; opacity: 0.5; letter-spacing: 1px;
    max-width: 460px; line-height: 1.7; margin: 0;
}
#gs-open-browser-btn {
    background: linear-gradient(135deg, rgba(46,204,113,0.3), rgba(46,204,113,0.1));
    border: 1px solid rgba(46,204,113,0.5);
    border-radius: 12px; padding: 14px 36px;
    color: white; cursor: pointer;
    font-family: 'Fira Sans', sans-serif;
    font-size: 0.9rem; text-transform: uppercase;
    letter-spacing: 2px; transition: all 0.2s ease;
    display: flex; align-items: center; gap: 10px;
}
#gs-open-browser-btn:hover {
    background: rgba(46,204,113,0.4);
    border-color: #2ecc71; transform: scale(1.03);
}
#gs-extlink-url {
    font-size: 0.62rem; opacity: 0.2;
    letter-spacing: 1px; word-break: break-all; max-width: 500px;
}
#gs-waiting-stream-msg {
    display: none; align-items: center; gap: 10px;
    font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 2px; opacity: 0.5; margin-top: 4px;
}
.gs-spinner-small {
    width: 16px; height: 16px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.15);
    border-top-color: rgba(255,255,255,0.6);
    animation: spin 1s linear infinite; flex-shrink: 0;
}

/* Remote video (viewer) */
#gs-remote-video {
    width: 1280px; height: 720px;
    object-fit: contain; background: #000;
    position: absolute; inset: 0;
}

/* ── STATUS BAR ───────────────────────────────────── */
#gs-status-bar {
    position: absolute; bottom: 28px; left: 50%;
    transform: translateX(-50%);
    display: flex; align-items: center; gap: 14px;
    background: linear-gradient(135deg, rgba(0,0,0,0.6), rgba(0,0,0,0.8));
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50px; padding: 10px 24px;
    font-size: 0.85rem; letter-spacing: 1px;
    z-index: 150;
}

#gs-status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #666; transition: background 0.3s;
}
#gs-status-dot.live { background: #e74c3c; box-shadow: 0 0 8px #e74c3c; animation: pulse 1.5s infinite; }
#gs-status-dot.connecting { background: #f39c12; }
#gs-status-dot.waiting { background: #3498db; }

#gs-status-text { text-transform: uppercase; letter-spacing: 2px; opacity: 0.9; }

/* ── UNMUTE BUTTON ────────────────────────────────── */
#gs-unmute-btn {
    position: absolute; bottom: 90px; right: 30px;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px; padding: 10px 20px;
    color: white; cursor: pointer; font-family: 'Fira Sans', sans-serif;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;
    display: none; z-index: 200;
    transition: all 0.2s ease;
}
#gs-unmute-btn:hover { border-color: white; }

/* ── VIEWER WAITING ───────────────────────────────── */
#gs-waiting-screen {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 20px; position: absolute; inset: 0;
}
#gs-waiting-screen .gs-spinner {
    width: 48px; height: 48px;
    border: 2px solid rgba(255,255,255,0.1);
    border-top-color: rgba(255,255,255,0.6);
    border-radius: 50%; animation: spin 1s linear infinite;
}
#gs-waiting-screen p {
    font-size: 0.85rem; text-transform: uppercase;
    letter-spacing: 3px; opacity: 0.5; margin: 0;
}

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
}
@keyframes spin {
    to { transform: rotate(360deg); }
}
</style>

<div id="game-stream-module">

    <!-- CLOSE BUTTON -->
    <button id="gs-close-btn" onclick="gsClose()">
        <span class="material-symbols-rounded" style="font-size:18px;">arrow_back</span>
        Back
    </button>

    <!-- ① ROLE SELECTOR -->
    <div id="gs-role-selector">
        <h2>Game Stream</h2>
        <div class="gs-role-btns">
            <div class="gs-role-btn" onclick="gsInitStreamer()">
                <span class="gs-icon material-symbols-rounded">cast</span>
                <span class="gs-label">Streamer</span>
                <span class="gs-desc">Share your screen</span>
            </div>
            <div class="gs-role-btn" onclick="gsInitViewer()">
                <span class="gs-icon material-symbols-rounded">tv</span>
                <span class="gs-label">Viewer</span>
                <span class="gs-desc">Watch the stream</span>
            </div>
        </div>
    </div>

    <!-- ② STREAMER UI — open stream-cam in external browser -->
    <div id="gs-streamer-ui">
        <div id="gs-extlink-panel">
            <div class="gs-extlink-icon material-symbols-rounded">cast</div>
            <p class="gs-extlink-title">Check your viewer</p>
            <p class="gs-extlink-sub">A popup is asking permission to open your browser — click <strong>Allow</strong> to start streaming</p>
            <div id="gs-waiting-stream-msg" style="display:flex;">
                <div class="gs-spinner-small"></div>
                Waiting for browser to open...
            </div>
            <div id="gs-stream-live-msg" style="display:none; align-items:center; gap:10px; font-size:0.72rem; text-transform:uppercase; letter-spacing:2px; color:#2ecc71;">
                <span style="font-size:1rem;">●</span>
                Stream is live
            </div>
            <button id="gs-retry-btn" onclick="gsRequestOpenUrl()" style="display:none;
                background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15);
                border-radius: 10px; padding: 10px 24px; color: white; cursor: pointer;
                font-family: 'Fira Sans', sans-serif; font-size: 0.72rem;
                text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px;">
                Resend popup
            </button>
        </div>
    </div>

    <!-- ③ VIEWER UI -->
    <div id="gs-viewer-ui">
        <div id="gs-waiting-screen">
            <div class="gs-spinner"></div>
            <p>Waiting for streamer...</p>
        </div>
        <video id="gs-remote-video" autoplay playsinline muted></video>
        <button id="gs-unmute-btn" onclick="gsUnmute()">🔇 Enable Sound</button>
    </div>

    <!-- STATUS BAR (shared) -->
    <div id="gs-status-bar">
        <div id="gs-status-dot"></div>
        <span id="gs-status-text">Select a role</span>
    </div>

</div>

<script>
(function() {
    // ── CONFIG ──────────────────────────────────────────────
    const PEER_CONFIG = {
        host: window.location.hostname,
        port: window.location.port || 443,
        path: '/peerjs',
        secure: window.location.protocol === 'https:',
        debug: 1
    };

    // ── STATE ────────────────────────────────────────────────
    let peer        = null;
    let myRole      = null;
    let pendingViewers = [];

    const socket = window.socket;
    const myRoom = window.myRoom || 'Lobby';
    const GS_ROOM = myRoom; // consistent with stream-cam.ejs

    // ── STATUS ───────────────────────────────────────────────
    function setStatus(text, state) {
        document.getElementById('gs-status-text').textContent = text;
        const dot = document.getElementById('gs-status-dot');
        dot.className = '';
        if (state) dot.classList.add(state);
    }

    // ── CLOSE / CLEANUP ──────────────────────────────────────
    window.gsClose = function() {
        clearTimeout(window._gsRetryTimer);
        if (socket && socket.connected) socket.emit('gs_leave', { room: GS_ROOM });
        if (peer) { peer.destroy(); peer = null; }
        socket.off('gs_viewer_joined');
        socket.off('gs_streamer_present');
        socket.off('gs_streamer_left');
        socket.off('gs_pending_viewers');
        socket.off('gs_stream_started');
        socket.off('gs_open_url_sent');
        socket.off('gs_open_url_error');
        if (typeof closeSubMenu === 'function') closeSubMenu();
    };

    // ── ROLE: STREAMER ───────────────────────────────────────
    // Choosing Streamer immediately asks the TV to send llLoadURL
    // to the clicker's viewer — no button needed here.
    window.gsInitStreamer = function() {
        myRole = 'streamer';
        document.getElementById('gs-role-selector').style.display = 'none';
        document.getElementById('gs-streamer-ui').style.display   = 'flex';
        setStatus('Waiting for browser...', 'waiting');

        // Register as streamer peer so viewers can connect once stream starts
        peer = new Peer(undefined, PEER_CONFIG);

        peer.on('open', function(id) {
            console.log('[GS] Streamer PeerID:', id);
            socket.emit('gs_join', { room: GS_ROOM, role: 'streamer', peerId: id });
        });

        peer.on('error', function(err) {
            console.error('[GS] Peer error:', err);
            setStatus('Connection error', 'idle');
        });

        socket.on('gs_viewer_joined', function(data) {
            pendingViewers.push(data.peerId);
        });

        socket.on('gs_pending_viewers', function(data) {
            if (Array.isArray(data.peerIds)) pendingViewers.push(...data.peerIds);
        });

        // stream-cam.ejs started the stream — update status
        socket.on('gs_stream_started', function() {
            document.getElementById('gs-waiting-stream-msg').style.display = 'none';
            document.getElementById('gs-stream-live-msg').style.display    = 'flex';
            document.getElementById('gs-retry-btn').style.display          = 'none';
            setStatus('Live — stream running in your browser', 'live');
        });

        // Ask TV to send llLoadURL to the clicker
        gsRequestOpenUrl();
    };

    // Sends gs_request_open_url to server → POST to TV → llLoadURL(last_clicker, url)
    // Also exposed as window so the "Resend popup" button can call it
    window.gsRequestOpenUrl = function() {
        const streamCamUrl = window.location.origin + '/stream-cam-page?room=' + encodeURIComponent(GS_ROOM);
        socket.emit('gs_request_open_url', {
            room:   GS_ROOM,
            url:    streamCamUrl,
            clicker: window.myName || ''
        });
        setStatus('Waiting for browser...', 'waiting');
        document.getElementById('gs-waiting-stream-msg').style.display = 'flex';
        document.getElementById('gs-stream-live-msg').style.display    = 'none';
        document.getElementById('gs-retry-btn').style.display          = 'none';

        // If no response after 10s show retry button
        clearTimeout(window._gsRetryTimer);
        window._gsRetryTimer = setTimeout(function() {
            document.getElementById('gs-retry-btn').style.display = 'block';
            setStatus('No response — try resend', 'waiting');
        }, 10000);
    };

    // Server confirmed popup was sent
    socket.on('gs_open_url_sent', function() {
        clearTimeout(window._gsRetryTimer);
        setStatus('Popup sent — click Allow in your viewer', 'waiting');
    });

    // Server failed to reach TV
    socket.on('gs_open_url_error', function(data) {
        clearTimeout(window._gsRetryTimer);
        document.getElementById('gs-waiting-stream-msg').style.display = 'none';
        document.getElementById('gs-retry-btn').style.display          = 'block';
        const reasons = {
            'no_tv_session': 'No TV session — re-click the TV inworld',
            'tv_offline':    'TV is offline',
            'tv_unreachable':'TV did not respond'
        };
        setStatus(reasons[data.reason] || 'Could not reach TV', 'idle');
    });

    // ── ROLE: VIEWER ─────────────────────────────────────────
    window.gsInitViewer = function() {
        myRole = 'viewer';
        document.getElementById('gs-role-selector').style.display = 'none';
        document.getElementById('gs-viewer-ui').style.display     = 'flex';
        setStatus('Waiting for streamer...', 'waiting');

        peer = new Peer(undefined, PEER_CONFIG);

        peer.on('open', function(id) {
            console.log('[GS] Viewer PeerID:', id);
            socket.emit('gs_join', { room: GS_ROOM, role: 'viewer', peerId: id });
        });

        peer.on('error', function(err) {
            console.error('[GS] Peer error:', err);
            setStatus('Connection error', 'idle');
        });

        peer.on('call', function(call) {
            console.log('[GS] Incoming call from streamer');
            setStatus('Connecting...', 'connecting');
            call.answer();

            call.on('stream', function(incomingStream) {
                console.log('[GS] Stream received!');
                const video   = document.getElementById('gs-remote-video');
                const waiting = document.getElementById('gs-waiting-screen');
                video.srcObject = incomingStream;
                waiting.style.display = 'none';
                video.play().catch(() => {});
                document.getElementById('gs-unmute-btn').style.display = 'block';
                setStatus('Live', 'live');
            });

            call.on('close', function() {
                setStatus('Stream ended', 'idle');
                document.getElementById('gs-waiting-screen').style.display = 'flex';
                document.getElementById('gs-remote-video').srcObject = null;
                document.getElementById('gs-unmute-btn').style.display = 'none';
            });
        });

        socket.on('gs_streamer_left', function() {
            setStatus('Streamer disconnected', 'idle');
            document.getElementById('gs-waiting-screen').style.display = 'flex';
            document.getElementById('gs-remote-video').srcObject = null;
            document.getElementById('gs-unmute-btn').style.display = 'none';
        });
    };

    window.gsUnmute = function() {
        const video = document.getElementById('gs-remote-video');
        video.muted = false;
        document.getElementById('gs-unmute-btn').textContent  = '🔊 Sound On';
        document.getElementById('gs-unmute-btn').style.opacity = '0.5';
    };

})();
</script>
