<style>
    /* Dynamic Theme Colors */
    :root {
        --accent-color: <%= (origin === 'music') ? '#00d4ff' : '#ff0000' %>;
    }

    #player-wrapper {
        position: fixed;
        top: 0px; left: 0px;
        width: 1280px; height: 720px;
        background: black;
        overflow: hidden;
        z-index: 2000;
    }
    #player-container { width: 100%; height: 100%; }

    .player-controls {
        position: absolute;
        top: 30px; /* Moved to top for better visibility */
        right: 30px;
        z-index: 2100;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    .backBut {
        width: 60px;
        height: 60px;
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid var(--accent-color); /* Dynamically set */
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        outline: none;
        backdrop-filter: blur(5px);
    }

    .backBut:hover { 
        background: var(--accent-color);
        color: black;
        transform: scale(1.1);
    }
</style>

<div id="player-wrapper">
    <div id="player-container"></div>
    <div class="player-controls">
        <button class="backBut" onclick="exitPlayer()" title="Go Back">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>
</div>


<script>

function exitPlayer() {
    const origin = "<%= origin %>";
    const target = "<%= targetID %>";
    const scroll = "<%= scrollPos %>";
    const menu   = "<%= typeof menu !== 'undefined' ? menu : '' %>";

    let returnUrl = "";

    if (origin === 'grid') {
        // Universal: return to whatever grid we came from, with the right menu
        returnUrl = `/music-grid?genre=${encodeURIComponent(target)}&menu=${encodeURIComponent(menu)}&scrollPos=${scroll}`;
    } else if (origin === 'music') {
        returnUrl = `/music-grid?genre=${encodeURIComponent(target)}&scrollPos=${scroll}`;
    } else if (origin === 'youtube') {
        returnUrl = `/youtube?tag=${encodeURIComponent(target)}&scrollPos=${scroll}`;
    } else {
        returnUrl = '/';
    }
console.log("*** PLAYER EXIT ***")    
console.log("origin: ", origin)
console.log("target: ", target)
console.log("menu: ", menu)
console.log("scroll: ", scroll)
console.log("*******************")  

    if (typeof handleNav === "function") {
        handleNav(returnUrl);
    } else {
        window.parent.postMessage({ action: 'nav', path: returnUrl }, '*');
    }
}


(function() {
    // 1. Setup local variables
    const video_id = "<%= (typeof videoId !== 'undefined') ? videoId : '' %>";
    let isRemoteCommand = false;
    let emitTimer = null;

    // 2. The Cleanup Function (Crucial for AJAX)
    function purgePriorPlayer() {
        if (window.ytPlayerInstance) {
            try {
                window.ytPlayerInstance.stopVideo();
                window.ytPlayerInstance.destroy();
            } catch (e) { console.warn("Cleanup ignored:", e); }
            window.ytPlayerInstance = null;
        }
        if (window.heartbeatInterval) {
            clearInterval(window.heartbeatInterval);
            window.heartbeatInterval = null;
        }
    }

    // 3. The Actual Builder
    window.renderYTPlayer = function() {
        if (!video_id || !document.getElementById('player-container')) return;
        
        purgePriorPlayer();

        console.log("Building player for:", video_id);
        window.ytPlayerInstance = new YT.Player('player-container', {
            videoId: video_id,
playerVars: { 
    'autoplay': 1,      // keep — starts video on load
    'controls': 1,      // keep — but consider your use case (see below)
    'rel': 0,           // keep — prevents related videos hijacking the player
    'disablekb': 0,     // disable keyboard shortcuts — prevents local-only seeks
    'fs': 0,            // disable fullscreen button — keeps layout consistent for all viewers
    'modestbranding': 1, // removes YouTube logo clutter
    'iv_load_policy': 3, // hides video annotations
    'cc_load_policy': 0, // no forced captions
    'loop': 1,

},
            events: {
'onReady': (event) => {
    if (window.syncTargetTime && window.syncTargetTime > 0) {
        
        // Compensa o tempo desde que o estado foi recebido até o player estar pronto
        const elapsed = window.syncArrivalTime 
            ? (Date.now() - window.syncArrivalTime) / 1000 
            : 0;
        const compensatedTime = window.syncTargetTime + elapsed;

        console.log("Sync elapsed compensation:", elapsed, "s");
        console.log("Seeking to compensated time:", compensatedTime);

        event.target.seekTo(compensatedTime, true);
        if (window.syncIsPaused) {
            event.target.pauseVideo();
        } else {
            event.target.playVideo();
        }
        window.syncTargetTime = null;
        window.syncIsPaused   = null;
        window.syncArrivalTime = null; // ← limpar também
    }

    // Heartbeat logic
    window.heartbeatInterval = setInterval(() => {
        if (window.ytPlayerInstance && window.ytPlayerInstance.getCurrentTime) {
            socket.emit('report_current_time', {
                time: window.ytPlayerInstance.getCurrentTime(),
                paused: window.ytPlayerInstance.getPlayerState() !== YT.PlayerState.PLAYING,
                videoId: video_id 
            });
        }
    }, 1000);
},
                'onStateChange': (event) => {

    if (event.data === YT.PlayerState.UNSTARTED) {
        console.warn("Video unavailable or invalid ID:", video_id);
        // Show the back button so the user can escape
        const controls = document.querySelector('.player-controls');
        if (controls) {
            controls.style.opacity = '1';
            controls.style.pointerEvents = 'auto';
        }
        return;
    }

                    // Show BACK when paused/stopped/ended, hide when playing
                    const controls = document.querySelector('.player-controls');
                    if (controls) {
                        const playing = event.data === YT.PlayerState.PLAYING;
                        controls.style.opacity = playing ? '0' : '1';
                        controls.style.pointerEvents = playing ? 'none' : 'auto';
                    }

                    if (isRemoteCommand) return;
                    clearTimeout(emitTimer);
                    emitTimer = setTimeout(() => {
                        const currentTime = window.ytPlayerInstance.getCurrentTime();
                        if (event.data === YT.PlayerState.PLAYING) {
                            socket.emit('toPlay', currentTime);
                        } else if (event.data === YT.PlayerState.PAUSED) {
                            socket.emit('toPause', currentTime);
                        }
                    }, 200);
                }
            }
        });
    };

    // 4. Execution Trigger
    // Check if YT is already loaded globally
    if (window.YT && window.YT.Player) {
        // Give AJAX 50ms to finish painting the div to the screen
        setTimeout(window.renderYTPlayer, 50);
    } else {
        // First time loading the site? Load the script.
        window.onYouTubeIframeAPIReady = window.renderYTPlayer;
        if (!$('script[src*="youtube.com/iframe_api"]').length) {
            $.getScript("https://www.youtube.com/iframe_api");
        }
    }

    // 5. Socket Listeners (Fresh start)
    if (typeof socket !== 'undefined') {
        socket.off('Play').off('Pause');
        socket.on('Play', (time) => {
          
            isRemoteCommand = true;
            window.ytPlayerInstance.seekTo(time, true);
              window.ytPlayerInstance.pauseVideo();
            window.ytPlayerInstance.playVideo();
            setTimeout(() => isRemoteCommand = false, 1000);
        });
        socket.on('Pause', (time) => {
            isRemoteCommand = true;
            window.ytPlayerInstance.pauseVideo();
            window.ytPlayerInstance.seekTo(time, true);
            setTimeout(() => isRemoteCommand = false, 1000);
        });
    }


    ///////////////////////////////////////77
    console.log("*** PLAYER OPEN ***")
console.log("videoID:", "<%= videoId %>")
console.log("origin:", "<%= origin %>")
console.log("target:", "<%= targetID %>")
console.log("menu:  ", "<%= typeof menu !== 'undefined' ? menu : 'UNDEFINED' %>")
console.log("scroll:", "<%= scrollPos %>")
console.log("*******************")
})();
</script>
