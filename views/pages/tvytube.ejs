<style>
    :root {
        --accent-color: <%= (origin === 'music') ? '#00d4ff' : '#ff0000' %>;
    }

    #player-wrapper {
        position: fixed;
        top: 0px; left: 0px;
        width: 1280px; height: 720px;
        background: black;
        overflow: hidden;
        z-index: 2000;
    }
    #player-container { width: 100%; height: 100%; }



.player-controls {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    display: flex; /* Makes the container a flex box */
    flex-direction: column; /* Stacks items vertically */
    justify-content: center; /* Centers vertically */
    align-items: center; /* Centers horizontally */
    z-index: 2100;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
}

    .backBut {
        position: fixed;
        top: 410px;
        left: 612px;
        width: 55px;
        height: 55px;
        background: rgba(232, 8, 8, 0.7);
        border: 1px solid transparent;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        outline: none;
        pointer-events: auto;
    }

    .backBut:hover {
        background: red;
        color: white;
        transform: scale(1.2);
    }

    #msg {
        position: fixed;
        top: 160px;
        left: 320px;
        font-weight: 400;
        letter-spacing: 1.0px;

        border: 1px solid transparent;
        border-radius: 10px;
        padding: 7px 20px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
        font-size: 18px;
    }
#msgBox {
    position: relative; /* Remove absolute positioning */
    top: -120px;
    background: rgba(0, 0, 0, 0.0);
    padding: 20px;
    border-radius: 10px;
    text-align: center;
    z-index: 2200; /* Ensure it is above buttons */
    pointer-events: none; /* Allow clicking if needed */
}
    #cover {
        position: fixed;
        top: 660px;
        left: 10px;
        width: 1250px;
        height: 50px;
        background: red;
    }

    /* This is your full-screen overlay */
#pause-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 1280px;
    height: 720px;
    background: rgba(0, 0, 0, 0.6); /* Subtle dimming effect */
    z-index: 2040; /* Just below the buttons but above the video */
    display: none; /* Hidden by default */
    justify-content: center;
    align-items: center;
    
}

/* When paused, we show the overlay and allow interactions */
.is-paused #pause-overlay {
    display: flex;
}
#player-wrapper.is-paused .player-controls {
    opacity: 1 !important;
    pointer-events: none !important;
}
.tip { color: #00f2ff; font-size: 18px;}
.error { color: #fff0ffe3; font-weight: 400; font-size: 18px;}
.action { color: #ffcc00; margin-top: 20px; font-size: 18px; }



</style>

<div id="player-wrapper">
    <div id="player-container"></div>

    <div id="pause-overlay"></div>
    
    <div class="player-controls"> </div>


    <div class="player-controls">
        <div id="msgBox">
        <p class="tip">TIP: USE THE 'GEAR ICON' TO SELECT THE HIGHEST QUALITY AVAILABLE.</p>
        <p class="error">VIDEO WON'T PLAY, IT MIGHT BE DUE TO AGE/REGION RESTRICTIONS OR IT HAS BEEN REMOVED.</p>
        <p class="action">RESTART VIDEO OR RETURN TO GRID</p>
     </div>
<button style="top: 410px;" class="backBut" onclick="exitPlayer()" title="Exit Player">
    <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
</button>

<button style="top: 332px;" class="backBut"  onclick="resumePlay()" title="Restart Play">
    <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="6 4, 20 12, 6 20, 6 4"></polygon>
    </svg>
</button>

     </div>

    </div>

</div>

<div id="cover"></div>

<script>

function resumePlay() {
    if (!window.ytPlayerInstance) return;

    // 1. Resume locally
    window.ytPlayerInstance.playVideo();

    // 2. Notify other viewers via Socket
    if (typeof socket !== 'undefined') {
        // We use the current time so it resumes exactly where it was
        const currentTime = window.ytPlayerInstance.getCurrentTime();
        socket.emit('toPlay', currentTime);
    }
    
}

function exitPlayer() {
    const origin = "<%= origin %>";
    // We get these from the server template variables
    const target = "<%= targetID || 'Live English News' %>"; 
    const scroll = "<%= scrollPos || 0 %>";
    const menu   = "<%= typeof menu !== 'undefined' ? menu : '' %>";
    const title   = "<%= typeof title !== 'undefined' ? title : '' %>";
    

    sessionStorage.removeItem('yt_playlist');
    sessionStorage.removeItem('yt_playlist_index');

    console.log("***********************")
    console.log("Origin: ", origin)
    console.log("Target: ", target)
    console.log("Scroll: ", scroll)
    console.log("menu: ", menu)
    console.log("title: ", title)
    console.log("***********************")

    let returnUrl = "";
    let isChannel=false;
    
    if (target.startsWith("UC")) isChannel=true;
    
    if (origin === 'live-tv') {
        // IMPORTANT: We need to append the parameters here too if we want to remember the state
        returnUrl = `/live-tv?genre=${encodeURIComponent(target)}&scrollPos=${scroll}`;

    } else if (origin === 'link') {
        returnUrl = menu || '/youtube-menu';

    } else if (origin === 'music') {
        let gridRoute = '/music-grid'; 
        returnUrl = `${gridRoute}?genre=${encodeURIComponent(target)}&scrollPos=${scroll}&menu=${encodeURIComponent(menu)}&title=${encodeURIComponent(title)}`;
    
    } else if (origin === 'movies') {
        let gridRoute = '/movies-grid'; 
        returnUrl = `${gridRoute}?genre=${encodeURIComponent(target)}&scrollPos=${scroll}&menu=${encodeURIComponent(menu)}&title=${encodeURIComponent(title)}&isChannel=${encodeURIComponent(isChannel)}`;
    
    } else if (origin === 'youtube') {
        let gridRoute = '/youtube-grid'; 
        returnUrl = `${gridRoute}?genre=${encodeURIComponent(target)}&scrollPos=${scroll}&menu=${encodeURIComponent(menu)}&title=${encodeURIComponent(title)}&isChannel=${encodeURIComponent(isChannel)}`;
    }

    console.log("Exiting to:", returnUrl);

    if (typeof handleNav === "function") {
        window.pendingScrollRestore = parseInt(scroll) || 0;
        handleNav(returnUrl);
    } else {
        window.location.href = returnUrl;
    }
}

(function() {
    const video_id = "<%= (typeof videoId !== 'undefined') ? videoId : '' %>";
    let isRemoteCommand = false;
    let emitTimer = null;

    // --- Click throttle shield ---
    const CLICK_THROTTLE_MS = 1200;
    let clickShieldActive = false;

    function purgePriorPlayer() {
        if (window.ytPlayerInstance) {
            try {
                window.ytPlayerInstance.stopVideo();
                window.ytPlayerInstance.destroy();
            } catch (e) { console.warn("Cleanup ignored:", e); }
            window.ytPlayerInstance = null;
        }
        if (window.heartbeatInterval) {
            clearInterval(window.heartbeatInterval);
            window.heartbeatInterval = null;
        }
    }

    window.renderYTPlayer = function() {
        if (!video_id || !document.getElementById('player-container')) return;
        purgePriorPlayer();

        window.ytPlayerInstance = new YT.Player('player-container', {
            videoId: video_id,
            playerVars: {
                'autoplay': 1,
                'controls': 1,
                'rel': 0,
                'disablekb': 0,
                'fs': 0,
                'modestbranding': 1,
                'iv_load_policy': 3,
                'cc_load_policy': 0,
                'loop': 1,
                'origin': window.location.origin, // Isso diz ao YT que seu site é seguro
                'enablejsapi': 1
            },
            events: {
                'onReady': (event) => {
                    if (window.syncTargetTime && window.syncTargetTime > 0) {
                        const elapsed = window.syncArrivalTime ? (Date.now() - window.syncArrivalTime) / 1000 : 0;
                        const compensatedTime = window.syncTargetTime + elapsed;
                        event.target.seekTo(compensatedTime, true);
                        if (window.syncIsPaused) {
                            event.target.pauseVideo();
                        } else {
                            event.target.playVideo();
                        }
                        window.syncTargetTime = null;
                        window.syncIsPaused = null;
                        window.syncArrivalTime = null;
                    }

                    window.heartbeatInterval = setInterval(() => {
                        if (window.ytPlayerInstance && window.ytPlayerInstance.getCurrentTime) {
                            socket.emit('report_current_time', {
                                time: window.ytPlayerInstance.getCurrentTime(),
                                paused: window.ytPlayerInstance.getPlayerState() !== YT.PlayerState.PLAYING,
                                videoId: video_id
                            });
                        }
                    }, 1000);
                },

                'onError': (event) => {
                    console.error("YouTube Player Error:", event.data);
                    const controls = document.querySelector('.player-controls');
                    const wrapper = document.getElementById('player-wrapper');
                    
                    // 1. Add the class to turn on the dark overlay background
                    if (wrapper) {
                        wrapper.classList.add('is-paused');
                    }
                    
                    // 2. Make the buttons and error messages fully visible and clickable
                    if (controls) {
                        controls.style.opacity = '1';
                        controls.style.pointerEvents = 'auto';
                    }
                },

                'onStateChange': (event) => {
                    const controls = document.querySelector('.player-controls');
                    const wrapper = document.getElementById('player-wrapper');
                    // Lógica de Loop: Se o vídeo terminar, volta ao início e dá play
                    if (event.data === YT.PlayerState.ENDED) {
                        const playlist = JSON.parse(sessionStorage.getItem('yt_playlist') || '[]');
                        const index = parseInt(sessionStorage.getItem('yt_playlist_index') || '0');
                        const next = index + 1;

                        if (playlist.length > 0 && next < playlist.length) {
                            // Advance to next video in playlist
                            sessionStorage.setItem('yt_playlist_index', String(next));
                            const nextId = playlist[next];
                            const menu   = "<%= typeof menu !== 'undefined' ? menu : '' %>";
                            handleNav(`/tvytube?videoId=${encodeURIComponent(nextId)}&vq=hd1080&origin=link&targetID=playlist&menu=${encodeURIComponent(menu)}&scrollPos=0`);
                        } else {
                            // No playlist or last video — clear and loop as before
                            sessionStorage.removeItem('yt_playlist');
                            sessionStorage.removeItem('yt_playlist_index');
                            event.target.seekTo(0);
                            event.target.playVideo();
                        }
                        return;
                    }

// 2. Determine state
    const isPausedOrEnded = (event.data === YT.PlayerState.PAUSED || 
                             event.data === YT.PlayerState.ENDED || 
                             event.data === YT.PlayerState.UNSTARTED);

    // 3. Sync Overlay and Buttons
    if (wrapper) {
        isPausedOrEnded ? wrapper.classList.add('is-paused') : wrapper.classList.remove('is-paused');
    }

    if (controls) {
        // If paused/ended, show controls (opacity: 1), else hide (opacity: 0)
        controls.style.opacity = isPausedOrEnded ? '1' : '0';
        controls.style.pointerEvents = isPausedOrEnded ? 'auto' : 'none';
    }

    // 5. Socket Logic
    if (isRemoteCommand) return;
    clearTimeout(emitTimer);
    emitTimer = setTimeout(() => {
        if (!window.ytPlayerInstance) return;
        const currentTime = window.ytPlayerInstance.getCurrentTime();
        if (event.data === YT.PlayerState.PLAYING) {
            socket.emit('toPlay', currentTime);
        } else if (event.data === YT.PlayerState.PAUSED) {
            socket.emit('toPause', currentTime);
        }
    }, 200);
}
            }
        });
    };

    if (window.YT && window.YT.Player) {
        setTimeout(window.renderYTPlayer, 50);
    } else {
        window.onYouTubeIframeAPIReady = window.renderYTPlayer;
        if (!$('script[src*="youtube.com/iframe_api"]').length) {
            $.getScript("https://www.youtube.com/iframe_api");
        }
    }

    if (typeof socket !== 'undefined') {
        socket.off('Play').off('Pause');

        
    socket.on('Play', (data) => {
    if (!window.ytPlayerInstance) return;
    
    // 1. Prevent loopback
    isRemoteCommand = true;

    // 2. Parse the time safely (ensure it's a number)
    const baseTime = parseFloat(data.timestamp) || 0;
    const latency = (Date.now() - (data.lastUpdate || Date.now())) / 1000;
    
    // 3. Calculate actual time. 
    // If it's a pause/play, latency is key. 
    // If it's a fresh start, latency might be 0.
    const actualCurrentTime = baseTime + latency;

    console.log(`Syncing to: ${actualCurrentTime} (Base: ${baseTime}, Latency: ${latency})`);

    // 4. Command the player
    // Seek first, then play. Some players reset to 0 if play() is called before seek completes.
    window.ytPlayerInstance.seekTo(actualCurrentTime, true);
    
    // Small delay can help some player APIs stabilize the seek before playing
    setTimeout(() => {
        window.ytPlayerInstance.playVideo();
    }, 50);

    setTimeout(() => isRemoteCommand = false, 1000);
});
        socket.on('Pause', (time) => {
            if (!window.ytPlayerInstance) return;
            isRemoteCommand = true;
            window.ytPlayerInstance.pauseVideo();
            window.ytPlayerInstance.seekTo(time, true);
            window.ytPlayerInstance.pauseVideo();

            setTimeout(() => isRemoteCommand = false, 1000);
        });
    }
})();
</script>
