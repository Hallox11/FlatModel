<!-- Estilos encapsulados para o Overlay -->
<style>
    #freebies-overlay-container {
        width: 1280px; height: 720px;
        color: #ffffff; font-family: 'Outfit', sans-serif;
        display: flex; flex-direction: column;
        background: rgba(0, 0, 0, 0.0);
        
    }

    /* ── HEADER ── */
    .freebies-header {
        width: 100%; height: 55px;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 35px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
        z-index: 100; flex-shrink: 0; box-sizing: border-box;
        margin-bottom: 0px;
    }

    .freebies-header h1 {
        font-size: 19px; font-weight: 300; letter-spacing: 3px;
        text-transform: uppercase; color: #ffcc00;
    }

    .header-back {
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px; color: white; padding: 8px 20px;
        cursor: pointer; transition: all 0.2s ease;
    }

    /* ── GRID SCROLL ── */
    #content-wrapper {
    flex-grow: 1;      
    overflow-y: auto;  
    overflow-x: hidden; 
    padding: 0px 23px; 
    box-sizing: border-box;
    width: 1235px;
    margin-left: 20px;
    }

/* 4. ESTILIZAÇÃO DA BARRA DE ROLAGEM (Red YouTube Style) */
#content-wrapper::-webkit-scrollbar {
    width: 12px;
}

#content-wrapper::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
}

#content-wrapper::-webkit-scrollbar-thumb {
    background: #ff0000; 
    border-radius: 10px;
    border: 2px solid rgba(0, 0, 0, 0.2);
}


#freebies-grid {
    /* Use columns instead of grid for true masonry */
    display: block; 
    column-gap: 20px;
    width: 100%;
}

.freebie-card {
    background: rgba(0,0,0,0.5);
    border: 2px solid rgba(255,255,255,0.1); 
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;

    /* CRITICAL FOR MASONRY: */
    display: inline-block; /* Keeps the card from splitting between columns */
    width: 100%;           /* Ensures card fills the column width */
    margin-bottom: 20px;   /* The vertical gap between cards */
    break-inside: avoid;   /* Modern browser instruction to not split card */
}

.freebie-card:hover {
    background: rgba(0,0,0,0.7);
    border-color: #ffcc00;
}

.card-img-wrap { 
        width: 100%; 
        position: relative; 
        background: rgba(0,0,0,0.2); /* Fundo para imagens com transparência */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-img-wrap img { 
        width: 100%; 
        height: auto; /* Permite que a altura se ajuste ao rácio original */
        max-height: 350px; /* Limite opcional para não "explodir" o layout com imagens muito verticais */
        object-fit: contain; /* Garante que a imagem inteira seja vista */
        display: block; 
    }

    /* ── BOTÃO TELEPORT (MODIFICADO) ── */
    .tp-btn {
        position: absolute; bottom: 10px; right: 10px;
        background: #ffcc00; border: none; border-radius: 8px;
        color: #000; padding: 8px 12px; font-size: 12px; font-weight: 600;
        display: flex; align-items: center; gap: 6px; cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.4); transition: all 0.2s;
    }

    .tp-btn:hover { transform: scale(1.05); background: #fff; }
    .tp-btn.loading { background: #555; color: #ccc; cursor: wait; }
    
    .tp-btn.loading::before {
        content: ""; width: 12px; height: 12px;
        border: 2px solid #ccc; border-top-color: transparent;
        border-radius: 50%; animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .card-body { padding: 15px; }
    .card-title { font-size: 15px; font-weight: 400; color: #ffcc00; margin-bottom: 8px; line-height: 1.2; }
    .card-desc { letter-spacing: 0.4px; font-size: 13px;font-weight: 400;  color: #f2f1f1; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .layout-btn {
        background: rgba(255,255,255,0.05); border: 1px solid #8e8b8b;
        color: #beb8b8; padding: 5px 12px; border-radius: 6px; cursor: pointer;
    }
    .layout-btn.active { color: #ffcc00; border-color: #ffcc00; background: rgba(255, 204, 0, 0.205); }

    .close-menu-btn{
        top: 13px;
        right: 25px;
        width: 35px;
        height: 35px;
        font-size: 16px;
    }
    /* ── PILL BUTTON STYLING ── */
.ltv-nav-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.173);
    color: white;
    padding: 3px 20px;
    border-radius: 20px; /* Pill shape */
    font-size: 0.80rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin: 0 5px;
}

.ltv-nav-btn:hover {
    background: hsla(48, 93%, 41%, 0.67);
    border-color: rgba(255, 255, 255, 0.3);
}

/* ── CENTERING THE TITLE ── */
.header-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.0rem;
    letter-spacing: 3px;
    opacity: 0.6;
    pointer-events: none; /* Allows clicking through if needed */
}
</style>

<div id="freebies-overlay-container">
    <div class="freebies-header">
        <button class="ltv-nav-btn" onclick="closeSubMenu()">
        <span class="material-symbols-rounded" style="font-size:23px!important; vertical-align:middle;">arrow_back</span> BACK
        </button>

        <h1 style="margin-left: 35px;">Freebies & Deals</h1>

        <div style="display:flex; align-items:center; gap:20px;margin-right: 30px;">

            <div id="layout-btns" style="display: flex; gap: 8px;">
                <button class="layout-btn" onclick="setFreebiesLayout(2)">2X</button>
                <button class="layout-btn" onclick="setFreebiesLayout(3)">3X</button>
                <button class="layout-btn active" onclick="setFreebiesLayout(4)">4X</button>
            </div>
        </div>

    </div>


    <div id="content-wrapper">
        <div id="loading-freebies" style="text-align: center; margin-top: 150px;">
            <div style="font-size: 40px; animation: spin 2s linear infinite;">✦</div>
            <p style="color: #666; margin-top: 15px; letter-spacing: 2px;">A sintonizar ofertas...</p>
        </div>
        <div id="freebies-grid" style="display:none;"></div>
    </div>
</div>

<script>
(function() {
    const TP_ICON = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`;

    window.setFreebiesLayout = function(cols, isRemote = false) {
        $('#freebies-grid').css('column-count', cols); 
        $('.layout-btn').removeClass('active');
$(`.layout-btn`).each(function() {
        // Extract the number from "2x" by parsing the integer
        const btnVal = parseInt($(this).text()); 
        if(btnVal == cols) {
            $(this).addClass('active');
        }
    });
        localStorage.setItem('freebies_cols', cols);

        if (!isRemote && window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'layout_change', cols: cols, room: window.myRoom });
        }
    };

    window.handleFreebieTeleport = async function(articleUrl, btnId) {
        const $btn = $(`#${btnId}`);
        if ($btn.hasClass('loading')) return;
        try {
            $btn.addClass('loading').html('A procurar...');
            const response = await fetch(`/api/freebies/teleport?articleUrl=${encodeURIComponent(articleUrl)}`);
            const data = await response.json();
            if (data.teleportUrl) {
                $.post('/send-command', { command: 'teleport', value: data.teleportUrl });
                $btn.html(TP_ICON + ' Sucesso!').css('background', '#4CAF50');
                setTimeout(() => $btn.removeClass('loading').html(TP_ICON + ' Teleport').css('background', ''), 3000);
            } else {
                alert("Não foi possível encontrar o link de teleport.");
                $btn.removeClass('loading').html(TP_ICON + ' Teleport');
            }
        } catch (e) {
            $btn.removeClass('loading').html(TP_ICON + ' Erro');
        }
    };

    function buildFreebieCard(item, index) {
        const cardId = `fb-card-${index}`;
        const btnId = `fb-tp-${index}`;
        return `
            <div class="freebie-card" id="${cardId}" 
                 onmouseenter="syncHover('${cardId}', true)" 
                 onmouseleave="syncHover('${cardId}', false)">
                <div class="card-img-wrap" onclick="window.open('${item.url}', '_blank')">
                    <img src="${item.image || ''}" onerror="this.src='./img/no_image.png'">
                    <button id="${btnId}" class="tp-btn" onclick="window.open('${item.url}', '_blank');">
                        ${TP_ICON} Teleport
                    </button>
                </div>
                <div class="card-body">
                    <div class="card-title">${item.title}</div>
                    <div class="card-desc">${item.desc || 'Sem descrição.'}</div>
                </div>
            </div>
        `;
    }

    // --- SYNC FUNCTIONS ---
    window.syncHover = function(cardId, isActive) {
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'hover', id: cardId, active: isActive, room: window.myRoom });
        }
    };

    // --- SOCKET LISTENER (Unified) ---
    if (window.socket) {
        window.socket.on('state_sync', (data) => {
            if (data.type === 'layout_change') window.setFreebiesLayout(data.cols, true);
            
            if (data.type === 'scroll') {
                window.isSyncing = true;
                $('#content-wrapper').scrollTop(data.position);
                setTimeout(() => { window.isSyncing = false; }, 100);
            }
            
            if (data.type === 'hover') {
                const el = document.getElementById(data.id);
                if (el) {
                    el.style.background = data.active ? 'rgba(0,0,0,0.7)' : ''; // Default resets to CSS
                    el.style.borderColor = data.active ? '#ffcc00' : '';
                }
            }
        });
    }

    // --- SCROLL BROADCASTER ---
    $('#content-wrapper').on('scroll', function() {
        if (window.isSyncing) return;
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'scroll', position: $(this).scrollTop(), room: window.myRoom });
        }
    });

    async function initFreebies(cols) {
        try {
            const res = await fetch('/api/freebies');
            const items = await res.json();
            $('#loading-freebies').hide();
            if (items && items.length) {
                const html = items.map((item, idx) => buildFreebieCard(item, idx)).join('');
                $('#freebies-grid').html(html).fadeIn();
                window.setFreebiesLayout(cols || localStorage.getItem('freebies_cols') || 3);
            }
        } catch (e) {
            $('#loading-freebies').html('<p style="color:red;">Falha na conexão.</p>');
        }
    }

    initFreebies(3);
})();
</script>