<style>
    #freebies-overlay-container {
        width: 1280px; height: 720px;
        color: #ffffff; font-family: 'Outfit', sans-serif;
        display: flex; flex-direction: column;
        background: rgba(0, 0, 0, 0.0);
        box-sizing: border-box;
        position: relative;
    }

    /* ── HEADER ── */
    .freebies-header {
        width: 100%; height: 57px;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 35px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.5) 80%, rgba(0, 0, 0, 0) 100%);
        z-index: 100; flex-shrink: 0; box-sizing: border-box;
    }

    .freebies-header h1 {
        font-size: 19px; font-weight: 300; letter-spacing: 3px;
        text-transform: uppercase; color: #ffcc00;
        margin: 0;
    }

    .header-back {
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px; color: white; padding: 8px 20px;
        cursor: pointer; transition: all 0.2s ease;
    }

    /* ── GRID SCROLL ── */
    #content-wrapper {
        flex-grow: 1;      
        overflow-y: auto;  
        overflow-x: hidden; 
        padding: 1px 22px 30px 15px; 
        box-sizing: border-box;
        width: calc(100% - 50px); /* Centers cleanly without overflowing 1280px */
        margin-left: 21px;
    }

    /* ── BARRA DE ROLAGEM (Red YouTube Style) ── */
    #content-wrapper::-webkit-scrollbar {
        width: 10px;
    }
    #content-wrapper::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.2);
    }
    #content-wrapper::-webkit-scrollbar-thumb {
        background: #ff0000; 
        border-radius: 10px;
        border: 2px solid rgba(0, 0, 0, 0.2);
    }

    /* ── TRUE MASONRY FEED GRID ── */
    #freebies-grid {
        display: block; 
        column-gap: 20px;
        column-fill: balance;
        width: 100%;
    }

    /* ── MASONRY CARDS ── */
    .freebie-card {
        background: rgba(20, 20, 25, 0.65);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255,255,255,0.08); 
        border-radius: 0px;
        overflow: hidden;
        transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        display: inline-block; /* Essential for dynamic masonry split prevention */
        width: 100%;          
        margin-bottom: 20px;   
        break-inside: avoid;   
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    .freebie-card:hover, .freebie-card.remote-hover {
    transform: translateY(-2px) scale(1.01);
    border: 2px solid rgb(249, 184, 20);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05)); 
    }

    .card-img-wrap { 
        width: 100%; 
        position: relative; 
        background: rgba(0,0,0,0.4); 
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        cursor: pointer;
    }

    .card-img-wrap img { 
        width: 100%; 
        height: auto; 
        max-height: 350px; /* Variable image heights allowed again! */
        object-fit: contain; 
        display: block; 
    }

    /* ── TELEPORT ── */
    .tp-btn {
        position: absolute; bottom: 10px; right: 10px;
        background: #ffcc00; border: none; border-radius: 8px;
        color: #000; padding: 8px 14px; font-size: 12px; font-weight: 600;
        display: flex; align-items: center; gap: 6px; cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5); transition: all 0.2s;
        z-index: 2;
    }

    .tp-btn:hover { transform: scale(1.05); background: #ffffff; }
    .tp-btn.loading { background: #555; color: #ccc; cursor: wait; }
    
    .tp-btn.loading::before {
        content: ""; width: 12px; height: 12px;
        border: 2px solid #ccc; border-top-color: transparent;
        border-radius: 50%; animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .card-body { padding: 16px; }
    .card-title { font-size: 15px; font-weight: 500; color: #ffcc00; margin-bottom: 8px; line-height: 1.3; }
    .card-desc { letter-spacing: 0.3px; font-size: 13px; font-weight: 400; color: #dcdcdc; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; opacity: 0.85; }

    /* ── BUTTON LAYOUTS ── */
    .layout-btn {
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2);
        color: #beb8b8; padding: 5px 14px; border-radius: 0px; cursor: pointer;
        font-family: 'Outfit', sans-serif; font-weight: 500; transition: all 0.2s;
    }

    .layout-btn:hover, .layout-btn.remote-hover {
        border-color: #5ab565; 
        background: rgba(56, 195, 72, 0.523);
        color: #fff;
    }

    .layout-btn.active { color: #000; border-color: #ffcc00; background: #ffcc00; font-weight: 600; }

</style>

<div id="freebies-overlay-container">
    <div class="freebies-header">

        <div style="display:flex; align-items:center; gap:20px;">
            <div id="layout-btns" style="display: flex; gap: 8px;margin-right: 10px;">
                <button class="layout-btn" onclick="setFreebiesLayout(2)">2X</button>
                <button class="layout-btn" onclick="setFreebiesLayout(3)">3X</button>
                <button class="layout-btn active" onclick="setFreebiesLayout(4)">4X</button>
            </div>
        </div>

                <h1>Freebies & Deals</h1>

            <div style="margin-right: 24px!important;margin-top:2px;">
                <button class="ltv-back-btn" onclick="closeSubMenu()">
                <span class="material-symbols-rounded" style="font-size:25px!important; vertical-align:middle;">close</span>
               </button>
            </div>




        
    </div>

    <div id="content-wrapper">
        <div id="loading-freebies" style="text-align: center; margin-top: 150px;">
            <div style="font-size: 40px; animation: spin 2s linear infinite; color: #ffcc00;">✦</div>
            <p style="color: #888; margin-top: 15px; letter-spacing: 2px;">A sintonizar ofertas...</p>
        </div>
        <div id="freebies-grid" style="display:none;"></div>
    </div>
</div>

<script>
(function() {
    const TP_ICON = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`;
    
    // Global cached dataset to allow client-side re-sorting instantly on layout changes
    let localFreebiesRawData = [];

    window.setFreebiesLayout = function(cols, isRemote = false) {
        localStorage.setItem('freebies_cols', cols);

        // Dynamic visual update of layout control active selectors
        $('.layout-btn').removeClass('active');
        $(`.layout-btn`).each(function() {
            const btnVal = parseInt($(this).text()); 
            if(btnVal == cols) $(this).addClass('active');
        });

        // Re-distribute logic across column streams asynchronously
        if (localFreebiesRawData.length > 0) {
            renderHorizontalMasonry(localFreebiesRawData, cols);
        }

        if (!isRemote && window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'layout_change', cols: cols, room: window.myRoom });
        }
    };

    // ── DISTRIBUTES MASONRY ITEMS ROW-BY-ROW ACROSS VERTICAL STRIPS ──
    function renderHorizontalMasonry(items, cols) {
        $('#freebies-grid').css('column-count', cols);

        // Pre-configure data collection slots per target column count
        let columnsData = Array.from({ length: cols }, () => []);
        
        // Feed cards directly left-to-right alternatingly across tracks
        items.forEach((item, idx) => {
            columnsData[idx % cols].push(buildFreebieCard(item, idx));
        });

        // Flatten sub-columns back into continuous stream elements for uniform layout heights across viewports
        const orchestratedHtml = columnsData.flat().join('');
        $('#freebies-grid').html(orchestratedHtml);
    }

    window.handleFreebieTeleport = async function(articleUrl, btnId, event) {
        if (event) event.stopPropagation(); // Stops interaction bubbling upward to image elements
        const $btn = $(`#${btnId}`);
        if ($btn.hasClass('loading')) return;
        try {
            $btn.addClass('loading').html('A procurar...');
            const response = await fetch(`/api/freebies/teleport?articleUrl=${encodeURIComponent(articleUrl)}`);
            const data = await response.json();
            if (data.teleportUrl) {
                $.post('/send-command', { command: 'teleport', value: data.teleportUrl });
                $btn.html(TP_ICON + ' Sucesso!').css('background', '#4CAF50');
                setTimeout(() => $btn.removeClass('loading').html(TP_ICON + ' Teleport').css('background', ''), 3000);
            } else {
                alert("Não foi possível encontrar o link de teleport.");
                $btn.removeClass('loading').html(TP_ICON + ' Teleport');
            }
        } catch (e) {
            $btn.removeClass('loading').html(TP_ICON + ' Erro');
        }
    };

    // ── REPAIRED STABLE STRUCTURAL CARD BUILDER ──
    function buildFreebieCard(item, index) {
        const cardId = `fb-card-${index}`;
        const btnId = `fb-tp-${index}`;
        return `
            <div class="freebie-card" id="${cardId}">
                <div class="card-img-wrap" onclick="window.open('${item.url}', '_blank')">
                    <img src="${item.image || ''}" onerror="this.src='./img/no_image.png'">
            <!--    <button id="${btnId}" class="tp-btn" onclick="window.handleFreebieTeleport('${item.url}', '${btnId}', event)">
                        ${TP_ICON} Teleport
                    </button>
            -->
                </div>
                <div class="card-body">
                    <div class="card-title">${item.title}</div>
                    <div class="card-desc">${item.desc || 'Sem descrição.'}</div>
                </div>
            </div>
        `;
    }

    // --- SOCKET LISTENER (Unified Room Sync) ---
    if (window.socket) {
        window.socket.on('state_sync', (data) => {
            if (data.type === 'layout_change') window.setFreebiesLayout(parseInt(data.cols), true);
            
            if (data.type === 'scroll') {
                window.isSyncing = true;
                $('#content-wrapper').scrollTop(data.position);
                setTimeout(() => { window.isSyncing = false; }, 100);
            }
        });
    }

    // --- SCROLL POSITION BROADCASTER ---
    $('#content-wrapper').on('scroll', function() {
        if (window.isSyncing) return;
        if (window.socket && window.myRoom) {
            window.socket.emit('state_sync', { type: 'scroll', position: $(this).scrollTop(), room: window.myRoom });
        }
    });

    async function initFreebies() {
        try {
            const res = await fetch('/api/freebies');
            localFreebiesRawData = await res.json();
            
            $('#loading-freebies').hide();
            if (localFreebiesRawData && localFreebiesRawData.length) {
                $('#freebies-grid').fadeIn();
                const initialCols = localStorage.getItem('freebies_cols') || 3;
                window.setFreebiesLayout(parseInt(initialCols));
            }
        } catch (e) {
            $('#loading-freebies').html('<p style="color:red; letter-spacing:1px;">Falha ao carregar ofertas.</p>');
        }
    }

    // Fire application engine
    initFreebies();
})();
</script>