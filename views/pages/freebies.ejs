<!-- Estilos encapsulados para o Overlay -->
<style>
    #freebies-overlay-container {
        width: 1280px; height: 720px;
        color: #ffffff; font-family: 'Outfit', sans-serif;
        display: flex; flex-direction: column;
        background: rgba(0, 0, 0, 0.95);
        position: absolute; top: 0; left: 0; z-index: 100;
    }

    /* ── HEADER ── */
    .freebies-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 30px; border-bottom: 1px solid rgba(255,255,255,0.1);
        flex-shrink: 0;
    }

    .freebies-header h1 {
        font-size: 22px; font-weight: 300; letter-spacing: 3px;
        text-transform: uppercase; color: #ffcc00; margin: 0;
    }

    .header-back {
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px; color: white; padding: 8px 20px;
        cursor: pointer; transition: all 0.2s ease;
    }

    /* ── GRID SCROLL ── */
    #freebies-grid-scroll {
        flex: 1; overflow-y: auto; padding: 25px;
    }

    #freebies-grid {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    }

    /* ── CARDS ── */
    .freebie-card {
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px; overflow: hidden; transition: all 0.3s ease;
        position: relative;
    }

    .freebie-card:hover {
        background: rgba(255,255,255,0.07); border-color: #ffcc00;
        transform: translateY(-5px);
    }

.card-img-wrap { 
        width: 100%; 
        position: relative; 
        background: rgba(0,0,0,0.2); /* Fundo para imagens com transparência */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-img-wrap img { 
        width: 100%; 
        height: auto; /* Permite que a altura se ajuste ao rácio original */
        max-height: 350px; /* Limite opcional para não "explodir" o layout com imagens muito verticais */
        object-fit: contain; /* Garante que a imagem inteira seja vista */
        display: block; 
    }

    /* ── BOTÃO TELEPORT (MODIFICADO) ── */
    .tp-btn {
        position: absolute; bottom: 10px; right: 10px;
        background: #ffcc00; border: none; border-radius: 8px;
        color: #000; padding: 8px 12px; font-size: 12px; font-weight: 600;
        display: flex; align-items: center; gap: 6px; cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.4); transition: all 0.2s;
    }

    .tp-btn:hover { transform: scale(1.05); background: #fff; }
    .tp-btn.loading { background: #555; color: #ccc; cursor: wait; }
    
    .tp-btn.loading::before {
        content: ""; width: 12px; height: 12px;
        border: 2px solid #ccc; border-top-color: transparent;
        border-radius: 50%; animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .card-body { padding: 15px; }
    .card-title { font-size: 15px; font-weight: 600; color: #ffcc00; margin-bottom: 8px; line-height: 1.2; }
    .card-desc { font-size: 13px; color: #bbb; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .layout-btn {
        background: rgba(255,255,255,0.05); border: 1px solid #444;
        color: #888; padding: 6px 12px; border-radius: 6px; cursor: pointer;
    }
    .layout-btn.active { color: #ffcc00; border-color: #ffcc00; background: rgba(255,204,0,0.1); }
</style>

<div id="freebies-overlay-container">
    <div class="freebies-header">
        <button class="header-back" onclick="closeSubMenu()">← Voltar</button>
        <h1>✦ Freebies & Deals</h1>
        <div style="display:flex; align-items:center; gap:20px;">
            <span id="item-count" style="font-size: 12px; color: #666; letter-spacing: 1px;"></span>
            <div id="layout-btns" style="display: flex; gap: 8px;">
                <button class="layout-btn" onclick="setFreebiesLayout(2)">2</button>
                <button class="layout-btn" onclick="setFreebiesLayout(3)">3</button>
                <button class="layout-btn active" onclick="setFreebiesLayout(4)">4</button>
            </div>
        </div>
    </div>

    <div id="freebies-grid-scroll">
        <div id="loading-freebies" style="text-align: center; margin-top: 150px;">
            <div style="font-size: 40px; animation: spin 2s linear infinite;">✦</div>
            <p style="color: #666; margin-top: 15px; letter-spacing: 2px;">A sintonizar ofertas...</p>
        </div>
        <div id="freebies-grid" style="display:none;"></div>
    </div>
</div>

<script>
(function() {
    const TP_ICON = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`;

    window.setFreebiesLayout = function(cols) {
        $('#freebies-grid').css('grid-template-columns', `repeat(${cols}, 1fr)`);
        $('.layout-btn').removeClass('active');
        $(`.layout-btn`).each(function() {
            if($(this).text() == cols) $(this).addClass('active');
        });
        localStorage.setItem('freebies_cols', cols);
    };

    // FUNÇÃO ON-DEMAND: Agora chama a API para extrair o SLURL no clique
    window.handleFreebieTeleport = async function(articleUrl, btnId) {
        const $btn = $(`#${btnId}`);
        if ($btn.hasClass('loading')) return;

        try {
            $btn.addClass('loading').html('A procurar...');
            
            // Chama o endpoint de extração que criámos no servidor
            const response = await fetch(`/api/freebies/teleport?articleUrl=${encodeURIComponent(articleUrl)}`);
            const data = await response.json();

            if (data.teleportUrl) {
                // Envia para o servidor da TV para executar o comando LSL
                $.post('/send-command', { command: 'teleport', value: data.teleportUrl });
                $btn.html(TP_ICON + ' Sucesso!').css('background', '#4CAF50');
                setTimeout(() => $btn.removeClass('loading').html(TP_ICON + ' Teleport').css('background', ''), 3000);
            } else {
                alert("Não foi possível encontrar o link de teleport neste site.");
                $btn.removeClass('loading').html(TP_ICON + ' Teleport');
            }
        } catch (e) {
            console.error("Erro no teleport:", e);
            $btn.removeClass('loading').html(TP_ICON + ' Erro');
        }
    };

    function buildFreebieCard(item, index) {
        const btnId = `fb-tp-${index}`;
        return `
            <div class="freebie-card">
                <div class="card-img-wrap" onclick="window.open('${item.url}', '_blank')">
                    <img src="${item.image || ''}" onerror="this.src='./img/no_image.png'">
                    <button id="${btnId}" class="tp-btn" 
                        onclick="handleFreebieTeleport('${item.url}', '${btnId}'); event.stopPropagation();">
                        ${TP_ICON} Teleport
                    </button>
                </div>
                <div class="card-body">
                    <div class="card-title">${item.title}</div>
                    <div class="card-desc">${item.desc || 'Sem descrição disponível.'}</div>
                </div>
            </div>
        `;
    }

    window.closeOverlay = function() {
        $('#freebies-overlay-container').fadeOut(300, function() { $(this).remove(); });
    };

    async function initFreebies() {
        try {
            const res = await fetch('/api/freebies');
            const items = await res.json();

            $('#loading-freebies').hide();
            
            if (items && items.length) {
                $('#item-count').text(`${items.length} OFERTAS`);
                const html = items.map((item, idx) => buildFreebieCard(item, idx)).join('');
                $('#freebies-grid').html(html).fadeIn();
                
                const savedCols = localStorage.getItem('freebies_cols') || 4;
                setFreebiesLayout(savedCols);
            }
        } catch (e) {
            $('#loading-freebies').html('<p style="color:red;">Falha na conexão com o servidor.</p>');
        }
    }

    initFreebies();
})();
</script>