<style>
    /* 1. Wrapper to activate the Goldenrod Theme */
    #sl-radio-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: fadeIn 0.4s ease-out;
    }


    /* 3. Title Styling */
    #sl-radio-wrapper #title {
        font-size: 42px;
        color: var(--accent, goldenrod);
        text-transform: uppercase;
        margin-bottom: 20px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Grid Container */
    #sl-radio-wrapper .conteiner {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important; /* Two columns for now */
        gap: 25px !important;
        width: 600px !important; /* Narrower because there are only 2 buttons */
        padding: 100px;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* 5. Radio Root Buttons */
    #sl-radio-wrapper .btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px); 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 40px 20px !important;
        font-size: 22px;
        color: white !important;
        text-align: center;
        display: flex !important;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }


    /* Hide scrollbar */
    #sl-radio-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }


/* Sync the remote hover to match the Goldenrod theme */
/* --- MULTI-USER SYNC --- */

/* Golden highlight for remote users on Radio buttons */
#sl-radio-wrapper .btn.remote-hover {
        backdrop-filter: blur(15px) !important; 
        border: 1px solid white !important; 
        background-color: rgba(0, 0, 0, 0.5) !important; 
        color: white !important; 
        font-size: 1.35rem; 
        transform: scale(1.1); 
        z-index: 100; 
        transition: all 0.1s ease-in-out; 
}


</style>

<div id="sl-radio-wrapper">
    
            <div class="close-menu-btn" onclick="closeSubMenu()">
        <span style="font-size: 25px;" class="material-symbols-rounded">close</span>
    </div>

  

    <div class="conteiner">

        <div data-type="radio-root" data-mode="sl" class="btn" tabindex="1">
            Second Life Radios
        </div>  

        <div data-type="radio-root" data-mode="inter" class="btn" tabindex="2">
            World Radios
        </div>  
    </div>

</div>