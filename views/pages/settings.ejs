<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TV Premium Settings</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

<style>
    :root { 
        --accent: #ffa260; 
        --success: #2ecc71; 
        --error: #ff6b6b;
        --bg-panel: rgba(20, 20, 20, 0.55); 
        --glass-border: #ffffff6b;
        --text-main: #fff;
        --sidebar-width: 280px;
    }

    * { box-sizing: border-box; outline: none; margin: 0; padding: 0; }

    #settings_wrapper { 
        width: 1280px; height: 720px; color: var(--text-main); 
        font-family: 'Inter', sans-serif; position: relative; overflow: hidden; 
        display: flex; flex-direction: column;
        background: radial-gradient(circle at top right, rgba(45,30,20,0.5), rgba(5,5,5,0.95)); 
    }

    #main_header_area {
        flex-shrink: 0; height: 80px; display: flex; align-items: center; justify-content: flex-start;
        padding: 0 30px; border-bottom: 1px solid var(--glass-border); z-index: 20;
        background: rgba(0,0,0,0.4);
    }

    #main_header { text-align: center; font-size: 22px; color: #fff; text-transform: uppercase; letter-spacing: 2px; font-weight: 600; }
    #main_header span { color: var(--accent); }

    #connection-container {
        display: flex; align-items: center; gap: 10px;
        padding: 6px 14px; background: rgba(255,255,255,0.03);
        border-radius: 20px; border: 1px solid rgba(255,255,255,0.05);
    }

    #status-dot { width: 8px; height: 8px; background: var(--error); border-radius: 50%; box-shadow: 0 0 8px var(--error); }
    .online-active #status-dot { background: var(--success); box-shadow: 0 0 12px var(--success); }

    #workspace { display: flex; flex-grow: 1; height: 640px; overflow: hidden; }

    #sidebar {
        width: var(--sidebar-width); background: rgba(0, 0, 0, 0.3);
        border-right: 1px solid var(--glass-border); padding: 25px 15px;
        display: flex; flex-direction: column; gap: 8px; flex-shrink: 0;
    }

    .tab-btn {
        display: flex; align-items: center; gap: 14px; width: 100%;
        padding: 14px 18px; background: transparent; border: none;
        border-radius: 14px; color: rgba(255,255,255,0.6); font-family: 'Inter', sans-serif;
        font-size: 14px; font-weight: 500; text-align: left; cursor: pointer; transition: all 0.2s ease;
    }
    .tab-btn:hover { color: #fff; background: rgba(255,162,96,0.05); }
    .tab-btn.active {
        color: #000; background: var(--accent); font-weight: 600;
        box-shadow: 0 4px 20px rgba(255,162,96,0.25);
    }
    .tab-btn .material-symbols-rounded { font-size: 22px; }

    #content_area {
        flex-grow: 1; width: calc(1280px - var(--sidebar-width)); height: 100%;
        padding: 20px 100px; overflow: hidden; position: relative;
    }

    .conteiner-col { 
        display: none; width: 100%; height: 100%; gap: 70px; 
    }
    .conteiner-col.active { display: flex; animation: fadeIn 0.25s ease-out; }

    .sub-panel {
        flex: 1; background: black; border: 1px solid var(--glass-border);
        border-radius: 20px; padding: 20px 25px; display: flex; flex-direction: column;
        justify-content: flex-start; height: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: scale(0.99); }
        to { opacity: 1; transform: scale(1); }
    }

    .section-title { 
        text-align: left; margin-bottom: 8px; font-weight: 600; font-size: 14px;
        color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em;
        border-bottom: 2px solid #ffa260; padding-bottom: 6px;
    }

    .btn1 { 
        display: block; width: 100%; margin: 4px 0; padding: 11px 14px; 
        font-size: 14px; font-weight: 500; color: #fff; 
        background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border);
        border-radius: 10px; cursor: pointer; transition: all 0.15s ease;
        font-family: 'Inter', sans-serif;
    }
    .btn1:hover { background: rgba(255,162,96,0.08); color: var(--accent); border-color: rgba(255,162,96,0.25); }
    .btn1.active::before {
        content: ''; display: inline-block; width: 6px; height: 6px;
        border-radius: 50%; background: var(--accent); margin-right: 8px;
        vertical-align: middle; box-shadow: 0 0 6px var(--accent);
    }

    .btn2 { 
        padding: 10px; font-size: 14px; font-weight: 500; color: #fff; 
        background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border);
        border-radius: 8px; cursor: pointer; transition: 0.15s; font-family: 'Inter', sans-serif;
    }
    .btn2:hover {background: rgba(255,162,96,0.08); color: var(--accent); border-color: rgba(255,162,96,0.25); }

    .sent { background: var(--success) !important; color: #000 !important; font-weight: 600; }

    /* Estilos Corrigidos da Grelha de Cores */
.color-grid-static {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.color-square {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    border: 2px solid transparent;
    cursor: pointer;
}
    .color-square:hover { transform: scale(1.08); }
    .color-square.selected { border-color: #fff; box-shadow: 0 0 8px rgba(255,255,255,0.4); }

    .label-mini { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; margin: 12px 0 6px 2px; display: block; }

    .btn-group { 
        display: flex; 
        margin: 0px 0px; 
        background: rgba(0,0,0,0.2); 
        border-radius: 10px; 
        padding: 3px; 
        gap: 10px;
    }

    .btn-split { flex: 1; padding: 9px 0; font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6); background: transparent; border: none; cursor: pointer; font-family: 'Inter', sans-serif; border-radius: 7px; }
    .btn-split.active { background: rgba(255,255,255,0.07); color: var(--accent); }
    .btn-center-label { flex: 1.2; text-align: center; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.7); text-transform: uppercase; }

    .divider { height: 1px; background: var(--glass-border); margin: 12px 0; }

    .ctrl-row { display: flex; align-items: stretch; margin-bottom: 10px; background: rgba(0,0,0,0.2); border-radius: 10px; padding: 6px; border: 1px solid var(--glass-border); }
    .btn-adj { width: 36px; height: 36px; font-size: 20px; font-weight: 700; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.02); border: none; border-radius: 6px; cursor: pointer; }
    .btn-adj:hover { background: rgba(255,162,96,0.12); color: var(--accent); }

    .btn-value { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .val-top { display: flex; align-items: center; gap: 6px; }
    .swatch-mini { width: 10px; height: 10px; border-radius: 3px; }
    .val-pct { font-size: 16px; font-weight: 600; color: var(--accent); }
    .val-sub { font-size: 12px; color: rgba(255,255,255,0.75); text-transform: uppercase; }

    .onoff-row, .neon-state-row { display: flex; gap: 6px; }
    .btn-half, .btn-third { flex: 1; padding: 9px; font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 8px; cursor: pointer; }
    .btn-half.active, .btn-third.active { background: var(--accent); color: #000; border-color: var(--accent); }

    .close-menu-btn {
        width: 40px; height: 40px; background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);
        border-radius: 10px; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer;
    }
    .close-menu-btn:hover { background: #ff6b6b; border-color: #ff6b6b; }
    
    .legs-row {
    display: flex;
    gap: 10px;
    margin-top: 4px;
}

.legs-row .btn1 {
    flex: 1;
    margin: 0;
}
</style>
</head>
<body>
<div id="settings_wrapper">
    
    <!-- Top Header Bar -->
    <div id="main_header_area">
        <div id="connection-container">
            <div id="status-dot"></div>
            <div id="tv-info">
                <span id="status-text" style="font-size:11px; font-weight:600; color:var(--error);">OFFLINE</span>
            </div>
        </div>
        <h1 id="main_header">Premium TV <span>Settings</span></h1>
        <div class="close-menu-btn" onclick="closeSubMenu()">
            <span class="material-symbols-rounded">close</span>
        </div>
    </div>

    <!-- Main Workspace Setup -->
    <div id="workspace">
        
        <!-- Left Navigation Sidebar -->
        <div id="sidebar">
            <button class="tab-btn active" onclick="switchTab('frame', this)">
                <span class="material-symbols-rounded">layers</span> DESIGN & STYLE
            </button>
            <button class="tab-btn" onclick="switchTab('size', this)">
                <span class="material-symbols-rounded">aspect_ratio</span> SHAPE & SIZE
            </button>
            <button class="tab-btn" onclick="switchTab('lighting', this)">
                <span class="material-symbols-rounded">wb_incandescent</span> AMBILIGHT & NEON
            </button>
            <button class="tab-btn" onclick="switchTab('security', this)">
                <span class="material-symbols-rounded">shield</span> SECURITY SYSTEM
            </button>
            <button class="tab-btn" onclick="switchTab('position', this)">
                <span class="material-symbols-rounded">open_with</span> POSITION PANEL
            </button>
                        <button class="tab-btn" onclick="switchTab('system', this)">
                <span class="material-symbols-rounded">settings_cinematic_blur</span> SYSTEM
            </button>
        </div>

        <!-- Right Content Panels Area -->
        <div id="content_area">

            <!-- Tab 1: Frame Design -->
            <div id="tab-frame" class="conteiner-col active">
                <div class="sub-panel">

                    <p class="section-title">STAND MODEL</p>
                    <button onclick="setActive('model',this);cmd('model','model1')" class="btn1" data-group="model">MODEL 1</button>
                    <button onclick="setActive('model',this);cmd('model','model2')" class="btn1" data-group="model">MODEL 2</button>
                    <button onclick="setActive('model',this);cmd('model','model3')" class="btn1" data-group="model">MODEL 3</button>

                    <p class="section-title" style="margin-top: 25px;">TV Texture</p>
                    <button onclick="setActive('texture',this); cmd('texture','369104f6-cb0e-4920-a41a-ac2f8c42337e',this)" class="btn1" data-group="texture">CARBON FIBER</button>
                    <button onclick="setActive('texture',this); cmd('texture','<0.176, 0.176, 0.176>',this)"  class="btn1" data-group="texture">MATTE BLACK</button>
                    <button onclick="setActive('texture',this); cmd('texture','704acfcc-dade-771a-c943-c295b464e2d9',this)"  class="btn1" data-group="texture">WOOD</button>

                    <p class="section-title" style="margin-top:25px;">STAND MODE</p>
                    <div class="legs-row">
                    <button class="btn1" id="legs-1" onclick="setLegs('show',this)" data-group="legs">STAND</button>
                    <button class="btn1" id="legs-2" onclick="setLegs('hide',this)" data-group="legs">WALL</button>
                    </div>
                </div>
                <div class="sub-panel">
                                        <!-- CONTAINER DA GRELHA DE CORES DE FUNDO DEVOLVIDO AQUI-->
                    <p class="section-title">BACK COLOR</p>
                    <div id="grid-back" class="color-grid-static" style="margin-top: 3px;">
                        <div class="color-square" style="background:#1a1a1a;" onclick="cmd('back_color','<0.10,0.10,0.10>')"></div>
                        <div class="color-square" style="background:#333333;" onclick="cmd('back_color','<0.20,0.20,0.20>')"></div>
                        <div class="color-square" style="background:#7f8c8d;" onclick="cmd('back_color','<0.50,0.55,0.56>')"></div>
                        <div class="color-square" style="background:#2c3e50;" onclick="cmd('back_color','<0.17,0.24,0.31>')"></div>
                        <div class="color-square" style="background:#c0392b;" onclick="cmd('back_color','<0.75,0.22,0.17>')"></div>

                        <div class="color-square" style="background:#d35400;" onclick="cmd('back_color','<0.83,0.33,0.00>')"></div>
                        <div class="color-square" style="background:#f1c40f;" onclick="cmd('back_color','<0.95,0.77,0.06>')"></div>
                        <div class="color-square" style="background:#27ae60;" onclick="cmd('back_color','<0.15,0.68,0.38>')"></div>
                        <div class="color-square" style="background:#2980b9;" onclick="cmd('back_color','<0.16,0.50,0.73>')"></div>
                        <div class="color-square" style="background:#8e44ad;" onclick="cmd('back_color','<0.56,0.27,0.68>')"></div>
                    </div>

                    <p class="section-title" style="margin-top: 25px;">Set Back Alpha</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px;margin-top: 4px;">
                        <button onclick="cmd('back_alpha','0.0',this)" class="btn2">0%</button>
                        <button onclick="cmd('back_alpha','0.1',this)" class="btn2">10%</button>
                        <button onclick="cmd('back_alpha','0.2',this)" class="btn2">20%</button>
                    </div>

                    <p style="margin-top: 25px;" class="section-title">Webscreen Alpha</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px;margin-top: 4px;">
                        <button onclick="cmd('web_alpha','0.0',this)" class="btn2">0%</button>
                        <button onclick="cmd('web_alpha','0.1',this)" class="btn2">10%</button>
                        <button onclick="cmd('web_alpha','0.2',this)" class="btn2">20%</button>
                    </div>

                    <p class="section-title" style="margin-top: 25px;">FRAME MODE</p>
                    <div class="legs-row">
                        <button class="btn1" id="frame-1" onclick="setFrame('show',this)" data-group="frame">SHOW</button>
                        <button class="btn1" id="frame-2" onclick="setFrame('hide',this)" data-group="frame">HIDE</button>
                    </div>

                    <div style="margin-top: auto;">
                        <button onclick="cmd('reset','visual')" class="btn1" style="font-size:14px; border-color:var(--accent); text-align: center; margin:0;">FACTORY DEFAULT</button>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Lighting -->
            <div id="tab-lighting" class="conteiner-col">
                                <div class="sub-panel">
                    <p class="section-title" ">LIGHT SWITCH</p>
                    <div class="onoff-row">
                        <button class="btn-half" active id="ambi-off" onclick="setAmbi('off')">OFF</button>
                        <button class="btn-half" id="ambi-on"  onclick="setAmbi('on')">ON</button>
                        <button class="btn-half" id="ambi-cycle"  onclick="setAmbi('cycle')">CYCLE</button>
                    </div>

                    <p class="section-title" style="margin-top: 25px;">NEON SWITCH</p>
                    <div class="neon-state-row">
                        <button class="btn-third active" id="neon-off"   onclick="setNeon('off')">OFF</button>
                        <button class="btn-third"         id="neon-fixed" onclick="setNeon('fixed')">FIXED</button>
                        <button class="btn-third"         id="neon-cycle" onclick="setNeon('cycle')">CYCLE</button>
                    </div>
 
                    <p class="section-title" style="margin-top: 25px;">CYCLE SPEED</p>
                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustSpeed(-0.05)">−</button>
                        <div class="btn-value">
                            <div class="val-top">
                                <div class="swatch-mini" id="neon-dot"></div>
                                <span class="val-pct" id="neon-pct">—</span>
                            </div>
                            <span class="val-sub" id="neon-sub">color</span>
                        </div>
                        <button class="btn-adj" onclick="adjustSpeed(0.05)">+</button>
                    </div>

               </div>
                <div class="sub-panel">
                    <p class="section-title">Ambilight Glow</p>
                    <span class="label-mini">Color Palette</span>
                    
                    <!-- CONTAINER DA GRELHA DE CORES AMBILIGHT DEVOLVIDO AQUI -->
                    <div id="grid-light" class="color-grid-static">
                        <div class="color-square" data-color="#ffffff" style="background:#ffffff;"></div>
                        <div class="color-square" data-color="#ffaa00" style="background:#ffaa00;"></div>
                        <div class="color-square" data-color="#ff0000" style="background:#ff0000;"></div>
                        <div class="color-square" data-color="#ff00ff" style="background:#ff00ff;"></div>
                        <div class="color-square" data-color="#0000ff" style="background:#0000ff;"></div>

                        <div class="color-square" data-color="#00ffff" style="background:#00ffff;"></div>
                        <div class="color-square" data-color="#00ff00" style="background:#00ff00;"></div>
                        <div class="color-square" data-color="#ffff00" style="background:#ffff00;"></div>
                        <div class="color-square" data-color="#ff5500" style="background:#ff5500;"></div>
                        <div class="color-square" data-color="#7a00ff" style="background:#7a00ff;"></div>
                    </div>

                    <p class="section-title" style="margin-top: 25px;">LIGHT CONTROLLERS</p>
                    <div class="ctrl-row">
                     
                        <button class="btn-adj" onclick="adjustInt(-0.1)">−</button>
                        <div class="btn-value">
                            <div class="val-top">
                                <span class="val-pct" id="ambi-pct">50%</span>
                            </div>
                            <span class="val-sub">intensity</span>
                        </div>
                        <button class="btn-adj" onclick="adjustInt(0.1)">+</button>
                    </div>

                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustRange(-0.1)">−</button>
                        <div class="btn-value">
                            <span class="val-pct" id="range-pct">50%</span>
                            <span class="val-sub">range</span>
                        </div>
                        <button class="btn-adj" onclick="adjustRange(0.1)">+</button>
                    </div>

                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustFall(-0.1)">−</button>
                        <div class="btn-value">
                            <span class="val-pct" id="fall-pct">50%</span>
                            <span class="val-sub">fall</span>
                        </div>
                        <button class="btn-adj" onclick="adjustFall(0.1)">+</button>
                    </div>

                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustGlow(-0.1)">−</button>
                        <div class="btn-value">
                            <span class="val-pct" id="glow-pct">50%</span>
                            <span class="val-sub">glow</span>
                        </div>
                        <button class="btn-adj" onclick="adjustGlow(0.1)">+</button>
                    </div>

                                        <div style="margin-top: auto;">
                        <button onclick="cmd('reset','size')" class="btn1" style="font-size:14px; border-color:var(--accent); text-align: center; margin:0;">FACTORY DEFAULT</button>
                    </div>
                </div>

            </div>

            <!-- Tab 3: Shape & Size -->
            <div id="tab-size" class="conteiner-col">
                <div class="sub-panel">
                    <p class="section-title">Scale Control</p>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:6px;margin-top: 4px;">
                        <button onclick="cmd('SCALE','-0.01',this)" class="btn2">−1%</button>
                        <button onclick="cmd('SCALE','0.01',this)" class="btn2">1%</button>
                        <button onclick="cmd('SCALE','-0.05',this)" class="btn2">−5%</button>
                        <button onclick="cmd('SCALE','0.05',this)"  class="btn2">+5%</button>
                        <button onclick="cmd('SCALE','-0.10',this)" class="btn2">−10%</button>
                        <button onclick="cmd('SCALE','0.10',this)"  class="btn2">+10%</button>
                        <button onclick="cmd('SCALE','-0.20',this)" class="btn2">−20%</button>
                        <button onclick="cmd('SCALE','0.20',this)"  class="btn2">+20%</button>
                    </div>

                    <p class="section-title" style="margin-top: 25px;">PRESET SCALES</p>
                    <button onclick="setActive('env',this);cmd('PRESET','house',this)"   class="btn1" data-group="env">HOUSE SCALE</button>
                    <button onclick="setActive('env',this);cmd('PRESET','outside',this)" class="btn1" data-group="env">OUTSIDE SCALE</button>
                    <button onclick="setActive('env',this);cmd('PRESET','cinema',this)"  class="btn1" data-group="env">CINEMA SCALE</button>
                </div>
                <div class="sub-panel">
                    <p class="section-title">Shape Aspect Ratio</p>
                    <button onclick="setActive('ratio',this);cmd('ratio','1/1',this)"  class="btn1" data-group="ratio">1:1 - SQUARE</button>
                    <button onclick="setActive('ratio',this);cmd('ratio','3/2',this)"  class="btn1" data-group="ratio">3:2 - CLASSIC</button>
                    <button onclick="setActive('ratio',this);cmd('ratio','4/3',this)"  class="btn1" data-group="ratio">4:3 - RETRO</button>
                    <button onclick="setActive('ratio',this);cmd('ratio','16/9',this)" class="btn1" data-group="ratio">16:9 - FULL HD</button>
                    <button onclick="setActive('ratio',this);cmd('ratio','21/9',this)" class="btn1" data-group="ratio">21:9 - CINEMA SCOPE</button>
                    <button onclick="setActive('ratio',this);cmd('ratio','32/9',this)"  class="btn1" data-group="ratio">32:9 - DUAL ULTRAWIDE</button>
             
                    <div style="margin-top: auto;">
                        <button onclick="cmd('reset','size')" class="btn1" style="font-size:14px; border-color:var(--accent); text-align: center; margin:0;">FACTORY DEFAULT</button>
                    </div>
            
                </div>
           </div>

            <!-- Tab 4: System -->
            <div id="tab-system" class="conteiner-col" style="width: 400px;margin: auto;">
                <div class="sub-panel" >
                    <p class="section-title">Reset Scripts</p>
                        <button onclick="cmd('legs','hide',this)" class="btn1">DEFAULT SETTING</button>
                        <button onclick="cmd('fullreset','',this)" class="btn1">RESET SCRIPTS</button>
                        <button onclick="cmd('kill','',this)" class="btn1">DELETE TV</button>
                </div>
            </div>
          
            <!-- Tab 5: Security -->
            <div id="tab-security" class="conteiner-col">
                <div class="sub-panel" style="max-width: 600px; margin: 0 auto;">
                 
                    <p class="section-title">HOUSE ALARME </p>
                    <div class="btn-group">
                        <button onclick="setActive('alert',this);cmd('alert','off',this)" class="btn1" data-group="alert">DISABLE</button>
                        <button onclick="setActive('alert',this);cmd('alert','on',this)" class="btn1 active" data-group="alert">ENABLE</button>
                    </div>
                    <p class="section-title" style="margin-top: 25px;">LOCK TV </p>
                    <div class="btn-group">
                        <button onclick="setActive('lock',this);cmd('lock','off',this)" class="btn1 active" data-group="lock">UNLOCK</button>
                        <button onclick="setActive('lock',this);cmd('lock','on',this)" class="btn1" data-group="lock">LOCK</button>
                    </div>
                    <p class="section-title" style="margin-top: 25px;">NAV BAR </p>
                    <div class="btn-group">
                        <button onclick="setActive('lock',this);cmd('browser','hide')" class="btn1 active" data-group="lock">HIDE</button>
                        <button onclick="setActive('lock',this);cmd('browser','show',this)" class="btn1" data-group="lock">SHOW</button>
                    </div>
                    
                    <p class="hint-text" style="color: rgba(255,255,255,0.3); font-size:13px; margin-top:20px; text-align:center; line-height:1.6;">
                        Locking the TV restricts browser access and playback controls exclusively to the device owner.
                    </p>
                </div>
            </div>

            <!-- Tab 6: Position & Rotation -->
            <div id="tab-position" class="conteiner-col">
                <div class="sub-panel">
                    <p class="section-title">Position Control</p>
                    
                    <span class="label-mini">X Position (Left/Right)</span>
                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustPosX(-0.02)">−</button>
                        <div class="btn-value"><span class="val-pct" id="pos-x">0.0</span><span class="val-sub">meters</span></div>
                        <button class="btn-adj" onclick="adjustPosX(0.02)">+</button>
                    </div>

                    <span class="label-mini">Y Position (Forward/Back)</span>
                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustPosY(-0.02)">−</button>
                        <div class="btn-value"><span class="val-pct" id="pos-y">0.0</span><span class="val-sub">meters</span></div>
                        <button class="btn-adj" onclick="adjustPosY(0.02)">+</button>
                    </div>

                    <span class="label-mini">Z Position (Up/Down)</span>
                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustPosZ(-0.02)">−</button>
                        <div class="btn-value"><span class="val-pct" id="pos-z">0.0</span><span class="val-sub">meters</span></div>
                        <button class="btn-adj" onclick="adjustPosZ(0.02)">+</button>
                    </div>
                </div>
                <div class="sub-panel">
                    <p class="section-title">Rotation</p>
                    <span class="label-mini">Horizontal (Y-Axis)</span>
                    <div class="ctrl-row">
                        <button class="btn-adj" onclick="adjustRotY(-1)">−1°</button>
                        <div class="btn-value"><span class="val-pct" id="rot-y">0°</span><span class="val-sub">degrees</span></div>
                        <button class="btn-adj" onclick="adjustRotY(1)">+1°</button>
                    </div>

                    <div style="margin-top: auto; display: flex; gap: 10px;">
                        <button onclick="resetPos()" class="btn1" style="font-size:12px; border-color:var(--accent); text-align: center; margin: 0; flex: 1;">RESET POS</button>
                        <button onclick="resetRot()" class="btn1" style="font-size:12px; border-color:var(--accent); text-align: center; margin: 0; flex: 1;">RESET ROT</button>
                    </div>
                </div>
            </div>
            
  </div>
        </div>
    </div>
</div>


<script>
    const TV_ID = "<%= tvId %>";

    function switchTab(tabId, el) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.conteiner-col').forEach(panel => panel.classList.remove('active'));
        
        el.classList.add('active');
        document.getElementById('tab-' + tabId).classList.add('active');
    }


    let selectedHex = null;
    let ambiOn      = false;
    let ambiInt     = 0.5;
    let neonState   = 'off';
    let neonSpeed   = 0.10;
    let fallValue  = 0.5;
     let glowValue  = 0.5;
    let rangeValue = 0.5;

    window.adjustFall = function(v) {
        fallValue = Math.min(1.0, Math.max(0.1, +(fallValue + v).toFixed(1)));
        document.getElementById('fall-pct').textContent = Math.round(fallValue * 100) + '%';
        cmd('ambi_fall', fallValue.toFixed(1));
    };
    window.adjustRange = function(v) {
        rangeValue = Math.min(1.0, Math.max(0.1, +(rangeValue + v).toFixed(1)));
        document.getElementById('range-pct').textContent = Math.round(rangeValue * 100) + '%';
        cmd('ambi_range', rangeValue.toFixed(1));
    };
    window.adjustGlow = function(v) {
        glowValue = Math.min(1.0, Math.max(0.1, +(glowValue + v).toFixed(1)));
        document.getElementById('glow-pct').textContent = Math.round(glowValue * 100) + '%';
        cmd('GLOW_ON', glowValue.toFixed(1));
    };

    function hexToSL(hex) {
        const r = (parseInt(hex.slice(1,3),16)/255).toFixed(2);
        const g = (parseInt(hex.slice(3,5),16)/255).toFixed(2);
        const b = (parseInt(hex.slice(5,7),16)/255).toFixed(2);
        return '<'+r+','+g+','+b+'>';
    }

    function speedPct() {
        return Math.round((1 - (neonSpeed - 0.02) / (0.5 - 0.02)) * 99) + 1;
    }

    function updateUI() {
        const hex = selectedHex || '#333333';


        document.getElementById('ambi-pct').textContent = Math.round(ambiInt * 100) + '%';
        document.getElementById('ambi-on').classList.toggle('active', ambiOn);
        document.getElementById('ambi-off').classList.toggle('active', !ambiOn);
        document.getElementById('fall-pct').textContent = Math.round(fallValue * 100) + '%';
        document.getElementById('range-pct').textContent = Math.round(rangeValue * 100) + '%';

        const neonDot = document.getElementById('neon-dot');
        const neonPct = document.getElementById('neon-pct');
        const neonSub = document.getElementById('neon-sub');

        if (neonState === 'cycle') {
            neonDot.style.background = 'conic-gradient(#f00,#ff0,#0f0,#0ff,#00f,#f0f,#f00)';
            neonDot.style.borderRadius = '50%';
            neonPct.textContent = speedPct() + '%';
            neonSub.textContent = 'speed';
        } else if (neonState === 'fixed') {
            neonDot.style.background = hex;
            neonDot.style.borderRadius = '3px';
            neonPct.textContent = '—';
            neonSub.textContent = 'fixed color';
        } else {
            neonDot.style.background = '#333';
            neonDot.style.borderRadius = '3px';
            neonPct.textContent = '—';
            neonSub.textContent = 'off';
        }

        document.getElementById('neon-off').classList.toggle('active',   neonState === 'off');
        document.getElementById('neon-fixed').classList.toggle('active', neonState === 'fixed');
        document.getElementById('neon-cycle').classList.toggle('active', neonState === 'cycle');
    }

    window.setActive = function(group, el) {
        document.querySelectorAll(`[data-group="${group}"]`).forEach(b => b.classList.remove('active'));
        el.classList.add('active');
    };


    window.setLegs = function(value, el) {
        setActive('legs', el);
        cmd('legs', value);
    };
    
    window.setFrame = function(value, el) {
        setActive('frame', el);
        cmd('frame', value);
    };


    window.setAmbi = function(state) {
        updateUI();
        ambiOn=true;
        if (state === 'off') {
            cmd('LIGHT_OFF', '');
        } 
        else if (state === 'on') {
            if (selectedHex) cmd('LIGHT_ON', hexToSL(selectedHex));
        } 
        else if (state === 'cycle') {
            cmd('neon_speed', neonSpeed.toFixed(2));
            if (selectedHex) cmd('LIGHT_CYCLE', hexToSL(selectedHex));
        }
    };

    window.adjustInt = function(v) {
        ambiInt = Math.min(1.0, Math.max(0.1, +(ambiInt + v).toFixed(1)));
        updateUI();
        if (ambiOn && selectedHex) cmd('ambi_intensity', ambiInt.toFixed(1));
    };

    window.setNeon = function(state) {
        neonState = state;
        updateUI();
        if (state === 'off') {
            cmd('NEON_OFF', '');
        } 
        else if (state === 'fixed') {
            if (selectedHex) cmd('NEON_ON', hexToSL(selectedHex));
        } 
        else if (state === 'cycle') {
            cmd('neon_speed', neonSpeed.toFixed(2));
            if (selectedHex) cmd('NEON_CYCLE', hexToSL(selectedHex));
        }
    };

    window.adjustSpeed = function(v) {
        neonSpeed = Math.min(0.5, Math.max(0.02, +(neonSpeed + v).toFixed(2)));
        updateUI();
        if (neonState === 'cycle') cmd('neon_speed', neonSpeed.toFixed(2));
    };

    window.cmd = function(command, value, el) {
        if (!TV_ID || TV_ID === 'undefined') return;
        if (el) { $(el).addClass('sent'); setTimeout(() => $(el).removeClass('sent'), 300); }
        $.ajax({
            type: 'POST', url: '/send-command', contentType: 'application/json',
            data: JSON.stringify({ command, value, object_id: TV_ID }),
            success: function() {
                $('#connection-container').addClass('online-active');
                $('#status-text').text('ONLINE').css('color','#2ecc71');
            }
        });
    };


const lContainer = document.getElementById('grid-light');

if (lContainer) {
    const squares = lContainer.querySelectorAll('.color-square');

    squares.forEach(d => {
        d.onclick = () => {
            const hex = d.dataset.color;

            selectedHex = hex;

            squares.forEach(s => s.classList.remove('selected'));
            d.classList.add('selected');

            updateUI();

            if (ambiOn) {
                cmd('LIGHT_ON', hexToSL(hex));
            }

            if (neonState === 'fixed') {
                cmd('NEON_ON', hexToSL(hex));
            }
        };
    });
}
const first = lContainer.querySelector('.color-square');
if (first) first.classList.add('selected');
selectedHex = first?.dataset.color;
    

    $(document).ready(function() {
        updateUI();
    });

    let posX = 0.0; let posY = 0.0; let posZ = 0.0; let rotY = 0;
    window.adjustPosX = function(v) {
        posX = +(posX + v);
        document.getElementById('pos-x').textContent = posX.toFixed(2);
        cmd('pos_x', posX);
    };
    window.adjustPosY = function(v) {
        posY = +(posY + v)
        document.getElementById('pos-y').textContent = posY.toFixed(2);
        cmd('pos_y', posY);
    };
    window.adjustPosZ = function(v) {
        posZ = +(posZ + v)
        document.getElementById('pos-z').textContent = posZ.toFixed(2);
        cmd('pos_z', posZ);
    };
    window.adjustRotY = function(v) {
        rotY = (rotY + v) % 360;
        if (rotY < 0) rotY += 360;
        document.getElementById('rot-y').textContent = rotY + '°';
        cmd('rot_y', rotY.toString());
    };
    window.resetPos = function() {
        posX = 0.0; posY = 0.0; posZ = 0.0;
        document.getElementById('pos-x').textContent = '0.0';
        document.getElementById('pos-y').textContent = '0.0';
        document.getElementById('pos-z').textContent = '0.0';
        cmd('pos_reset', '0');
    };
    window.resetRot = function() {
        rotY = 0;
        document.getElementById('rot-y').textContent = '0°';
        cmd('rot_reset', '0');
    };
</script>
</body>
</html>