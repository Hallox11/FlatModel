        <a onclick="cmd('texture','14c859c9-b22a-d4b0-2ee5-f17b6edacd70',this)" class="btn">Texture 01</a>
        <a onclick="cmd('texture','5b76a72b-fcbb-83e5-6fe2-7cbb3d128601',this)" class="btn">Texture 02</a>
        <a onclick="cmd('texture','23d2f974-8e1a-8c32-f7e3-4f1f18117c50',this)" class="btn">Texture 03</a>
        <a onclick="cmd('texture','33a30f78-0f71-b4dc-243c-c45a29dd0348',this)" class="btn">Texture 04</a>
        <a onclick="cmd('texture','dca8b93b-ee7e-cea0-346f-1e78257c9828',this)" class="btn">Texture 05</a>
        <a onclick="cmd('texture','c3743161-f03a-9015-b614-f3fe0dc5aaa3',this)" class="btn">Texture 06</a>
    </div>

    <div class="conteiner2">
