        <a onclick="cmd('ratio','16/9',this)"  class="btn">16/9 fullHD</a>
        <a onclick="cmd('ratio','21/9',this)"  class="btn">21/9 Cinema</a>
        <a onclick="cmd('ratio','4/3',this)"   class="btn">4/3 oldTV</a>
        <a onclick="cmd('ratio','3/2',this)"  class="btn">3/2 35mm</a>
        <a onclick="cmd('ratio','16/10',this)"  class="btn">16/10 Cinema</a>
        <a onclick="cmd('ratio','4/3',this)"   class="btn">4/3 oldTV</a>
    </div>

    <div class="conteiner3">
        <p style="font-size:28px; text-align:center;">Portrait / Page</p>
        <a onclick="cmd('ratio','1/1',this)"   class="btn">1/1 square</a>
        <a onclick="cmd('ratio','9/16',this)"  class="btn">9/16 phone</a>
        <a onclick="cmd('ratio','A4',this)"    class="btn">A4 page</a>
        <a onclick="cmd('ratio','2/3',this)"   class="btn">2/3 Portaite 1</a>
        <a onclick="cmd('ratio','4/5',this)"  class="btn">4/5 Portait22</a>
        <a onclick="cmd('ratio','10/16',this)"    class="btn">10/16 Portait3</a>
    </div>

<div class="conteiner4">
        <p style="font-size:28px; text-align:center;">Mode</p>
        
        <div class="btn-group">
            <a onclick="cmd('wall','',this)" class="btn-split btn-left" title="Hide Legs">WALL</a>
            <a onclick="cmd('wall','',this)" class="btn-split btn-center">MODE</a>
            <a onclick="cmd('stand','',this)" class="btn-split btn-right" title="Show Legs">STAND</a>
        </div>
        <div class="btn-group">
            <a onclick="cmd('frame_0ff','',this)" class="btn-split btn-left" title="Hide Legs">HIDE</a>
            <a onclick="cmd('wall','',this)" class="btn-split btn-center">FRAME</a>
            <a onclick="cmd('frame_on','',this)" class="btn-split btn-right" title="Show Legs">SHOW</a>
        </div>
                <div class="btn-group">
            <a onclick="cmd('button_off','',this)" class="btn-split btn-left" title="Hide Legs">HIDE</a>
            <a onclick="cmd('wall','',this)" class="btn-split btn-center">BUTTONS</a>
            <a onclick="cmd('button_on','',this)" class="btn-split btn-right" title="Show Legs">SHOW</a>
        </div>


        <a onclick="cmd('reset','',this)" class="btn">RESET</a>
    </div>

    <!-- BOTÃO PARA FECHAR O OVERLAY -->
    <button class="close-btn" onclick="closeSubMenu()" tabindex="30">
        <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>
</div>

<script>
    (function() {
        const BASE_URL = "<%- baseUrl %>";
        var valWeb = 0.5, valScr = 0.5, bgIdx = 1;
        
        // ✅ ID vem diretamente do servidor — sem depender de sessão
        let myTvId = "<%- tvId %>" || null;

        if (myTvId && myTvId !== "null") {
            console.log("[Identity] Locked to TV ID:", myTvId);
        } else {
            console.error("[Identity] No TV ID found. Commands won't work.");
        }

        window.cmd = function(command, value, el) {
            if (!myTvId || myTvId === "null") {
                console.error("[CMD] No target TV. Aborting.");
                return;
            }
            if(el) {
                $(el).addClass('sent');
                setTimeout(() => { $(el).removeClass('sent'); }, 200);
            }

            $.ajax({
                type: 'POST',
                url: BASE_URL + '/send-command',
                contentType: 'application/json',
                data: JSON.stringify({ command, value, target_id: myTvId }),
                success: (res) => console.log('Command sent:', command),
                error: (x) => console.error('Error:', x.status)
            });
        };

        window.hide_web = function(dir, el) {
            valWeb = (dir === "UP") ? Math.min(1.0, +(valWeb + 0.1).toFixed(1)) : Math.max(0.2, +(valWeb - 0.1).toFixed(1));
            cmd('web_alpha', String(valWeb), el);
        };

        window.hide_scr = function(dir, el) {
            valScr = (dir === "UP") ? Math.min(1.0, +(valScr + 0.1).toFixed(1)) : Math.max(0.1, +(valScr - 0.1).toFixed(1));
            cmd('screen_alpha', String(valScr), el);
        };

        window.background = function(dir, el) {
            bgIdx = (dir === "UP") ? bgIdx + 1 : Math.max(1, bgIdx - 1);
            cmd('background', String(bgIdx), el);
        };

        window.closeSettings = function() {
            $('#overlay-content').fadeOut().html('');
            if(typeof socket !== 'undefined') {
                socket.emit('mirror_ajax_nav', { path: null, action: 'CLOSE' });
            }
        };
    })();
</script>