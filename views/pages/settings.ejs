<style>
    :root { 
        --accent: #ffa260; 
        --success: #2ecc71; 
        --error: #ff6b6b;
        --bg-panel: rgba(255, 255, 255, 0.03); 
        --glass-border: rgba(255, 255, 255, 0.08);
        --text-main: #fff;
    }

    * { box-sizing: border-box; outline: none; }

    #settings_wrapper { 
        width: 1280px; height: 720px; 
        color: var(--text-main); font-family: 'Poppins', sans-serif; 
        position: relative; overflow: hidden; display: flex; flex-direction: column; 
        box-shadow: inset 0 0 100px rgba(0,0,0,0.5);
        background: #0d0d0d;
    }

    #main_header_area {
        flex-shrink: 0; height: 90px; display: flex; align-items: center; justify-content: center;
        background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid var(--glass-border); z-index: 20;
    }

    #main_header { 
        font-size: 26px; color: var(--accent); text-transform: uppercase; 
        letter-spacing: 3px; font-weight: 600; margin: 0;
    }

    #connection-container {
        position: absolute; left: 30px; display: flex; align-items: center; gap: 12px;
        padding: 8px 15px; background: rgba(255,255,255,0.03); border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(5px);
    }

    #tv-info { display: flex; flex-direction: column; line-height: 1.2; }
    #status-text { font-size: 11px; font-weight: 800; color: var(--error); }
    #tv-location { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; }
    #status-dot { width: 8px; height: 8px; background: var(--error); border-radius: 50%; box-shadow: 0 0 8px var(--error); }

    .online-active #status-dot { background: var(--success); box-shadow: 0 0 12px var(--success); }
    .online-active #status-text { color: var(--success); }

    #settings_scroll_content {
        flex-grow: 1; overflow-y: auto; padding: 30px 40px;
        display: flex; gap: 20px; justify-content: center;
    }

    .conteiner-col { 
        width: 230px; background: var(--bg-panel); backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border); border-radius: 20px;
        padding: 20px; min-height: 520px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    }

    .section-title { 
        text-align: center; margin-bottom: 15px; font-weight: 600; font-size: 14px;
        color: rgba(255,255,255,0.9); border-bottom: 1px solid rgba(255,162,96,0.15);
        padding-bottom: 10px; text-transform: uppercase;
    }

    .btn1 { 
        display: block; width: 100%; margin: 5px 0px; padding: 10px; 
        font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.8); 
        background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); 
        border-radius: 12px; cursor: pointer; transition: all 0.3s ease;
    }

    .btn1:hover { background: rgba(255, 162, 96, 0.1) !important; color: var(--accent); }
    .sent { background: var(--success) !important; color: #000 !important; }

    /* Light System Controls */
    .light-ui-row { display: flex; align-items: center; justify-content: space-between; gap: 4px; margin-top: 10px; }
    .btn-light-io { flex: 2; font-size: 10px !important; font-weight: 700; background: rgba(255,162,96,0.05); }
    .light-active { background: var(--accent) !important; color: #000 !important; }
    .color-picker-box { width: 100%; height: 40px; border-radius: 12px; border: 1px solid var(--glass-border); background: #000; cursor: pointer; margin-top: 8px; }

    /* Groups */
    .btn-group { display: flex; margin: 12px 0; }
    .btn-split { flex: 1; padding: 12px 0; font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); cursor: pointer; }
    .btn-left { border-radius: 12px 0 0 12px; border-right: none; }
    .btn-right { border-radius: 0 12px 12px 0; border-left: none; }
    .btn-center { cursor: default; background: rgba(255, 162, 96, 0.05); color: var(--accent); border-left: none; border-right: none; flex: 1.2; text-align: center; display: flex; align-items: center; justify-content: center; font-size: 10px; }

    .btn-row-triple { display: flex; gap: 4px; margin-bottom: 4px; }
    .btn-mini-scale { flex: 1; padding: 8px 2px !important; font-size: 11px !important; }
</style>

<div id="settings_wrapper">
    <div id="main_header_area">
        <div id="connection-container">
            <div id="status-dot"></div>
            <div id="tv-info">
                <span id="status-text">OFFLINE</span>
                <small id="tv-location">Checking Status...</small>
            </div>
        </div>
        <h1 id='main_header'>TV Settings</h1>
    </div>

    <div id="settings_scroll_content">
        <div class="conteiner-col">
            <p class="section-title">Textures</p>
            <button onclick="cmd('texture','carbon',this)" class="btn1">Carbon</button>
            <button onclick="cmd('texture','gold',this)" class="btn1">Gold</button>
            <button onclick="cmd('texture','matte',this)" class="btn1">Matte</button>
            
            <p class="section-title" style="margin-top:20px">Ambient Light</p>
            <input type="color" id="light_hex" class="color-picker-box" onchange="syncLight()" value="#ffa260">
            <div class="light-ui-row">
                <button onclick="adjustLight(-0.1)" class="btn1" style="flex:1">-</button>
                <button id="light_toggle" onclick="toggleLight()" class="btn1 btn-light-io">LIGHT OFF</button>
                <button onclick="adjustLight(0.1)" class="btn1" style="flex:1">+</button>
            </div>
        </div>

        <div class="conteiner-col">
            <p class="section-title">Aspect Ratio</p>
            <button onclick="cmd('ratio','3/2',this)" class="btn1">3/2 Classic</button>
            <button onclick="cmd('ratio','4/3',this)" class="btn1">4/3 SDTV</button>
            <button onclick="cmd('ratio','16/9',this)" class="btn1">16/9 HDTV</button>
            <button onclick="cmd('ratio','18/9',this)" class="btn1">18/9 Wide</button>
            <button onclick="cmd('ratio','21/9',this)" class="btn1">21/9 Ultra</button>
        </div>

        <div class="conteiner-col">
            <p class="section-title">Scale Control</p>
            <div class="btn-row-triple">
                <button onclick="cmd('SCALE','0.05',this)" class="btn1 btn-mini-scale">+5%</button>
                <button onclick="cmd('SCALE','0.10',this)" class="btn1 btn-mini-scale">+10%</button>
                <button onclick="cmd('SCALE','0.20',this)" class="btn1 btn-mini-scale">+20%</button>
            </div>
            <div class="btn-row-triple">
                <button onclick="cmd('SCALE','-0.05',this)" class="btn1 btn-mini-scale">-5%</button>
                <button onclick="cmd('SCALE','-0.10',this)" class="btn1 btn-mini-scale">-10%</button>
                <button onclick="cmd('SCALE','-0.20',this)" class="btn1 btn-mini-scale">-20%</button>
            </div>
            <div style="margin-top: 15px;">
                <button onclick="cmd('PRESET','house',this)" class="btn1" style="color: var(--accent);">House</button>
                <button onclick="cmd('PRESET','outside',this)" class="btn1" style="color: var(--accent);">Outside</button>
                <button onclick="cmd('PRESET','cinema',this)" class="btn1" style="color: var(--accent);">Cinema</button>
            </div>
        </div>

        <div class="conteiner-col">
            <p class="section-title">Back & Alpha</p>
            <div class="btn-group">
                <button onclick="cmd('back_alpha','-0.1',this)" class="btn-split btn-left">-10</button>
                <div class="btn-split btn-center">BACK</div>
                <button onclick="cmd('back_alpha','+0.1',this)" class="btn-split btn-right">+10</button>
            </div>
            <div class="btn-group">
                <button onclick="cmd('screen_alpha','-0.1',this)" class="btn-split btn-left">-10</button>
                <div class="btn-split btn-center">SCREEN</div>
                <button onclick="cmd('screen_alpha','+0.1',this)" class="btn-split btn-right">+10</button>
            </div>
            <button onclick="cmd('screen_alpha_set','1.0',this)" class="btn1" style="font-size:11px;">SET SOLID SCREEN</button>
        </div>

        <div class="conteiner-col">
            <p class="section-title">System</p>
            <div class="btn-group">
                <button onclick="cmd('legs','hide',this)" class="btn-split btn-left">HIDE</button>
                <div class="btn-split btn-center">LEGS</div>
                <button onclick="cmd('legs','show',this)" class="btn-split btn-right">SHOW</button>
            </div>
            <div class="btn-group">
                <button onclick="cmd('frame','hide',this)" class="btn-split btn-left">HIDE</button>
                <div class="btn-split btn-center">FRAME</div>
                <button onclick="cmd('frame','show',this)" class="btn-split btn-right">SHOW</button>
            </div>
            <button onclick="cmd('reboot','',this)" class="btn1" style="color:#3498db; margin-top:20px;">RESTART</button>
            <button onclick="cmd('reset','',this)" class="btn1" style="color:#e74c3c;">RESET</button>
        </div>
    </div>
</div>

<script>
    const TV_ID = "<%= tvId %>";
    let lightPower = false;
    let lightInt = 0.6; // Intensidade padrão inicial

    function hexToSL(hex) {
        let r = parseInt(hex.slice(1, 3), 16) / 255;
        let g = parseInt(hex.slice(3, 5), 16) / 255;
        let b = parseInt(hex.slice(5, 7), 16) / 255;
        return `<${r.toFixed(2)},${g.toFixed(2)},${b.toFixed(2)}>`;
    }

    // FUNÇÃO PRINCIPAL: Agora ela monta a string COR + | + INTENSIDADE
window.syncLight = function() {
    if(!lightPower) return;
    const colorVector = hexToSL(document.getElementById('light_hex').value);
    
    // Força a string a ter o formato: <0,0,0>|0.60
    const intensityStr = parseFloat(lightInt).toFixed(2);
    const combinedValue = colorVector + "|" + intensityStr;
    
    window.cmd('LIGHT_ALL', combinedValue);
}

window.adjustLight = function(v) {
    lightInt = Math.min(Math.max(lightInt + v, 0.1), 1.0);
    if(lightPower) syncLight();
}

    window.toggleLight = function() {
        lightPower = !lightPower;
        const btn = document.getElementById('light_toggle');
        if(lightPower) {
            btn.classList.add('light-active');
            btn.innerText = "LIGHT ON";
            syncLight();
        } else {
            btn.classList.remove('light-active');
            btn.innerText = "LIGHT OFF";
            // Envia intensidade 0 para desligar completamente
            window.cmd('LIGHT_ALL', '<0,0,0>|0.0');
        }
    }



    // Ajax Core (Seu original)
    window.cmd = function(command, value, el) {
        if (!TV_ID || TV_ID === "undefined") return;
        if(el) { $(el).addClass('sent'); setTimeout(() => $(el).removeClass('sent'), 300); }
        $.ajax({
            type: 'POST', 
            url: '/send-command', 
            contentType: 'application/json',
            data: JSON.stringify({ command, value, object_id: TV_ID }),
            success: function() { setOnlineUI(); }
        });
    };

    function setOnlineUI(loc) {
        $('#connection-container').addClass('online-active');
        $('#status-text').text('ONLINE');
        if(loc) $('#tv-location').text('Region: ' + loc);
    }
</script>