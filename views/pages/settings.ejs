<style>
    /* Reset e Variáveis - Design Glassmorphism Moderno */
    :root { 
        --accent: #ffa260; 
        --success: #2ecc71; 
        --error: #ff6b6b;
        --bg-panel: rgba(255, 255, 255, 0.03); 
        --glass-border: rgba(255, 255, 255, 0.08);
        --text-main: #fff;
    }

    * { box-sizing: border-box; outline: none; }

    #settings_wrapper { 
        width: 1280px; 
        height: 720px; 
        color: var(--text-main); 
        font-family: 'Poppins', sans-serif; 
        position: relative; 
        background: rgba(0,0,0,0.9);
        overflow: hidden;
        display: flex;
        flex-direction: column; 
        box-shadow: inset 0 0 100px rgba(0,0,0,0.5);
    }

    /* Header Area */
    #main_header_area {
        flex-shrink: 0;
        height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        background: rgba(0, 0, 0, 0.3); 
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid var(--glass-border);
        z-index: 20;
    }

    #main_header { 
        font-size: 26px; 
        color: var(--accent); 
        text-transform: uppercase; 
        letter-spacing: 3px;
        font-weight: 600;
        margin: 0;
    }

    /* Connection Indicator UI */
    #connection-container {
        position: absolute;
        left: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 15px;
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(5px);
        transition: all 0.4s ease;
    }

    #tv-info { display: flex; flex-direction: column; line-height: 1.2; }
    #status-text { font-size: 11px; font-weight: 800; letter-spacing: 1px; color: var(--error); transition: color 0.4s ease; }
    #tv-location { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; }
    #status-dot { width: 8px; height: 8px; background: var(--error); border-radius: 50%; box-shadow: 0 0 8px var(--error); transition: all 0.4s ease; }

    /* Online State Class */
    .online-active #status-dot { background: var(--success); box-shadow: 0 0 12px var(--success); }
    .online-active #status-text { color: var(--success); }
    .online-active #connection-container { border-color: rgba(46, 204, 113, 0.2); background: rgba(46, 204, 113, 0.05); }

    /* Layout Columns */
    #settings_scroll_content {
        flex-grow: 1;
        overflow-y: auto; 
        padding: 40px 60px;
        display: flex;
        gap: 30px;
        justify-content: space-between;
    }

    .conteiner-col { 
        width: 275px; 
        background: var(--bg-panel); 
        backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border); 
        border-radius: 20px;
        padding: 25px; 
        min-height: 520px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    }

    .section-title { 
        text-align: center; margin-bottom: 25px; font-weight: 600; font-size: 16px;
        color: rgba(255,255,255,0.9); border-bottom: 1px solid rgba(255,162,96,0.15);
        padding-bottom: 12px; text-transform: uppercase;
    }

    .btn1 { 
        display: block; width: 100%; margin: 14px 0; padding: 14px; 
        font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.8); 
        background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); 
        border-radius: 12px; cursor: pointer; transition: all 0.3s ease;
        letter-spacing: 2px;
    }

    .btn1:hover { 
        background: rgba(235, 18, 18, 0.1) !important; 
        color: #777; }
    
    .sent { background: var(--success) !important; color: #000 !important; }

    .btn-group { display: flex; margin: 12px 0; }
    .btn-split { flex: 1; padding: 14px 0; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); cursor: pointer; }
    .btn-left { border-radius: 12px 0 0 12px; border-right: none; }
    .btn-right { border-radius: 0 12px 12px 0; border-left: none; }
    .btn-center { cursor: default; background: rgba(255, 162, 96, 0.05); color: var(--accent); border-left: none; border-right: none; }

    .close-btn { position: absolute; right: 40px; width: 45px; height: 45px; border-radius: 50%; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.6); cursor: pointer; font-size: 28px; }
.btn-center {
    flex: 1.2; /* Makes the middle label slightly wider than the buttons */
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    letter-spacing: 1px;
}

</style>

<div id="settings_wrapper">
    <div id="main_header_area">
        <div id="connection-container">
            <div id="status-dot"></div>
            <div id="tv-info">
                <span id="status-text">OFFLINE</span>
                <small id="tv-location">Waiting for Signal...</small>
            </div>
        </div>
        <h1 id='main_header'>TV Settings</h1>
        <button class="close-btn" onclick="closeSettings()">&times;</button>
    </div>

    <div id="settings_scroll_content">
        <div class="conteiner-col">
            <p class="section-title">Textures</p>
            <button onclick="cmd('texture','14c859c9-b22a-d4b0-2ee5-f17b6edacd70',this)" class="btn1">Carbon</button>
            <button onclick="cmd('texture','gold',this)" class="btn1">Gold</button>
            <button onclick="cmd('texture','matte',this)" class="btn1">Matte</button>
        </div>

        <div class="conteiner-col">
            <p class="section-title">Aspect Ratio</p>
            <button onclick="cmd('ratio','3/2',this)" class="btn1">3/2   35mm filme</button>
            <button onclick="cmd('ratio','4/3',this)" class="btn1">4/3   classic Tv</button>
            <button onclick="cmd('ratio','16/9',this)" class="btn1">16/9   fullHDmovies</button>
            <button onclick="cmd('ratio','18/9',this)" class="btn1">18/9   wideHDmovies</button>
            <button onclick="cmd('ratio','21/9',this)" class="btn1">21/9   cinemaScope</button>
        </div>

        <div class="conteiner-col">
            <p class="section-title">Visuals</p>
            <button onclick="cmd('glow','on',this)" class="btn1">Glow On</button>
            <button onclick="cmd('glow','off',this)" class="btn1">Glow Off</button>
        </div>

<div class="conteiner-col">
    <p class="section-title">System</p>

    <div class="btn-group">
        <button onclick="cmd('legs','hide',this)" class="btn-split btn-left">HIDE</button>
        <div class="btn-split btn-center">LEGS</div>
        <button onclick="cmd('legs','show',this)" class="btn-split btn-right">SHOW</button>
    </div>

    <div class="btn-group">
        <button onclick="cmd('frame','hide',this)" class="btn-split btn-left">HIDE</button>
        <div class="btn-split btn-center">FRAME</div>
        <button onclick="cmd('frame','show',this)" class="btn-split btn-right">SHOW</button>
    </div>

    <div class="btn-group">
        <button onclick="cmd('buttons','hide',this)" class="btn-split btn-left">HIDE</button>
        <div class="btn-split btn-center">BUTTONS</div>
        <button onclick="cmd('buttons','show',this)" class="btn-split btn-right">SHOW</button>
    </div>

    <div style="margin-top: 20px;">
        <button onclick="cmd('reboot','',this)" class="btn1" style="color: #3498db; margin: 5px 0;">RESTART</button>
        <button onclick="cmd('reset','',this)" class="btn1" style="color: #e74c3c; margin: 5px 0;">RESET</button>
    </div>
</div>

<div class="conteiner-col">
    <p class="section-title">Scale Control</p>
    
    <div style="display: flex; gap: 5px; margin-bottom: 10px;">
        <button onclick="cmd('SCALE','0.05',this)" class="btn1" style="flex:1">+5%</button>
        <button onclick="cmd('SCALE','0.10',this)" class="btn1" style="flex:1">+10%</button>
        <button onclick="cmd('SCALE','0.20',this)" class="btn1" style="flex:1">+20%</button>
    </div>

    <div style="display: flex; gap: 5px;">
        <button onclick="cmd('SCALE','-0.05',this)" class="btn1" style="flex:1">-5%</button>
        <button onclick="cmd('SCALE','-0.10',this)" class="btn1" style="flex:1">-10%</button>
        <button onclick="cmd('SCALE','-0.20',this)" class="btn1" style="flex:1">-20%</button>
    </div>

    <button onclick="cmd('RESIZE','',this)" class="btn1" style="color: var(--accent); margin-top: 20px;">ADVANCED MENU</button>
</div>

    </div>
</div>

<script>
    (function() {
        // --- SOCKET LOGIC ---
        // Ensure socket is available (it's initialized in your main index.ejs)
        if (typeof socket !== 'undefined') {
            
            // This listens for the 'tv_registered' event you already have in your node.js /register route!
            socket.on('tv_registered', function(data) {
                console.log("TV Signal Received:", data);
                
                // Turn UI Online
                $('#connection-container').addClass('online-active');
                $('#status-text').text('ONLINE');
                $('#tv-location').text('Region: ' + (data.location || 'Active'));
                
                // Optional: Auto-offline after 1 minute of silence
                clearTimeout(window.offlineTimer);
                window.offlineTimer = setTimeout(() => {
                    $('#connection-container').removeClass('online-active');
                    $('#status-text').text('OFFLINE');
                    $('#tv-location').text('Signal Lost');
                }, 60000);
            });
        }


        const TV_ID = "<%= tvId %>";
        // --- COMMAND LOGIC ---
window.cmd = function(command, value, el) {
    const sessionId = localStorage.getItem("sessionId");

    if (!sessionId) {
        console.warn("No session — access denied");
        return;
    }

    if(el) { 
        $(el).addClass('sent'); 
        setTimeout(() => $(el).removeClass('sent'), 300); 
    }

    $.ajax({
        type: 'POST',
        url: '/send-command',
        contentType: 'application/json',
        data: JSON.stringify({ 
            command: command, 
            value: value, 
            sessionId: sessionId   // ✅ THIS is the key
        }),
        success: () => console.log('Sent'),
        error: () => {
            $('#connection-container').removeClass('online-active');
            $('#status-text').text('OFFLINE');
        }
    });
};
        window.closeSettings = function() {
            $('#overlay-content').fadeOut(200);
        };
    })();
</script>