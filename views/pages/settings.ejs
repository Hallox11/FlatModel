<!-- SETTINGS MODULE (AJAX FRAGMENT) -->
<style>
    /* CSS ESPECÍFICO DO MÓDULO */
    #settings_wrapper {
        width: 1280px;
        height: 720px;
        color: #fff;
        font-family: 'Fira Sans', sans-serif;
        position: relative;
    }

    #main_header {
        position: absolute;
        top: 30px;
        left: 520px;
        font-size: 25px;
        font-weight: 400;
        color: orange;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0;
    }

    #msg p {
        position: absolute;
        top: 65px;
        left: 200px;
        color: #f1c40f;
        font-size: 21px;
    }

    [class^="conteiner"] {
        position: absolute;
        top: 120px;
        height: 520px;
        width: 280px;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(10px);
        border: 2px solid #ffa260;
        border-radius: 15px;
        padding: 10px;
        box-sizing: border-box;
    }

    .conteiner1 { left: 50px; }
    .conteiner2 { left: 350px; }
    .conteiner3 { left: 650px; }
    .conteiner4 { left: 950px; height: 565px; }

    .btn {
        display: block;
        width: 90%;
        margin: 8px auto;
        padding: 8px;
        font-size: 22px;
        text-decoration: none;
        color: white;
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid #ffa260;
        border-radius: 8px;
        cursor: pointer;
        text-align: center;
    }

    .btn:hover {
        background: #2ecc71;
        color: #000;
        transform: scale(1.05);
    }

    .nav-arrows { position: absolute; z-index: 100; display: flex; gap: 10px; left: 961px; width: 260px; justify-content: space-between; }
    #nav_row { top: 370px; }
    #zom_row { top: 423px; }
    #scr_row { top: 476px; }
    #web_row { top: 529px; }
    #bp_row  { top: 582px; }

    .arrow-btn { width: 45%; padding: 5px; font-weight: bold; border: 2px solid #ffa260; color: white; background: rgba(0,0,0,0.5); border-radius: 5px; cursor: pointer; text-align: center; }
    .arrow-btn:hover { background: #2ecc71; color: #000; }

    #back_overlay {
        position: absolute;
        top: 655px;
        left: 550px;
        width: 180px;
        color: #f1c40f;
        border: 2px solid #f1c40f;
        background: none;
        border-radius: 8px;
        font-size: 30px;
        cursor: pointer;
    }

    .sent { background: #2ecc71 !important; color: #000 !important; }


    /* Split button container */
    .btn-group {
        display: flex;
        width: 90%;
        margin: 8px auto;
        gap: 2px; /* Small gap between segments */
    }

    .btn-split {
        flex: 1;
        padding: 8px 0;
        font-size: 18px; /* Slightly smaller to fit 3 words */
        text-decoration: none;
        color: white;
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid #ffa260;
        cursor: pointer;
        text-align: center;
        transition: 0.2s;
    }

    .btn-left { border-radius: 8px 0 0 8px; }
    .btn-center { border-radius: 0; }
    .btn-right { border-radius: 0 8px 8px 0; }

    .btn-split:hover {
        background: #2ecc71;
        color: #000;
    }

        #settings_wrapper .close-btn {
        position: absolute;
        top: 10px;
        left: 1200px;
        width: 50px;
        height: 50px;
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid black; /* Music Accent Color */
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #settings_wrapper .close-btn:hover, 
    #settings_wrapper .close-btn:focus {
        color: white;
        transform: scale(1.3) ;
        box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
    }
</style>

<div id="settings_wrapper">
    <h1 id='main_header'>ON-SCREEN SETTINGS</h1>

    <div id="msg">
        <p>On-screen settings not working? Click the right frame button for a SL Hud</p>
    </div>

    <!-- SETAS DE NAVEGAÇÃO -->


    <!-- COLUNAS -->
    <div class="conteiner1">
