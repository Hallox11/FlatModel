<style>
/* ===============================
   WRAPPER
=============================== */
#youtube-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20,20,20,0.6), rgba(0,0,0,0.5));
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0,0,0,0.9);
    margin: 20px auto;
    position: relative;
}

/* ===============================
   HEADER
=============================== */
#youtube-menu-wrapper .yt-header {
    font-family: 'Segoe UI', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 7px;
    margin-bottom: 25px;
    opacity: 0.9;
    text-shadow: 0 0 20px rgba(0,0,0,0.2), 0 2px 8px rgba(0,0,0,0.7);
}

/* ===============================
   SEARCH
=============================== */
#youtube-menu-wrapper .search-container {
    width: 100%;
    margin-bottom: 25px;
}

#youtube-menu-wrapper .search-input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.1);
    padding: 16px 25px;
    border-radius: 15px;
    font-size: 1.3rem;
    color: white;
    outline: none;
    transition: 0.3s;
    min-width: 0;
}

#youtube-menu-wrapper .search-input:focus {
    border-color: #ff0000;
    background: rgba(255,255,255,0.1);
    box-shadow: 0 0 20px rgba(255,0,0,0.2);
}

#youtube-menu-wrapper .search-btn {
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 15px;
    color: white;
    padding: 14px 22px;
    cursor: pointer;
    transition: 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

#youtube-menu-wrapper .search-btn:hover {
    background: #ff0000;
    border-color: #ff0000;
}

/* ===============================
   GRID CONTAINER
=============================== */
#youtube-menu-wrapper .yt-grid-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    width: 100%;
}

/* ===============================
   FEATURE ROW
=============================== */
#youtube-menu-wrapper .feature-row {
    grid-column: span 5;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 5px;
}

#youtube-menu-wrapper .feature-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 22px;
    border-radius: 15px;
    color: white;
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-transform: uppercase;
}

#youtube-menu-wrapper .feature-btn:hover {
    background: white;
    color: black;
}

#youtube-menu-wrapper .feature-btn.btn-fav {
    border-color: #ffd700;
    color: #ffd700;
}

#youtube-menu-wrapper .feature-btn.btn-fav:hover {
    background: #ffd700;
    color: black;
    border-color: #ffd700;
}

/* ===============================
   CATEGORY CARDS
=============================== */
#youtube-menu-wrapper .yt-group {
    background: rgba(0,0,0,0.4);
    border: 2px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    box-shadow: 0 5px 20px rgba(0,0,0,0.5);
}

#youtube-menu-wrapper .yt-group:hover {
    transform: scale(1.07);
    background: rgba(0,0,0,0.7);
    border-color: rgba(255,255,255,0.8);
}

#youtube-menu-wrapper .yt-main-btn {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
    text-align: center;
}

#youtube-menu-wrapper .yt-sub-btn {
    font-size: 0.70rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 50px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.15);
    letter-spacing: 1px;
    transition: all 0.3s ease;
    text-align: center;
    white-space: nowrap;
}

/* ===============================
   COLOR CATEGORIES
=============================== */
/* Red — action/trending */
#youtube-menu-wrapper .yt-red { border-color: rgba(255,75,43,0.4); }
#youtube-menu-wrapper .yt-red .yt-main-btn { color: #ff4b2b; }
#youtube-menu-wrapper .yt-red .yt-sub-btn { color: #ff4b2b; border-color: rgba(255,75,43,0.6); }
#youtube-menu-wrapper .yt-red .yt-sub-btn:hover { background: #ff4b2b; color: white; }

/* Cyan — tech/info */
#youtube-menu-wrapper .yt-cyan { border-color: rgba(0,212,255,0.4); }
#youtube-menu-wrapper .yt-cyan .yt-main-btn { color: #00d4ff; }
#youtube-menu-wrapper .yt-cyan .yt-sub-btn { color: #00d4ff; border-color: rgba(0,212,255,0.6); }
#youtube-menu-wrapper .yt-cyan .yt-sub-btn:hover { background: #00d4ff; color: white; }

/* Amber — lifestyle/classic */
#youtube-menu-wrapper .yt-amber { border-color: rgba(255,179,71,0.4); }
#youtube-menu-wrapper .yt-amber .yt-main-btn { color: #ffb347; }
#youtube-menu-wrapper .yt-amber .yt-sub-btn { color: #ffb347; border-color: rgba(255,179,71,0.6); }
#youtube-menu-wrapper .yt-amber .yt-sub-btn:hover { background: #ffb347; color: white; }

/* Purple — docs/knowledge */
#youtube-menu-wrapper .yt-purple { border-color: rgba(189,0,255,0.4); }
#youtube-menu-wrapper .yt-purple .yt-main-btn { color: #d385ee; }
#youtube-menu-wrapper .yt-purple .yt-sub-btn { color: #d385ee; border-color: rgba(189,0,255,0.6); }
#youtube-menu-wrapper .yt-purple .yt-sub-btn:hover { background: #d385ee; color: white; }

/* ===============================
   MODALS
=============================== */
.yt-modal-overlay {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.95);
    border-radius: 30px;
    z-index: 100;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.yt-modal-overlay[style*="flex"] {
    opacity: 1;
}

/* ===============================
   MODAL GRID
=============================== */
.modal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    width: 100%;
    overflow: hidden;
    padding: 10px;
}

/* ===============================
   CATEGORY + FAVORITE ITEMS
=============================== */
.cat-item,
.fav-item {
    background: rgba(255,255,255,0.05);
    padding: 15px;
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    text-align: center;
    cursor: pointer;
    border-radius: 8px;
    font-weight: bold;
    transition: 0.2s;
}

.cat-item:hover { background: #ff0000; }

.fav-item {
    border-color: #ffd700;
    color: #ffd700;
}

.fav-item:hover {
    background: #ffd700;
    color: black;
}

/* ===============================
   REMOTE HOVER STATES
=============================== */
#youtube-menu-wrapper .yt-group.remote-hover {
    transform: scale(1.07);
    background: rgba(0,0,0,0.7);
    border-color: rgba(255,255,255,0.8);
}

#youtube-menu-wrapper .feature-btn.remote-hover {
    background: white !important;
    color: black !important;
}

#youtube-menu-wrapper .feature-btn.btn-fav.remote-hover {
    background: #ffd700 !important;
    color: black !important;
}

.cat-item.remote-hover { background: #ff0000 !important; }

.fav-item.remote-hover {
    background: #ffd700 !important;
    color: black !important;
}
</style>

<div id="youtube-menu-wrapper">
    <div class="close-menu-btn" onclick="closeSubMenu()">
        <span class="material-symbols-rounded">close</span>
    </div>

    <div class="yt-header">Youtube Search</div>

    <div class="search-container">
        <div style="display: flex; gap: 10px; align-items: center;">
            <input type="text" id="yt-search-field" class="search-input"
                   placeholder="Search YouTube or paste Channel ID..."
                   onkeypress="if(event.key === 'Enter') executeSearch()">
            <button onclick="executeSearch()" class="search-btn">
                <span class="material-symbols-rounded">search</span>
            </button>
        </div>
    </div>

    <div class="yt-grid-container">

        <!-- Feature Row -->
        <div class="feature-row">
            <div class="feature-btn" onclick="handleNav('/youtube-grid?genre=viral videos 2026&menu=/youtube-menu')">
                <span class="material-symbols-rounded">trending_up</span> Trending
            </div>
            <div class="feature-btn btn-fav" onclick="toggleYtFavModal(true)">
                <span class="material-symbols-rounded">star</span> Favoritos
            </div>
            <div class="feature-btn" onclick="toggleYtCatModal(true)">
                <span class="material-symbols-rounded">category</span> Categorias
            </div>
        </div>

        <!-- Category Cards -->
        <div class="yt-group yt-red" onclick="handleNav('/youtube-grid?genre=Gaming&menu=/youtube-menu')">
            <div class="yt-main-btn">Gaming</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=Gaming highlights&menu=/youtube-menu')">HIGHLIGHTS</span>
        </div>

        <div class="yt-group yt-cyan" onclick="handleNav('/youtube-grid?genre=Tecnologia&menu=/youtube-menu')">
            <div class="yt-main-btn">Tech</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=Tech Reviews&menu=/youtube-menu')">REVIEWS</span>
        </div>

        <div class="yt-group yt-amber" onclick="handleNav('/youtube-grid?genre=Cooking&menu=/youtube-menu')">
            <div class="yt-main-btn">Cooking</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=best recipes&menu=/youtube-menu')">RECIPES</span>
        </div>

        <div class="yt-group yt-purple" onclick="handleNav('/youtube-grid?genre=Documentaries&menu=/youtube-menu')">
            <div class="yt-main-btn">Docs</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=history documentary&menu=/youtube-menu')">HISTORY</span>
        </div>

        <div class="yt-group yt-red" onclick="handleNav('/youtube-grid?genre=Comedy&menu=/youtube-menu')">
            <div class="yt-main-btn">Comedy</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=stand up comedy&menu=/youtube-menu')">STAND UP</span>
        </div>

        <div class="yt-group yt-cyan" onclick="handleNav('/youtube-grid?genre=Music Videos&menu=/youtube-menu')">
            <div class="yt-main-btn">Music</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=Music VEVO&menu=/youtube-menu')">VEVO</span>
        </div>

        <div class="yt-group yt-amber" onclick="handleNav('/youtube-grid?genre=Fitness&menu=/youtube-menu')">
            <div class="yt-main-btn">Fitness</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=workout routines&menu=/youtube-menu')">WORKOUTS</span>
        </div>

        <div class="yt-group yt-purple" onclick="handleNav('/youtube-grid?genre=Travel&menu=/youtube-menu')">
            <div class="yt-main-btn">Travel</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=travel vlog&menu=/youtube-menu')">VLOGS</span>
        </div>

        <div class="yt-group yt-red" onclick="handleNav('/youtube-grid?genre=Noticias&menu=/youtube-menu')">
            <div class="yt-main-btn">News</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=world news today&menu=/youtube-menu')">WORLD</span>
        </div>

        <div class="yt-group yt-cyan" onclick="handleNav('/youtube-grid?genre=Science&menu=/youtube-menu')">
            <div class="yt-main-btn">Science</div>
            <span class="yt-sub-btn" onclick="event.stopPropagation(); handleNav('/youtube-grid?genre=space exploration&menu=/youtube-menu')">SPACE</span>
        </div>

    </div>

    <!-- CATEGORIES MODAL -->
    <div id="yt-cat-modal-new" class="yt-modal-overlay">
        <h2 style="color: white; margin-bottom: 20px; letter-spacing: 3px;">CATEGORIAS</h2>
        <div class="modal-grid"></div>
        <button class="yt-group yt-red" style="margin-top: 30px; width: 200px; justify-content: center;"
                onclick="toggleYtCatModal(false)">VOLTAR</button>
    </div>

    <!-- FAVORITES MODAL -->
    <div id="yt-fav-modal-new" class="yt-modal-overlay">
        <h2 style="color: #ffd700; margin-bottom: 20px; letter-spacing: 3px;">FAVORITOS</h2>
        <div id="fav-list-container" class="modal-grid"></div>
        <button class="yt-group yt-amber" style="margin-top: 30px; width: 200px; justify-content: center;"
                onclick="toggleYtFavModal(false)">VOLTAR</button>
    </div>
</div>

<script>
if (!window.ytMenuInitialized) {

    window.ytMenuInitialized = true;

    // ===============================
    // STATIC DATA
    // ===============================
    const YT_CATEGORIES = [
        "Comedy", "Music Videos", "Gaming", "Documentaries",
        "Tech Reviews", "Cooking", "Fitness", "Travel"
    ];

    const YT_FAVORITES = [
        { name: "LoFi HipHop", id: "UC8_x5X0n7t3cCyVb5dH9tXw" },
        { name: "MrBeast",     id: "UCX6OQ3DkcsbYNE6H8uQQuVA" },
        { name: "Veritasium",  id: "UCHnyfMqiRRG1u-2MsSQLbXA" },
        { name: "Kurzgesagt",  id: "UCsXVk37bltHxD1rDPwtNM8Q" }
    ];

    // ===============================
    // SEARCH
    // ===============================
    window.executeSearch = function() {
        const input = document.getElementById('yt-search-field');
        const query = input.value.trim();

        if (!query) {
            input.placeholder = "Type something first...";
            return;
        }

        input.placeholder = "Searching...";

        // Detect channel ID — starts with 'UC' and is 24 chars
        const isChannelId = /^UC[\w-]{22}$/.test(query);

        if (isChannelId) {
            handleNav(`/youtube?tag=${encodeURIComponent(query)}&isChannel=true&menu=/youtube-menu`);
        } else {
            handleNav(`/youtube-grid?genre=${encodeURIComponent(query)}&menu=/youtube-menu`);
        }
    };

    // ===============================
    // MODALS (WITH SYNC)
    // ===============================
    window.toggleYtCatModal = function(show, isRemote = false) {
        const modal = document.getElementById('yt-cat-modal-new');
        if (!modal) return;

        modal.style.display = show ? 'flex' : 'none';

        if (show) renderCategories();

        if (!isRemote && window.socket) {
            socket.emit('state_sync', {
                type: 'yt_cat_modal',
                show,
                room: window.myRoom
            });
        }
    };

    window.toggleYtFavModal = function(show, isRemote = false) {
        const modal = document.getElementById('yt-fav-modal-new');
        if (!modal) return;

        modal.style.display = show ? 'flex' : 'none';

        if (show) renderFavorites();

        if (!isRemote && window.socket) {
            socket.emit('state_sync', {
                type: 'yt_fav_modal',
                show,
                room: window.myRoom
            });
        }
    };

    // ===============================
    // RENDER FUNCTIONS
    // ===============================
    function renderCategories() {
        const grid = document.querySelector('#yt-cat-modal-new .modal-grid');
        if (!grid) return;
        grid.innerHTML = YT_CATEGORIES.map(cat => `
            <div class="cat-item" data-cat="${cat}">${cat}</div>
        `).join('');
    }

    function renderFavorites() {
        const grid = document.getElementById('fav-list-container');
        if (!grid) return;
        grid.innerHTML = YT_FAVORITES.map(fav => `
            <div class="fav-item" data-id="${fav.id}">${fav.name}</div>
        `).join('');
    }

    // ===============================
    // EVENTS (NO DUPLICATION)
    // ===============================

    // CATEGORY CARD CLICK
    $(document).on('click', '.yt-group', function() {
        // handled via inline onclick on each card
    });

    // CATEGORY MODAL ITEM CLICK
    $(document).on('click', '.cat-item', function() {
        const cat = $(this).data('cat');
        toggleYtCatModal(false);
        handleNav(`/youtube-grid?genre=${encodeURIComponent(cat)}&menu=/youtube-menu`);
    });

    // FAVORITE CLICK
    $(document).on('click', '.fav-item', function() {
        const id = $(this).data('id');
        toggleYtFavModal(false);
        handleNav(`/youtube?tag=${encodeURIComponent(id)}&isChannel=true`);
    });

    // ESC CLOSE
    $(document).on('keydown', function(e) {
        if (e.key === 'Escape') {
            toggleYtCatModal(false);
            toggleYtFavModal(false);
        }
    });
}
</script>
