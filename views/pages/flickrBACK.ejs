///////////////////////////////////////////////////////////////////////////////////////
function page_up(){
   
     var query=$("#tag").val();
     var page = $('#page').val();
     page++;
     if(page>numPages) page=numPages;
     else{
     if(callMode=="tag"){ tagSearch(query, page);}
     if(callMode=="userPhotos"){ userSearch (callMode,query,page);}
     if(callMode=="favoritePhotos"){ userSearch (callMode,query,page);}
     if(callMode=="groupPhotos"){ userSearch (callMode,query,page);}
      }
     $('#page').val(page);
}
///////////////////////////////////////////////////////////////////////////////////////
function page_dw(){
    
    var query=$("#tag").val();
     var page = $('#page').val();
     page--;
     if(page<1) page=1;
     else {
     if(callMode=="tag"){ tagSearch(query, page);}
     if(callMode=="userPhotos"){ userSearch (callMode,query,page);}
     if(callMode=="favoritePhotos"){ userSearch (callMode,query,page);}
