function back(){
                    window.open("./?"+return_url, "_self");

}

function stepBack(){  
                           
                     if(step===1 && callMode==="userPhotos") {setPage("main"); step=0}
                     if(step===2 && callMode==="userPhotos") {setPage("user1"); step=1;}
                     
                     if(step===1 && callMode==="groupPhotos") {setPage("main"); step=0}
                     if(step===2 && callMode==="groupPhotos") {setPage("group1"); step=1;}

                     if(step===1 && callMode==="tag") {setPage("main"); step=0}
                     if(step===2 && callMode==="tag") {setPage("tags1"); step=1;}
                   
                     if(step===1 && callMode==="favoritePhotos") {setPage("main"); step=0}
                     if(step===2 && callMode==="favoritePhotos") {setPage("user1"); step=1;}
                      
                    
}
