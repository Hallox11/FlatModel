<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1280, user-scalable=no">
    <title>Main Menu - Smart TV</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="./js/myScripts.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@200;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --accent: goldenrod;
            --glass: rgba(255, 255, 255, 0.1);
            --text-color: #ffffff;
        }

        body {
            width: 1280px; height: 720px; margin: 0;
            background-color: #000; background-size: cover !important;
            background-position: center center !important;
            background-attachment: fixed !important;
            background-repeat: no-repeat !important;
            color: var(--text-color); font-family: 'Fira Sans', sans-serif;
            overflow: hidden; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            transition: opacity 0.3s ease;
        }

        #main-grid {
            width: 1100px; display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px; padding: 20px; margin-bottom: 60px;
            transition: all 0.4s ease;
        }

        #sub-content-overlay {
            display: none; position: absolute; top: 0; left: 0;
            width: 1280px; height: 720px;
            flex-direction: column; align-items: center; justify-content: center;
            z-index: 100; background: rgba(0,0,0,0.2);
            backdrop-filter: blur(5px);
        }

        .btn {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
            backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-top: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 12px; padding: 30px 10px;
            text-decoration: none; color: white; font-size: 1.15rem;
            text-align: center; display: flex; align-items: center;
            justify-content: center; cursor: pointer;
            transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
            will-change: transform; transform: translateZ(0);
            outline: none; /* Remove focus outline */
        }

        .btn:hover {
            transform: translateY(-8px) scale(1.05) translateZ(0);
            background: rgba(255, 255, 255, 0.15); color: var(--accent);
            border-top-color: var(--accent);
            box-shadow: 0 15px 45px rgba(218, 165, 32, 0.4);
        }

        /* Ensure no focus ring appears on click */
        .btn:focus, .btn-small:focus {
            outline: none;
        }

        .status-bar {
            position: absolute; bottom: 40px; width: 1150px;
            display: flex; align-items: flex-end;
            justify-content: space-between; padding: 0 40px;
        }

        .btn-small {
            background: rgba(0,0,0,0.5); backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2); color: white;
            padding: 10px 22px; border-radius: 12px; font-size: 0.85rem;
            cursor: pointer; display: flex; align-items: center; gap: 10px;
            outline: none;
        }

        .btn-small:hover { background: var(--accent); color: black; }

        #hour { font-size: 2.3rem; font-weight: 200; text-shadow: 0 0 20px rgba(218, 165, 32, 0.4); }
        #date-display { color: var(--accent); font-size: 0.8rem; letter-spacing: 1px; }
        #vers { position: absolute; bottom: 10px; width: 100%; text-align: center; font-size: 0.7rem; opacity: 0.3; }

        .conteiner {
            width: 700px; height: 450px; overflow-y: auto; padding: 20px;
            -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
        }
        .conteiner::-webkit-scrollbar { width: 0px; }


        /* Standard button style */
/* Update this part in your main file */

#browsers-menu-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
}

/* Force the grid for browsers */
#browsers-menu-wrapper .conteiner {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    width: 1100px; /* Make it wider to match the main grid */
}

#browsers-menu-wrapper .btn {
    background: rgba(255, 107, 107, 0.2) !important; 
    border: 1px solid #ff6b6b !important;
    padding: 20px 10px !important; /* Smaller padding for the menu */
}
    </style>
</head>

<body>

<div id="main-grid">
    <div data-type="menu" data-mode="radios" class="btn" id="main01">RADIOS</div>
    <div data-type="menu" data-mode="music" class="btn" id="main02">MUSIC</div>
    <div data-type="menu" data-mode="movies" class="btn" id="main03">MOVIES</div>
    <div data-type="menu" data-mode="youtube" class="btn" id="main04">YOUTUBE</div>
    <div data-type="menu" data-mode="xxx" class="btn" id="main08">XXX</div>
    <div data-type="menu" data-mode="sl" class="btn" id="main05">SECOND LIFE</div>
    <div data-type="menu" data-mode="flickr" class="btn" id="main06">FLICKR</div>
    <div data-type="menu" data-mode="browsers" class="btn" id="main07">BROWSERS</div>
</div>

    <div id="sub-content-overlay"></div>

    <div class="status-bar">
        <div class="controls">
            <button class="btn-small" onclick="nextBackground()">
                <span class="material-symbols-rounded">palette</span> Theme
            </button>
            <button class="btn-small" onclick="handleNav('help')">
                <span class="material-symbols-rounded">help</span> Help
            </button>
        </div>
        <div class="system-info">
            <div id="hour">00:00:00</div>
            <div id="date-display">---</div>
        </div>
    </div>

    <div id="vers">WebTv v4.5 (AJAX Ready)</div>

<script>
    var socket;
    var myRoom;
    var backPics = [];
    var index = 0;

    window.onload = function() {
        const params = new URLSearchParams(window.location.search);
        myRoom = params.get('room') || 'Lobby';

        if (typeof io !== 'undefined') {
            socket = io.connect();
            socket.emit('join_room', myRoom);

            socket.on('update_bg', function(data) {
                if (data.image) {
                    document.body.style.backgroundImage = `url(${data.image})`;
                    localStorage.setItem("user_bg", data.image);
                }
            });

            socket.on('mirror_ajax_nav', function(data) {
                if(data.mode) handleNav(data.mode, true);
                if(data.action === 'CLOSE') closeSubMenu(true);
            });
        }

        const savedBg = localStorage.getItem("user_bg");
        if (savedBg) document.body.style.backgroundImage = "url('" + savedBg + "')";
        fetchBackground(savedBg); 
        updateClock();
    };


    function closeSubMenu(isRemote = false) {
        if (!isRemote && socket) {
            socket.emit('mirror_ajax_nav', { action: 'CLOSE', room: myRoom });
        }

        $('#sub-content-overlay').fadeOut(200, function() {
            $(this).empty().hide();
            $('#main-grid').show().css({'opacity': '1', 'transform': 'scale(1)'});
        });
    }

    function fetchBackground(hasSavedBg) {
        fetch('./backgrounds.txt').then(r => r.text()).then(data => {
            try {
                backPics = JSON.parse(data);
                if (hasSavedBg) {
                    const savedIdx = backPics.indexOf(hasSavedBg);
                    if (savedIdx !== -1) index = savedIdx;
                }
            } catch(e) {}
        });
    }

    function nextBackground() {
        if (backPics.length > 0) {
            index = (index + 1) % backPics.length;
            const pic = backPics[index];
            document.body.style.backgroundImage = `url(${pic})`;
            localStorage.setItem("user_bg", pic);
            if (socket) socket.emit('change_bg', { image: pic, room: myRoom });
        }
    }

    function updateClock() {
        var now = new Date();
        $("#hour").text(now.toTimeString().split(' ')[0]);
        var options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
        $("#date-display").text(now.toLocaleDateString('en-US', options).toUpperCase());
        setTimeout(updateClock, 1000);
    }


</script>
</body>
</html>