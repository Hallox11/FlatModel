
<style>
    /* 1. Wrapper to activate the Gold/Movie Theme */
    #movies-menu-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 800px;
        animation: fadeIn 0.4s ease-out;
    }

    /* 2. The Circular Close Button (Top Right) */
    #movies-menu-wrapper .close-btn {
        position: absolute;
        top: -10px;
        right: 0px;
        width: 50px;
        height: 50px;
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid #ffcc00; /* Cinema Gold Color */
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #movies-menu-wrapper .close-btn:hover, 
    #movies-menu-wrapper .close-btn:focus {
        background: #ffcc00;
        color: black;
        transform: scale(1.1) rotate(90deg);
        box-shadow: 0 0 15px rgba(255, 204, 0, 0.5);
    }

    /* 3. Title Styling */
    #movies-menu-wrapper #title {
        font-size: 30px;
        color: #ffcc00;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Grid Container - 2 Columns */
    #movies-menu-wrapper .conteiner {
        display: grid !important;
        grid-template-columns: 2fr 1fr !important; /* Larger main button, smaller list button */
        gap: 12px !important;
        width: 100% !important;
        max-height: 480px;
        overflow-y: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 20px;
        border: 1px solid rgba(255, 204, 0, 0.1);
    }

    /* 5. Movie Button Styling */
    #movies-menu-wrapper .btn {
        background: rgba(255, 204, 0, 0.05) !important;
        border: 1px solid rgba(255, 204, 0, 0.2) !important;
        border-radius: 12px;
        padding: 22px 15px !important;
        font-size: 20px;
        color: white !important;
        text-align: center;
        display: flex !important;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    /* Special style for "Lists" buttons */
    #movies-menu-wrapper .list-btn {
        background: rgba(255, 255, 255, 0.05) !important;
        font-size: 16px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    #movies-menu-wrapper .btn:focus, 
    #movies-menu-wrapper .btn:hover {
        background: #ffcc00 !important;
        color: #000 !important;
        transform: scale(1.03);
        outline: none;
        box-shadow: 0 5px 15px rgba(255, 204, 0, 0.3);
    }

    /* Full-Width Override */
    #movies-menu-wrapper .full-row {
        grid-column: span 2;
    }

    /* Hide scrollbar */
    #movies-menu-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div id="movies-menu-wrapper">
    
    <button class="close-btn" onclick="closeSubMenu()" tabindex="50">
        <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <div id="title">Movies Menu</div>

    <div class="conteiner">
        <div data-type="movie" data-mode="mixmovies" class="btn full-row" tabindex="1">YT Mix Search Movies</div> 
        <div data-type="movie" data-mode="movie_trailers" class="btn full-row" tabindex="2">Movie Trailers</div> 
        
        <div data-type="movie" data-mode="mojo" class="btn full-row" tabindex="3">WatchMojo</div> 
        <div data-type="movie" data-mode="movie_central" class="btn full-row" tabindex="4">Movie Central</div> 
        <div data-type="movie" data-mode="popcornflix" class="btn full-row" tabindex="5">PopcornFlix</div> 
        <div data-type="movie" data-mode="v_movies" class="btn full-row" tabindex="6">V Movies</div> 

        <div data-type="movie" data-mode="retrospective" class="btn" tabindex="7">Retrospective</div> 
        <div data-type="movie" data-mode="retrospective_list" class="btn list-btn" tabindex="8">Lists</div>

        <div data-type="movie" data-mode="western" class="btn" tabindex="9">Western Movies</div> 
        <div data-type="movie" data-mode="western_list" class="btn list-btn" tabindex="10">Lists</div>

        <div data-type="movie" data-mode="mr_bean" class="btn" tabindex="11">Mr. Bean</div> 
        <div data-type="movie" data-mode="mr_bean_list" class="btn list-btn" tabindex="12">Lists</div>

        <div data-type="movie" data-mode="pink_panther" class="btn" tabindex="13">Pink Panther</div>
        <div data-type="movie" data-mode="warner_kids" class="btn" tabindex="14">Warner Bros Kids</div> 
    </div>

</div>