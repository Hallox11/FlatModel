<style>
/* ============================================================
   CINEMA HUB - PREMIUM TV INTERFACE (MUSIC DESIGN LOGIC)
   ============================================================ */

#movies-menu-wrapper {
    width: 1050px;
    padding: 25px;
    background: radial-gradient(circle at center, rgba(20, 20, 20, 0.6), rgba(0, 0, 0, 0.5));
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
    margin: 20px auto;
    position: relative; /* Essential for the close button positioning */
}

#movies-menu-wrapper .movies-header {
    font-family: 'Segoe UI', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
    text-transform: uppercase;
    letter-spacing: 7px;
    margin-bottom: 35px;
    opacity: 0.9;
}

.movies-grid-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr); 
    gap: 20px;
    width: 100%;
}

.feature-row {
    grid-column: span 5;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
}

.feature-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 22px;
    border-radius: 15px;
    color: white;
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s ease;
}

.feature-btn:hover { background: white; color: black; }

.movie-group {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
}

.movie-group:hover {
    transform: translateY(-5px); /* Changed from 0px to create a lift effect */
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 255, 255, 0.4);
}

.main-title-btn {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
    text-align: center;
}

.sub-list-btn {
    font-size: 0.70rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 50px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    letter-spacing: 1px;
    transition: all 0.3s ease;
    text-align: center;
    white-space: nowrap;
}

/* ACTION / TRENDING: Red */
.cat-action { border-color: rgba(255, 75, 43, 0.3); }
.cat-action .main-title-btn { color: #ff4b2b; }
.cat-action .sub-list-btn { color: #ff4b2b; border-color: rgba(255, 75, 43, 0.4); }
.cat-action .sub-list-btn:hover { background: #ff4b2b; color: white; }

/* KIDS / ANIMATION: Cyan */
.cat-kids { border-color: rgba(0, 212, 255, 0.3); }
.cat-kids .main-title-btn { color: #00d4ff; }
.cat-kids .sub-list-btn { color: #00d4ff; border-color: rgba(0, 212, 255, 0.4); }
.cat-kids .sub-list-btn:hover { background: #00d4ff; color: white; }

/* CLASSIC / WESTERN: Amber */
.cat-classic { border-color: rgba(255, 179, 71, 0.3); }
.cat-classic .main-title-btn { color: #ffb347; }
.cat-classic .sub-list-btn { color: #ffb347; border-color: rgba(255, 179, 71, 0.4); }
.cat-classic .sub-list-btn:hover { background: #ffb347; color: white; }

/* DOCUMENTARY / HISTORY: Purple */
.cat-docs { border-color: rgba(189, 0, 255, 0.3); }
.cat-docs .main-title-btn { color: #bd00ff; }
.cat-docs .sub-list-btn { color: #bd00ff; border-color: rgba(189, 0, 255, 0.4); }
.cat-docs .sub-list-btn:hover { background: #bd00ff; color: white; }

.close-menu-btn {
        position: absolute;
        top: 25px;
        right: 25px;
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s;
        z-index: 10;
    }

.close-menu-btn:hover {
        background: #ff0000;
        border-color: #ff0000;
        transform: scale(1.1);
    }
</style>

<div id="movies-menu-wrapper">

    <div class="close-menu-btn" onclick="closeSubMenu()">
        <span style="font-size: 25px;" class="material-symbols-rounded">close</span>
    </div>
    
    <div class="movies-header">Cinema Hub</div>

    <div class="movies-grid-container">
        <div class="feature-row">
            <div class="feature-btn" onclick="handleNav('/movies-grid?genre=mixmovies&menu=/movies-menu')">MIX SEARCH</div>
            <div class="feature-btn" onclick="handleNav('/movies-grid?genre=movie trailers&menu=/movies-menu')">TRAILERS</div>
            <div class="feature-btn" onclick="handleNav('/movies-grid?genre=movie central&menu=/movies-menu')">MOVIE CENTRAL</div>
        </div>

        <div class="movie-group cat-action" onclick="handleNav('/movies-grid?genre=watchmojo&menu=/movies-menu')">
            <div class="main-title-btn">WatchMojo</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=popcornflix&menu=/movies-menu')">POPCORNFLIX</span>
        </div>

        <div class="movie-group cat-action" onclick="handleNav('/movies-grid?genre=v movies&menu=/movies-menu')">
            <div class="main-title-btn">V Movies</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=full movies&menu=/movies-menu')">FULL MOVIES</span>
        </div>

        <div class="movie-group cat-classic" onclick="handleNav('/movies-grid?genre=retrospective&menu=/movies-menu')">
            <div class="main-title-btn">Retro</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=retrospective list&menu=/movies-menu')">VIEW LISTS</span>
        </div>

        <div class="movie-group cat-classic" onclick="handleNav('/movies-grid?genre=western&menu=/movies-menu')">
            <div class="main-title-btn">Western</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=western list&menu=/movies-menu')">VIEW LISTS</span>
        </div>

        <div class="movie-group cat-kids" onclick="handleNav('/movies-grid?genre=mr bean&menu=/movies-menu')">
            <div class="main-title-btn">Mr. Bean</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=mr bean comedy&menu=/movies-menu')">COMEDY</span>
        </div>

        <div class="movie-group cat-kids" onclick="handleNav('/movies-grid?genre=pink panther&menu=/movies-menu')">
            <div class="main-title-btn">Pink Panther</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=cartoons&menu=/movies-menu')">CARTOONS</span>
        </div>

        <div class="movie-group cat-kids" onclick="handleNav('/movies-grid?genre=warner kids&menu=/movies-menu')">
            <div class="main-title-btn">Warner Kids</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=kids movies&menu=/movies-menu')">KIDS LISTS</span>
        </div>

        <div class="movie-group cat-docs" onclick="handleNav('/movies-grid?genre=documentaries&menu=/movies-menu')">
            <div class="main-title-btn">Docs</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=history documentary&menu=/movies-menu')">HISTORY</span>
        </div>

        <div class="movie-group cat-action" onclick="handleNav('/movies-grid?genre=action movies&menu=/movies-menu')">
            <div class="main-title-btn">Action</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=thriller movies&menu=/movies-menu')">THRILLERS</span>
        </div>

        <div class="movie-group cat-classic" onclick="handleNav('/movies-grid?genre=scifi movies&menu=/movies-menu')">
            <div class="main-title-btn">Sci-Fi</div>
            <span class="sub-list-btn" onclick="event.stopPropagation(); handleNav('/movies-grid?genre=scifi classics&menu=/movies-menu')">CLASSICS</span>
        </div>
    </div>

</div>