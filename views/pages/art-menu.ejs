<style>
    #museum-menu-container {
        width: 800px;
        padding: 40px;
        background: rgba(0, 0, 0, 0.9); /* Ligeiramente mais opaco para legibilidade */
        backdrop-filter: blur(20px);
        border-radius: 24px;
        border: 1px solid rgba(218, 165, 32, 0.3);
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 25px 60px rgba(0,0,0,0.8);
        position: relative;
    }

    .museum-header {
        font-family: 'Segoe UI', sans-serif;
        font-size: 1.6em;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 6px;
        margin-bottom: 40px;
        border-bottom: 2px solid goldenrod;
        padding-bottom: 10px;
    }

    .museum-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        width: 100%;
        margin-bottom: 20px;
    }

    .museum-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 30px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .museum-card:hover {
        background: rgba(218, 165, 32, 0.15);
        border-color: goldenrod;
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(218, 165, 32, 0.1);
    }

    .museum-card h3 {
        margin: 0;
        color: goldenrod;
        font-size: 1.3em;
        letter-spacing: 2px;
        font-weight: 600;
    }

    .museum-card p {
        margin: 0;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.8em;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .museum-close-btn {
        position: absolute;
        top: 25px;
        right: 25px;
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
    }

    .museum-close-btn:hover {
        background: #900;
        border-color: #f33;
        transform: rotate(90deg);
    }
</style>

<div id="museum-menu-container">
    <div class="museum-close-btn" onclick="closeSubMenu()">
        <span style="font-size: 22px;" class="material-symbols-rounded">close</span>
    </div>

    <div class="museum-header">World Galleries</div>

    <div class="museum-grid">
        <div class="museum-card" onclick="selectMuseum('met')">
            <h3>The MET</h3>
            <p>New York, USA • 500k+ Objects</p>
        </div>

        <div class="museum-card" onclick="selectMuseum('aic')">
            <h3>Chicago AIC</h3>
            <p>Illinois, USA • Impressionism Hub</p>
        </div>

        <div class="museum-card" onclick="selectMuseum('cma')">
            <h3>Cleveland CMA</h3>
            <p>Ohio, USA • Open Access Masterpieces</p>
        </div>

        <div class="museum-card" onclick="selectMuseum('rijks')">
            <h3>Rijksmuseum</h3>
            <p>Amsterdam, NL • Dutch Golden Age</p>
        </div>
    </div>
</div>

<script>
    /**
     * Esta função agora usa o teu sistema global de navegação (handleNav)
     * Isso garante que o overlay seja atualizado e o socket sincronize a sala.
     */
function selectMuseum(source) {
    console.log("Setting global source to:", source);
    
    // Guardamos numa variável global que a Galeria vai ler
    window.pendingMuseumSource = source; 

    if (typeof handleNav === 'function') {
        // Chamamos o handleNav normalmente
        handleNav(`art-gallery?source=${source}`);
    }
}
</script>