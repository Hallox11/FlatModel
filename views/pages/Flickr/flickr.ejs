<style>
/* ==========================================================================
   1. CORE WRAPPER & LAYOUT
   ========================================================================== */
#flickr-wrapper { 
    width: 1280px;
    height: 720px;
    color: #fff;
    font-family: 'Segoe UI', Roboto, sans-serif;
    display: flex;          
    flex-direction: column; 
    overflow: hidden;       
    position: relative;

}

/* Navbar */
#flickr-nav-container {
    width: 100%;
    height: 70px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 30px;
    
    backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 100;
    flex-shrink: 0;
    box-sizing: border-box;
}

/* ==========================================================================
   2. GRID & SCROLLBAR (O Coração do App)
   ========================================================================== */
#flickr-results-grid { 
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); /* Auto ajusta */
    grid-auto-rows: 10px; 
    gap: 15px;
    margin-left: 20px;
    width: 1230px; 
    height: 630px; 
    padding: 10px 30px 60px 30px;
    box-sizing: border-box;
    overflow-y: scroll;
    overflow-x: hidden;
    scrollbar-gutter: stable;
}

/* Custom Scrollbar */
#flickr-results-grid::-webkit-scrollbar { width: 8px; }
#flickr-results-grid::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
#flickr-results-grid::-webkit-scrollbar-thumb { 
    background: goldenrod; 
    border-radius: 10px; 
}

/* ==========================================================================
   3. DYNAMIC LAYOUT MODES (Grid 1, 2, 3)
   ========================================================================== */

/* MODO 1: FEED CENTRALIZADO (Fixes "Empty Screen" issue) */
/* Modos Fixos (Forçam a quantidade de colunas) */
.grid-cols-4 { grid-template-columns: repeat(4, 1fr) !important; }
.grid-cols-3 { grid-template-columns: repeat(3, 1fr) !important; }
.grid-cols-2 { grid-template-columns: repeat(2, 1fr) !important; }

/* Modo 1 (Feed) */
.grid-cols-1 { display: block !important; }
.grid-cols-1 .flickr-card {
    max-width: 600px;
    margin: 0 auto 40px auto !important;
    grid-row-end: auto !important;
}
/* ==========================================================================
   4. CARDS & INTERACTION
   ========================================================================== */
.flickr-card { 
    width: 100%;
    border: none; 
    cursor: pointer; 
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    outline: 0px solid transparent;
    outline-offset: -2px;
    transform: translateZ(0);
    backface-visibility: hidden;
    transition: transform 0.25s ease, outline 0.25s ease;
    border-radius: 4px;
}

.flickr-card img { width: 100%; height: auto; display: block; }

.flickr-card:hover { 
    transform: scale(1.02); 
    outline: 1px solid white;
    z-index: 10;
}

/* Remote Sync Signal */
.flickr-card.remote-hover {
    outline: 2px solid #ffffff !important; 
    transform: scale(1.05) !important;
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.4);
    z-index: 999;
    position: relative;
}

/* ==========================================================================
   5. UI ELEMENTS (Buttons, Search, Tags)
   ========================================================================== */
.nav-group { display: flex; gap: 8px; align-items: center; }

.modern-btn {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgb(230, 229, 229);
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.modern-btn:hover {
    background: rgba(218, 165, 32, 0.15);
    border-color: rgba(218, 165, 32, 0.5);
    color: #fff;
}

.view-btn-active {
    background: goldenrod !important;
    color: #000 !important;
    border-color: goldenrod !important;
    box-shadow: 0 4px 12px rgba(218, 165, 32, 0.3);
}

/* Search Bar */
.search-pill {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    padding: 2px 2px 2px 12px;
    height: 30px;
    width: 250px;
    transition: 0.3s;
}

.search-pill:focus-within { border-color: goldenrod; background: rgba(255,255,255,0.1); }
.search-pill input { background: transparent; border: none; color: #fff; outline: none; font-size: 12px; width: 100%; }

.search-go-btn {
    background: #ffd50557;
    color: #fff; border: none; border-radius: 4px;
    padding: 7px 12px; font-size: 13px; font-weight: 400; cursor: pointer;
}

/* App Branding/Title */
.current-tag { display: flex; flex-direction: column; margin-right: 20px; min-width: 140px; }
.current-tag span { font-size: 16px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; }
.current-tag small { color: goldenrod; font-size: 11px; margin-top: 2px; opacity: 0.8; letter-spacing: 1px; }

/* ==========================================================================
   6. LIGHTBOX & OVERLAYS
   ========================================================================== */
#flickr-lightbox {
    position: fixed; top: 0; left: 0;
    width: 1280px; height: 720px;
    background: rgba(0, 0, 0, 0.9); 
    display: none; justify-content: center; align-items: center;
    z-index: 10000; flex-direction: column;
}

#lightbox-img-container {
    position: relative; max-width: 90%; max-height: 80%;
    border: 2px solid rgba(255,255,255,0.1); background: #000;
}

#lightbox-img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }

/* Navigation & Controls */
.ss-nav { 
    position: absolute; top: 50%; transform: translateY(-50%); 
    background: rgba(0, 0, 0, 0.5); color: white; padding: 20px 15px;
    cursor: pointer; font-size: 30px; border: none; transition: 0.2s;
}
.ss-nav:hover { background: goldenrod; color: black; }
.ss-prev { left: 40px; border-radius: 5px; }
.ss-next { right: 40px; border-radius: 5px; }

.ss-close { 
    position: absolute; top: 20px; right: 20px; 
    color: white; background: rgba(255,255,255,0.1); 
    border: 1px solid white; border-radius: 50%;
    width: 50px; height: 50px; font-size: 30px; cursor: pointer;
}

/* Utils */
.spinner { 
    border: 3px solid rgba(218,165,32,0.1); border-top: 3px solid goldenrod; 
    border-radius: 50%; width: 35px; height: 35px; margin: 0 auto 15px; 
    animation: spin 1s linear infinite; 
}
@keyframes spin { to { transform: rotate(360deg); } }  

</style>


<div id="flickr-wrapper"> 
    <div  id="flickr-main-ui">
<div id="flickr-nav-container">
<div class="nav-group" style="flex: 4;">
<div class="current-tag">
    <span>FLICKR VIEWER</span>
    <small id="search-context">LATEST PHOTOS</small> 
</div>

        <button class="modern-btn" onclick="window.showFavoritesPage()">Channels</button>
        <button class="modern-btn" onclick="window.showCategoriesPage()">Categories</button>
        
        <div class="search-pill" style="margin-left: 15px; max-width: 250px;">
            <input id="flickr-search" type="text" placeholder="Search..." onkeydown="if(event.key==='Enter') window.runFlickrSearch()">
            <button onclick="window.runFlickrSearch()" class="search-go-btn">GO</button>
        </div>

        <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.1); margin: 0 15px;"></div>
        

<button class="modern-btn view-btn" onclick="window.changeLayout('4', this)">4x</button>
<button class="modern-btn view-btn" onclick="window.changeLayout('3', this)">3x</button>
<button class="modern-btn view-btn" onclick="window.changeLayout('2', this)">2x</button>
<button class="modern-btn view-btn" onclick="window.changeLayout('1', this)">1x</button>
        
        <span id="photo-count" style="color: rgba(255,255,255,0.3); font-size: 9px; margin-left: 10px; letter-spacing: 1px;">0 PHOTOS</span>
    </div>

    <div class="nav-group-right">
        <button class="modern-btn close-style" onclick="closeSubMenu();">
            <span>&times;</span>
            <span style="margin-left: 5px;">CLOSE</span>
        </button>
    </div>
</div>

        <div id="favorites-manager" style="display:none; padding: 20px; background: rgba(0,0,0,0.4); border-radius:10px; margin:0 20px 20px 20px;">
            <h3 style="color:goldenrod; margin-top:0;">Public Channels</h3>
            <div id="channels-list" style="display:flex; flex-wrap:wrap; gap:5px;"></div>
        </div>

        <div id="categories-manager" style="display:none; padding: 20px; background: rgba(0,0,0,0.4); border-radius:10px; margin:0 20px 20px 20px;">
            <h3 style="color:goldenrod; margin-top:0;">Quick Categories</h3>
            <div id="categories-list" style="display:flex; flex-wrap:wrap; gap:5px;"></div>
        </div>

<div id="flickr-loader" style="display:none; text-align:center; padding:50px; color:goldenrod;">
    <div class="spinner" style="border: 4px solid rgba(218,165,32,0.1); border-top: 4px solid goldenrod; border-radius: 50%; width: 40px; height: 40px; margin: 0 auto 10px; animation: spin 1s linear infinite;"></div>
    <p style="font-weight:bold; letter-spacing:1px;">FETCHING PHOTOS...</p>
</div>

        <div id="flickr-results-grid"></div>
    </div>
</div>

<div id="flickr-lightbox" onclick="window.exitSlideshow()">
    <button class="ss-close" onclick="window.exitSlideshow()">&times;</button>
    <button class="ss-nav ss-prev" onclick="event.stopPropagation(); window.prevPhoto()">❮</button>
    <button class="ss-nav ss-next" onclick="event.stopPropagation(); window.nextPhoto()">❯</button>

    <div id="lightbox-img-container" onclick="event.stopPropagation()">
        <img id="lightbox-img" src="">
        <div id="ss-info" style="position: absolute; bottom: -40px; color: white; text-align: center; width: 100%;">
            <span id="img-title" style="font-weight:400; font-size:18px; text-shadow: 2px 2px 4px #000;"></span>
        </div>
    </div>
</div>

<script>
(function() {

const flickrGrid = document.getElementById('flickr-results-grid');

flickrGrid.addEventListener('wheel', (e) => {
    // Impede o scroll padrão lento
    e.preventDefault();

    // Ajuste este número para aumentar/diminuir a sensibilidade
    const speedMultiplier = 2.5; 

    // Move o scroll manualmente
    flickrGrid.scrollTop += e.deltaY * speedMultiplier;

    // Sincroniza o scroll com os outros usuários (opcional, já que você já tem o emit no scroll)
    // O seu código de scroll atual capturará essa mudança automaticamente.
}, { passive: false });




// CHANGE LAYOUT    
window.changeLayout = function(type, btn, isRemote = false) {
    const grid = $('#flickr-results-grid');
    
    // Limpa tudo
    grid.removeClass('grid-cols-1 grid-cols-2 grid-cols-3 grid-cols-4');
    $('.view-btn').removeClass('view-btn-active');
    if (btn) $(btn).addClass('view-btn-active');

    // Aplica o novo modo
    if (type !== 'auto') {
        grid.addClass(`grid-cols-${type}`);
    }

    // Reset de estilos internos para garantir que o Masonry ou o Feed funcionem
    if (type === '1') {
        $('.flickr-card').css('grid-row-end', ''); 
    } else {
        setTimeout(() => {
            window.currentPhotos.forEach((_, i) => window.resizeGridItem(i));
        }, 50);
    }

    grid.scrollTop(0);

    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_layout_change', 
            layoutType: type, 
            room: window.myRoom 
        });
    }
};


// PHOTO SEARCH
window.currentPhotos = [];
window.currentIndex = 0;
window.runFlickrSearch = function(manualQuery = null, incomingPhotos = null, isRemote = false) {
    const tags = manualQuery || $('#flickr-search').val();
    $('#search-context').text(`${tags.toUpperCase()}`); // add title
    // SE as fotos já vieram prontas pelo Socket (incomingPhotos), 
    // APENAS desenhe o grid. NÃO faça uma nova chamada de API.
    if (incomingPhotos) {
        console.log("Sincronizando fotos via Socket (Sem nova requisição API)");
        $('#flickr-loader').hide();
        $('#flickr-results-grid').show();
        window.renderGrid(incomingPhotos);
        return; // <--- O "Pulo do Gato" está aqui. Interrompe o loop.
    }

    // Se chegou aqui, é uma busca MANUAL do usuário
    $('#flickr-loader').fadeIn(100);

    $.getJSON(`/api/flickr/search?tags=${encodeURIComponent(tags)}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            window.renderGrid(photos);

            // Avisa os outros, mas envia os DADOS das fotos junto
            if (window.socket && !isRemote) {
                window.socket.emit('state_sync', {
                    type: 'flickr_results_sync',
                    query: tags,
                    photos: photos, // Envia as fotos já baixadas
                    room: window.myRoom
                });
            }
        });
};
// RENDER GRID
window.renderGrid = function(photos) {
    window.currentPhotos = photos; 

    // ATUALIZAÇÃO DO CONTADOR:
    // Seleciona o elemento e atualiza com o número de fotos retornadas
    const countLabel = photos ? photos.length : 0;
    $('#photo-count').text(`${countLabel} PHOTOS`);

    if (!photos || photos.length === 0) {
        $('#flickr-results-grid').html('<p style="color:gray; text-align:center; padding:20px;">No photos found.</p>');
        return;
    }

    let html = photos.map((p, i) => `
        <div class="flickr-card" id="card-${i}" onclick="window.startSlideshow(${i})">
            <img src="https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_z.jpg" 
                 onload="window.resizeGridItem(${i})">
        </div>`).join('');
    $('#flickr-results-grid').html(html);
};
// RESIZE GRID
window.resizeGridItem = function(index) {
        const item = document.getElementById(`card-${index}`);
        const grid = document.getElementById('flickr-results-grid');
        if (!item || !grid) return;
        const rowHeight = 10, rowGap = 15;
        const img = item.querySelector('img');
        const rowSpan = Math.ceil((img.getBoundingClientRect().height + rowGap) / (rowHeight + rowGap));
        item.style.gridRowEnd = `span ${rowSpan}`;
    };

// --- 3. CATEGORIES ---
window.showCategoriesPage = function(isRemote = false) {
    $('#flickr-results-grid, #favorites-manager').hide();
    $('#categories-manager').fadeIn(200);
    
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_show_categories', room: window.myRoom });
    }

    const cats = ["Nature", "Architecture", "Cyberpunk", "Space", "Abstract", "Night", "Landscape"];
    let html = cats.map(c => `
        <div class="fav-chip">
            <button onclick="window.runFlickrSearch('${c}', null, false)" 
                    style="background:none; border:none; color:goldenrod; padding:10px 15px; cursor:pointer; font-weight:bold;">
                # ${c}
            </button>
        </div>`).join('');
    $('#categories-list').html(html);
};
// --- 4. FAVORITES/CHANNELS ---
window.showFavoritesPage = function(isRemote = false) {
//////////////////////////////////////////////////////////
    // 1. UI Toggle
    $('#flickr-results-grid, #categories-manager').hide();
    $('#favorites-manager').fadeIn(200);
    
    // 2. Load the actual data
    window.loadFavoritesList();

    // 3. SYNC: Tell others to open the favorites/channels manager
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_show_channels', 
            room: window.myRoom 
        });
    }
};

window.loadFavoritesList = function() {
        fetch('/api/favorites')
            .then(res => res.json())
            .then(data => {
                const channels = data.channels || data;
                let html = Object.entries(channels).map(([name, id]) => `
                    <div class="fav-chip">
                        <button onclick="window.viewChannel('${id}')" style="background:none; border:none; color:goldenrod; padding:10px 15px; cursor:pointer;">${name}</button>
                    </div>`).join('');
                $('#channels-list').html(html || '<p style="color:gray; padding:10px;">No channels found.</p>');
            });
    };

window.viewChannel = function(userId, isRemote = false) {
    $('#favorites-manager, #categories-manager, #flickr-results-grid').hide();
    $('#flickr-loader').fadeIn(200);
    
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_channel_sync', 
            userId: userId, 
            room: window.myRoom 
        });
    }

    // CHAMADA PARA O SEU SERVIDOR (Mais seguro e funciona!)
    $.getJSON(`/api/flickr/channel/${userId}`)
        .done(function(photos) {
            $('#flickr-loader').hide();
            $('#flickr-results-grid').fadeIn(300);
            window.renderGrid(photos); // Isso agora vai funcionar porque photos é o array correto
        })
        .fail(function() {
            $('#flickr-loader').text("Error: Could not load channel.");
            setTimeout(() => {
                $('#flickr-loader').hide();
                $('#favorites-manager').show();
            }, 2000);
        });
};
// --- 5. SLIDESHOW ---
window.startSlideshow = function(index, isRemote = false) {
        window.currentIndex = index;
        window.updateLightbox();
        $('#flickr-main-ui').fadeOut(100, () => {
            $('#flickr-lightbox').css('display', 'flex').hide().fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'start_slideshow', index: index, room: window.myRoom });
        }
    };

window.updateLightbox = function() {
    const p = window.currentPhotos[window.currentIndex];
    if (!p) {
        console.error("Slideshow Error: No photo found at index", window.currentIndex);
        return;
    }

    // Tenta carregar a versão Grande (_b)
    const urlLarge = `https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_b.jpg`;
    const urlMedium = `https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_z.jpg`;
    
    const imgElement = $('#lightbox-img');
    
    // Define a imagem e, se der erro (404), carrega a média
    imgElement.attr('src', urlLarge);
    imgElement.on('error', function() {
        $(this).attr('src', urlMedium);
    });

    $('#img-title').text(p.title || "Untitled");

    if (window.socket) {
        window.socket.emit('state_sync', { 
            type: 'flickr_remote_nav', 
            index: window.currentIndex, 
            url: urlLarge, 
            title: p.title, 
            room: window.myRoom 
        });
    }
};
window.nextPhoto = function() {
        window.currentIndex = (window.currentIndex + 1) % window.currentPhotos.length;
        window.updateLightbox();
    };

window.prevPhoto = function() {
        window.currentIndex = (window.currentIndex - 1 + window.currentPhotos.length) % window.currentPhotos.length;
        window.updateLightbox();
    };

window.exitSlideshow = function(isRemote = false) {
        $('#flickr-lightbox').fadeOut(200, () => {
            $('#flickr-main-ui').fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'exit_slideshow', room: window.myRoom });
        }
    };

    // --- 6. INITIAL LOAD & SCROLL ---
    $(document).ready(() => {
        // Only load if the grid is empty
        if(!window.currentPhotos.length) window.runFlickrSearch('Second life');
    });

$('#flickr-results-grid').on('scroll', function() {
    if (window.isSyncing) return;  // ← global flag
    if (window.socket && window.socket.connected) {
        window.socket.emit('state_sync', {
            type: 'scroll',          // ← global event type
            position: $(this).scrollTop(),
            room: window.myRoom
        });
    }
});  
    
    // Add this to your Flickr script block
window.closeSubMenuWithLightbox = function() {
    // If the lightbox is open, close it first
    if ($('#flickr-lightbox').is(':visible')) {
        window.exitSlideshow();
    } else {
        // Otherwise, close the whole Flickr app
        closeSubMenu();
    }
};



})();
</script>