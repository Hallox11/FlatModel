<style>
    /* Scoped styles for Instructions Overlay */
    #instructions-overlay-wrapper {
        width: 1280px;
        height: 720px;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent; /* Parent overlay handles the blur */
        color: white;
        font-family: 'Fira Sans', sans-serif;
        overflow: hidden;
    }

    #instructions-content-panel {
        position: absolute;
        width: 1000px;
        top: 60px;
        padding: 40px;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.8);
        text-align: center;
        box-sizing: border-box;
    }

    .instr-title {
        font-size: 42px;
        color: #00d4ff;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 3px;
        text-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    }

    .instr-section-title {
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #eee;
    }

    .instr-text-line {
        font-size: 20px;
        margin: 12px 0;
        line-height: 1.5;
    }

    .instr-red { color: #ff3333; }
    .instr-green { color: #2ecc71; }
    .instr-yellow { color: #f1c40f; }

    .instr-footer {
        position: absolute;
        bottom: 0;
        width: 1280px;
        height: 200px;
        background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .instr-legal-box {
        background: rgba(255, 255, 255, 0.1);
        padding: 15px 30px;
        border-radius: 10px;
        font-size: 18px;
        text-align: center;
        width: 900px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        opacity: 0.9;
    }

    .instr-back-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        color: white;
        padding: 12px 100px;
        font-size: 22px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
    }

    .instr-back-btn:hover {
        background: #00d4ff;
        color: black;
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
    }
</style>

<div id="instructions-overlay-wrapper">
    <div id="instructions-content-panel">
        <div class="instr-title">Instructions</div>

        <div class="instr-section-title">FRAME BUTTONS</div>
        <div class="instr-text-line">
            ( <b class="instr-yellow">Right Button</b> - Settings HUD for Size, Aspect, Textures, etc. )
        </div>
        <div class="instr-text-line">
            ( <b class="instr-yellow">Left Button</b> - Page Back when browsing external sites )
        </div>

        <div style="margin: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); width: 60%; margin-left: 20%;"></div>

        <div class="instr-text-line instr-green">
            ( Use <b>SETUP</b> for the Menu or get the HUD via the Right Frame Button )
        </div>
        <div class="instr-text-line instr-green">
            ( Move mouse to the <b class="instr-yellow">Top</b> during video playback for the Back button )
        </div>
        
        <div class="instr-text-line instr-red" style="margin-top: 25px; font-style: italic;">
            ( For legal reasons, copyright movies are not streamed )
        </div>
    </div>

    <div class="instr-footer">
        <div class="instr-legal-box">
            This TV is a pass-through device, all media is broadcast directly from original sites.<br>
            Internet links are subject to change or deletion at any time.
        </div>

        <button class="instr-back-btn" onclick="closeSubMenu()">Back</button>
    </div>
</div>

<script>
