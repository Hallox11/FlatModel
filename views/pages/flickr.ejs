<style>
    /* Fixed Container to prevent horizontal scroll at 1280px */
    #flickr-wrapper { 
        
        width: 1260px; 
        margin-right: 10px; 
        overflow: hidden; 
        position: relative; 
        top:15px;
    
    }
    
#flickr-results-grid { 
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    grid-auto-rows: 10px; 
    gap: 15px;
    width: 100%; 
    max-height: 630px; 

    /* FIX: Reserves space for the scrollbar so it doesn't "push" the grid */
    scrollbar-gutter: stable; 

    overflow-y: scroll; /* Force it to always be visible if content is long */
    overflow-x: hidden;
    padding: 0px 20px 40px 20px; /* Added bottom padding for better feel */
    box-sizing: border-box;
}
    
    #flickr-results-grid::-webkit-scrollbar { width: 8px; }
    #flickr-results-grid::-webkit-scrollbar-thumb { background: goldenrod; border-radius: 4px; }

.flickr-card { 
    width: 100%;
    /* Remove border entirely from the base state to avoid layout math */
    border: none; 
    cursor: pointer; 
    overflow: hidden;
    background: rgba(0,0,0,0.3);
    
    /* 1. STABILITY: Use outline instead of border */
    outline: 0px solid transparent;
    outline-offset: -2px; /* Draws the line INSIDE the image edge */

    /* 2. GPU ACCELERATION: Prevents blurry shaking during scale */
    transform: translateZ(0);
    backface-visibility: hidden;
    transition: transform 0.2s ease, outline 0.2s ease;
}

.flickr-card:hover { 
    /* 3. NO LAYOUT CHANGE: Outline doesn't affect width/height */
    transform: scale(1.02); 
    outline: 1px solid white;
    z-index: 10; /* Ensure the hover effect stays on top of neighbors */
}
    .flickr-card img { width: 100%; height: auto; display: block; }

    /* Lightbox Container - Locked to 1280x720 */
    #flickr-lightbox {
        position: fixed;
        top: 0; left: 0;
        width: 1280px; height: 720px;
        background: rgba(0, 0, 0, 0.85); 
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        flex-direction: column;
    }

    #lightbox-img-container {
        position: relative;
        max-width: 90%;
        max-height: 80%;
        border: 2px solid rgba(255,255,255,0.2);
        background: #000;
        box-shadow: 0 0 30px rgba(0,0,0,0.5);
    }

    #lightbox-img {
        max-width: 100%;
        max-height: 100%;
        display: block;
        object-fit: contain; 
    }

    .ss-nav { 
        position: absolute; 
        top: 50%; 
        transform: translateY(-50%); 
        background: rgba(0, 0, 0, 0.5); 
        color: white; 
        
       
        cursor: pointer; 
        font-size: 30px; 
        z-index: 10001;
    }
    .ss-nav:hover { background: goldenrod; color: black; }
    .ss-prev { left: 40px; border-radius: 0 5px 5px 0; }
    .ss-next { right: 40px; border-radius: 5px 0 0 5px; }

    .ss-close { 
        position: absolute; 
        top: 20px; right: 20px; 
        color: white; background: rgba(255,0,0,0.3); 
        border: 1px solid white; border-radius: 50%;
        width: 50px; height: 50px; font-size: 30px; 
        cursor: pointer; z-index: 10002;
    }
    .fav-chip { display: inline-flex; align-items: center; background: rgba(255,255,255,0.1); border-radius: 20px; margin: 5px; border: 1px solid rgba(255,255,255,0.1); transition: 0.2s; }
    .fav-chip:hover { background: rgba(218, 165, 32, 0.3); }

@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

/* Circular Back Button Styling */
/* Layout & Navigation */
#flickr-nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 25px;
    position: fixed;
    top: 5px;
    z-index: 1000;
    width: 99%;
    box-sizing: border-box;
}

.nav-group { display: flex; gap: 10px; flex: 1; }
.nav-group-right { display: flex; justify-content: flex-end; flex: 1; }

/* Buttons */
.modern-btn {
    background: #534b4bbf;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #e0e0e0;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
}

.modern-btn:hover {
    background: rgba(218, 165, 32, 0.2);
    border-color: goldenrod;
    color: goldenrod;
}

/* Search Pill */
.search-pill-container { flex: 2; display: flex; justify-content: center; }

.search-pill {
    display: flex;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    padding: 3px 3px 3px 15px;
    width: 100%;
    max-width: 380px;
    transition: 0.3s;
}

.search-pill:focus-within {
    border-color: goldenrod;
    background: rgba(0, 0, 0, 0.6);
    box-shadow: 0 0 15px rgba(218, 165, 32, 0.2);
}

.search-pill input {
    background: transparent;
    border: none;
    color: white;
    outline: none;
    font-size: 14px;
    width: 100%;
}

.search-go-btn {
    background: goldenrod;
    color: #000;
    border: none;
    border-radius: 50px;
    padding: 6px 18px;
    font-weight: 800;
    cursor: pointer;
}

/* Managers & Panels */
.manager-panel {
    padding: 20px;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    margin: 15px 25px;
    border: 1px solid rgba(255,255,255,0.05);
}

.panel-title { color: goldenrod; margin: 0 0 15px 0; font-size: 16px; text-transform: uppercase; letter-spacing: 1px; }
.chip-container { display: flex; flex-wrap: wrap; gap: 8px; }

/* Loader */
#flickr-loader { text-align: center; padding: 60px; color: goldenrod; }
.spinner { 
    border: 3px solid rgba(218,165,32,0.1); 
    border-top: 3px solid goldenrod; 
    border-radius: 50%; 
    width: 35px; height: 35px; 
    margin: 0 auto 15px; 
    animation: spin 1s linear infinite; 
}

/* Modern Close Button */
.flickr-close-btn-modern {
    background: #1a1a1a; /* Dark center */
    border: none;
    color: white;
    width: 35px;
    height: 35px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    
    /* The Gold/Yellow Ring */
    box-shadow: 0 0 0 2px #e1a91a; 
}

.flickr-close-btn-modern svg {
    transition: all 0.2s ease-in-out;
    stroke-width: 3; /* Normal thickness */
}

/* Hover/Selected State */
.flickr-close-btn-modern:hover {
    transform: scale(1.1); /* Circle gets slightly bigger */
    background: #000;
    box-shadow: 0 0 0 3px #ffc107, 0 0 15px rgba(255, 193, 7, 0.4);
}

.flickr-close-btn-modern:hover svg {
    stroke-width: 5; /* "X" becomes physically thicker */
    transform: scale(1.2); /* "X" becomes physically larger */
    filter: drop-shadow(0 0 2px rgba(255,255,255,0.5));
}

/* Active/Pressed State */
.flickr-close-btn-modern:active {
    transform: scale(0.95);
    box-shadow: 0 0 0 1px #e1a91a;
}

@keyframes spin { to { transform: rotate(360deg); } }


/* Unique Sync Style for Flickr Cards only */
/* Unique Sync Style for Flickr Cards only */
.flickr-card.remote-hover {
    /* Use outline instead of border to prevent pushing neighbors */
    outline: 2px solid #ffffff !important; 
    outline-offset: -2px;
    
    /* Use transform to lift it without affecting the grid rows */
    transform: scale(1.05) !important;
    
    /* Increase shadow to make it obvious it's a remote action */
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.5), 0 10px 20px rgba(0,0,0,0.5);
    
    z-index: 999; /* Pop it above everything else */
    position: relative;
    transition: all 0.3s ease;
}



/* The "Remote Viewing" Label */

</style>

<div id="flickr-wrapper"> 
    <div  id="flickr-main-ui">
<div id="flickr-nav-container">
            <div class="nav-group">
                <button class="modern-btn" onclick="window.showFavoritesPage()">CHANNELS</button>
                <button class="modern-btn" onclick="window.showCategoriesPage()">CATEGORIES</button>
            </div>

            <div class="search-pill-container">
                <div class="search-pill">
                    <input id="flickr-search" type="text" placeholder="Explore photos..." 
                           onkeydown="if(event.key==='Enter') window.runFlickrSearch()">
                    <button onclick="window.runFlickrSearch()" class="search-go-btn">GO</button>
                </div>
            </div>

            <div class="nav-group-right">
                <button class="flickr-close-btn-modern" onclick="   closeSubMenu(); ">
                    <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="3" fill="none">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>

        <div id="favorites-manager" style="display:none; padding: 20px; background: rgba(0,0,0,0.4); border-radius:10px; margin:0 20px 20px 20px;">
            <h3 style="color:goldenrod; margin-top:0;">Public Channels</h3>
            <div id="channels-list" style="display:flex; flex-wrap:wrap; gap:5px;"></div>
        </div>

        <div id="categories-manager" style="display:none; padding: 20px; background: rgba(0,0,0,0.4); border-radius:10px; margin:0 20px 20px 20px;">
            <h3 style="color:goldenrod; margin-top:0;">Quick Categories</h3>
            <div id="categories-list" style="display:flex; flex-wrap:wrap; gap:5px;"></div>
        </div>

<div id="flickr-loader" style="display:none; text-align:center; padding:50px; color:goldenrod;">
    <div class="spinner" style="border: 4px solid rgba(218,165,32,0.1); border-top: 4px solid goldenrod; border-radius: 50%; width: 40px; height: 40px; margin: 0 auto 10px; animation: spin 1s linear infinite;"></div>
    <p style="font-weight:bold; letter-spacing:1px;">FETCHING PHOTOS...</p>
</div>

        <div id="flickr-results-grid"></div>
    </div>
</div>

<div id="flickr-lightbox" onclick="window.exitSlideshow()">
    <button class="ss-close" onclick="window.exitSlideshow()">&times;</button>
    <button class="ss-nav ss-prev" onclick="event.stopPropagation(); window.prevPhoto()">❮</button>
    <button class="ss-nav ss-next" onclick="event.stopPropagation(); window.nextPhoto()">❯</button>

    <div id="lightbox-img-container" onclick="event.stopPropagation()">
        <img id="lightbox-img" src="">
        <div id="ss-info" style="position: absolute; bottom: -40px; color: white; text-align: center; width: 100%;">
            <span id="img-title" style="font-weight:400; font-size:18px; text-shadow: 2px 2px 4px #000;"></span>
        </div>
    </div>
</div>

<script>
(function() {
    const FLICKR_KEY = "<%= apiKey %>";
    window.currentPhotos = [];
    window.currentIndex = 0;
    window.isSyncingScroll = false;

    // --- 1. THE ONLY SEARCH FUNCTION (Consolidated) ---
window.runFlickrSearch = function(manualQuery = null, incomingPhotos = null, isRemote = false) {
    const tags = manualQuery || $('#flickr-search').val();
    
    // 1. Local UI Reset
    $('#favorites-manager, #categories-manager, #flickr-results-grid').hide();
    $('#flickr-loader').fadeIn(100); 

    // 2. SYNC: Tell others to show the loader IMMEDIATELY
    if (window.socket && !isRemote && tags) {
        window.socket.emit('state_sync', {
            type: 'flickr_loading_start',
            query: tags,
            room: window.myRoom
        });
    }

    // 3. If photos already arrived via sync from someone else
    if (incomingPhotos) {
        $('#flickr-search').val(tags);
        $('#flickr-loader').hide();
        $('#flickr-results-grid').show();
        window.renderGrid(incomingPhotos);
        return; 
    }

    if (!tags) {
        $('#flickr-loader').hide();
        return;
    }

    // 4. Fetch from Flickr
    const url = `https://www.flickr.com/services/rest/?method=flickr.photos.search&api_key=${FLICKR_KEY}&text=${encodeURIComponent(tags)}&format=json&nojsoncallback=1&per_page=50&sort=interestingness-desc`;
    
    $.getJSON(url, function(data) {
        const photos = data.photos?.photo || [];
        
        // Success: Hide loader and show grid
        $('#flickr-loader').hide();
        $('#flickr-results-grid').show();
        window.renderGrid(photos);

        // 5. SYNC: Send the final results to everyone
        if (window.socket && !isRemote) { 
            window.socket.emit('state_sync', {
                type: 'flickr_results_sync',
                query: tags,
                photos: photos, 
                room: window.myRoom
            });
        }
    });
};


window.renderGrid = function(photos) {
        window.currentPhotos = photos;
        if (!photos.length) {
            $('#flickr-results-grid').html('<p style="color:gray; padding:20px;">No photos found.</p>');
            return;
        }
        let html = photos.map((p, i) => `
            <div class="flickr-card" id="card-${i}" onclick="window.startSlideshow(${i})">
                <img src="https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_z.jpg" onload="window.resizeGridItem(${i})">
            </div>`).join('');
        $('#flickr-results-grid').html(html);
    };

    window.resizeGridItem = function(index) {
        const item = document.getElementById(`card-${index}`);
        const grid = document.getElementById('flickr-results-grid');
        if (!item || !grid) return;
        const rowHeight = 10, rowGap = 15;
        const img = item.querySelector('img');
        const rowSpan = Math.ceil((img.getBoundingClientRect().height + rowGap) / (rowHeight + rowGap));
        item.style.gridRowEnd = `span ${rowSpan}`;
    };

    // --- 3. CATEGORIES ---
window.showCategoriesPage = function(isRemote = false) {
    $('#flickr-results-grid, #favorites-manager').hide();
    $('#categories-manager').fadeIn(200);
    
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { type: 'flickr_show_categories', room: window.myRoom });
    }

    const cats = ["Nature", "Architecture", "Cyberpunk", "Space", "Abstract", "Night", "Landscape"];
    let html = cats.map(c => `
        <div class="fav-chip">
            <button onclick="window.runFlickrSearch('${c}', null, false)" 
                    style="background:none; border:none; color:goldenrod; padding:10px 15px; cursor:pointer; font-weight:bold;">
                # ${c}
            </button>
        </div>`).join('');
    $('#categories-list').html(html);
};
    // --- 4. FAVORITES/CHANNELS ---
window.showFavoritesPage = function(isRemote = false) {
    // 1. UI Toggle
    $('#flickr-results-grid, #categories-manager').hide();
    $('#favorites-manager').fadeIn(200);
    
    // 2. Load the actual data
    window.loadFavoritesList();

    // 3. SYNC: Tell others to open the favorites/channels manager
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_show_channels', 
            room: window.myRoom 
        });
    }
};

    window.loadFavoritesList = function() {
        fetch('/api/favorites')
            .then(res => res.json())
            .then(data => {
                const channels = data.channels || data;
                let html = Object.entries(channels).map(([name, id]) => `
                    <div class="fav-chip">
                        <button onclick="window.viewChannel('${id}')" style="background:none; border:none; color:goldenrod; padding:10px 15px; cursor:pointer;">🖼️ ${name}</button>
                    </div>`).join('');
                $('#channels-list').html(html || '<p style="color:gray; padding:10px;">No channels found.</p>');
            });
    };

window.viewChannel = function(userId, isRemote = false) {
    // 1. UI: Show loader, hide other menus
    $('#favorites-manager, #categories-manager, #flickr-results-grid').hide();
    $('#flickr-loader').fadeIn(200);
    
    // 2. Sync to Room
    if (window.socket && !isRemote) {
        window.socket.emit('state_sync', { 
            type: 'flickr_channel_sync', 
            userId: userId, 
            room: window.myRoom 
        });
    }

    // 3. FIX: Call Flickr API directly instead of the server
    // This bypasses the 404 error by going straight to the source
    const url = `https://www.flickr.com/services/rest/?method=flickr.people.getPublicPhotos&api_key=${FLICKR_KEY}&user_id=${userId}&format=json&nojsoncallback=1&per_page=50`;
    
    $.getJSON(url, function(data) {
        if (data && data.photos) {
            const photos = data.photos.photo || [];
            
            // 4. Update the grid and hide loader
            $('#flickr-loader').hide();
            $('#flickr-results-grid').fadeIn(300);
            window.renderGrid(photos);
            
            // Sync the photos to others in the room
            if (window.socket && !isRemote) {
                window.socket.emit('state_sync', {
                    type: 'flickr_results_sync',
                    photos: photos, 
                    room: window.myRoom
                });
            }
        } else {
            $('#flickr-loader').text("No photos found for this ID.");
            setTimeout(() => $('#flickr-loader').hide(), 2000);
        }
    }).fail(function() {
        // If Flickr itself fails or the ID is wrong
        $('#flickr-loader').text("Error: User ID not found.");
        setTimeout(() => {
            $('#flickr-loader').hide();
            $('#favorites-manager').show();
        }, 2000);
    });
};

// --- 5. SLIDESHOW ---
    window.startSlideshow = function(index, isRemote = false) {
        window.currentIndex = index;
        window.updateLightbox();
        $('#flickr-main-ui').fadeOut(100, () => {
            $('#flickr-lightbox').css('display', 'flex').hide().fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'start_slideshow', index: index, room: window.myRoom });
        }
    };

    window.updateLightbox = function() {
        const p = window.currentPhotos[window.currentIndex];
        if (!p) return;
        const url = `https://live.staticflickr.com/${p.server}/${p.id}_${p.secret}_b.jpg`;
        $('#lightbox-img').attr('src', url);
        $('#img-title').text(p.title || "Untitled");

        if (window.socket) {
            window.socket.emit('state_sync', { 
                type: 'flickr_remote_nav', index: window.currentIndex, url: url, title: p.title, room: window.myRoom 
            });
        }
    }; 

    window.nextPhoto = function() {
        window.currentIndex = (window.currentIndex + 1) % window.currentPhotos.length;
        window.updateLightbox();
    };

    window.prevPhoto = function() {
        window.currentIndex = (window.currentIndex - 1 + window.currentPhotos.length) % window.currentPhotos.length;
        window.updateLightbox();
    };

    window.exitSlideshow = function(isRemote = false) {
        $('#flickr-lightbox').fadeOut(200, () => {
            $('#flickr-main-ui').fadeIn(200);
        });
        if (!isRemote && window.socket) {
            window.socket.emit('state_sync', { type: 'exit_slideshow', room: window.myRoom });
        }
    };

    // --- 6. INITIAL LOAD & SCROLL ---
    $(document).ready(() => {
        // Only load if the grid is empty
        if(!window.currentPhotos.length) window.runFlickrSearch('Second life');
    });

$('#flickr-results-grid').on('scroll', function() {
    if (window.isSyncing) return;  // ← global flag
    if (window.socket && window.socket.connected) {
        window.socket.emit('state_sync', {
            type: 'scroll',          // ← global event type
            position: $(this).scrollTop(),
            room: window.myRoom
        });
    }
});  
    
    // Add this to your Flickr script block
window.closeSubMenuWithLightbox = function() {
    // If the lightbox is open, close it first
    if ($('#flickr-lightbox').is(':visible')) {
        window.exitSlideshow();
    } else {
        // Otherwise, close the whole Flickr app
        closeSubMenu();
    }
};



})();
</script>