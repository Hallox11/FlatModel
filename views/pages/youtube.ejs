<style>

#yt-module {
    width: 1200px; /* Full width */
    height: 720px; /* Fixed height */
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Prevent the whole module from scrolling */
    color: #fff;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    box-sizing: border-box;
}

#yt-module .nav-bar {
    flex-shrink: 0; /* Prevents the bar from squishing */
    padding: 15px 25px;
    display: flex;
    gap: 12px;
    background: transparent;
    z-index: 99;
    border-bottom: 1px solid #222;
    align-items: center;
}

/* New Scrollable Wrapper */
#yt-content-scroll {
    flex-grow: 1;
    overflow-y: auto;
    overflow-x: hidden;
    width: 100%;
}

    #yt-module #yt-search-input {
        flex-grow: 1;
        background: #222;
        color: #fff;
        border: 1px solid #444;
        padding: 12px;
        border-radius: 4px;
        font-size: 16px;
    }

    #yt-module .search-btn, #yt-module .cat-modal-btn {
        padding: 0 20px;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
        text-transform: uppercase;
        height: 45px;
        white-space: nowrap;
    }

    #yt-module .search-btn { background: #ff0000; }
    #yt-module .cat-modal-btn { background: #333; border: 1px solid #ff6b6b; color: #ff6b6b; }

    /* Modal */
    #yt-cat-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 1280px;
        height: 720px;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .cat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        width: 90%;
        max-width: 1000px;
    }

    .cat-item {
        background: #1a1a1a;
        padding: 15px;
        border: 1px solid #444;
        color: #ff6b6b;
        text-align: center;
        cursor: pointer;
        font-weight: bold;
        transition: 0.2s;
        border-radius: 4px;
    }

    .cat-item:hover { background: #ff0000; color: #fff; border-color: #fff; }

    /* Grid */
#yt-module .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    padding: 25px;
    box-sizing: border-box;
}

    #yt-module .video-card {
        background: #161616;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s;
        border: 1px solid white;
        border-radius: 4px;
        cursor: pointer;
    }

    #yt-module .video-card:hover {
        transform: translateY(0px);
        border-color: #ff0000 !important;
    }

    #yt-module .thumb-wrap {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #000;
        position: relative;
    }

    #yt-module .thumb-wrap img { 
        width: 100%; 
        height: 230px; 
        object-fit: cover;
     }

    #yt-module .duration-badge {
        position: absolute;
        bottom: 6px;
        right: 6px;
        background: rgba(0,0,0,0.85);
        color: #fff;
        font-size: 11px;
        padding: 2px 5px;
        border-radius: 3px;
        font-weight: bold;
    }

    #yt-module .video-meta { 
        padding: 4px 10px 10px;
     }
   
   
    #yt-module .video-title { 
    letter-spacing: 0.9px; 
    font-size: 13px; 
    margin: 5px; 
    color: #eee; 
    text-transform: uppercase; 
    margin-bottom: 0px; 
    line-height: 1.0;
    
    /* ADD THESE: */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
    
    #yt-module .video-channel { 
        font-size: 13px;
         margin: 1px;
         color: #ff6b6b; }

    #yt-module .loading-msg {
        text-align: center;
        padding: 60px;
        color: #555;
        font-size: 18px;
        grid-column: 1 / -1;
    }

    #yt-module .error-msg {
        text-align: center;
        padding: 60px;
        color: #ff4444;
        font-size: 16px;
        grid-column: 1 / -1;
    }

    /* Load more */
    #yt-module .load-more-wrap {
        text-align: center;
        padding: 10px 25px 30px;
    }

    #yt-module .load-more-btn {
        background: transparent;
        color: #ff6b6b;
        border: 1px solid #ff6b6b;
        padding: 10px 40px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
        text-transform: uppercase;
        transition: 0.2s;
    }

    #yt-module .load-more-btn:hover { background: #ff0000; color: #fff; border-color: #ff0000; }
    #yt-module .load-more-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    #yt-module .fav-modal-btn { 
    background: #111; 
    border: 1px solid #ffd700; 
    color: #ffd700; 
    padding: 0 20px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    height: 45px;
}




    /* Update these specific parts in your <style> block */

#yt-fav-modal {
    display: none; 
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 1280px; 
    height: 720px; 
    background: rgba(0, 0, 0, 0.98); /* Slightly darker for better contrast */
    z-index: 10000; 
    flex-direction: column; 
    align-items: center; 
    padding-top: 20px;
    box-sizing: border-box;
}

/* Container for the buttons that allows vertical scrolling */
.fav-scroll-container {
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
}

.fav-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4 columns as seen in your image */
    gap: 10px;
    width: 1200px; /* Slightly less than 1240 to account for scrollbar padding */
    padding: 10px;
}

.fav-item {
    background: #111;
    padding: 12px 5px;
    border: 1.5px solid #ffd700; /* Goldenrod border */
    color: #ffd700;
    text-align: center;
    cursor: pointer;
    border-radius: 4px;
    font-weight: bold;
    font-size: 14px;
    text-transform: capitalize;
    transition: all 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.fav-item:hover {
    background: #ffd700;
    color: #000;
}

#yt-module .close-btn {
    background: #222;
    color: #ff4444;
    border: 1px solid #ff4444;
    border-radius: 50%; /* Circular button */
    width: 45px;
    height: 45px;
    cursor: pointer;
    font-size: 20px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
    flex-shrink: 0;
}

#yt-module .close-btn:hover {
    background: #ff4444;
    color: #fff;
    box-shadow: 0 0 10px rgba(255, 68, 68, 0.5);
}

    #yt-content-scroll::-webkit-scrollbar { width: 12px; }
    #yt-content-scroll::-webkit-scrollbar-track { background: #333; border-radius: 10px; }
    #yt-content-scroll::-webkit-scrollbar-thumb { background: red; border-radius: 10px; }

</style>

<div id="yt-module">
