<script>
window.ytSearch = function() {
    const val = document.getElementById('yt-search-input').value.trim();
    if (!val) return;
    // Change 'youtube-grid' to 'youtube'
    handleNav('youtube?tag=' + encodeURIComponent(val));
};

window.selectYtCat = function(cat) {
    toggleYtCatModal(false);
    // Change 'youtube-grid' to 'youtube'
    handleNav('youtube?tag=' + encodeURIComponent(cat));
};

window.toggleYtCatModal = function(show) {
    document.getElementById('yt-cat-modal').style.display = show ? 'flex' : 'none';
    if (window.socket && !window.isRemoteAction) {
        socket.emit('state_sync', { type: 'yt_modal', show });
    }
};


window.toggleYtFavModal = function(show) {
    const modal = document.getElementById('yt-fav-modal');
    if (!modal) return;

    modal.style.display = show ? 'flex' : 'none';
    
    // Only emit if this was a LOCAL click, not a command from the socket
    if (window.socket && !window.isRemoteAction) {
        socket.emit('state_sync', { 
            type: 'yt_fav_modal', 
            show: show,
            room: "Lobby"
        });
    }
};

window.selectChannel = function(el) {
    const id = el.getAttribute('data-id');
    toggleYtFavModal(false);
    handleNav('/youtube?tag=' + encodeURIComponent(id) + '&isChannel=true');
};


window.playYouTube = function(el) {
    // 1. Extract data directly from the clicked element's attributes
    const videoId = el.getAttribute('data-video-id');
    const title = el.getAttribute('data-title');
    
    // 2. Use the variables passed from the server (via index.js)
    const currentTag = "<%= tag %>"; 
    const isChan = "<%= isChannel %>"; // Use the variable we just added to index.js
    
    // 3. Get the scroll position of the CORRECT container
    const scrollContainer = document.getElementById('yt-content-scroll');
    const scroll = scrollContainer ? scrollContainer.scrollTop : 0;
    
    const mode = (isChan === 'true') ? 'channel' : 'search';
    const caller = 'youtube'; 

    // 4. Build the URL
    const url = `/tvytube?videoId=${videoId}&tag=${encodeURIComponent(currentTag)}&isChannel=${isChan}&playMode=${mode}&caller=${caller}&scrollPos=${scroll}`;
    
    console.log("Navigating to Player:", url);
    handleNav(url); 
};

// --- SCROLL SYNC ---
// Change the ID from 'yt-module' to 'yt-content-scroll'
var scrollContainer = document.getElementById('yt-content-scroll');

scrollContainer.addEventListener('scroll', function() {
    if (window.isSyncing) return;
    
    if (window.socket && window.socket.connected) {
        socket.emit('state_sync', {
            type: 'scroll',
            position: this.scrollTop,
            room: window.myRoom
        });
    }
});


// Load quota on page init
async function loadQuota() {
    try {
        const res = await fetch('/api/quota');
        const q = await res.json();
        document.getElementById('quota-display').textContent = `(${q.used}/10000)`;
    } catch(e) {
        document.getElementById('quota-display').textContent = '';
    }
}

// Load quota when grid opens
loadQuota();

// --- AUTO-RESTORE SCROLL ON LOAD ---
(function() {
    const urlParams = new URLSearchParams(window.location.search);
    const savedScroll = urlParams.get('scrollPos');
    
    if (savedScroll) {
        // Increase delay slightly if the grid is large or slow to render
        setTimeout(() => {
            const container = document.getElementById('yt-content-scroll');
            if (container) {
                container.scrollTo({
                    top: parseInt(savedScroll),
                    behavior: 'auto' // 'auto' is usually better for instant restoration
                });
                console.log("Restored scroll to:", savedScroll);
            }
        }, 300); // Adjusting to 300ms for safer AJAX timing
    }
})();
</script>
