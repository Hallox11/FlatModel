<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1280, user-scalable=no">
    <title>Main Menu - Smart TV</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet" />
<script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>
    <script src="./js/myScripts.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@200;400;600&display=swap" rel="stylesheet">

<style>
    :root {
        --accent: #daa520;
        --glass: rgba(255, 255, 255, 0.1);
        --text-color: #ffffff;
    }

    body {
        width: 1280px; height: 720px; margin: 0;
        background: #000 no-repeat center center fixed ;
        background-size: cover !important;
        color: var(--text-color); font-family: 'Fira Sans', sans-serif;
        overflow: hidden; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        transition: background-image 0.8s ease-in-out, opacity 0.3s ease;
    }

    /* --- GRID & MAIN BUTTONS --- */
    #main-grid {
        width: 1100px; display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 35px; padding: 20px; margin-bottom: 60px;
        transition: all 0.4s ease;
    }

    .btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px); 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top-color: rgba(255, 255, 255, 0.3);
        border-radius: 12px; padding: 30px 10px;
        text-decoration: none; color: white; font-size: 1.4rem;
        text-align: center; display: flex; align-items: center;
        justify-content: center; cursor: pointer;
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        outline: none; text-transform: uppercase; letter-spacing: 2px;
    }
        .btn:hover { 
        backdrop-filter: blur(15px) !important; 
        border: 1px solid white !important; 
        background-color: rgba(0, 0, 0, 0.5) !important; 
        color: white !important; 
        font-size: 1.35rem; 
        transform: scale(1.1); 
        z-index: 100; 
        transition: all 0.1s ease-in-out; 
    }

    /* --- BOTTOM LAYOUT --- */
    .status-bar {
        position: absolute; bottom: 40px; left: 40px; 
        width: 1200px; display: flex;
        align-items: flex-end; justify-content: flex-end;
        pointer-events: none;
    }

    /* --- CONTROL PANEL --- */

/* Base State */
#controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    /* Remove display: flex from here */
    opacity: 0;
    pointer-events: none;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 9999;
}

#controls.active {
    display: flex !important; /* Force it to show when active */
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
}

    /* --- NAV BUTTONS --- */
    .nav-btn-glass {
        background: transparent; border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px; color: white; padding: 8px 15px;
        font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;
        display: flex; align-items: center; gap: 10px;
        cursor: pointer; transition: all 0.3s ease;
       
    }

    .nav-btn-glass:hover {
        background: rgba(255, 255, 255, 0.2);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-3px); color: var(--accent);
    }


    /* --- BURGER BUTTON --- */
    #burger-menu-btn {
        position: absolute; bottom: 30px; left: 50%;
        transform: translateX(-50%);
        width: 60px; height: 60px; border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white; cursor: pointer; z-index: 1000;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #burger-menu-btn.hide { opacity: 0 !important; visibility: hidden !important; pointer-events: none; }

    /* --- CLOCK & DATE --- */
    .clock-glass {
        background: transparent; padding: 10px 25px;
        text-align: right; min-width: 180px;
        font-variant-numeric: tabular-nums;
        pointer-events: auto; opacity: 1;
        transition: all 0.3s ease;
    }

    #hour { font-size: 2.2rem; font-weight: 200; line-height: 1; margin-bottom: 4px; }
    #date-display { color: var(--accent); font-size: 0.95rem; opacity: 1; }

    /* --- SLIDERS & OVERLAYS --- */
    #sub-content-overlay {
        display: none; position: absolute; inset: 0;
        width: 1280px; height: 720px;
        flex-direction: column; align-items: center; justify-content: center;
        z-index: 100;
    }

#theme-slider {
    position: absolute; bottom: 120px; width: 100%; height: 140px;
    display: none; z-index: 50;
    overflow: hidden;   /* ← ADD THIS */
    cursor: grab;       /* ← ADD THIS */
}

    #theme-track { display: flex; gap: 15px; padding: 0 40px; transition: transform 0.3s ease; }

    .theme-thumb {
        min-width: 200px; height: 120px; border-radius: 12px;
        background: no-repeat center / cover;
        cursor: pointer; border: 2px solid rgba(255,255,255,0.2);
        transition: transform 0.2s ease, border 0.2s;
    }

.theme-thumb.active { 
    border: 3px solid rgba(255, 255, 255, 0.8); 
    transform: scale(1.05); 
}

    /* --- CONTRAST MODES --- */
    body.dark-text, 
    body.dark-text #sub-content-overlay *, 
    body.dark-text #main-grid * {
        --text-color: #000000 !important;
        color: #000000 !important; font-weight: 600;
    }

    body.dark-text .btn, 
    body.dark-text .nav-btn-glass, 
    body.dark-text .clock-glass {
        border-color: rgba(0, 0, 0, 0.3) !important;
        text-shadow: 0px 0px 1px rgba(255, 255, 255, 0.3);
    }

    body.dark-text .material-symbols-rounded, 
    body.dark-text svg {
        color: #000000 !important; stroke: #000000 !important;
    }

    /* --- UTILS --- */
    #vers { position: absolute; bottom: 10px; width: 100%; text-align: center; font-size: 0.7rem; opacity: 0.3; pointer-events: none; }
    

    
    .remote-hover { 
        backdrop-filter: blur(15px) !important; 
        border: 1px solid white !important; 
        background-color: rgba(0, 0, 0, 0.5) !important; 
        color: white !important; 
        font-size: 1.35rem; 
        transform: scale(1.1); 
        z-index: 100; 
        transition: all 0.1s ease-in-out; 
    }

</style>
</head>

<body>

<div id="main-grid">
    <div data-type="menu" data-mode="radios" class="btn">Radios</div>
    <div data-type="menu" data-mode="music" class="btn">Music</div>
    <div data-type="menu" data-mode="movies" class="btn">Movies</div>
    <div data-type="menu" data-mode="youtube" class="btn">YouTube</div>
    <div data-type="menu" data-mode="xxx" class="btn">XXX</div>
<div data-type="menu" 
     data-mode="/sl-destinations?tag=Editor Picks&url=https://secondlife.com/destination-guide/editor-picks" 
     class="btn">
     Second Life
</div>
    <div data-type="menu" data-mode="flickr" class="btn">Flickr</div>
    <div data-type="menu" data-mode="browsers" class="btn">Browsers</div>
</div>

<div id="sub-content-overlay"></div>

<div id="theme-slider">
    <div id="theme-track"></div>
</div>

<!-- 1. Permanent Clock (Background Layer of the bottom) -->
<div class="status-bar">
    <div class="clock-glass">
        <div id="hour">00:00:00</div>
        <div id="date-display">WED, MAR 25, 2026</div>
    </div>
</div>

<!-- 2. The Toggle Button (Middle Layer) -->
<button id="burger-menu-btn" onclick="toggleControls()">
    <span class="material-symbols-rounded">menu</span>
</button>

<!-- 3. The Sliding Control Panel (Top Layer) -->
<div class="controls" id="controls">
    <button class="nav-btn-glass" onclick="changeBackground('prev')">
        <span class="material-symbols-rounded">arrow_back</span>
    </button>
    <button class="nav-btn-glass" onclick="toggleThemeSlider()">
        <span class="material-symbols-rounded">palette</span>
        <span>Theme</span>
    </button>
        <button class="nav-btn-glass" onclick="changeBackground('next')">
        <span class="material-symbols-rounded">arrow_forward</span>
    </button>
    <button class="nav-btn-glass" onclick="toggleTextContrast()">
        <span class="material-symbols-rounded">contrast</span>
        <span>Text</span>
    </button>

    <button class="nav-btn-glass" onclick="handleNav('help')">
        <span class="material-symbols-rounded">help</span>
    </button>
    <button class="nav-btn-glass" onclick="openSettings()">
        <span class="material-symbols-rounded">settings</span>
    </button>
    <button class="nav-btn-glass" style="width: 55px;color: #ff5555!important;" onclick="toggleControls()">
        <span class="material-symbols-rounded">close</span>
        <span></span>
    </button>
</div>

<script>



let backPics = [];
let index = 0;
let sliderOffset = 0;

let isMenuOpen = false; // Renamed for clarity

function syncUI(action) {
    if (action === 'open') {
        // 1. Force display flex to override jQuery's inline 'display: none'
        $('#controls').css('display', 'flex').addClass('active'); 
        $('#burger-menu-btn').fadeOut(200);
        
        isMenuOpen = true; // Set the state to OPEN
    } else {
        $('#controls').removeClass('active');
        // 2. Smoothly hide and let jQuery handle the 'display: none' logic
        $('#controls').fadeOut(200);
        $('#theme-slider').fadeOut(200);
        $('#burger-menu-btn').fadeIn(200);
        
        isMenuOpen = false; // Set the state to CLOSED
    }
}

function toggleControls() {
    console.log("Menu status: ", isMenuOpen);
    
    if (!isMenuOpen) {
        syncUI('open');
        if (window.socket) window.socket.emit('control_event', { action: 'open', room: myRoom });
    } else {
        hideAllUI();
    }
}

function hideAllUI() {
    // 1. Close it locally on this screen
    syncUI('close');

    // 2. Tell the server to tell everyone else to close it
    if (window.socket && window.socket.connected) {
        window.socket.emit('control_event', { 
            action: 'close', 
            room: myRoom 
        });
    }
}
// ── BACKGROUNDS ───────────────────────────────────────
function updateBG(url, shouldEmit = true) {
    document.body.style.backgroundImage = `url(${url})`;
    localStorage.setItem("user_bg", url);
    index = backPics.indexOf(url);

    if (shouldEmit && socket) {
        // MUDA ISTO: Envia no formato que o teu listener 'state_sync' entende
        socket.emit('state_sync', { 
            type: 'background', 
            url: url, 
            room: myRoom 
        });
    }

    $('.theme-thumb').removeClass('active');
    $(`.theme-thumb[data-index="${index}"]`).addClass('active');
}

function changeBackground(direction) {
    if (!backPics.length) return;
    index = (direction === 'next')
        ? (index + 1) % backPics.length
        : (index - 1 + backPics.length) % backPics.length;
    updateBG(backPics[index], true);
    if ($('#theme-slider').is(':visible')) {
        syncSliderScroll();
        // ← ADD THIS
        if (socket) socket.emit('slider_event', { visible: true, offset: sliderOffset, room: myRoom });
    }
}

// ── THEME SLIDER ──────────────────────────────────────
function toggleThemeSlider() {
    const slider = $('#theme-slider');
    if (slider.is(':visible')) {
        slider.fadeOut(200);
        if (socket) socket.emit('slider_event', { visible: false, room: myRoom });
    } else {
        buildThemeSlider();
        slider.fadeIn(200, syncSliderScroll);
        if (socket) socket.emit('slider_event', { visible: true, room: myRoom });
    }
}

function buildThemeSlider() {
    const track = $('#theme-track').empty();
    backPics.forEach((pic, i) => {
        const activeClass = (i === index) ? 'active' : '';
        track.append(`<div class="theme-thumb ${activeClass}" style="background-image:url('${pic}')" data-index="${i}"></div>`);
    });
}

function syncSliderScroll() {
    const itemWidth = 215;
    const containerWidth = $('#theme-slider').width();
    const newOffset = -(index * itemWidth) + (containerWidth / 2) - (itemWidth / 2);
    
    const maxScroll = -((backPics.length * itemWidth) - containerWidth);
    const finalOffset = Math.min(0, Math.max(maxScroll, newOffset));
    
    applySliderScroll(finalOffset, true);
}

function applySliderScroll(offset, shouldEmit = false) {
    sliderOffset = offset;
    $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);

    if (shouldEmit && socket) {
        socket.emit('slider_event', { 
            visible: true, 
            offset: sliderOffset, 
            room: myRoom 
        });
    }
}

// ── SLIDER DRAG SCROLL ────────────────────────────────
(function() {
    let isDragging = false;
    let startX = 0;
    let startOffset = 0;

    $('#theme-slider').on('mousedown', function(e) {
        isDragging = true;
        startX = e.clientX;
        startOffset = sliderOffset;
        $(this).css('cursor', 'grabbing');
        e.preventDefault();
    });

$(document).on('mousemove', function(e) {
    if (!isDragging) return;
    const dx = e.clientX - startX;
    const containerWidth = $('#theme-slider').width();
    const maxScroll = -((backPics.length * 215) - containerWidth);
    sliderOffset = Math.min(0, Math.max(maxScroll, startOffset + dx));
    $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);

    // ← ADD THIS BLOCK
    clearTimeout(window._sliderSyncTimer);
    window._sliderSyncTimer = setTimeout(() => {
        if (socket) socket.emit('slider_event', { visible: true, offset: sliderOffset, room: myRoom });
    }, 50);
});

    $(document).on('mouseup mouseleave', function() {
        if (isDragging) {
            isDragging = false;
            $('#theme-slider').css('cursor', 'grab');
        }
    });
})();
// ── CLOCK ─────────────────────────────────────────────
function updateClock() {
    var now = new Date();
    $("#hour").text(now.toTimeString().split(' ')[0]);
    var options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
    $("#date-display").text(now.toLocaleDateString('en-US', options).toUpperCase());
    setTimeout(updateClock, 1000);
}

// ── BOOT ──────────────────────────────────────────────
window.onload = function() {
    socket = window.socket;

    $('#theme-slider').hide();

    // All socket listeners in one place
socket.on('sync_ui', function(data) {
    // data.action will be either 'open' or 'close'
    syncUI(data.action);
});

socket.on('sync_slider', function(data) {
    if (data.visible) {
        buildThemeSlider();
        if (data.offset !== undefined) {
            // A drag scroll came in — apply offset directly, no re-centering
            sliderOffset = data.offset;
            $('#theme-slider').show();
            $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);
        } else {
            $('#theme-slider').fadeIn(200, syncSliderScroll);
        }
    } else {
        $('#theme-slider').fadeOut(200);
    }
});


fetch('/api/backgrounds')
    .then(r => r.json())
    .then(data => {
        backPics = data;

        // 1. Primeiro, verificamos se o servidor já tem um fundo (através do socket)
        // O force_sync_arrival disparado pelo servidor no connection tratará disso.
        
        // 2. Ouvinte para o estado inicial vindo do servidor
        socket.on('force_sync_arrival', function(state) {
            if (state.currentBg) {
                console.log("Sincronizando fundo com a sala:", state.currentBg);
                updateBG(state.currentBg, false); // false = não avisar de volta (evita loop)
            } else {
                // SÓ SE o servidor estiver vazio é que tentamos o local ou aleatório
                const savedBg = localStorage.getItem("user_bg");
                if (savedBg && backPics.includes(savedBg)) {
                    updateBG(savedBg, true); // Avisa a sala que este é o novo fundo
                } else if (backPics.length) {
                    const randomIndex = Math.floor(Math.random() * backPics.length);
                    updateBG(backPics[randomIndex], true);
                }
            }
        });

        // Caso o force_sync_arrival já tenha passado, pedimos o estado de novo
        socket.emit('request_current_state');
    });

    updateClock();
};


function openSettings() {
    // 1. Hide the controls first so they don't stay on screen
    hideAllUI();

    // 2. Hide the main grid with a nice transition
    $('#main-grid').css({'opacity': '0', 'transform': 'scale(0.9)', 'pointer-events': 'none'});
    $('.status-bar').fadeOut(200);
    $('#burger-menu-btn').fadeOut(200);

    // 3. AJAX call to fetch the settings page
    $.ajax({
        url: '/settings', // The route that renders settings.ejs
        type: 'GET',
        success: function(data) {
            $('#sub-content-overlay').html(data).fadeIn(300).css('display', 'flex');
            
            // Sync with other viewers if needed
            if (window.socket) {
                window.socket.emit('mirror_ajax_nav', { 
                    action: 'OPEN', 
                    path: '/settings', 
                    room: myRoom 
                });
            }
        },
        error: function(err) {
            console.error("Error loading settings:", err);
            // Revert UI if it fails
            $('#main-grid').css({'opacity': '1', 'transform': 'scale(1)', 'pointer-events': 'auto'});
            $('#burger-menu-btn').fadeIn(200);
        }
    });
}
// ── DELEGATED EVENTS ──────────────────────────────────
$(document).on('click', '.theme-thumb', function() {
    updateBG(backPics[$(this).data('index')], true);
});

</script>
</body>
</html>