<script>



let backPics = [];
let index = 0;
let sliderOffset = 0;

let isMenuOpen = false; // Renamed for clarity



function shareRoom() {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const btn = document.querySelector('[data-mode="share"]');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.style.borderColor = '#4caf7d';
        btn.style.color = '#4caf7d';
        setTimeout(() => {
            btn.textContent = original;
            btn.style.borderColor = '';
            btn.style.color = '';
        }, 2000);
    });
}


function syncUI(action) {
    if (action === 'open') {
        // 1. Force display flex to override jQuery's inline 'display: none'
        $('#controls').css('display', 'flex').addClass('active'); 
        $('.burger-menu-btn').fadeOut(200);
        
        isMenuOpen = true; // Set the state to OPEN
    } else {
        $('#controls').removeClass('active');
        // 2. Smoothly hide and let jQuery handle the 'display: none' logic
        $('#controls').fadeOut(200);
        $('#theme-slider').fadeOut(200);
        $('.burger-menu-btn').fadeIn(200);
        
        isMenuOpen = false; // Set the state to CLOSED
    }
}

function toggleControls() {
    console.log("Menu status: ", isMenuOpen);
    
    if (!isMenuOpen) {
        syncUI('open');
        if (window.socket) window.socket.emit('control_event', { action: 'open', room: myRoom });
    } else {
        hideAllUI();
    }
}

function hideAllUI() {
    // 1. Close it locally on this screen
    syncUI('close');

    // 2. Tell the server to tell everyone else to close it
    if (window.socket && window.socket.connected) {
        window.socket.emit('control_event', { 
            action: 'close', 
            room: myRoom 
        });
    }
}
// ── BACKGROUNDS ───────────────────────────────────────
function updateBG(url, shouldEmit = true) {
    document.body.style.backgroundImage = `url(${url})`;
    localStorage.setItem("user_bg", url);
    index = backPics.indexOf(url);

    if (shouldEmit && socket) {
        // MUDA ISTO: Envia no formato que o teu listener 'state_sync' entende
        socket.emit('state_sync', { 
            type: 'background', 
            url: url, 
            room: myRoom 
        });
    }

    $('.theme-thumb').removeClass('active');
    $(`.theme-thumb[data-index="${index}"]`).addClass('active');
}

function changeBackground(direction) {
    if (!backPics.length) return;
    index = (direction === 'next')
        ? (index + 1) % backPics.length
        : (index - 1 + backPics.length) % backPics.length;
    updateBG(backPics[index], true);
    if ($('#theme-slider').is(':visible')) {
        syncSliderScroll();
        // ← ADD THIS
        if (socket) socket.emit('slider_event', { visible: true, offset: sliderOffset, room: myRoom });
    }
}

// ── THEME SLIDER ──────────────────────────────────────
function toggleThemeSlider() {
    const slider = $('#theme-slider');
    if (slider.is(':visible')) {
        slider.fadeOut(200);
        if (socket) socket.emit('slider_event', { visible: false, room: myRoom });
    } else {
        buildThemeSlider();
        slider.fadeIn(200, syncSliderScroll);
        if (socket) socket.emit('slider_event', { visible: true, room: myRoom });
    }
}

function buildThemeSlider() {
    const track = $('#theme-track').empty();
    backPics.forEach((pic, i) => {
        const activeClass = (i === index) ? 'active' : '';
        track.append(`<div class="theme-thumb ${activeClass}" style="background-image:url('${pic}')" data-index="${i}"></div>`);
    });
}

function syncSliderScroll() {
    const itemWidth = 215;
    const containerWidth = $('#theme-slider').width();
    const newOffset = -(index * itemWidth) + (containerWidth / 2) - (itemWidth / 2);
    
    const maxScroll = -((backPics.length * itemWidth) - containerWidth);
    const finalOffset = Math.min(0, Math.max(maxScroll, newOffset));
    
    applySliderScroll(finalOffset, true);
}

function applySliderScroll(offset, shouldEmit = false) {
    sliderOffset = offset;
    $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);

    if (shouldEmit && socket) {
        socket.emit('slider_event', { 
            visible: true, 
            offset: sliderOffset, 
            room: myRoom 
        });
    }
}

// ── SLIDER DRAG SCROLL ────────────────────────────────
(function() {
    let isDragging = false;
    let startX = 0;
    let startOffset = 0;

    $('#theme-slider').on('mousedown', function(e) {
        isDragging = true;
        startX = e.clientX;
        startOffset = sliderOffset;
        $(this).css('cursor', 'grabbing');
        e.preventDefault();
    });

$(document).on('mousemove', function(e) {
    if (!isDragging) return;
    const dx = e.clientX - startX;
    const containerWidth = $('#theme-slider').width();
    const maxScroll = -((backPics.length * 215) - containerWidth);
    sliderOffset = Math.min(0, Math.max(maxScroll, startOffset + dx));
    $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);

    // ← ADD THIS BLOCK
    clearTimeout(window._sliderSyncTimer);
    window._sliderSyncTimer = setTimeout(() => {
        if (socket) socket.emit('slider_event', { visible: true, offset: sliderOffset, room: myRoom });
    }, 50);
});

    $(document).on('mouseup mouseleave', function() {
        if (isDragging) {
            isDragging = false;
            $('#theme-slider').css('cursor', 'grab');
        }
    });
})();
// ── CLOCK ─────────────────────────────────────────────
function updateClock() {
    var now = new Date();
    $("#hour").text(now.toTimeString().split(' ')[0]);
    var options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
    $("#date-display").text(now.toLocaleDateString('en-US', options).toUpperCase());
    setTimeout(updateClock, 1000);
}

// ── BOOT ──────────────────────────────────────────────
window.onload = function() {
    socket = window.socket;

    $('#theme-slider').hide();

    // All socket listeners in one place
socket.on('sync_ui', function(data) {
    // data.action will be either 'open' or 'close'
    syncUI(data.action);
});

socket.on('sync_slider', function(data) {
    if (data.visible) {
        buildThemeSlider();
        if (data.offset !== undefined) {
            // A drag scroll came in — apply offset directly, no re-centering
            sliderOffset = data.offset;
            $('#theme-slider').show();
            $('#theme-track').css('transform', `translateX(${sliderOffset}px)`);
        } else {
            $('#theme-slider').fadeIn(200, syncSliderScroll);
        }
    } else {
        $('#theme-slider').fadeOut(200);
    }
});


fetch('/api/backgrounds')
    .then(r => r.json())
    .then(data => {
        backPics = data;
      
        // 1. Primeiro, verificamos se o servidor já tem um fundo (através do socket)
        // O force_sync_arrival disparado pelo servidor no connection tratará disso.
        
        // 2. Ouvinte para o estado inicial vindo do servidor
        socket.on('force_sync_arrival', function(state) {
            if (state.currentBg) {
                //console.log("Sincronizando fundo com a sala:", state.currentBg);
                updateBG(state.currentBg, false); // false = não avisar de volta (evita loop)
            } else {
                // SÓ SE o servidor estiver vazio é que tentamos o local ou aleatório
                const savedBg = localStorage.getItem("user_bg");
                if (savedBg && backPics.includes(savedBg)) {
                    updateBG(savedBg, true); // Avisa a sala que este é o novo fundo
                } else if (backPics.length) {
                    const randomIndex = Math.floor(Math.random() * backPics.length);
                    updateBG(backPics[randomIndex], true);
                }
              
            }
        });

        // Caso o force_sync_arrival já tenha passado, pedimos o estado de novo
        socket.emit('request_current_state');
         });

    updateClock();
};


function openSettings() {
    handleNav('settings');
}


// ── DELEGATED EVENTS ──────────────────────────────────
$(document).on('click', '.theme-thumb', function() {
    updateBG(backPics[$(this).data('index')], true);
});

/////////////////////////////////////////////////777
(function() {
    // Init — show current room in indicator
    function initRoomIndicator() {
        const room = window.myRoom || 'Lobby';
        document.getElementById('room-indicator-code').textContent = room;
        document.getElementById('room-code-display').textContent   = room;
    }

    // Wait for myRoom to be set
    const roomCheck = setInterval(() => {
        if (window.myRoom) { initRoomIndicator(); clearInterval(roomCheck); }
    }, 100);

    let panelOpen = false;

    window.toggleRoomPanel = function() {
        panelOpen = !panelOpen;
        document.getElementById('room-panel').classList.toggle('open', panelOpen);
        document.getElementById('room-panel-overlay').classList.toggle('open', panelOpen);
        if (panelOpen) {
            const room = window.myRoom || 'Lobby';
            document.getElementById('room-indicator-code').textContent = room;
            document.getElementById('room-code-display').textContent   = room;
        }
    };

    window.copyRoomLink = function() {
        const url = window.location.origin + '/?room=' + encodeURIComponent(window.myRoom || 'Lobby');
        navigator.clipboard.writeText(url).then(() => {
            setRoomFeedback('✓ Link copied!', '#4caf7d');
        });
    };

    window.joinRoomFromPanel = function() {
        const raw = document.getElementById('room-join-input').value.trim();
        if (!raw) { setRoomFeedback('Enter a room code or URL', '#e05555'); return; }

        // Accept full URL or just the room code
        let code = raw;
        try {
            const parsed = new URL(raw);
            code = parsed.searchParams.get('room') || raw;
        } catch(e) { /* not a URL, use as-is */ }

        if (!code) { setRoomFeedback('Invalid room code', '#e05555'); return; }

        setRoomFeedback('Joining…', 'rgba(255,255,255,0.4)');
        window.location.href = window.location.origin + '/?room=' + encodeURIComponent(code);
    };

    function setRoomFeedback(msg, color) {
        const fb = document.getElementById('room-panel-feedback');
        fb.textContent = msg;
        fb.style.color = color;
        setTimeout(() => { fb.textContent = ''; fb.style.color = ''; }, 3000);
    }

    // Close panel when clicking outside
    document.addEventListener('click', function(e) {
        if (!panelOpen) return;
        const panel     = document.getElementById('room-panel');
        const indicator = document.getElementById('room-indicator');
        const overlay   = document.getElementById('room-panel-overlay');
        if (!panel.contains(e.target) && !indicator.contains(e.target) && !overlay.contains(e.target)) {
            panelOpen = false;
            panel.classList.remove('open');
            overlay.classList.remove('open');
        }
    });
})();

// ── GAME STREAM TOAST ─────────────────────────────────
(function() {
    let toastTimer = null;

    window.gsToastShow = function() {
        const toast = document.getElementById('gs-stream-toast');
        if (!toast) return;
        toast.classList.add('visible');
        // Auto-dismiss after 12 seconds
        clearTimeout(toastTimer);
        toastTimer = setTimeout(window.gsToastDismiss, 12000);
    };

    window.gsToastDismiss = function() {
        clearTimeout(toastTimer);
        const toast = document.getElementById('gs-stream-toast');
        if (toast) toast.classList.remove('visible');
    };

    window.gsToastOpen = function() {
        // Opens the viewer page in a new browser tab/window
        // Points to /stream-cam-page with the current room so it connects to the right stream
        const room = window.myRoom || 'Lobby';
        const url  = window.location.origin + '/stream-cam-page?room=' + encodeURIComponent(room);
        window.open(url, '_blank');
        window.gsToastDismiss();
    };
})();
</script>
