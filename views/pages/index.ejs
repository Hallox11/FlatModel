<style>
    :root {
        --accent: #daa520;
        --glass: rgba(255, 255, 255, 0.1);
        --text-color: #ffffff;
    }

    body {
        width: 1280px; height: 720px; margin: 0;
        background: #000 no-repeat center center fixed ;
        background-size: cover !important;
        color: var(--text-color); font-family: 'Fira Sans', sans-serif;
        overflow: hidden; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        transition: background-image 0.8s ease-in-out, opacity 0.3s ease;
    }

    /* --- GRID & MAIN BUTTONS --- */
#main-grid {
        width: 1050px; display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px; padding: 20px; margin-bottom: 110px;
        transition: all 0.4s ease;
}

.btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px); 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top-color: rgba(255, 255, 255, 0.3);
        border-radius: 8px; padding: 20px 10px;
        text-decoration: none; color: white; font-size: 1.4rem;
        text-align: center; display: flex; align-items: center;
        justify-content: center; cursor: pointer;
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        outline: none; text-transform: uppercase; letter-spacing: 2px;
}
.btn:hover, .btn.remote-hover { 
    transform: translateY(-3px) scale(1.05);
    border-color: rgba(255, 255, 255, 0.6);
            background-color: rgba(0, 0, 0, 0.5); 
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.15),
        0 20px 48px rgba(0,0,0,0.7),
        0 0 24px var(--card-glow, rgba(255,255,255,0.05));
}

    /* --- BOTTOM LAYOUT --- */
.status-bar {
        position: absolute; bottom: 40px; left: 40px; 
        width: 1200px; display: flex;
        align-items: flex-end; justify-content: flex-end;
        pointer-events: none;
}

    /* --- CONTROL PANEL --- */

#controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    /* Remove display: flex from here */
    opacity: 0;
    pointer-events: none;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 9999;
}

#controls.active {
    display: flex !important; /* Force it to show when active */
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
}

    /* --- NAV BUTTONS --- */
.nav-btn-glass {
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.7));
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
         border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px; 
        color: white;
         padding: 8px 15px;
        font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;
        display: flex; align-items: center; gap: 10px;
        cursor: pointer; transition: all 0.3s ease;
       
}

.nav-btn-glass:hover, .nav-btn-glass.remote-hover {
        background: #458c9bd9;
        border-color: rgba(255, 255, 255, 0.3);
        transform: scale(1.0);
}

    /* --- BURGER BUTTON --- */
.burger-menu-btn {
        position: absolute; bottom: 30px; left: 612px;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px); 
        box-shadow: 0 0px 11px 0 rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white; cursor: pointer; z-index: 1000;
        display: flex; align-items: center; justify-content: center;
       
}
.burger-menu-btn:hover, .burger-menu-btn.remote-hover {
        background: #3c7986d9;
        border-color: rgba(255, 255, 255, 0.3);
        transform: scale(1.0);
}

.burger-menu-btn.hide { 
        opacity: 0 !important; 
        visibility: hidden !important;
        pointer-events: none; 
}
.material-symbols-rounded {
    font-size: 30px;
    font-weight: 200;
}


    /* --- CLOCK & DATE --- */
    .clock-glass {
        background: transparent; padding: 10px 25px;
        text-align: right; min-width: 180px;
        font-variant-numeric: tabular-nums;
        pointer-events: auto; opacity: 1;
        transition: all 0.3s ease;
    }

    #hour { font-size: 2.2rem; font-weight: 200; line-height: 1; margin-bottom: 4px; }
    #date-display {color: var(--accent); font-size: 0.95rem; opacity: 1; }

    /* --- SLIDERS & OVERLAYS --- */
#sub-content-overlay {
        display: none; position: absolute; inset: 0;
        width: 1280px; height: 720px;
        flex-direction: column; align-items: center; justify-content: center;
        z-index: 100;
}

#theme-slider {
    position: absolute;
     bottom: 80px;
      width: 100%;
       height: 140px;
       padding: 10px 10px;
    display: none; z-index: 50;
    overflow: hidden;   /* ← ADD THIS */
    cursor: grab;       /* ← ADD THIS */
}

#theme-track { display: flex; gap: 15px; padding: 0 40px; transition: transform 0.3s ease; }

.theme-thumb {
        min-width: 200px; height: 120px; border-radius: 12px;
        background: no-repeat center / cover;
        cursor: pointer; border: 2px solid rgba(255,255,255,0.2);
        transition: transform 0.2s ease, border 0.2s;
}

.theme-thumb.active { 
    border: 1px solid rgba(255, 255, 255, 0.8); 
    transform: scale(1.1); 
}


    /* --- UTILS --- */
#vers {
        position: absolute; bottom: 10px; width: 100%; text-align: center; font-size: 0.7rem; opacity: 0.3; pointer-events: none; }
   
        




/* ── ROOM INDICATOR ── */
#room-indicator {
    position: absolute;
    top: 18px; right: 24px;
    display: flex; align-items: center; gap: 7px;
    background: rgba(0,0,0,0.45);
    border: 1px solid rgba(218,165,32,0.25);
    border-radius: 20px;
    padding: 5px 14px 5px 10px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    z-index: 500;
    transition: all 0.2s ease;
}
#room-indicator:hover {
    border-color: rgba(218,165,32,0.6);
    background: rgba(0,0,0,0.65);
}
#room-indicator-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4caf7d;
    animation: pulse-dot 2s infinite;
}
#room-indicator-code {
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
}

/* ── ROOM PANEL OVERLAY ── */
#room-panel-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    z-index: 498;
    display: none;
    animation: fadeOverlay 0.2s ease;
}
#room-panel-overlay.open { display: block; }
@keyframes fadeOverlay { from { opacity: 0; } to { opacity: 1; } }

/* ── ROOM PANEL ── */
#room-panel {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 480px;
    background: rgba(10,10,12,0.96);
    border: 1px solid rgba(218,165,32,0.3);
    border-radius: 20px;
    padding: 32px 32px 28px;
    display: none;
    flex-direction: column;
    gap: 20px;
    backdrop-filter: blur(24px);
    z-index: 499;
    animation: fadeInScale 0.22s ease;
}
#room-panel.open { display: flex; }

@keyframes fadeInScale {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.96); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

#room-panel-close {
    position: absolute; top: 14px; right: 14px;
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.5); cursor: pointer; font-size: 16px;
    display: flex; align-items: center; justify-content: center; transition: 0.2s;
}
#room-panel-close:hover { background: #c0392b; border-color: #c0392b; color: #fff; }

.room-panel-label {
    font-size: 0.9rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #ffc32c;
    margin-bottom: -8px;
}

.room-panel-hint {
    font-size: 1rem;
    color: rgba(255,255,255,0.9);
    line-height: 1.55;
    margin-top: 0px;
    text-align: center;
}

#room-code-display {
    flex: 1;
    background: rgba(218,165,32,0.08);
    border: 1px solid rgba(218,165,32,0.3);
    border-radius: 10px;
    padding: 11px 16px;
    font-size: 1rem;
    letter-spacing: 4px;
    color: #daa520;
    text-align: center;
    font-family: 'Fira Sans', monospace;
}

.room-panel-input {
    flex: 1;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 10px;
    padding: 11px 14px;
    font-family: 'Fira Sans', sans-serif;
    font-size: 1rem;
    color: white;
    outline: none;
    transition: border-color 0.2s;
}
.room-panel-input:focus { border-color: rgba(218,165,32,0.5); }
.room-panel-input::placeholder { color: rgba(255,255,255,0.2); }

.room-panel-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    color: white;
    padding: 11px 18px;
    cursor: pointer;
    font-family: 'Fira Sans', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.2s;
    white-space: nowrap;
}
.room-panel-btn:hover { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.3); }
.room-panel-btn.accent {
    background: rgba(218,165,32,0.15);
    border-color: rgba(218,165,32,0.4);
    color: #daa520;
}
.room-panel-btn.accent:hover { background: rgba(218,165,32,0.28); }

#room-panel-feedback {
    font-size: 1rem;
    letter-spacing: 0.5px;
    text-align: center;
    min-height: 16px;
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
}

@keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
}

/* ── GAME STREAM TOAST ── */
#gs-stream-toast {
    position: absolute;
    top: 24px; left: 50%;
    transform: translateX(-50%) translateY(-120px);
    display: flex; align-items: center; gap: 14px;
    background: linear-gradient(135deg, rgba(10,10,10,0.92), rgba(20,20,20,0.96));
    border: 1px solid rgba(46,204,113,0.35);
    border-top-color: rgba(46,204,113,0.6);
    border-radius: 14px;
    padding: 14px 20px;
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(46,204,113,0.1);
    z-index: 9999;
    transition: transform 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                opacity 0.3s ease;
    opacity: 0;
    pointer-events: none;
    min-width: 360px;
}
#gs-stream-toast.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
}
#gs-stream-toast .gs-toast-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    background: #2ecc71;
    box-shadow: 0 0 8px #2ecc71;
    animation: pulse-dot 1.5s infinite;
}
#gs-stream-toast .gs-toast-text {
    flex: 1;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.7);
    line-height: 1.4;
}
#gs-stream-toast .gs-toast-text strong {
    display: block;
    color: #fff;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 1px;
    margin-bottom: 2px;
}
#gs-toast-open-btn {
    background: linear-gradient(135deg, rgba(46,204,113,0.25), rgba(46,204,113,0.1));
    border: 1px solid rgba(46,204,113,0.5);
    border-radius: 10px;
    color: #2ecc71;
    padding: 9px 16px;
    font-family: 'Fira Sans', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
    display: flex; align-items: center; gap: 6px;
    flex-shrink: 0;
}
#gs-toast-open-btn:hover {
    background: rgba(46,204,113,0.35);
    border-color: #2ecc71;
    transform: scale(1.04);
}
#gs-toast-dismiss-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    padding: 4px;
    font-size: 16px;
    line-height: 1;
    transition: color 0.2s;
    flex-shrink: 0;
}
#gs-toast-dismiss-btn:hover { color: rgba(255,255,255,0.6); }


/* ============================================================
   GLOBAL LOADER OVERLAY
   ============================================================ */
#loading-overlay {
    display: none; /* Hidden by default */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
