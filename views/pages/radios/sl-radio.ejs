<style>
    :root {
        --accent: #ffd86b;
        --bg-dark: rgba(0, 0, 0, 0.85);
    }

    #sl-radio-master-container {
        height: 720px;
        width: 1280px;
        margin: auto;
        padding: 40px 20px;
        color: white;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        position: relative;
        background:  rgba(0,0,0,0.5);
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* TOP DIAL SECTION */
    .dial-container {
        position: relative;
        top:50px;
        width: 100%;
        overflow: hidden;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255,216,107,0.1);
    }

    .dial-needle {
        position: absolute;
        top: 0; bottom: 0; left: 50%;
        width: 2px;
        background: linear-gradient(to bottom, transparent, var(--accent), transparent);
        box-shadow: 0 0 12px var(--accent);
        z-index: 5;
        pointer-events: none;
    }

    .dial {
        display: flex;
        gap: 60px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        padding: 40px 0;
        padding-left: calc(50% - 50px); 
        padding-right: calc(50% - 50px);
        cursor: grab;
        scroll-behavior: smooth;
    }
    .dial:active { cursor: grabbing; }
    .dial::-webkit-scrollbar { display: none; }

    .station {
        flex: 0 0 100px;
        text-align: center;
        font-size: 18px;
        opacity: 0.7;
        transform: scale(0.9);
        transition: all 0.3s ease;
        cursor: pointer;
        white-space: nowrap;
        scroll-snap-align: center;
        user-select: none;
        text-transform: uppercase;
        letter-spacing: 2;
    }

    .station.active {
        opacity: 1;
        transform: scale(1.5);
        color: #ffb090;
        font-weight: bold;
    }

    /* PLAYER SECTION */
    #radio_player_ui {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 30px;
        margin-top: 50px;
    }

    .display-wrapper {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
    }

    .glass-display {
        width: 180px;
        height: 180px;
        background: rgba(0,0,0,0.5);
        
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 25px rgba(255, 255, 255, 0.4);
        position: relative;
    }

    #freq_display {
        font-family: 'Courier New', Courier, monospace;
        font-size: 40px;
        color: #ffb090;
        text-shadow: 0 0 10px var(--accent);
        font-weight: 400;
    }

    .mhz-label {
        font-size: 16px;
        color: rgba(255,216,107,0.6);
        letter-spacing: 1px;
        margin-top: 2px;
    }

    /* SIDE ARROWS */
    .side-arrow {
        background:rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.1);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        opacity: 0.5;
                box-shadow: 0 0 25px rgba(255, 216, 107, 0.4);
    }
    .side-arrow:hover {
        opacity: 1;
        background: rgba(255,216,107,0.1);
        border-color: var(--accent);
        color: var(--accent);
    }

    #station_display { 
        font-size: 40px; 
        color: white; 
        margin-bottom: 5px; 
        font-weight: 600;
        text-transform: uppercase;    
    }
    
    
        #status_text { 
            font-size: 20px; 
            color: rgba(255,255,255,0.4); 
            text-transform: uppercase; 
            margin-bottom: 20px; 
            letter-spacing: 2px; }

    #sl-radio-master-container .close-btn {
        position: absolute;
        top: 20px;
        right: 70px; 
        width: 45px;
        height: 45px;
        border: 1px solid black;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #equalizer {
    width: 300px;
    height: 40px;
    margin-bottom: 20px;
    border-radius: 5px;
    background: rgba(0, 0, 0, 0.2);
    /* Reflects the accent color from your :root */
    border-bottom: 1px solid rgba(255, 216, 107, 0.2);
}
</style>

