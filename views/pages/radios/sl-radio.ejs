<style>
    :root {
        --accent: #ffd86b;
        --bg-dark: rgba(0, 0, 0, 0.85);
    }

    #sl-radio-master-container {
        height: 720px;
        width: 1280px;
        margin: auto;
        padding: 40px 20px;
        color: white;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        position: relative;
        background: rgba(0,0,0,0.5);
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* TOP DIAL SECTION */
    .dial-container {
        position: relative;
        top: 50px;
        width: 100%;
        overflow: hidden;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255,216,107,0.1);
    }

    .dial-needle {
        position: absolute;
        top: 0; bottom: 0; left: 50%;
        width: 2px;
        background: linear-gradient(to bottom, transparent, var(--accent), transparent);
        box-shadow: 0 0 12px var(--accent);
        z-index: 5;
        pointer-events: none;
    }

    .dial {
        display: flex;
        gap: 60px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        padding: 40px 0;
        padding-left: calc(50% - 50px); 
        padding-right: calc(50% - 50px);
        cursor: grab;
        scroll-behavior: smooth;
    }
    .dial:active { cursor: grabbing; }
    .dial::-webkit-scrollbar { display: none; }

    .station {
        flex: 0 0 100px;
        text-align: center;
        font-size: 18px;
        opacity: 0.7;
        transform: scale(0.9);
        transition: all 0.3s ease;
        cursor: pointer;
        white-space: nowrap;
        scroll-snap-align: center;
        user-select: none;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .station.active {
        opacity: 1;
        transform: scale(1.5);
        color: #ffb090;
        font-weight: bold;
    }

    /* PLAYER SECTION */
    #radio_player_ui {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 30px;
        margin-top: 50px;
    }

    .display-wrapper {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
    }

    .glass-display {
        width: 180px;
        height: 180px;
        background: rgba(0,0,0,0.5);
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 25px rgba(255, 216, 107, 0.4);
        position: relative;
        border: 1px solid rgba(255,216,107,0.1);
    }

    #freq_display {
        font-family: 'Courier New', Courier, monospace;
        font-size: 40px;
        color: #ffb090;
        text-shadow: 0 0 10px var(--accent);
    }

    .mhz-label {
        font-size: 16px;
        color: rgba(255,216,107,0.6);
        letter-spacing: 1px;
    }

    .side-arrow {
        background: rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.1);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }
    .side-arrow:hover {
        background: rgba(255,216,107,0.1);
        border-color: var(--accent);
        color: var(--accent);
        transform: scale(1.1);
    }

    #station_display { 
        font-size: 40px; 
        color: white; 
        margin-bottom: 5px; 
        font-weight: 600;
        text-transform: uppercase;    
    }
    
    #status_text { 
        font-size: 20px; 
        color: rgba(255,255,255,0.4); 
        text-transform: uppercase; 
        letter-spacing: 2px; 
    }

    #sl-radio-master-container .close-btn {
        position: absolute;
        top: 20px;
        right: 70px; 
        width: 45px;
        height: 45px;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(0, 0, 0, 0.6);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
    }
    #sl-radio-master-container .close-btn:hover { background: #ff4444; border-color: #ff4444; }
</style>

<div id="sl-radio-master-container">
    <button class="close-btn" onclick="closeSubMenu()">
        <svg viewBox="0 0 24 24" width="26" height="26" stroke="currentColor" stroke-width="3" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <div class="dial-container">
        <div class="dial-needle"></div>
        <div class="dial" id="dial">
            <div class="station" data-stream="https://ice1.somafm.com/illstreet-128-mp3">Tableau</div>  
            <div class="station" data-stream="https://strm112.1.fm/bossanova_mobile_mp3">Samba Cafe</div>  
            <div class="station" data-stream="https://ice.somafm.com/dronezone">Black Kite</div>  
            <div class="station" data-stream="https://stream2.10223.cc:8025/cc_sim_v4_b12">Chouchou</div>  
            <div class="station" data-stream="https://stream2.10223.cc:8025/memento_v3">Memento Mori</div>  
            <div class="station" data-stream="https://q2stream.wqxr.org/q2">Delicatessen</div>  
            <div class="station" data-stream="https://d-oo-b.cc:8008">Two Fish</div>  
            <div class="station" data-stream="https://www.radioparadise.com/mp3-192">Satyr Dance</div>
            <div class="station" data-stream="https://ice1.somafm.com/suburbsofgoa-128-mp3">Acc Alpha</div>  
            <div class="station" data-stream="https://icy.unitedradio.it/SubasioPerUnOraDAmore.mp3">Retrospect</div>  
        </div>
    </div>

    <div id="radio_player_ui">
        <div class="display-wrapper">
            <button class="side-arrow" onclick="window.stepStation(-1)">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>

            <div class="glass-display">
                <div id="freq_display">88.0</div>
                <div class="mhz-label">MHz</div>
            </div>

            <button class="side-arrow" onclick="window.stepStation(1)">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </div>

        <div id="station_display">Off Air</div>
        <div id="status_text">Tune the radio</div>
        <audio id="sl_native_player" crossorigin="anonymous"></audio>
    </div>
</div>

<script>
{
    const dial = document.getElementById("dial");
    const stations = Array.from(document.querySelectorAll(".station"));
    const audio = document.getElementById('sl_native_player');
    const display = document.getElementById("station_display");
    const freqDisplay = document.getElementById("freq_display");
    const statusText = document.getElementById("status_text");

    let isDown = false;
    let startX;
    let scrollLeft;
    let tuneTimeout;
    let lastSyncedIndex = -1; // ✅ Evita emissões repetidas do mesmo index

    function updateUI(index) {
        stations.forEach(s => s.classList.remove("active"));
        const target = stations[index];
        if (target) {
            target.classList.add("active");
            display.textContent = target.textContent;
            const fakeFreq = (88.0 + (index * 2.1)).toFixed(1);
            freqDisplay.textContent = fakeFreq;
        }
    }

    function loadStream(station, isRemote = false) {
        const url = station.getAttribute('data-stream');
        if (audio.src !== url) {
            audio.pause();
            audio.src = url;
            audio.load();
            
            statusText.textContent = isRemote ? 'Synced with Room...' : 'Connecting...';
            
            audio.play().catch(err => { 
                statusText.textContent = "Interaction Required"; 
            });

            audio.onplaying = () => { statusText.textContent = 'Live Audio Stream'; };
            audio.onerror = () => { statusText.textContent = 'Station Offline'; };
        }
    }

    // ✅ Função centralizada para sintonizar (com flag de bloqueio de socket)
    function tuneTo(index, isRemote = false) {
        if (index < 0 || index >= stations.length) return;
        if (index === lastSyncedIndex && !isRemote) return; // ✅ Bloqueia duplicados locais

        const target = stations[index];
        lastSyncedIndex = index;

        // Mover o dial visualmente
        dial.scrollTo({
            left: target.offsetLeft - (dial.offsetWidth / 2) + (target.offsetWidth / 2),
            behavior: 'smooth'
        });

        updateUI(index);
        loadStream(target, isRemote);

        // ✅ SÓ emite se NÃO for um comando vindo de fora
        if (!isRemote && window.socket) {
            window.socket.emit('sync_radio_dial', { index: index });
        }
    }

    window.stepStation = function(dir) {
        const activeIdx = stations.findIndex(s => s.classList.contains('active'));
        tuneTo(activeIdx + dir, false);
    };

    function handleManualSelection() {
        if (!dial || isDown) return;
        const center = dial.getBoundingClientRect().left + (dial.offsetWidth / 2);
        let closestIdx = 0;
        let minDist = Infinity;

        stations.forEach((station, idx) => {
            const stationCenter = station.getBoundingClientRect().left + (station.offsetWidth / 2);
            const dist = Math.abs(center - stationCenter);
            if (dist < minDist) {
                minDist = dist;
                closestIdx = idx;
            }
        });

        updateUI(closestIdx);

        clearTimeout(tuneTimeout);
        tuneTimeout = setTimeout(() => {
            tuneTo(closestIdx, false);
        }, 350);
    }

    // --- EVENTOS DO DIAL ---
    dial.addEventListener("mousedown", (e) => {
        isDown = true;
        dial.style.scrollSnapType = "none";
        dial.style.scrollBehavior = "auto";
        startX = e.pageX - dial.offsetLeft;
        scrollLeft = dial.scrollLeft;
    });

    window.addEventListener("mouseup", () => {
        if (!isDown) return;
        isDown = false;
        dial.style.scrollSnapType = "x mandatory";
        dial.style.scrollBehavior = "smooth";
        handleManualSelection();
    });

    dial.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - dial.offsetLeft;
        dial.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });

    dial.addEventListener("scroll", () => {
        if (!isDown) handleManualSelection();
    });

    // --- SOCKETS (RECEPÇÃO) ---
// --- SOCKETS (RECEPÇÃO) ---
if (window.socket) {
    // 1. Ouvir atualizações em tempo real
    window.socket.off('update_radio_ui').on('update_radio_ui', (data) => {
        if (!isDown) tuneTo(data.index, true);
    });

    // 2. Ouvir o estado global (Crucial para novos viewers)
    window.socket.off('force_sync_arrival').on('force_sync_arrival', (state) => {
        if (state.radioDialIndex !== undefined && state.radioDialIndex !== null) {
            console.log("Sincronização imediata recebida:", state.radioDialIndex);
            // Pequeno delay para garantir que o scroll funciona após render
            setTimeout(() => tuneTo(state.radioDialIndex, true), 100);
        }
    });

    // 3. Pedir o estado explicitamente ao entrar
    window.socket.emit('request_current_state');
}

// --- STARTUP LOGIC ---
// Em vez de forçar o index 5 logo de cara, vamos verificar o estado global primeiro
$(document).ready(function() {
    // Se o socket já tem a info, ele vai disparar o force_sync_arrival.
    // Caso contrário, esperamos um pouco e se nada acontecer, usamos o index 5 como último recurso.
    setTimeout(() => {
        const hasActive = stations.some(s => s.classList.contains('active'));
        if (!hasActive) {
            console.log("Nenhum estado recebido, usando fallback index 5");
            tuneTo(5, true);
        }
    }, 1200); // Aumentamos ligeiramente para dar tempo ao socket
});
}
</script>