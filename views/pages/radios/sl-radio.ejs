<style>
    /* 1. Wrapper for Goldenrod Theme */
    #sl-radio-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 700px; /* Slimmer for a list view */
        animation: fadeIn 0.4s ease-out;
    }

    /* 2. Circular Close Button (Top Right) */
    #sl-radio-wrapper .close-btn {
        position: absolute;
        top: -10px;
        right: -50px; /* Offset to the side of the list */
        width: 45px;
        height: 45px;
        background: rgba(0, 0, 0, 0.6);
        border: 1px solid black;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #sl-radio-wrapper .close-btn:hover, 
    #sl-radio-wrapper .close-btn:focus {
        color: white;
        transform: scale(1.3) ;
        box-shadow: 0 0 15px rgba(218, 165, 32, 0.5);
    }

    /* 3. Title Styling */
    #sl-radio-wrapper #title {
        font-size: 28px;
        color: #564f4f;
        text-transform: uppercase;
        margin-bottom: 20px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Scrollable List Container */
    #sl-radio-wrapper .conteiner {
        display: flex !important;
        flex-direction: column !important;
        gap: 8px !important;
        width: 100% !important;
        height: 500px !important;
        padding: 10px 20px;
        overflow-y: auto;

        mask-image: linear-gradient(to bottom, transparent, black 5%, black 95%, transparent);
    }

    /* 5. List Item Button Styling */
    #sl-radio-wrapper .btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px) !important; 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 10px;
        padding: 18px 25px !important;
        font-size: 20px;
        color: white !important;
        text-align: center !important;
        display: flex !important;
        align-items: center;
        width: 100%;
        min-height: 60px;
        transition: all 0.2s ease;
        cursor: pointer;
        box-sizing: border-box; /* Ensures padding doesn't break width */
    }



    /* Hide scrollbar */
    #sl-radio-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

