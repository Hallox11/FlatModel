<canvas id="equalizer" width="300" height="40" style="display: block; margin: 10px auto;"></canvas>

        <div id="station_display">Off Air</div>
        <div id="status_text">Tune the radio</div>
        <audio id="sl_native_player"></audio>
    </div>
</div>

<script>
{
    const dial = document.getElementById("dial");
    const stations = Array.from(document.querySelectorAll(".station"));
    const audio = document.getElementById('sl_native_player');
    const display = document.getElementById("station_display");
    const freqDisplay = document.getElementById("freq_display");
    const statusText = document.getElementById("status_text");

    let isDown = false;
    let startX;
    let scrollLeft;
    let tuneTimeout;

    audio.volume = 1.0;



window.stepStation = function(dir) {
    const activeIdx = stations.findIndex(s => s.classList.contains('active'));
    let nextIdx = activeIdx + dir;
    
    if (nextIdx >= 0 && nextIdx < stations.length) {
        const target = stations[nextIdx];
        
        // 1. Move our own dial
        dial.scrollTo({
            left: target.offsetLeft - (dial.offsetWidth / 2) + (target.offsetWidth / 2),
            behavior: 'smooth'
        });

        // 2. TELL THE SERVER (So others move too)
        // We manually emit here because 'isDown' is false during a button click
        socket.emit('sync_radio_dial', { index: nextIdx });
    }
};

function loadStream(station) {
    const url = station.getAttribute('data-stream');

    // 1. Check if we are actually switching to a NEW url
    if (audio.src !== url) {
        
        // 2. KILL THE PREVIOUS STREAM COMPLETELY
        audio.pause();
        audio.src = ""; // Clear the source
        audio.load();   // Force the browser to dump the buffer
        
        display.textContent = station.textContent;
        statusText.textContent = 'Connecting...';

        // 3. SET THE NEW STREAM
        audio.src = url;
        
        // We use a slight delay or a direct play call
        audio.play().catch((err) => { 
            console.log("Autoplay blocked or stream error:", err);
            statusText.textContent = "Click to Resume"; 
        });

        audio.onplaying = () => { 
            statusText.textContent = 'Live Audio Stream'; 
        };
        
        audio.onerror = () => { 
            statusText.textContent = 'Station Offline'; 
        };
    }
}

function updateActive() {
    if (!dial) return;
    const center = dial.getBoundingClientRect().left + (dial.offsetWidth / 2);
    let closest = null;
    let minDist = Infinity;

    stations.forEach(station => {
        const stationCenter = station.getBoundingClientRect().left + (station.offsetWidth / 2);
        const dist = Math.abs(center - stationCenter);
        if (dist < minDist) {
            minDist = dist;
            closest = station;
        }
    });

    stations.forEach(s => s.classList.remove("active"));
    
    if (closest) {
        closest.classList.add("active");
        const idx = stations.indexOf(closest);

        // Update the MHz frequency display (88.0 + index logic)
        const fakeFreq = (88.0 + (idx * 2.1)).toFixed(1);
        document.getElementById("freq_display").textContent = fakeFreq;

        clearTimeout(tuneTimeout);
        tuneTimeout = setTimeout(() => {
            // SYNC LOGIC: Only tell the server if WE are the ones moving it
            if (isDown) {
                socket.emit('sync_radio_dial', { index: idx });
            }
            
            // Load the actual audio stream
            if (!isDown) loadStream(closest);
        }, 300);
    }
}

dial.addEventListener("mousedown", (e) => {
        isDown = true;
        dial.style.scrollSnapType = "none";
        dial.style.scrollBehavior = "auto";
        startX = e.pageX - dial.offsetLeft;
        scrollLeft = dial.scrollLeft;
    });

    window.addEventListener("mouseup", () => {
        if (!isDown) return;
        isDown = false;
        dial.style.scrollSnapType = "x mandatory";
        dial.style.scrollBehavior = "smooth";
        updateActive();
    });

    dial.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - dial.offsetLeft;
        dial.scrollLeft = scrollLeft - (x - startX) * 1.5;
        updateActive();
    });

    dial.addEventListener("scroll", () => {
        if (!isDown) updateActive();
    });

    // Listen for other users moving the dial
// Listen for the broadcast from the server
socket.on('update_radio_ui', (data) => {
    const target = stations[data.index];
    if (target) {
        // Stop current audio before moving
        audio.pause();
        audio.src = "";
        
        dial.scrollTo({
            left: target.offsetLeft - (dial.offsetWidth / 2) + (target.offsetWidth / 2),
            behavior: 'smooth'
        });

        // The 'scroll' event listener you already have 
        // will eventually call loadStream(target) once the slide finishes.
    }
});

// --- STARTUP LOGIC ---
    const startIdx = 5; // Change this number to start at any station (0-9)
    const initialTarget = stations[startIdx];

    if (initialTarget) {
        // 1. Instantly snap the dial to the target (no smooth behavior for instant load)
        dial.scrollLeft = initialTarget.offsetLeft - (dial.offsetWidth / 2) + (initialTarget.offsetWidth / 2);
        
        // 2. Set the active classes and UI text
        initialTarget.classList.add("active");
        display.textContent = initialTarget.textContent;
        
        // 3. Update Frequency Display
        const fakeFreq = (88.0 + (startIdx * 2.1)).toFixed(1);
        freqDisplay.textContent = fakeFreq;

        // 4. Load the stream immediately
        loadStream(initialTarget);
    } else {
        // Fallback if index 5 doesn't exist
        updateActive();
    }

    updateActive();
}



</script>