<style>
    /* 1. Wrapper for Goldenrod Theme */
    #inter-radio-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 700px; /* Matching the first radio list width */
        animation: fadeIn 0.4s ease-out;
    }

    /* 2. Circular Close Button (Top Right) */
    #inter-radio-wrapper .close-btn {
        position: absolute;
        top: -10px;
        right: -50px; /* Offset to the side of the list */
        width: 45px;
        height: 45px;
        border: 1px solid black;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 110;
        transition: all 0.2s ease;
        outline: none;
    }

    #inter-radio-wrapper .close-btn:hover, 
    #inter-radio-wrapper .close-btn:focus {
        color: white;
        transform: scale(1.3) ;
        box-shadow: 0 0 15px rgba(218, 165, 32, 0.5);
    }

    /* 3. Title Styling */
    #inter-radio-wrapper #title {
        font-size: 28px;
        color: #564f4f;
        text-transform: uppercase;
        margin-bottom: 20px;
        letter-spacing: 4px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    /* 4. The Scrollable List Container */
    #inter-radio-wrapper .conteiner {
        display: flex !important;
        flex-direction: column !important;
        gap: 8px !important;
        width: 100% !important;
        height: 500px !important;
        padding: 10px 20px;
        overflow-y: auto;

    }

    /* 5. List Item Button Styling */
    #inter-radio-wrapper .btn {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
        backdrop-filter: blur(5px) !important; 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 10px;
        padding: 18px 25px !important;
        font-size: 20px;
        color: white !important;
        text-align: center !important;
        display: flex !important;
        align-items: center;
        width: 100%;
        min-height: 60px;
        transition: all 0.2s ease;
        cursor: pointer;
        box-sizing: border-box; /* Ensures padding doesn't break width */
    }



    /* 6. Back to Main Button (Styled exactly like list buttons) */
    .back-btn {
        margin-top: 20px;
        justify-content: center !important; /* Center the "Back" text */
    }

    /* Hide scrollbar */
    #inter-radio-wrapper .conteiner::-webkit-scrollbar { width: 0px; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div id="inter-radio-wrapper">
    
    <button class="close-btn" onclick="closeSubMenu()" tabindex="40">
        <svg viewBox="0 0 24 24" width="26" height="26" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <div id="title">World Radios</div>

    <div class="conteiner">
        <div class="btn" data-type="radio" data-mode="pt" tabindex="1">Portugal Radios</div>  
        <div class="btn" data-type="radio" data-mode="nz" tabindex="2">New Zealand Radios</div>
        <div class="btn" data-type="radio" data-mode="es" tabindex="3">Spain Radios</div>  
        <div class="btn" data-type="radio" data-mode="br" tabindex="4">Brasil Radios</div>  
        <div class="btn" data-type="radio" data-mode="fr" tabindex="5">France Radios</div>  
        <div class="btn" data-type="radio" data-mode="it" tabindex="6">Italian Radios</div>  
        <div class="btn" data-type="radio" data-mode="mr" tabindex="7">Marroc Radios</div>
    </div>



</div>