<style>
    #inter-radio-root * { box-sizing: border-box; }
    #inter-radio-root { width: 1280px; height: 720px; overflow: hidden; background-size: cover; color: white; font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; position: relative; }

    #ir-header {     width: 100%;
    height: 60px; /* Um pouco maior para suavizar o fade */
    display: flex;
    align-items: center;
    padding: 0 50px;
    /* Efeito de Fade Moderno */
    background: linear-gradient(to bottom, 
        rgba(0, 0, 0, 1) 0%, 
        rgba(0, 0, 0, 0.5) 80%, 
        rgba(0, 0, 0, 0) 100%
    );
    z-index: 100;
    flex-shrink: 0; 
    box-sizing: border-box; }
    .ir-header-info { flex: 1; min-width: 0; }
    .ir-header-info h1 { margin: 0; font-size: 24px; color: #2cf3de; text-transform: uppercase; letter-spacing: 3px; font-weight: 400; }
    #ir-status { font-size: 16px; color: rgba(255,255,255,0.95); }

    .ir-player-tools { display: flex; align-items: center; background: rgba(255,255,255,0.05); padding: 12px 25px; border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); gap: 30px; }
    .controls-hidden { display: none !important; }

    #ir-play-btn { background: #ffffff; color: #000; border: none; padding: 5px 24px; border-radius: 8px; font-weight: 600; cursor: pointer; }
    .ir-vol { display: flex; align-items: center; gap: 12px; }
    #ir-volume { width: 100px; cursor: pointer; accent-color: #2cf3de; }

    .ir-back-btn { background: #e74c3c !important; border: none !important; color: white !important; padding: 8px 20px !important; border-radius: 8px !important; cursor: pointer; }

    #ir-content { flex: 1; overflow-y: auto; padding: 30px; }
    #ir-menu { display: flex; gap: 20px; width: 850px; margin: 10px auto; }
    .ir-column { flex: 1; border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 15px; }
    .ir-col-header { color: #DAA520; text-align: center; margin-bottom: 10px; text-transform: uppercase; }
    .ir-scroll { height: 360px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; }
    .ir-btn { background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 10px; border-radius: 8px; cursor: pointer; text-align: center; text-transform: uppercase; }
    .ir-btn:hover { background: rgba(218,165,32,0.3); }
    
    #ir-grid { display: none; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; max-width: 1200px; margin: 0 auto; }
    .ir-card { background: rgba(0,0,0,0.4); border-radius: 10px; padding: 15px; text-align: center; cursor: pointer; height: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
    .ir-card img { width: 65px; height: 65px; background: white; border-radius: 5px; margin-bottom: 10px; }
    .ir-card p {
    display: -webkit-box;
    -webkit-line-clamp: 2;            /* Limits text to 2 lines */
    -webkit-box-orient: vertical;
    overflow: hidden;                /* Hides the overflow */
    text-overflow: ellipsis;         /* Adds the '...' */
    margin: 5px 0 0 0;               /* Adjusts spacing for better look */
    font-size: 13px;                 /* Slightly smaller font to fit better */
    width: 100%;
    word-break: break-word;          /* Ensures long words don't break the layout */
}
/* 4. ESTILIZAÇÃO DA BARRA DE ROLAGEM (Red YouTube Style) */
#ir-content::-webkit-scrollbar {
    width: 12px;
}

#ir-content::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
}

#ir-content::-webkit-scrollbar-thumb {
    background: #ff0000; 
    border-radius: 10px;
    border: 2px solid rgba(0, 0, 0, 0.2);
}
#ir-header { 
    width: 100%; 
    height: 80px; 
    display: grid; 
    grid-template-columns: 1fr 2fr 1fr; /* Left (Title), Center (Status), Right (Nav/Controls) */
    align-items: center; 
    padding: 0 60px; 
    background: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 80%, rgba(0,0,0,0) 100%); 
    z-index: 100; 
    flex-shrink: 0; 
}

.ir-header-left h1 { margin: 0; font-size: 24px; color: #2cf3de; text-transform: uppercase; letter-spacing: 3px; }
.ir-header-center { justify-self: center; text-align: center; color: white; font-weight: bold; font-size: 18px; }
.ir-header-right { justify-self: end; display: flex; align-items: center; gap: 15px; }
</style>

<div id="inter-radio-root">
<header id="ir-header">
    <div class="ir-header-left">
        <h1>Radios Explorer</h1>
    </div>

    <div class="ir-header-center">
        <p id="ir-center-text">Select a Country or a Genre</p>
    </div>

    <div class="ir-header-right">
        <!-- Player Controls (Hidden until grid view) -->
        <div id="ir-controls" class="controls-hidden">
            <audio id="ir-audio"></audio>
            <button id="ir-play-btn" onclick="irTogglePlay()">Play</button>
        </div>

        <!-- Navigation Buttons -->
        <button class="ir-back-btn" id="ir-btn-exit" onclick="irExit()">Exit</button>
        <button class="ir-back-btn" id="ir-btn-back" style="display:none" onclick="irRequestBack()">Back</button>
    </div>
</header>

    <div id="ir-content">
        <div id="ir-menu">
            <div class="ir-column">
                <div class="ir-col-header">By Country</div>
                <div class="ir-scroll" id="ir-country-list">
                    <div class="ir-btn" onclick="irLoad('country','pt','Portugal')">Portugal</div>
                    <div class="ir-btn" onclick="irLoad('country','br','Brasil')">Brasil</div>
                    <div class="ir-btn" onclick="irLoad('country','nz','New Zealand')">New Zealand</div>
                    <div class="ir-btn" onclick="irLoad('country','es','Spain')">Spain</div>
                    <div class="ir-btn" onclick="irLoad('country','fr','France')">France</div>
                    <div class="ir-btn" onclick="irLoad('country','it','Italy')">Italy</div>
                    <div class="ir-btn" onclick="irLoad('country','us','USA')">USA</div>
                </div>
                <input class="ir-search" placeholder="Search country..." oninput="irFilter('ir-country-list', this.value)">
            </div>
            <div class="ir-column">
                <div class="ir-col-header">By Genre</div>
                <div class="ir-scroll" id="ir-genre-list">
                    <div class="ir-btn" onclick="irLoad('tag','jazz','Jazz')">Jazz</div>
                    <div class="ir-btn" onclick="irLoad('tag','rock','Rock')">Rock</div>
                    <div class="ir-btn" onclick="irLoad('tag','pop','Pop')">Pop</div>
                    <div class="ir-btn" onclick="irLoad('tag','chillout','Chillout')">Chillout</div>
                    <div class="ir-btn" onclick="irLoad('tag','disco','Disco')">Disco</div>
                    <div class="ir-btn" onclick="irLoad('tag','classical','Classical')">Classical</div>
                    <div class="ir-btn" onclick="irLoad('tag','electronic','Electronic')">Electronic</div>
                </div>
                <input class="ir-search" placeholder="Search genre..." oninput="irFilter('ir-genre-list', this.value)">
            </div>
        </div>
        <div id="ir-grid"></div>
    </div>
</div>

<script>
(function() {

    let currentPlayingUrl = null;
    let irViewState = 'menu';
    const audio = document.getElementById('ir-audio');
    const playBtn = document.getElementById('ir-play-btn');
    const menu = document.getElementById('ir-menu');
    const grid = document.getElementById('ir-grid');
    const gridBack = document.getElementById('ir-grid-back');
    const controls = document.getElementById('ir-controls');

    window.irLoad = function(type, value, label) {
        if (window.socket && window.myRoom) {
            window.socket.emit('RequestRadioGrid', { type, value, label, room: window.myRoom });
        }
    };

window.irExecuteLoad = async function(type, value, label) {
    irViewState = 'grid';
    // 1. Re-select the elements inside the function to ensure they are found
    const menu = document.getElementById('ir-menu');
    const grid = document.getElementById('ir-grid');
    const controls = document.getElementById('ir-controls');
    const centerText = document.getElementById('ir-center-text');
    document.getElementById('ir-btn-exit').style.display = 'none';
    document.getElementById('ir-btn-back').style.display = 'block';

    // 2. Add a safety check
    if (!menu || !grid || !controls) {
        console.error("UI Error: Could not find menu, grid, or controls element. Check your HTML IDs.");
        return;
    }

    // 3. Now safe to update styles
    menu.style.display = 'none';
    grid.style.display = 'grid';

    
    controls.classList.remove('controls-hidden');
    if(centerText) centerText.innerText = 'Loading ' + label + '...';
    
    grid.innerHTML = `<div>Loading ${label}...</div>`;

    // 4. Fetch logic...
    const url = type === 'country'
        ? `https://de1.api.radio-browser.info/json/stations/bycountrycodeexact/${value}?order=clickcount&reverse=true&limit=100`
        : `https://de1.api.radio-browser.info/json/stations/bytag/${value}?order=clickcount&reverse=true&limit=100`;

    try {
        const res = await fetch(url);
        const stations = await res.json();
        irRender(stations);
    } catch (e) { 
        grid.innerHTML = 'Failed to load.'; 
    }
};
   

if (window.socket) {
        // Sync Grid View
        window.socket.on('UpdateRadioGrid', (data) => {
            window.irExecuteLoad(data.type, data.value, data.label);
        });

        // Sync Audio Playback
       window.socket.on('TuneRadio', (data) => {
    if (audio && data.stream) {
        audio.src = data.stream;
        audio.play();

        currentPlayingUrl = data.stream;

        playBtn.innerText = 'Pause';

        const centerText = document.getElementById('ir-center-text');
        if (centerText) {
            centerText.innerText = 'Playing: ' + data.name;
        }
    }
});
    window.socket.on('ShowRadioMenu', () => {
        window.irShowMenu();
    });

    }

// 1. New function to broadcast the back action
window.irRequestBack = function() {
    // 1. Emite o evento para o servidor para sincronizar todos os clientes
    if (window.socket && window.myRoom) {
        window.socket.emit('RequestRadioBack', { room: window.myRoom });
    }
    
};

// 2. Updated Menu display logic (The receiver)
window.irShowMenu = function() {
    const audio = document.getElementById('ir-audio');
    console.log(audio)
    // 1. Force o áudio a parar
    if (audio) {
        audio.pause();
        audio.src = '';
        audio.load();
    }
    
    console.log("STOPPING");
    
    // 2. Reset a variável de controle
    if (typeof currentPlayingUrl !== 'undefined') {
        currentPlayingUrl = null;
    }

    // 3. Atualização da Interface (UI)
    document.getElementById('ir-center-text').innerText = 'Select a Country or a Genre';
    
    // Gerenciamento correto da visibilidade dos botões
    document.getElementById('ir-btn-exit').style.display = 'block';
    document.getElementById('ir-btn-back').style.display = 'none';
    
    // Alternância de visibilidade entre Menu e Grid
    document.getElementById('ir-menu').style.display = 'flex';
    document.getElementById('ir-grid').style.display = 'none';
    
    // Ocultar controles do player
    document.getElementById('ir-controls').classList.add('controls-hidden');
    
    // Reset do texto do botão Play
    document.getElementById('ir-play-btn').innerText = 'Play';
};
 

window.irRender = function(stations) {
        grid.innerHTML = '';
        stations.forEach(s => {
            if (!s.favicon || !s.favicon.startsWith('http')) return;
            const card = document.createElement('div');
            card.className = 'ir-card';
            card.innerHTML = `<img src="${s.favicon}" onerror="this.src='https://placehold.co/60x60/222/fff?text=R'"><p>${s.name}</p>`;
            card.onclick = () => window.irPlay(s.url_resolved, s.name);
            grid.appendChild(card);
        });
    };

window.irPlay = function(url, name) {
    // 1. Prevent re-launching if it's the same station
    if (currentPlayingUrl === url) {
        if (audio.paused) {
            audio.play();
            playBtn.innerText = 'Pause';
        }
        return; 
    }

    // 2. Load the new stream
    currentPlayingUrl = url;
    audio.src = url;
    audio.play();
    
    // 3. Update the UI
    playBtn.innerText = 'Pause';
    document.getElementById('ir-center-text').innerText = 'Playing: ' + name;

    // 4. Sync with other viewers
    if (window.socket) {
        window.socket.emit('TuneRadio', { stream: url, name: name, room: window.myRoom });
    }
};

    window.irTogglePlay = function() {
        if (audio.paused) { audio.play(); playBtn.innerText = 'Pause'; }
        else { audio.pause(); playBtn.innerText = 'Play'; }
    };

    window.irFilter = function(id, q) {
        document.querySelectorAll(`#${id} .ir-btn`).forEach(b => {
            b.style.display = b.innerText.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
        });
    };
    

})();
</script>