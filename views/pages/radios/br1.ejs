        <style>
            /* STRETCH TO FIT - NO SCROLL STRATEGY */
            body, html {
                margin: 0;
                padding: 0;
                height: 100vh;
                width: 100vw;
                overflow: hidden; /* Disables scroll */
                background-color: #000;
                color: white;
                font-family: sans-serif;
            }

            .viewport-wrapper {
                display: flex;
                flex-direction: column;
                height: 100vh;
                padding: 1vh 2vw;
                box-sizing: border-box;
                background: rgba(0,0,0,0.4); /* Darkens background for readability */
            }

            #header {
                flex-shrink: 0;
                text-align: center;
            }

            #header h1 {
                font-size: 3vh;
                margin: 1vh 0;
                text-transform: uppercase;
            }

            /* The Player Area */
            #radio {
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(255,255,255,0.1);
                backdrop-filter: blur(10px);
                border-radius: 15px;
                padding: 1vh;
                margin-bottom: 1vh;
                height: 12vh;
            }

            /* The Grid of Radios */
            #radios {
                display: grid;
                grid-template-columns: repeat(8, 1fr); /* 8 items across */
                grid-template-rows: repeat(5, 1fr);    /* 5 rows down = 40 items */
                gap: 0.8vh;
                list-style: none;
                padding: 0;
                margin: 0;
                flex-grow: 1; /* Fills available middle space */
                overflow: hidden;
            }

            #radios li {
                display: flex;
                justify-content: center;
                align-items: center;
                background: rgba(255,255,255,0.05);
                border-radius: 8px;
                transition: transform 0.2s;
                border: 1px solid rgba(255,255,255,0.1);
            }

            #radios li:hover {
                background: rgba(255,255,255,0.2);
                transform: scale(1.05);
            }

            #radios li img {
                max-height: 7vh; /* Forces icons to stay small enough to fit */
                width: auto;
                max-width: 90%;
                object-fit: contain;
            }

            /* Bottom Button Area */
            .footer-area {
                flex-shrink: 0;
                display: flex;
                justify-content: center;
                padding: 1vh 0;
            }

            #bback {
                padding: 1vh 5vw;
                font-size: 2vh;
                cursor: pointer;
                border-radius: 20px;
                border: none;
                background: #ff4d4d;
                color: white;
                font-weight: bold;
            }

            marquee { width: 200px; color: #fff; }
        </style>

