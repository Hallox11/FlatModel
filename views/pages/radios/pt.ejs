<!doctype html>
<html lang="en">
<head prefix="og: http://ogp.me/ns#">
    <meta charset="UTF-8">
    <title>Radios Portugal - TV Edition</title>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="./../js/myScripts.js"></script>
    <meta name="viewport" content="width=1280, user-scalable=no">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --glass: rgba(0, 0, 0, 0.6);
            --glass-border: rgba(255, 255, 255, 0.15);
            --accent: #00d2ff;
        }

        body {
            margin: 0; padding: 0;
            width: 1280px; height: 720px;
            font-family: 'Fira Sans', sans-serif;
            background-color: #111;
            background-size: cover;
            background-position: center;
            color: white;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        #title {
            width: 100%;
            padding: 30px 0 10px 0;
            text-align: center;
            font-size: 34px;
            font-weight: 300;
            letter-spacing: 3px;
            text-transform: uppercase;
            background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
        }

        .container {
            width: 1180px;
            height: 540px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            display: flex;
            padding: 25px;
            gap: 25px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
            margin-top: 10px;
        }

        .player-side {
            flex: 0 0 320px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.03);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
        }

        #radio-logo {
            width: 200px; height: 200px;
            object-fit: contain;
            border-radius: 15px;
            margin-bottom: 25px;
            background: white;
            padding: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
        }

        .text-box { width: 100%; overflow: hidden; height: 80px; }
        #radio-title { font-size: 26px; display: block; color: var(--accent); margin-bottom: 5px; }
        #radio-signal { font-size: 16px; opacity: 0.6; }

        .list-side {
            flex: 1;
            overflow-y: auto;
            padding-right: 15px;
        }

        .list-side::-webkit-scrollbar { width: 6px; }
        .list-side::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

        #radios {
            list-style: none;
            padding: 0; margin: 0;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
        }

        #radios li {
            background: rgba(255,255,255,0.07);
            border: 2px solid transparent;
            border-radius: 12px;
            transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            aspect-ratio: 1.2 / 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }

        #radios li:hover {
            background: rgba(255,255,255,0.15);
            border-color: var(--accent);
            transform: scale(1.05);
        }

        #radios img.cover {
            max-width: 90%;
            max-height: 80%;
            object-fit: contain;
        }

        #bback {
            position: absolute;
            bottom: 30px;
            left: 50px;
            background: rgba(255,255,255,0.9);
            color: #000;
            border: none;
            padding: 14px 45px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
        }
    </style>

