<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Radio 720p</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0; padding: 0;
            width: 100vw; height: 100vh;
            overflow: hidden;
            background: #0f0f0f url('https://images.unsplash.com/photo-1494232410401-ad00d5433cfa?q=80&w=2070') no-repeat center center fixed;
            background-size: cover;
            color: white; font-family: 'Segoe UI', sans-serif;
            display: flex; flex-direction: column;
        }

        /* Header with Controls */
        .header-controls {
            height: 90px;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex; align-items: center;
            padding: 0 20px; gap: 20px; flex-shrink: 0;
        }

        .header-info { flex-grow: 1; min-width: 0; }
        .header-info h1 { margin: 0; font-size: 18px; color: #00aeef; text-transform: uppercase; }
        #status-text { margin: 0; font-size: 13px; color: #aaa; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .player-tools { display: flex; align-items: center; gap: 15px; }
        
        .btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white; padding: 8px 15px;
            border-radius: 5px; cursor: pointer; font-size: 14px;
        }
        .btn:hover { background: #00aeef; }
        .back-btn { background: #e74c3c; border: none; font-weight: bold; }

        /* Grid Area */
        .content-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 20px;
            width: 1240px;
            margin-left: 20px;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px; max-width: 1200px; margin: 0 auto;
        }

        .radio-card {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 10px; padding: 15px;
            text-align: center; cursor: pointer; transition: 0.2s;
            border: 1px solid transparent; height: 160px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            position: relative; /* Needed for absolute heart button */
        }
        .radio-card:hover { border-color: #00aeef; background: rgba(0, 174, 239, 0.1); transform: translateY(-3px); }
        .radio-card img { width: 65px; height: 65px; object-fit: contain; background: white; border-radius: 5px; margin-bottom: 10px; }
        .radio-card p { margin: 0; font-size: 12#4px; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* Favorite Button Style */
        .fav-btn {
            position: absolute;
            top: 8px; right: 8px;
            background: rgba(0, 0, 0, 0.5);
            border: none; color: white;
            border-radius: 50%; width: 26px; height: 26px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            font-size: 14px; transition: 0.3s; z-index: 10;
        }
        .fav-btn:hover { background: #e74c3c; transform: scale(1.1); }
        .fav-btn.active { color: #e74c3c; background: white; }
    </style>
</head>
<body>

<header class="header-controls">
    <button class="btn back-btn" onclick="closeSubMenu()">BACK</button>
    
    <div class="header-info">
        <h1 id="main-title">World Radios</h1>
        <p id="status-text">Select a station</p>
    </div>

    <div class="player-tools">
        <audio id="audio-player"></audio>
        <button class="btn" onclick="togglePlay()" id="play-pause-btn">Play</button>
        <div style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 12px;">VOL</span>
            <input type="range" id="volume-slider" min="0" max="1" step="0.1" value="1" oninput="changeVolume(this.value)" style="width: 80px;">
        </div>
    </div>
</header>

<div class="content-area">
    <div class="menu-list" id="country-menu" style="display: flex; flex-direction: column; gap: 10px; max-width: 300px; margin: 50px auto;">
        <button class="btn" onclick="loadCountryRadios('pt', 'Portugal')">Portugal</button>  
        <button class="btn" onclick="loadCountryRadios('br', 'Brasil')">Brasil</button>  
        <button class="btn" onclick="loadCountryRadios('es', 'Espanha')">Espanha</button>  
        <button class="btn" onclick="loadCountryRadios('fr', 'França')">França</button>
<h3 style="width:100%; text-align:center; margin-top:20px;">By Genre</h3>
    <button class="btn" onclick="loadTagRadios('jazz', 'Jazz')">Jazz</button>
    <button class="btn" onclick="loadTagRadios('rock', 'Rock')">Rock</button>
    <button class="btn" onclick="loadTagRadios('disco', 'Disco')">Disco 70s/80s</button>
    <button class="btn" onclick="loadTagRadios('chillout', 'Chillout')">Relax/Chill</button>

    </div>
    <div id="radio-grid" class="grid-container" style="display: none;"></div>
</div>

<script>
const API_BASE = 'https://de1.api.radio-browser.info/json/stations/bycountrycodeexact/';
const player = document.getElementById('audio-player');
const playBtn = document.getElementById('play-pause-btn');
let isFetching = false; 

async function loadCountryRadios(code, name) {
    if (isFetching) return; 
    isFetching = true;

    const grid = document.getElementById('radio-grid');
    const menu = document.getElementById('country-menu');
    const statusText = document.getElementById('status-text');
    const mainTitle = document.getElementById('main-title');

    if (menu) menu.style.display = 'none';
    if (grid) {
        grid.style.display = 'grid';
        grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center; padding:20px;">Filtrando rádios com logo...</div>';
    }
    
    if (mainTitle) mainTitle.innerText = name + " Radios";
    if (statusText) statusText.innerText = "Organizando por relevância...";

    try {
        const response = await fetch(`${API_BASE}${code}?order=clickcount&reverse=true`);
        const stations = await response.json();

        if (!stations || !Array.isArray(stations) || stations.length === 0) {
            grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center;">Nenhuma rádio encontrada.</div>';
            isFetching = false;
            return;
        }

        grid.innerHTML = ''; 
        const seenNames = []; 
        let addedCount = 0;
        const MAX_RADIOS = 80; 

        stations.forEach(station => {
            const currentName = station.name.trim().toLowerCase();
            const hasLogo = station.favicon && station.favicon.startsWith('http');
            const isDuplicate = seenNames.some(seen => 
                currentName.includes(seen) || seen.includes(currentName)
            );

            if (hasLogo && !isDuplicate && addedCount < MAX_RADIOS) {
                seenNames.push(currentName);
                addedCount++;

                const card = document.createElement('div');
                card.className = 'radio-card';
                
                // Encode station data for the favorite function
                const stationData = encodeURIComponent(JSON.stringify(station));

                card.innerHTML = `
                    <button class="fav-btn" onclick="toggleFavorite(event, '${stationData}')">❤</button>
                    <img src="${station.favicon}" onerror="this.onerror=null; this.src='https://via.placeholder.com/60/222/fff?text=Radio';">
                    <p title="${station.name}">${station.name}</p>
                `;
                
                card.onclick = () => playRadio(station.url_resolved, station.name);
                grid.appendChild(card);
            }
        });

        if (statusText) statusText.innerText = "Selecione uma rádio para ouvir";

    } catch (error) {
        console.error("Fetch failed:", error);
        if (grid) grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center;">Erro de conexão.</div>';
    } finally {
        isFetching = false;
    }
}

async function toggleFavorite(event, stationData) {
    event.stopPropagation(); // Prevents the radio card click event from firing
    const station = JSON.parse(decodeURIComponent(stationData));
    const btn = event.currentTarget;
    
    try {
        const response = await fetch('/radio-favorites', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(station)
        });

        const result = await response.json();
        
        if (response.ok) {
            btn.classList.add('active');
            console.log(result.message);
        } else {
            console.warn(result.message);
        }
    } catch (error) {
        console.error("Error saving favorite:", error);
    }
}

function playRadio(url, name) {
    document.getElementById('status-text').innerText = "Playing: " + name;
    player.src = url;
    player.play();
    playBtn.innerText = "Pause";
}

function togglePlay() {
    if (!player.src) return;
    if (player.paused) {
        player.play();
        playBtn.innerText = "Pause";
    } else {
        player.pause();
        playBtn.innerText = "Play";
    }
}

function changeVolume(val) { player.volume = val; }

///////////////////////////////////////////////////////////////
// New function to load by Genre/Tag
async function loadTagRadios(tag, displayName) {
    if (isFetching) return;
    isFetching = true;

    const grid = document.getElementById('radio-grid');
    const menu = document.getElementById('country-menu');
    const statusText = document.getElementById('status-text');
    const mainTitle = document.getElementById('main-title');

    menu.style.display = 'none';
    grid.style.display = 'grid';
    grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center; padding:20px;">Searching for ' + displayName + '...</div>';
    mainTitle.innerText = displayName + " Stations";

    try {
        // We use the 'bytag' endpoint here
        const response = await fetch(`https://de1.api.radio-browser.info/json/stations/bytag/${tag}?order=clickcount&reverse=true`);
        const stations = await response.json();

        if (!stations || stations.length === 0) {
            grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center;">No stations found for this tag.</div>';
            return;
        }

        grid.innerHTML = '';
        const seenNames = [];
        let addedCount = 0;

        stations.forEach(station => {
            const currentName = station.name.trim().toLowerCase();
            const hasLogo = station.favicon && station.favicon.startsWith('http');
            const isDuplicate = seenNames.some(seen => currentName.includes(seen) || seen.includes(currentName));

            if (hasLogo && !isDuplicate && addedCount < 60) {
                seenNames.push(currentName);
                addedCount++;

                const card = document.createElement('div');
                card.className = 'radio-card';
                const stationData = encodeURIComponent(JSON.stringify(station));

                card.innerHTML = `
                    <button class="fav-btn" onclick="toggleFavorite(event, '${stationData}')">❤</button>
                    <img src="${station.favicon}" onerror="this.onerror=null; this.src='https://via.placeholder.com/60/222/fff?text=Radio';">
                    <p title="${station.name}">${station.name}</p>
                `;
                card.onclick = () => playRadio(station.url_resolved, station.name);
                grid.appendChild(card);
            }
        });

        statusText.innerText = "Found " + addedCount + " stations for " + displayName;
    } catch (e) {
        grid.innerHTML = 'Error searching tags.';
    } finally {
        isFetching = false;
    }
}
</script>

</body>
</html>